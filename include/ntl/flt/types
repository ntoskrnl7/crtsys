/** @brief Result returned by a minifilter pre-operation callback. */
enum class pre_result : unsigned long {
  success_with_callback = FLT_PREOP_SUCCESS_WITH_CALLBACK,
  success_no_callback = FLT_PREOP_SUCCESS_NO_CALLBACK,
  pending = FLT_PREOP_PENDING,
  disallow_fast_io = FLT_PREOP_DISALLOW_FASTIO,
  complete = FLT_PREOP_COMPLETE,
  synchronize = FLT_PREOP_SYNCHRONIZE,
  disallow_fsfilter_io = FLT_PREOP_DISALLOW_FSFILTER_IO,
};

/** @brief Result returned by a minifilter post-operation callback. */
enum class post_result : unsigned long {
  finished = FLT_POSTOP_FINISHED_PROCESSING,
  more_processing_required = FLT_POSTOP_MORE_PROCESSING_REQUIRED,
  disallow_fsfilter_io = FLT_POSTOP_DISALLOW_FSFILTER_IO,
};

/** @brief Chooses whether mixed post processing ends or continues when safe. */
enum class post_continuation {
  finished,
  when_safe,
};

/** @brief Flags controlling which read/write operations reach a callback. */
enum class operation_flags : unsigned long {
  none = 0,
  skip_paging_io = FLTFL_OPERATION_REGISTRATION_SKIP_PAGING_IO,
  skip_cached_io = FLTFL_OPERATION_REGISTRATION_SKIP_CACHED_IO,
  skip_non_dasd_io = FLTFL_OPERATION_REGISTRATION_SKIP_NON_DASD_IO,
#ifdef FLTFL_OPERATION_REGISTRATION_SKIP_NON_CACHED_NON_PAGING_IO
  skip_non_cached_non_paging_io =
      FLTFL_OPERATION_REGISTRATION_SKIP_NON_CACHED_NON_PAGING_IO,
#endif
};

/** @brief Combines operation registration flags. */
constexpr operation_flags operator|(operation_flags left,
                                    operation_flags right) noexcept {
  return static_cast<operation_flags>(static_cast<unsigned long>(left) |
                                      static_cast<unsigned long>(right));
}

/** @brief Move-only rundown reference returned by explicit attachment. */
class instance_ref {
public:
  instance_ref() noexcept = default;

  /** @brief Takes ownership of one Filter Manager rundown reference. */
  explicit instance_ref(PFLT_INSTANCE value) noexcept : value_(value) {}

  instance_ref(const instance_ref &) = delete;
  instance_ref &operator=(const instance_ref &) = delete;

  instance_ref(instance_ref &&other) noexcept
      : value_(std::exchange(other.value_, nullptr)) {}

  instance_ref &operator=(instance_ref &&other) noexcept {
    if (this != &other) {
      reset();
      value_ = std::exchange(other.value_, nullptr);
    }
    return *this;
  }

  /** @brief Releases the owned rundown reference. */
  ~instance_ref() { reset(); }

  /** @brief Returns a non-owning facade for the referenced instance. */
  flt::instance view() const noexcept;

  /** @brief Returns the native referenced instance pointer. */
  PFLT_INSTANCE native_handle() const noexcept { return value_; }

  /** @brief Returns true when a rundown reference is owned. */
  explicit operator bool() const noexcept { return value_ != nullptr; }

  /** @brief Releases the current rundown reference early. */
  void reset() noexcept {
    if (value_) {
      FltObjectDereference(value_);
      value_ = nullptr;
    }
  }

private:
  PFLT_INSTANCE value_ = nullptr;
};

/** @brief Non-owning facade for a registered Filter Manager filter. */
class filter {
public:
  /** @brief Creates an empty filter facade. */
  filter() noexcept = default;

  /** @brief Wraps a native filter without changing its reference count. */
  explicit filter(PFLT_FILTER value) noexcept : value_(value) {}

  /** @brief Returns the native filter pointer. */
  PFLT_FILTER native_handle() const noexcept { return value_; }

  /** @brief Returns true when a native filter is present. */
  explicit operator bool() const noexcept { return value_ != nullptr; }

  /**
   * @brief Attaches the default instance definition to a volume.
   * @param target Target Filter Manager volume.
   * @return A referenced instance owner or the Filter Manager status.
   * @note Runs at PASSIVE_LEVEL. Instance attributes come from the INF.
   */
  ntl::result<instance_ref> try_attach(volume target) const noexcept;

  /**
   * @brief Attaches a named INF instance definition to a volume.
   * @param target Target Filter Manager volume.
   * @param instance_name Registry instance-definition name.
   * @return A referenced instance owner or the Filter Manager status.
   * @note Runs at PASSIVE_LEVEL.
   */
  ntl::result<instance_ref>
  try_attach(volume target, std::wstring_view instance_name) const noexcept;

  /**
   * @brief Attaches an instance at an explicitly supplied altitude.
   * @param target Target Filter Manager volume.
   * @param altitude Decimal altitude string.
   * @param instance_name Optional instance name.
   * @return A referenced instance owner or the Filter Manager status.
   * @note Runs at PASSIVE_LEVEL. Prefer named INF definitions in production.
   */
  ntl::result<instance_ref>
  try_attach_at(volume target, std::wstring_view altitude,
                std::wstring_view instance_name = {}) const noexcept;

  /**
   * @brief Detaches the highest instance of this filter from a volume.
   * @param target Target Filter Manager volume.
   */
  ntl::status try_detach(volume target) const noexcept;

  /**
   * @brief Detaches one named instance from a volume.
   * @param target Target Filter Manager volume.
   * @param instance_name Attached instance name.
   */
  ntl::status try_detach(volume target,
                         std::wstring_view instance_name) const noexcept;

  /**
   * @brief Enumerates every current attachment owned by this filter.
   * @return Instance name, altitude, volume, and filter identity records.
   * @note Runs at PASSIVE_LEVEL because the result owns dynamic strings.
   */
  ntl::result<std::vector<instance_information>> try_instances() const noexcept;

private:
  PFLT_FILTER value_ = nullptr;
};

