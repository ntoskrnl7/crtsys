/** @brief Compile-time tag for an operation without read/write flags. */
template <operation_id Value> class operation_tag {
  friend struct operation;

public:
  /** @brief Returns the runtime operation identifier. */
  static constexpr operation_id value = Value;

  /** @brief Returns the native Filter Manager major-function value. */
  static constexpr UCHAR native_value = static_cast<UCHAR>(Value);

private:
  constexpr operation_tag() noexcept = default;
};

/** @brief Compile-time tag for read/write operations that accept flags. */
template <operation_id Value> class read_write_operation_tag {
  friend struct operation;

public:
  /** @brief Returns the runtime operation identifier. */
  static constexpr operation_id value = Value;

  /** @brief Returns the native Filter Manager major-function value. */
  static constexpr UCHAR native_value = static_cast<UCHAR>(Value);

private:
  constexpr read_write_operation_tag() noexcept = default;
};

