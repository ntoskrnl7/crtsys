namespace detail {

inline bool make_unicode_view(std::wstring_view value,
                              UNICODE_STRING &native) noexcept {
  constexpr auto maximum_characters =
      (std::numeric_limits<USHORT>::max)() / sizeof(wchar_t);
  if (value.size() > maximum_characters)
    return false;

  native.Buffer = const_cast<PWCH>(value.data());
  native.Length = static_cast<USHORT>(value.size() * sizeof(wchar_t));
  native.MaximumLength = native.Length;
  return true;
}

inline bool assign_instance_string(const unsigned char *buffer,
                                   std::size_t buffer_size, USHORT offset,
                                   USHORT length, std::wstring &destination) {
  if ((length % sizeof(wchar_t)) != 0 || offset > buffer_size ||
      length > buffer_size - offset)
    return false;

  const auto *first = reinterpret_cast<const wchar_t *>(buffer + offset);
  destination.assign(first, first + length / sizeof(wchar_t));
  return true;
}

inline ntl::result<instance_information>
parse_instance_information(const std::vector<unsigned char> &buffer) noexcept {
  if (buffer.size() < sizeof(INSTANCE_FULL_INFORMATION))
    return ntl::unexpected(STATUS_INFO_LENGTH_MISMATCH);

  try {
    const auto *native =
        reinterpret_cast<const INSTANCE_FULL_INFORMATION *>(buffer.data());
    instance_information result;
    if (!assign_instance_string(buffer.data(), buffer.size(),
                                native->InstanceNameBufferOffset,
                                native->InstanceNameLength, result.name) ||
        !assign_instance_string(buffer.data(), buffer.size(),
                                native->AltitudeBufferOffset,
                                native->AltitudeLength, result.altitude) ||
        !assign_instance_string(buffer.data(), buffer.size(),
                                native->VolumeNameBufferOffset,
                                native->VolumeNameLength, result.volume_name) ||
        !assign_instance_string(buffer.data(), buffer.size(),
                                native->FilterNameBufferOffset,
                                native->FilterNameLength, result.filter_name))
      return ntl::unexpected(STATUS_INFO_LENGTH_MISMATCH);
    return result;
  } catch (...) {
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

template <class Query>
inline ntl::result<instance_information>
query_instance_information(Query &&query) noexcept {
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

  ULONG required = 0;
  NTSTATUS status = query(nullptr, 0, &required);
  if (status != STATUS_BUFFER_TOO_SMALL && status != STATUS_BUFFER_OVERFLOW)
    return ntl::unexpected(status);

  try {
    std::vector<unsigned char> buffer(required);
    for (unsigned int retry = 0; retry != 3; ++retry) {
      ULONG returned = 0;
      status =
          query(buffer.data(), static_cast<ULONG>(buffer.size()), &returned);
      if (status == STATUS_BUFFER_TOO_SMALL ||
          status == STATUS_BUFFER_OVERFLOW) {
        buffer.resize(returned);
        continue;
      }
      if (!NT_SUCCESS(status))
        return ntl::unexpected(status);
      if (returned > buffer.size())
        return ntl::unexpected(STATUS_INFO_LENGTH_MISMATCH);
      buffer.resize(returned);
      return parse_instance_information(buffer);
    }
    return ntl::unexpected(status);
  } catch (...) {
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

} // namespace detail

inline ntl::result<instance_information>
instance::try_information() const noexcept {
  if (!value_)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);

  return detail::query_instance_information(
      [this](PVOID buffer, ULONG size, PULONG returned) noexcept {
        return FltGetInstanceInformation(value_, InstanceFullInformation,
                                         buffer, size, returned);
      });
}

inline ntl::result<instance_ref>
filter::try_attach(volume target) const noexcept {
  if (!value_ || !target)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

  PFLT_INSTANCE attached = nullptr;
  const NTSTATUS status =
      FltAttachVolume(value_, target.native_handle(), nullptr, &attached);
  if (!NT_SUCCESS(status))
    return ntl::unexpected(status);
  return instance_ref{attached};
}

inline ntl::result<instance_ref>
filter::try_attach(volume target,
                   std::wstring_view instance_name) const noexcept {
  if (!value_ || !target)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

  UNICODE_STRING native_name{};
  if (instance_name.empty() ||
      !detail::make_unicode_view(instance_name, native_name))
    return ntl::unexpected(instance_name.empty() ? STATUS_INVALID_PARAMETER
                                                 : STATUS_NAME_TOO_LONG);

  PFLT_INSTANCE attached = nullptr;
  const NTSTATUS status =
      FltAttachVolume(value_, target.native_handle(), &native_name, &attached);
  if (!NT_SUCCESS(status))
    return ntl::unexpected(status);
  return instance_ref{attached};
}

inline ntl::result<instance_ref>
filter::try_attach_at(volume target, std::wstring_view altitude,
                      std::wstring_view instance_name) const noexcept {
  if (!value_ || !target)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

  UNICODE_STRING native_altitude{};
  UNICODE_STRING native_name{};
  if (altitude.empty() || !detail::make_unicode_view(altitude, native_altitude))
    return ntl::unexpected(altitude.empty() ? STATUS_INVALID_PARAMETER
                                            : STATUS_NAME_TOO_LONG);
  if (!instance_name.empty() &&
      !detail::make_unicode_view(instance_name, native_name))
    return ntl::unexpected(STATUS_NAME_TOO_LONG);

  PFLT_INSTANCE attached = nullptr;
  const NTSTATUS status = FltAttachVolumeAtAltitude(
      value_, target.native_handle(), &native_altitude,
      instance_name.empty() ? nullptr : &native_name, &attached);
  if (!NT_SUCCESS(status))
    return ntl::unexpected(status);
  return instance_ref{attached};
}

inline ntl::status filter::try_detach(volume target) const noexcept {
  if (!value_ || !target)
    return STATUS_INVALID_PARAMETER;
  if (KeGetCurrentIrql() > APC_LEVEL)
    return STATUS_INVALID_DEVICE_STATE;
  return FltDetachVolume(value_, target.native_handle(), nullptr);
}

inline ntl::status
filter::try_detach(volume target,
                   std::wstring_view instance_name) const noexcept {
  if (!value_ || !target)
    return STATUS_INVALID_PARAMETER;
  if (KeGetCurrentIrql() > APC_LEVEL)
    return STATUS_INVALID_DEVICE_STATE;

  UNICODE_STRING native_name{};
  if (instance_name.empty() ||
      !detail::make_unicode_view(instance_name, native_name))
    return instance_name.empty() ? STATUS_INVALID_PARAMETER
                                 : STATUS_NAME_TOO_LONG;
  return FltDetachVolume(value_, target.native_handle(), &native_name);
}

inline ntl::result<std::vector<instance_information>>
filter::try_instances() const noexcept {
  if (!value_)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

  try {
    std::vector<instance_information> result;
    for (ULONG index = 0;; ++index) {
      auto current = detail::query_instance_information(
          [this, index](PVOID buffer, ULONG size, PULONG returned) noexcept {
            return FltEnumerateInstanceInformationByFilter(
                value_, index, InstanceFullInformation, buffer, size, returned);
          });
      if (!current) {
        if (static_cast<NTSTATUS>(current.status()) == STATUS_NO_MORE_ENTRIES)
          return result;
        return ntl::unexpected(current.status());
      }
      result.push_back(std::move(*current));
    }
  } catch (...) {
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

/** @brief Typed view of the objects associated with a minifilter callback. */
class related_objects {
public:
  /** @brief Wraps the callback-owned related-object structure. */
  explicit related_objects(PCFLT_RELATED_OBJECTS value) noexcept
      : value_(value) {}

  /** @brief Returns the registered filter. */
  flt::filter filter() const noexcept {
    return flt::filter{value_ ? value_->Filter : nullptr};
  }

  /** @brief Returns the target volume. */
  flt::volume volume() const noexcept {
    return flt::volume{value_ ? value_->Volume : nullptr};
  }

  /** @brief Returns the attached minifilter instance. */
  flt::instance instance() const noexcept {
    return flt::instance{value_ ? value_->Instance : nullptr};
  }

  /** @brief Returns the kernel FILE_OBJECT facade. */
  ntl::file file() const noexcept {
    return ntl::file{value_ ? value_->FileObject : nullptr};
  }

  /** @brief Returns the native transaction object when present. */
  PKTRANSACTION transaction() const noexcept {
    return value_ ? value_->Transaction : nullptr;
  }

  /** @brief Returns the native related-object structure. */
  PCFLT_RELATED_OBJECTS native() const noexcept { return value_; }

  /**
   * @brief Returns whether the current file-system object supports a context.
   * @param definition Typed context declaration registered by the filter.
   * @note Filter Manager support queries require IRQL <= APC_LEVEL.
   */
  template <class T, context_scope Scope>
  bool supports(const context_definition<T, Scope> &) const noexcept {
    if (KeGetCurrentIrql() > APC_LEVEL)
      return false;
    return detail::context_api<Scope>::supports(context_objects());
  }

  /**
   * @brief Gets an existing typed context and owns the returned reference.
   * @param definition Typed context declaration registered by the filter.
   * @return A move-only context reference or the Filter Manager status.
   */
  template <class T, context_scope Scope>
  ntl::result<context_ref<T, Scope>>
  try_get(const context_definition<T, Scope> &) const noexcept {
    return detail::get_context<T, Scope>(context_objects());
  }

  /**
   * @brief Gets or atomically installs one typed context.
   * @param definition Typed context declaration registered by the filter.
   * @param args Arguments forwarded to T's noexcept constructor.
   * @return The existing or newly installed context reference.
   *
   * The helper uses FLT_SET_CONTEXT_KEEP_IF_EXISTS. If another thread wins
   * the creation race, its referenced context is returned and the losing
   * allocation is destroyed automatically.
   */
  template <class T, context_scope Scope, class... Args>
  ntl::result<context_ref<T, Scope>>
  try_get_or_create(const context_definition<T, Scope> &definition,
                    Args &&...args) const noexcept {
    return detail::get_or_create_context<T, Scope>(
        context_objects(), definition, std::forward<Args>(args)...);
  }

private:
  detail::native_context_objects context_objects() const noexcept {
    if (!value_)
      return {};
    return {value_->Filter, value_->Volume, value_->Instance,
            value_->FileObject, value_->Transaction};
  }

  PCFLT_RELATED_OBJECTS value_ = nullptr;
};

/** @brief View of post-operation callback flags. */
class post_operation_flags {
public:
  /** @brief Wraps native post-operation flags. */
  explicit post_operation_flags(FLT_POST_OPERATION_FLAGS value) noexcept
      : value_(value) {}

  /** @brief Returns true when the instance is draining during teardown. */
  bool draining() const noexcept {
    return (value_ & FLTFL_POST_OPERATION_DRAINING) != 0;
  }

  /** @brief Returns the native flag value. */
  FLT_POST_OPERATION_FLAGS native() const noexcept { return value_; }

private:
  FLT_POST_OPERATION_FLAGS value_ = 0;
};

/** @brief View of minifilter unload flags. */
class unload_flags {
public:
  /** @brief Wraps native unload flags. */
  explicit unload_flags(FLT_FILTER_UNLOAD_FLAGS value) noexcept
      : value_(value) {}

  /** @brief Returns true when the unload cannot be vetoed. */
  bool mandatory() const noexcept {
    return (value_ & FLTFL_FILTER_UNLOAD_MANDATORY) != 0;
  }

  /** @brief Returns the native flag value. */
  FLT_FILTER_UNLOAD_FLAGS native() const noexcept { return value_; }

private:
  FLT_FILTER_UNLOAD_FLAGS value_ = 0;
};

