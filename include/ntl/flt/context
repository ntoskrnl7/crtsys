namespace ntl::flt {

/** @brief Filter Manager object to which a context is attached. */
enum class context_scope {
  volume,
  instance,
  file,
  stream,
  stream_handle,
  transaction,
};

/** @brief Pool used by Filter Manager for a typed context. */
enum class context_pool {
  nonpaged,
  nonpaged_nx,
  paged,
};

namespace detail {

constexpr ULONG make_context_tag(char a, char b, char c, char d) noexcept {
  return static_cast<ULONG>(static_cast<unsigned char>(a)) |
         (static_cast<ULONG>(static_cast<unsigned char>(b)) << 8) |
         (static_cast<ULONG>(static_cast<unsigned char>(c)) << 16) |
         (static_cast<ULONG>(static_cast<unsigned char>(d)) << 24);
}

template <context_scope Scope> constexpr ULONG default_context_tag() noexcept {
  if constexpr (Scope == context_scope::volume)
    return make_context_tag('N', 'T', 'L', 'v');
  else if constexpr (Scope == context_scope::instance)
    return make_context_tag('N', 'T', 'L', 'i');
  else if constexpr (Scope == context_scope::file)
    return make_context_tag('N', 'T', 'L', 'f');
  else if constexpr (Scope == context_scope::stream)
    return make_context_tag('N', 'T', 'L', 's');
  else if constexpr (Scope == context_scope::stream_handle)
    return make_context_tag('N', 'T', 'L', 'h');
  else
    return make_context_tag('N', 'T', 'L', 't');
}

constexpr POOL_TYPE native_context_pool(context_pool pool) noexcept {
  switch (pool) {
  case context_pool::nonpaged:
    return NonPagedPool;
  case context_pool::nonpaged_nx:
    return NonPagedPoolNx;
  case context_pool::paged:
    return PagedPool;
  }

  return NonPagedPoolNx;
}

template <context_scope Scope> constexpr FLT_CONTEXT_TYPE native_context_type() {
  if constexpr (Scope == context_scope::volume)
    return FLT_VOLUME_CONTEXT;
  else if constexpr (Scope == context_scope::instance)
    return FLT_INSTANCE_CONTEXT;
  else if constexpr (Scope == context_scope::file)
    return FLT_FILE_CONTEXT;
  else if constexpr (Scope == context_scope::stream)
    return FLT_STREAM_CONTEXT;
  else if constexpr (Scope == context_scope::stream_handle)
    return FLT_STREAMHANDLE_CONTEXT;
  else
    return FLT_TRANSACTION_CONTEXT;
}

inline constexpr ULONG managed_context_signature =
    make_context_tag('N', 'T', 'L', 'C');

struct managed_context_header {
  ULONG signature;
  const void *type;
  void (*destroy)(PFLT_CONTEXT) noexcept;
};

template <class T> struct managed_context_storage {
  managed_context_header header;
  alignas(T) unsigned char value[sizeof(T)];
};

template <class T> struct context_type_token {
  inline static const unsigned char value = 0;
};

template <class T> constexpr const void *context_type() noexcept {
  return &context_type_token<T>::value;
}

template <class T> T *context_value(PFLT_CONTEXT context) noexcept {
  auto *storage = static_cast<managed_context_storage<T> *>(context);
  return reinterpret_cast<T *>(storage->value);
}

template <class T> void destroy_context(PFLT_CONTEXT context) noexcept {
  auto *storage = static_cast<managed_context_storage<T> *>(context);
  context_value<T>(context)->~T();
  storage->header.signature = 0;
  storage->header.type = nullptr;
  storage->header.destroy = nullptr;
}

inline void FLTAPI context_cleanup(PFLT_CONTEXT context,
                                   FLT_CONTEXT_TYPE) noexcept {
  if (!context)
    return;

  auto *header = static_cast<managed_context_header *>(context);
  if (header->signature == managed_context_signature && header->destroy)
    header->destroy(context);
}

template <class T, class... Args>
void construct_context(PFLT_CONTEXT context, Args &&...args) noexcept {
  static_assert(std::is_nothrow_constructible_v<T, Args...>,
                "Filter Manager context constructors must be noexcept");

  auto *storage = static_cast<managed_context_storage<T> *>(context);
  storage->header = {};
  ::new (storage->value) T(std::forward<Args>(args)...);
  storage->header.type = context_type<T>();
  storage->header.destroy = destroy_context<T>;
  storage->header.signature = managed_context_signature;
}

template <class T> bool is_context_type(PFLT_CONTEXT context) noexcept {
  if (!context)
    return false;
  const auto *header = static_cast<const managed_context_header *>(context);
  return header->signature == managed_context_signature &&
         header->type == context_type<T>();
}

struct native_context_objects {
  PFLT_FILTER filter = nullptr;
  PFLT_VOLUME volume = nullptr;
  PFLT_INSTANCE instance = nullptr;
  PFILE_OBJECT file = nullptr;
  PKTRANSACTION transaction = nullptr;
};

template <context_scope Scope> struct context_api;

template <> struct context_api<context_scope::volume> {
  static bool valid(const native_context_objects &objects) noexcept {
    return objects.filter && objects.volume;
  }
  static bool supports(const native_context_objects &objects) noexcept {
    return valid(objects);
  }
  static NTSTATUS get(const native_context_objects &objects,
                      PFLT_CONTEXT *context) noexcept {
    return FltGetVolumeContext(objects.filter, objects.volume, context);
  }
  static NTSTATUS set(const native_context_objects &objects,
                      PFLT_CONTEXT context,
                      PFLT_CONTEXT *old_context) noexcept {
    return FltSetVolumeContext(objects.volume, FLT_SET_CONTEXT_KEEP_IF_EXISTS,
                               context, old_context);
  }
};

template <> struct context_api<context_scope::instance> {
  static bool valid(const native_context_objects &objects) noexcept {
    return objects.filter && objects.instance;
  }
  static bool supports(const native_context_objects &objects) noexcept {
    return valid(objects);
  }
  static NTSTATUS get(const native_context_objects &objects,
                      PFLT_CONTEXT *context) noexcept {
    return FltGetInstanceContext(objects.instance, context);
  }
  static NTSTATUS set(const native_context_objects &objects,
                      PFLT_CONTEXT context,
                      PFLT_CONTEXT *old_context) noexcept {
    return FltSetInstanceContext(objects.instance,
                                 FLT_SET_CONTEXT_KEEP_IF_EXISTS, context,
                                 old_context);
  }
};

template <> struct context_api<context_scope::file> {
  static bool valid(const native_context_objects &objects) noexcept {
    return objects.filter && objects.instance && objects.file;
  }
  static bool supports(const native_context_objects &objects) noexcept {
    return valid(objects) &&
           FltSupportsFileContextsEx(objects.file, objects.instance) != FALSE;
  }
  static NTSTATUS get(const native_context_objects &objects,
                      PFLT_CONTEXT *context) noexcept {
    return FltGetFileContext(objects.instance, objects.file, context);
  }
  static NTSTATUS set(const native_context_objects &objects,
                      PFLT_CONTEXT context,
                      PFLT_CONTEXT *old_context) noexcept {
    return FltSetFileContext(objects.instance, objects.file,
                             FLT_SET_CONTEXT_KEEP_IF_EXISTS, context,
                             old_context);
  }
};

