/**
 * @brief Declares one typed Filter Manager context used by a minifilter.
 * @tparam T C++ state stored in the context.
 * @tparam Scope Filter Manager object that owns the context.
 *
 * Use the public file_context, stream_context, stream_handle_context,
 * instance_context, volume_context, or transaction_context aliases.
 */
template <class T, context_scope Scope> class context_definition {
  static_assert(Scope != context_scope::volume,
                "volume contexts use the NonPagedPool-only specialization");

public:
  using value_type = T;
  static constexpr context_scope scope = Scope;

  /**
   * @brief Creates a context in NonPagedPoolNx with the default NTL tag.
   */
  constexpr context_definition() noexcept = default;

  /** @brief Selects the allocation pool while retaining the default tag. */
  constexpr explicit context_definition(context_pool pool) noexcept
      : pool_(pool) {}

  /** @brief Selects a diagnostic tag while retaining the scope's default. */
  constexpr explicit context_definition(ULONG pool_tag) noexcept
      : pool_tag_(pool_tag) {}

  /** @brief Selects both the allocation pool and diagnostic pool tag. */
  constexpr context_definition(context_pool pool, ULONG pool_tag) noexcept
      : pool_(pool), pool_tag_(pool_tag) {}

  /** @brief Returns the pool used by FltAllocateContext. */
  constexpr context_pool pool() const noexcept { return pool_; }

  /** @brief Returns the context pool tag registered with Filter Manager. */
  constexpr ULONG pool_tag() const noexcept { return pool_tag_; }

private:
  context_pool pool_ = context_pool::nonpaged_nx;
  ULONG pool_tag_ = detail::default_context_tag<Scope>();
};

/**
 * @brief Declares volume state using Filter Manager's required NonPagedPool.
 *
 * Filter Manager does not permit callers to select another pool for a volume
 * context, so this specialization deliberately exposes no pool constructor.
 */
template <class T>
class context_definition<T, context_scope::volume> {
public:
  using value_type = T;
  static constexpr context_scope scope = context_scope::volume;

  /** @brief Creates a NonPagedPool volume context with the default NTL tag. */
  constexpr context_definition() noexcept = default;

  /** @brief Selects the diagnostic tag for the NonPagedPool allocation. */
  constexpr explicit context_definition(ULONG pool_tag) noexcept
      : pool_tag_(pool_tag) {}

  /** @brief Returns Filter Manager's required volume-context pool. */
  constexpr context_pool pool() const noexcept {
    return context_pool::nonpaged;
  }

  /** @brief Returns the context pool tag registered with Filter Manager. */
  constexpr ULONG pool_tag() const noexcept { return pool_tag_; }

private:
  ULONG pool_tag_ = detail::default_context_tag<context_scope::volume>();
};

/** @brief Declares state owned by one volume. */
template <class T>
using volume_context = context_definition<T, context_scope::volume>;

/** @brief Declares state owned by one filter instance on a volume. */
template <class T>
using instance_context = context_definition<T, context_scope::instance>;

/** @brief Declares state shared by all streams of one file in an instance. */
template <class T>
using file_context = context_definition<T, context_scope::file>;

/** @brief Declares state owned by one file stream in an instance. */
template <class T>
using stream_context = context_definition<T, context_scope::stream>;

/** @brief Declares state owned by one open FILE_OBJECT in an instance. */
template <class T>
using stream_handle_context =
    context_definition<T, context_scope::stream_handle>;

/** @brief Declares state owned by one file-system transaction. */
template <class T>
using transaction_context = context_definition<T, context_scope::transaction>;

/**
 * @brief Owns one reference returned by a Filter Manager context routine.
 * @tparam T C++ context state.
 * @tparam Scope Filter Manager object carrying the state.
 *
 * Destruction calls FltReleaseContext. The reference is move-only so each
 * successful allocation/get/set result has one obvious release owner.
 */
template <class T, context_scope Scope> class context_ref {
public:
  context_ref() noexcept = default;
  context_ref(const context_ref &) = delete;
  context_ref &operator=(const context_ref &) = delete;

  context_ref(context_ref &&other) noexcept : context_(other.release()) {}

  context_ref &operator=(context_ref &&other) noexcept {
    if (this != &other) {
      reset();
      context_ = other.release();
    }
    return *this;
  }

  /** @brief Releases the owned Filter Manager reference. */
  ~context_ref() { reset(); }

  /** @brief Returns the typed C++ state. */
  T *get() const noexcept {
    return context_ ? detail::context_value<T>(context_) : nullptr;
  }

  /** @brief Returns the typed state by reference. */
  T &operator*() const noexcept { return *get(); }

  /** @brief Provides member access to the typed state. */
  T *operator->() const noexcept { return get(); }

  /** @brief Returns true when a context reference is owned. */
  explicit operator bool() const noexcept { return context_ != nullptr; }

  /** @brief Returns the native context pointer without releasing ownership. */
  PFLT_CONTEXT native_context() const noexcept { return context_; }

  /** @brief Releases the reference now. */
  void reset() noexcept {
    if (context_) {
      FltReleaseContext(context_);
      context_ = nullptr;
    }
  }

private:
  template <class U, context_scope OtherScope>
  friend ntl::result<context_ref<U, OtherScope>> detail_adopt_context(
      PFLT_CONTEXT) noexcept;

  explicit context_ref(PFLT_CONTEXT context) noexcept : context_(context) {}

  PFLT_CONTEXT release() noexcept {
    PFLT_CONTEXT result = context_;
    context_ = nullptr;
    return result;
  }

  PFLT_CONTEXT context_ = nullptr;
};

template <class T, context_scope Scope>
ntl::result<context_ref<T, Scope>>
detail_adopt_context(PFLT_CONTEXT context) noexcept {
  if (!detail::is_context_type<T>(context)) {
    if (context)
      FltReleaseContext(context);
    return ntl::unexpected(STATUS_OBJECT_TYPE_MISMATCH);
  }
  return ntl::ok(context_ref<T, Scope>{context});
}

namespace detail {

template <class T, context_scope Scope>
ntl::result<context_ref<T, Scope>>
get_context(const native_context_objects &objects) noexcept {
  if (KeGetCurrentIrql() > APC_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);
  if (!context_api<Scope>::valid(objects))
    return ntl::unexpected(STATUS_INVALID_PARAMETER);

  PFLT_CONTEXT context = nullptr;
  const NTSTATUS status = context_api<Scope>::get(objects, &context);
  if (!NT_SUCCESS(status))
    return ntl::unexpected(status);
  return detail_adopt_context<T, Scope>(context);
}

template <class T, context_scope Scope, class... Args>
ntl::result<context_ref<T, Scope>> get_or_create_context(
    const native_context_objects &objects,
    const context_definition<T, Scope> &definition, Args &&...args) noexcept {
  static_assert(alignof(managed_context_storage<T>) <=
                    MEMORY_ALLOCATION_ALIGNMENT,
                "Filter Manager context type requires unsupported alignment");
  static_assert(std::is_nothrow_destructible_v<T>,
                "Filter Manager context destructors must be noexcept");
  static_assert(sizeof(managed_context_storage<T>) <= MAXUSHORT,
                "Filter Manager context storage exceeds MAXUSHORT");

  auto existing = get_context<T, Scope>(objects);
  if (existing)
    return existing;
  if (existing.status() != STATUS_NOT_FOUND)
    return ntl::unexpected(existing.status());

  if (!context_api<Scope>::supports(objects))
    return ntl::unexpected(STATUS_NOT_SUPPORTED);
  const POOL_TYPE pool = native_context_pool(definition.pool());
  PFLT_CONTEXT allocated = nullptr;
  NTSTATUS status = FltAllocateContext(
      objects.filter, native_context_type<Scope>(),
      sizeof(managed_context_storage<T>), pool, &allocated);
  if (!NT_SUCCESS(status))
    return ntl::unexpected(status);

  construct_context<T>(allocated, std::forward<Args>(args)...);
  auto created_result = detail_adopt_context<T, Scope>(allocated);
  if (!created_result)
    return ntl::unexpected(created_result.status());
  context_ref<T, Scope> created = std::move(*created_result);

  PFLT_CONTEXT old_context = nullptr;
  status = context_api<Scope>::set(objects, created.native_context(),
                                   &old_context);
  if (NT_SUCCESS(status))
    return ntl::ok(std::move(created));

  if (status == STATUS_FLT_CONTEXT_ALREADY_DEFINED && old_context)
    return detail_adopt_context<T, Scope>(old_context);

  if (old_context)
    FltReleaseContext(old_context);
  return ntl::unexpected(status);
}

