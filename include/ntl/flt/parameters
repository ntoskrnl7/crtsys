/** @brief Validates and retains callback data for one operation type. */
template <operation_id Expected> class operation_parameters {
public:
  /** @brief Returns true when the callback carries the expected operation. */
  explicit operator bool() const noexcept { return data_ != nullptr; }

protected:
  explicit operation_parameters(PFLT_CALLBACK_DATA data) noexcept
      : data_(data && data->Iopb &&
                      data->Iopb->MajorFunction == static_cast<UCHAR>(Expected)
                  ? data
                  : nullptr) {}

  PFLT_IO_PARAMETER_BLOCK iopb() const noexcept {
    return data_ ? data_->Iopb : nullptr;
  }

  PFLT_CALLBACK_DATA callback() const noexcept { return data_; }

  void dirty() const noexcept {
    if (data_)
      FltSetCallbackDataDirty(data_);
  }

private:
  PFLT_CALLBACK_DATA data_ = nullptr;
};

} // namespace detail

/** @brief Typed view of IRP_MJ_CREATE parameters. */
class create_parameters
    : public detail::operation_parameters<operation_id::create> {
  using base = detail::operation_parameters<operation_id::create>;

public:
  /** @brief Wraps create parameters after validating the major function. */
  explicit create_parameters(PFLT_CALLBACK_DATA data) noexcept : base(data) {}

  PIO_SECURITY_CONTEXT security_context() const noexcept {
    return iopb() ? iopb()->Parameters.Create.SecurityContext : nullptr;
  }

  /** @brief Returns the packed create options and disposition. */
  ULONG options() const noexcept {
    return iopb() ? iopb()->Parameters.Create.Options : 0;
  }

  /** @brief Returns the low 24-bit FILE_* create options. */
  ULONG create_options() const noexcept { return options() & 0x00ffffffUL; }

  /** @brief Returns the high 8-bit FILE_* create disposition. */
  UCHAR disposition() const noexcept {
    return static_cast<UCHAR>(options() >> 24);
  }

  USHORT file_attributes() const noexcept {
    return iopb() ? iopb()->Parameters.Create.FileAttributes : 0;
  }

  USHORT share_access() const noexcept {
    return iopb() ? iopb()->Parameters.Create.ShareAccess : 0;
  }

  ULONG ea_length() const noexcept {
    return iopb() ? iopb()->Parameters.Create.EaLength : 0;
  }

  PVOID ea_buffer() const noexcept {
    return iopb() ? iopb()->Parameters.Create.EaBuffer : nullptr;
  }

  LARGE_INTEGER allocation_size() const noexcept {
    return iopb() ? iopb()->Parameters.Create.AllocationSize : LARGE_INTEGER{};
  }

  /** @brief Replaces the packed create options and marks callback data dirty.
   */
  void options(ULONG value) noexcept {
    if (!iopb())
      return;
    iopb()->Parameters.Create.Options = value;
    dirty();
  }

  /** @brief Replaces file attributes and marks callback data dirty. */
  void file_attributes(USHORT value) noexcept {
    if (!iopb())
      return;
    iopb()->Parameters.Create.FileAttributes = value;
    dirty();
  }

  /** @brief Replaces share access and marks callback data dirty. */
  void share_access(USHORT value) noexcept {
    if (!iopb())
      return;
    iopb()->Parameters.Create.ShareAccess = value;
    dirty();
  }

  /** @brief Replaces the EA buffer and marks callback data dirty. */
  void ea(PVOID buffer, ULONG length) noexcept {
    if (!iopb())
      return;
    iopb()->Parameters.Create.EaBuffer = buffer;
    iopb()->Parameters.Create.EaLength = length;
    dirty();
  }

  /** @brief Replaces allocation size and marks callback data dirty. */
  void allocation_size(LARGE_INTEGER value) noexcept {
    if (!iopb())
      return;
    iopb()->Parameters.Create.AllocationSize = value;
    dirty();
  }
};

/** @brief Typed view shared by IRP_MJ_READ and IRP_MJ_WRITE. */
template <operation_id Expected>
class transfer_parameters : public detail::operation_parameters<Expected> {
  static_assert(Expected == operation_id::read ||
                    Expected == operation_id::write,
                "transfer_parameters supports only read and write");
  using base = detail::operation_parameters<Expected>;

public:
  /** @brief Wraps transfer parameters after validating the major function. */
  explicit transfer_parameters(PFLT_CALLBACK_DATA data) noexcept : base(data) {}

  ULONG length() const noexcept {
    if (!this->iopb())
      return 0;
    if constexpr (Expected == operation_id::read)
      return this->iopb()->Parameters.Read.Length;
    else
      return this->iopb()->Parameters.Write.Length;
  }

  ULONG key() const noexcept {
    if (!this->iopb())
      return 0;
    if constexpr (Expected == operation_id::read)
      return this->iopb()->Parameters.Read.Key;
    else
      return this->iopb()->Parameters.Write.Key;
  }

  LARGE_INTEGER byte_offset() const noexcept {
    if (!this->iopb())
      return LARGE_INTEGER{};
    if constexpr (Expected == operation_id::read)
      return this->iopb()->Parameters.Read.ByteOffset;
    else
      return this->iopb()->Parameters.Write.ByteOffset;
  }

  PVOID buffer() const noexcept {
    if (!this->iopb())
      return nullptr;
    if constexpr (Expected == operation_id::read)
      return this->iopb()->Parameters.Read.ReadBuffer;
    else
      return this->iopb()->Parameters.Write.WriteBuffer;
  }

  PMDL mdl() const noexcept {
    if (!this->iopb())
      return nullptr;
    if constexpr (Expected == operation_id::read)
      return this->iopb()->Parameters.Read.MdlAddress;
    else
      return this->iopb()->Parameters.Write.MdlAddress;
  }

  void length(ULONG value) noexcept {
    if (!this->iopb())
      return;
    if constexpr (Expected == operation_id::read)
      this->iopb()->Parameters.Read.Length = value;
    else
      this->iopb()->Parameters.Write.Length = value;
    this->dirty();
  }

  void key(ULONG value) noexcept {
    if (!this->iopb())
      return;
    if constexpr (Expected == operation_id::read)
      this->iopb()->Parameters.Read.Key = value;
    else
      this->iopb()->Parameters.Write.Key = value;
    this->dirty();
  }

  void byte_offset(LARGE_INTEGER value) noexcept {
    if (!this->iopb())
      return;
    if constexpr (Expected == operation_id::read)
      this->iopb()->Parameters.Read.ByteOffset = value;
    else
      this->iopb()->Parameters.Write.ByteOffset = value;
    this->dirty();
  }

  void buffer(PVOID value, PMDL mdl = nullptr) noexcept {
    if (!this->iopb())
      return;
    if constexpr (Expected == operation_id::read) {
      this->iopb()->Parameters.Read.ReadBuffer = value;
      this->iopb()->Parameters.Read.MdlAddress = mdl;
    } else {
      this->iopb()->Parameters.Write.WriteBuffer = value;
      this->iopb()->Parameters.Write.MdlAddress = mdl;
    }
    this->dirty();
  }
};

using read_parameters = transfer_parameters<operation_id::read>;
using write_parameters = transfer_parameters<operation_id::write>;

