/** @brief Typed view of IRP_MJ_DIRECTORY_CONTROL parameters. */
class directory_control_parameters
    : public detail::operation_parameters<operation_id::directory_control> {
  using base = detail::operation_parameters<operation_id::directory_control>;

public:
  explicit directory_control_parameters(PFLT_CALLBACK_DATA data) noexcept
      : base(data) {}

  UCHAR minor_function() const noexcept {
    return iopb() ? iopb()->MinorFunction : 0xff;
  }

  bool is_query() const noexcept {
    return minor_function() == IRP_MN_QUERY_DIRECTORY;
  }

  bool is_notify() const noexcept {
    return minor_function() == IRP_MN_NOTIFY_CHANGE_DIRECTORY;
  }

  bool is_notify_ex() const noexcept {
#ifdef IRP_MN_NOTIFY_CHANGE_DIRECTORY_EX
    return minor_function() == IRP_MN_NOTIFY_CHANGE_DIRECTORY_EX;
#else
    return false;
#endif
  }

  ULONG length() const noexcept {
    if (!iopb())
      return 0;
    if (is_query())
      return iopb()->Parameters.DirectoryControl.QueryDirectory.Length;
    if (is_notify())
      return iopb()->Parameters.DirectoryControl.NotifyDirectory.Length;
    if (is_notify_ex())
      return iopb()->Parameters.DirectoryControl.NotifyDirectoryEx.Length;
    return 0;
  }

  PUNICODE_STRING file_name() const noexcept {
    return is_query()
               ? iopb()->Parameters.DirectoryControl.QueryDirectory.FileName
               : nullptr;
  }

  FILE_INFORMATION_CLASS information_class() const noexcept {
    return is_query() ? iopb()
                            ->Parameters.DirectoryControl.QueryDirectory
                            .FileInformationClass
                      : FileDirectoryInformation;
  }

  PVOID buffer() const noexcept {
    if (!iopb())
      return nullptr;
    if (is_query())
      return iopb()->Parameters.DirectoryControl.QueryDirectory.DirectoryBuffer;
    if (is_notify())
      return iopb()
          ->Parameters.DirectoryControl.NotifyDirectory.DirectoryBuffer;
    if (is_notify_ex())
      return iopb()
          ->Parameters.DirectoryControl.NotifyDirectoryEx.DirectoryBuffer;
    return nullptr;
  }

  PMDL mdl() const noexcept {
    if (!iopb())
      return nullptr;
    if (is_query())
      return iopb()->Parameters.DirectoryControl.QueryDirectory.MdlAddress;
    if (is_notify())
      return iopb()->Parameters.DirectoryControl.NotifyDirectory.MdlAddress;
    if (is_notify_ex())
      return iopb()->Parameters.DirectoryControl.NotifyDirectoryEx.MdlAddress;
    return nullptr;
  }
};

/** @brief Typed view shared by file-system and device-control operations. */
template <operation_id Expected>
class control_parameters : public detail::operation_parameters<Expected> {
  static_assert(Expected == operation_id::file_system_control ||
                    Expected == operation_id::device_control ||
                    Expected == operation_id::internal_device_control,
                "control_parameters supports only FSCTL and IOCTL operations");
  using base = detail::operation_parameters<Expected>;

public:
  explicit control_parameters(PFLT_CALLBACK_DATA data) noexcept : base(data) {}

  /** @brief Returns true for the dedicated fast-I/O IOCTL layout. */
  bool is_fast_io() const noexcept {
    if constexpr (Expected == operation_id::file_system_control)
      return false;
    else
      return this->callback() && FLT_IS_FASTIO_OPERATION(this->callback());
  }

  ULONG code() const noexcept {
    if (!this->iopb())
      return 0;
    if constexpr (Expected == operation_id::file_system_control)
      return this->iopb()->Parameters.FileSystemControl.Common.FsControlCode;
    else if (is_fast_io())
      return this->iopb()->Parameters.DeviceIoControl.FastIo.IoControlCode;
    else
      return this->iopb()->Parameters.DeviceIoControl.Common.IoControlCode;
  }

  ULONG input_length() const noexcept {
    if (!this->iopb())
      return 0;
    if constexpr (Expected == operation_id::file_system_control)
      return this->iopb()
          ->Parameters.FileSystemControl.Common.InputBufferLength;
    else if (is_fast_io())
      return this->iopb()->Parameters.DeviceIoControl.FastIo.InputBufferLength;
    else
      return this->iopb()->Parameters.DeviceIoControl.Common.InputBufferLength;
  }

  ULONG output_length() const noexcept {
    if (!this->iopb())
      return 0;
    if constexpr (Expected == operation_id::file_system_control)
      return this->iopb()
          ->Parameters.FileSystemControl.Common.OutputBufferLength;
    else if (is_fast_io())
      return this->iopb()->Parameters.DeviceIoControl.FastIo.OutputBufferLength;
    else
      return this->iopb()->Parameters.DeviceIoControl.Common.OutputBufferLength;
  }

  ULONG method() const noexcept { return code() & 3UL; }

  PVOID input_buffer() const noexcept {
    if (!this->iopb())
      return nullptr;
    if constexpr (Expected == operation_id::file_system_control) {
      if (method() == METHOD_BUFFERED)
        return this->iopb()->Parameters.FileSystemControl.Buffered.SystemBuffer;
      if (method() == METHOD_NEITHER)
        return this->iopb()->Parameters.FileSystemControl.Neither.InputBuffer;
      return this->iopb()
          ->Parameters.FileSystemControl.Direct.InputSystemBuffer;
    } else {
      if (is_fast_io())
        return this->iopb()->Parameters.DeviceIoControl.FastIo.InputBuffer;
      if (method() == METHOD_BUFFERED)
        return this->iopb()->Parameters.DeviceIoControl.Buffered.SystemBuffer;
      if (method() == METHOD_NEITHER)
        return this->iopb()->Parameters.DeviceIoControl.Neither.InputBuffer;
      return this->iopb()->Parameters.DeviceIoControl.Direct.InputSystemBuffer;
    }
  }

  PVOID output_buffer() const noexcept {
    if (!this->iopb())
      return nullptr;
    if constexpr (Expected == operation_id::file_system_control) {
      if (method() == METHOD_BUFFERED)
        return this->iopb()->Parameters.FileSystemControl.Buffered.SystemBuffer;
      if (method() == METHOD_NEITHER)
        return this->iopb()->Parameters.FileSystemControl.Neither.OutputBuffer;
      return this->iopb()->Parameters.FileSystemControl.Direct.OutputBuffer;
    } else {
      if (is_fast_io())
        return this->iopb()->Parameters.DeviceIoControl.FastIo.OutputBuffer;
      if (method() == METHOD_BUFFERED)
        return this->iopb()->Parameters.DeviceIoControl.Buffered.SystemBuffer;
      if (method() == METHOD_NEITHER)
        return this->iopb()->Parameters.DeviceIoControl.Neither.OutputBuffer;
      return this->iopb()->Parameters.DeviceIoControl.Direct.OutputBuffer;
    }
  }

  PMDL output_mdl() const noexcept {
    if (!this->iopb() || is_fast_io() || method() == METHOD_BUFFERED)
      return nullptr;
    if constexpr (Expected == operation_id::file_system_control) {
      return method() == METHOD_NEITHER
                 ? this->iopb()
                       ->Parameters.FileSystemControl.Neither.OutputMdlAddress
                 : this->iopb()
                       ->Parameters.FileSystemControl.Direct.OutputMdlAddress;
    } else {
      return method() == METHOD_NEITHER
                 ? this->iopb()
                       ->Parameters.DeviceIoControl.Neither.OutputMdlAddress
                 : this->iopb()
                       ->Parameters.DeviceIoControl.Direct.OutputMdlAddress;
    }
  }
};

using file_system_control_parameters =
    control_parameters<operation_id::file_system_control>;
using device_control_parameters =
    control_parameters<operation_id::device_control>;
using internal_device_control_parameters =
    control_parameters<operation_id::internal_device_control>;

/** @brief Empty parameter view for operations with no typed NTL fields. */
class no_parameters {
public:
  explicit no_parameters(PFLT_CALLBACK_DATA data) noexcept : data_(data) {}

  /** @brief Returns true when callback data and its IOPB are present. */
  explicit operator bool() const noexcept {
    return data_ != nullptr && data_->Iopb != nullptr;
  }

private:
  PFLT_CALLBACK_DATA data_ = nullptr;
};

/** @brief Maps a compile-time operation to its only legal parameter view. */
template <operation_id Value> struct operation_parameter_traits {
  using type = no_parameters;
};

template <> struct operation_parameter_traits<operation_id::create> {
  using type = create_parameters;
};

template <> struct operation_parameter_traits<operation_id::read> {
  using type = read_parameters;
};

template <> struct operation_parameter_traits<operation_id::write> {
  using type = write_parameters;
};

template <> struct operation_parameter_traits<operation_id::query_information> {
  using type = query_information_parameters;
};

template <> struct operation_parameter_traits<operation_id::set_information> {
  using type = set_information_parameters;
};

template <> struct operation_parameter_traits<operation_id::directory_control> {
  using type = directory_control_parameters;
};

template <>
struct operation_parameter_traits<operation_id::file_system_control> {
  using type = file_system_control_parameters;
};

template <> struct operation_parameter_traits<operation_id::device_control> {
  using type = device_control_parameters;
};

template <>
struct operation_parameter_traits<operation_id::internal_device_control> {
  using type = internal_device_control_parameters;
};

template <operation_id Value>
using operation_parameters_t = typename operation_parameter_traits<Value>::type;

} // namespace ntl::flt
