  /**
   * @brief Registers one typed Filter Manager context declaration.
   * @param definition Context type, scope, allocation pool, and pool tag.
   * @return This registration for fluent configuration.
   */
  template <class T, context_scope Scope>
  registration &context(const context_definition<T, Scope> &definition) {
    const ntl::status result = try_context(definition);
    if (result.is_err())
      throw ntl::exception(result, "Invalid minifilter context registration");
    return *this;
  }

  /**
   * @brief Registers one typed context declaration without throwing.
   * @return STATUS_SUCCESS or an invalid/duplicate registration status.
   */
  template <class T, context_scope Scope>
  ntl::status
  try_context(const context_definition<T, Scope> &definition) noexcept {
    static_assert(alignof(detail::managed_context_storage<T>) <=
                      MEMORY_ALLOCATION_ALIGNMENT,
                  "Filter Manager context type requires unsupported alignment");
    static_assert(std::is_nothrow_destructible_v<T>,
                  "Filter Manager context destructors must be noexcept");
    static_assert(sizeof(detail::managed_context_storage<T>) <= MAXUSHORT,
                  "Filter Manager context storage exceeds MAXUSHORT");

    constexpr auto native_type = detail::native_context_type<Scope>();
    const auto bit = static_cast<ULONG>(native_type);
    if ((registered_contexts_ & bit) != 0)
      return STATUS_OBJECT_NAME_COLLISION;
    if (definition.pool_tag() == 0)
      return STATUS_INVALID_PARAMETER;
    FLT_CONTEXT_REGISTRATION native{};
    native.ContextType = native_type;
    native.ContextCleanupCallback = detail::context_cleanup;
    native.Size = sizeof(detail::managed_context_storage<T>);
    native.PoolTag = definition.pool_tag();

    try {
      native_contexts_.push_back(native);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    registered_contexts_ |= bit;
    return STATUS_SUCCESS;
  }

private:
  template <operation_id Value>
  static constexpr void assert_read_write_operation() noexcept {
    static_assert(Value == operation_id::read || Value == operation_id::write,
                  "Filter Manager operation flags apply only to read/write");
  }

  template <operation_id Value, typename Pre, typename Post>
  registration &on_impl(UCHAR major_function, Pre pre, Post post,
                        operation_flags flags) {
    const ntl::status result = try_on_impl<Value>(
        major_function, std::move(pre), std::move(post), flags);
    if (result.is_err())
      throw ntl::exception(result, "Invalid minifilter operation registration");
    return *this;
  }

  template <operation_id Value, typename Pre, typename Post, typename SafePost>
  registration &on_safe_impl(UCHAR major_function, Pre pre, Post post,
                             SafePost safe_post, operation_flags flags) {
    const ntl::status result =
        try_on_safe_impl<Value>(major_function, std::move(pre), std::move(post),
                                std::move(safe_post), flags);
    if (result.is_err())
      throw ntl::exception(result, "Invalid minifilter operation registration");
    return *this;
  }

  template <operation_id Value, class Completion, typename Pre, typename Post>
  registration &on_completion_impl(UCHAR major_function, Pre pre, Post post,
                                   operation_flags flags) {
    const ntl::status result = try_on_completion_impl<Value, Completion>(
        major_function, std::move(pre), std::move(post), flags);
    if (result.is_err())
      throw ntl::exception(result,
                           "Invalid typed minifilter completion registration");
    return *this;
  }

  template <operation_id Value, class Completion, typename Pre, typename Post,
            typename SafePost>
  registration &on_completion_safe_impl(UCHAR major_function, Pre pre,
                                        Post post, SafePost safe_post,
                                        operation_flags flags) {
    const ntl::status result = try_on_completion_safe_impl<Value, Completion>(
        major_function, std::move(pre), std::move(post), std::move(safe_post),
        flags);
    if (result.is_err())
      throw ntl::exception(result,
                           "Invalid typed minifilter safe-post registration");
    return *this;
  }

  template <operation_id Value, typename Pre, typename Post, typename SafePost>
  ntl::status try_on_safe_impl(UCHAR major_function, Pre pre, Post post,
                               SafePost safe_post,
                               operation_flags flags) noexcept {
    if (major_function == IRP_MJ_OPERATION_END)
      return STATUS_INVALID_PARAMETER;
    if (callback_index_[major_function])
      return STATUS_OBJECT_NAME_COLLISION;

    std::unique_ptr<detail::operation_callback_slot> callbacks;
    try {
      callbacks = std::make_unique<detail::operation_callback_slot>();
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    ntl::status result{STATUS_SUCCESS};
    if constexpr (detail::is_pre_callback_v<Value, Pre>) {
      result = callbacks->pre.template set<Value>(std::move(pre));
    } else {
      result = callbacks->pre.template set_normal<Value>(std::move(pre));
    }
    if (result.is_err())
      return result;

    if constexpr (detail::is_immediate_post_callback_v<Value, Post>) {
      result = callbacks->post.template set_safe<Value>(std::move(post),
                                                        std::move(safe_post));
    } else {
      result = callbacks->post.template set_normal_safe<Value>(
          std::move(post), std::move(safe_post));
    }
    if (result.is_err())
      return result;

    FLT_OPERATION_REGISTRATION native{};
    native.MajorFunction = major_function;
    native.Flags = static_cast<FLT_OPERATION_REGISTRATION_FLAGS>(flags);
    native.PreOperation = detail::pre_operation_trampoline;
    native.PostOperation = detail::post_operation_trampoline;

    try {
      native_operations_.push_back(native);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    try {
      callback_slots_.push_back(std::move(callbacks));
    } catch (...) {
      native_operations_.pop_back();
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    callback_index_[major_function] = callback_slots_.back().get();
    return STATUS_SUCCESS;
  }

  template <operation_id Value, class Completion, typename Pre, typename Post,
            typename SafePost>
  ntl::status try_on_completion_safe_impl(UCHAR major_function, Pre pre,
                                          Post post, SafePost safe_post,
                                          operation_flags flags) noexcept {
    if (major_function == IRP_MJ_OPERATION_END)
      return STATUS_INVALID_PARAMETER;
    if (callback_index_[major_function])
      return STATUS_OBJECT_NAME_COLLISION;

    std::unique_ptr<detail::operation_callback_slot> callbacks;
    try {
      callbacks = std::make_unique<detail::operation_callback_slot>();
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    ntl::status result =
        callbacks->pre.template set_completion<Value, Completion>(
            std::move(pre));
    if (result.is_err())
      return result;

    result = callbacks->post.template set_completion_safe<Value, Completion>(
        std::move(post), std::move(safe_post));
    if (result.is_err())
      return result;

    FLT_OPERATION_REGISTRATION native{};
    native.MajorFunction = major_function;
    native.Flags = static_cast<FLT_OPERATION_REGISTRATION_FLAGS>(flags);
    native.PreOperation = detail::pre_operation_trampoline;
    native.PostOperation = detail::post_operation_trampoline;

    try {
      native_operations_.push_back(native);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    try {
      callback_slots_.push_back(std::move(callbacks));
    } catch (...) {
      native_operations_.pop_back();
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    callback_index_[major_function] = callback_slots_.back().get();
    return STATUS_SUCCESS;
  }

  template <operation_id Value, class Completion, typename Pre, typename Post>
  ntl::status try_on_completion_impl(UCHAR major_function, Pre pre, Post post,
                                     operation_flags flags) noexcept {
    if (major_function == IRP_MJ_OPERATION_END)
      return STATUS_INVALID_PARAMETER;
    if (callback_index_[major_function])
      return STATUS_OBJECT_NAME_COLLISION;

    std::unique_ptr<detail::operation_callback_slot> callbacks;
    try {
      callbacks = std::make_unique<detail::operation_callback_slot>();
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    ntl::status result =
        callbacks->pre.template set_completion<Value, Completion>(
            std::move(pre));
    if (result.is_err())
      return result;

    if constexpr (detail::is_normal_completion_post_callback_v<
                      Value, Completion, Post>) {
      result =
          callbacks->post.template set_completion_normal<Value, Completion>(
              std::move(post));
    } else {
      result =
          callbacks->post.template set_completion_draining<Value, Completion>(
              std::move(post));
    }
    if (result.is_err())
      return result;

    FLT_OPERATION_REGISTRATION native{};
    native.MajorFunction = major_function;
    native.Flags = static_cast<FLT_OPERATION_REGISTRATION_FLAGS>(flags);
    native.PreOperation = detail::pre_operation_trampoline;
    native.PostOperation = detail::post_operation_trampoline;

    try {
      native_operations_.push_back(native);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    try {
      callback_slots_.push_back(std::move(callbacks));
    } catch (...) {
      native_operations_.pop_back();
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    callback_index_[major_function] = callback_slots_.back().get();
    return STATUS_SUCCESS;
  }

  template <operation_id Value, typename Pre, typename Post>
  ntl::status try_on_impl(UCHAR major_function, Pre pre, Post post,
                          operation_flags flags) noexcept {
    if (major_function == IRP_MJ_OPERATION_END)
      return STATUS_INVALID_PARAMETER;
    if (callback_index_[major_function])
      return STATUS_OBJECT_NAME_COLLISION;

    std::unique_ptr<detail::operation_callback_slot> callbacks;
    try {
      callbacks = std::make_unique<detail::operation_callback_slot>();
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    ntl::status result{STATUS_SUCCESS};
    if constexpr (detail::is_pre_callback_v<Value, Pre>) {
      result = callbacks->pre.template set<Value>(std::move(pre));
    } else {
      result = callbacks->pre.template set_normal<Value>(std::move(pre));
    }
    if (result.is_err())
      return result;

    if constexpr (!std::is_same_v<std::decay_t<Post>, std::nullptr_t>) {
      if constexpr (detail::is_post_callback_v<Value, Post>) {
        result = callbacks->post.template set<Value>(std::move(post));
      } else {
        result = callbacks->post.template set_normal<Value>(std::move(post));
      }
      if (result.is_err())
        return result;
    }

    FLT_OPERATION_REGISTRATION native{};
    native.MajorFunction = major_function;
    native.Flags = static_cast<FLT_OPERATION_REGISTRATION_FLAGS>(flags);
    native.PreOperation = detail::pre_operation_trampoline;
    native.PostOperation = std::is_same_v<std::decay_t<Post>, std::nullptr_t>
                               ? nullptr
                               : detail::post_operation_trampoline;

    try {
      native_operations_.push_back(native);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    try {
      callback_slots_.push_back(std::move(callbacks));
    } catch (...) {
      native_operations_.pop_back();
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    callback_index_[major_function] = callback_slots_.back().get();
    return STATUS_SUCCESS;
  }

  std::array<detail::operation_callback_slot *, 256> callback_index_{};
  std::vector<std::unique_ptr<detail::operation_callback_slot>> callback_slots_;
  std::vector<FLT_OPERATION_REGISTRATION> native_operations_;
  std::vector<FLT_CONTEXT_REGISTRATION> native_contexts_;
  ULONG registered_contexts_ = 0;
  unload_callback unload_callback_ = nullptr;
  instance_setup_callback instance_setup_callback_ = nullptr;
  instance_query_teardown_callback instance_query_teardown_callback_ =
      detail::allow_manual_detach;
  instance_teardown_callback instance_teardown_start_callback_ = nullptr;
  instance_teardown_callback instance_teardown_complete_callback_ = nullptr;
  FLT_REGISTRATION_FLAGS flags_ = 0;
};

static_assert(sizeof(registration) <= 4096,
              "minifilter registration must remain kernel-stack friendly");

