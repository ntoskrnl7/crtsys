        major_function.native_value, std::move(pre), std::move(post),
        operation_flags::none);
  }

  /** @brief Nonthrowing typed read/write completion registration. */
  template <class Completion, operation_id Value, typename Pre, typename Post,
            std::enable_if_t<
                detail::is_completion_pre_callback_v<Value, Completion, Pre> &&
                    (detail::is_normal_completion_post_callback_v<
                         Value, Completion, Post> ||
                     detail::is_draining_completion_post_callback_v<
                         Value, Completion, Post>),
                int> = 0>
  ntl::status try_on_with_completion(
      read_write_operation_tag<Value> major_function, Pre pre, Post post,
      operation_flags flags = operation_flags::none) noexcept {
    assert_read_write_operation<Value>();
    return try_on_completion_impl<Value, Completion>(
        major_function.native_value, std::move(pre), std::move(post), flags);
  }

  /** @brief Nonthrowing typed completion registration with safe processing. */
  template <class Completion, operation_id Value, typename Pre, typename Post,
            typename SafePost,
            std::enable_if_t<
                detail::is_completion_pre_callback_v<Value, Completion, Pre> &&
                    detail::is_normal_completion_immediate_post_callback_v<
                        Value, Completion, Post> &&
                    detail::is_normal_completion_safe_post_callback_v<
                        Value, Completion, SafePost>,
                int> = 0>
  ntl::status try_on_with_completion(operation_tag<Value> major_function,
                                     Pre pre, Post post,
                                     SafePost safe_post) noexcept {
    return try_on_completion_safe_impl<Value, Completion>(
        major_function.native_value, std::move(pre), std::move(post),
        std::move(safe_post), operation_flags::none);
  }

  /** @brief Nonthrowing typed read/write completion with safe processing. */
  template <class Completion, operation_id Value, typename Pre, typename Post,
            typename SafePost,
            std::enable_if_t<
                detail::is_completion_pre_callback_v<Value, Completion, Pre> &&
                    detail::is_normal_completion_immediate_post_callback_v<
                        Value, Completion, Post> &&
                    detail::is_normal_completion_safe_post_callback_v<
                        Value, Completion, SafePost>,
