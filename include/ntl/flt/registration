/** @brief Owns one operation-typed pre-callback behind a stable erased ABI. */
class pre_callback_slot {
public:
  pre_callback_slot() noexcept = default;
  pre_callback_slot(const pre_callback_slot &) = delete;
  pre_callback_slot &operator=(const pre_callback_slot &) = delete;

  pre_callback_slot(pre_callback_slot &&other) noexcept { move_from(other); }

  pre_callback_slot &operator=(pre_callback_slot &&other) noexcept {
    if (this != &other) {
      reset();
      move_from(other);
    }
    return *this;
  }

  ~pre_callback_slot() { reset(); }

  template <operation_id Operation, typename Callback>
  ntl::status set(Callback callback) noexcept {
    using pointer = pre_operation_callback<Operation>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A minifilter pre-callback must be a captureless noexcept callback "
        "whose callback_data type matches registration::on(operation)");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects,
                 void *&completion_context) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      return typed(detail::callback_data_impl<Operation>{data},
                   related_objects{objects}, completion_context);
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, typename Callback>
  ntl::status set_normal(Callback callback) noexcept {
    using pointer = normal_pre_operation_callback<Operation>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A normal-only minifilter pre-callback must be a captureless noexcept "
        "callback whose callback_data type matches "
        "registration::on(operation)");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects, void *&) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      return typed(detail::callback_data_impl<Operation>{data},
                   related_objects{objects});
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, class Completion, typename Callback>
  ntl::status set_completion(Callback callback) noexcept {
    using pointer = completion_pre_operation_callback<Operation, Completion>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A typed-completion pre-callback must be a captureless noexcept "
        "callback whose callback_data and completion types match registration");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects,
                 void *&completion_context) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      completion_slot<Completion> completion;
      const pre_result result =
          typed(detail::callback_data_impl<Operation>{data},
                related_objects{objects}, completion);
      if (result == pre_result::success_with_callback ||
          result == pre_result::synchronize) {
        completion_context = detail::completion_access::release(completion);
      }
      return result;
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    return STATUS_SUCCESS;
  }

  explicit operator bool() const noexcept { return invoke_ != nullptr; }

  pre_result invoke(PFLT_CALLBACK_DATA data, PCFLT_RELATED_OBJECTS objects,
                    void *&completion_context) const noexcept {
    return invoke_(object_, data, objects, completion_context);
  }

  void reset() noexcept {
    if (destroy_)
      destroy_(object_);
    object_ = nullptr;
    invoke_ = nullptr;
    destroy_ = nullptr;
  }

private:
  using invoke_function = pre_result (*)(void *, PFLT_CALLBACK_DATA,
                                         PCFLT_RELATED_OBJECTS,
                                         void *&) noexcept;
  using destroy_function = void (*)(void *) noexcept;

  void move_from(pre_callback_slot &other) noexcept {
    object_ = other.object_;
    invoke_ = other.invoke_;
    destroy_ = other.destroy_;
    other.object_ = nullptr;
    other.invoke_ = nullptr;
    other.destroy_ = nullptr;
  }

  void *object_ = nullptr;
  invoke_function invoke_ = nullptr;
  destroy_function destroy_ = nullptr;
};

/** @brief Owns one operation-typed post-callback behind a stable erased ABI. */
class post_callback_slot {
public:
  post_callback_slot() noexcept = default;
  post_callback_slot(const post_callback_slot &) = delete;
  post_callback_slot &operator=(const post_callback_slot &) = delete;

  post_callback_slot(post_callback_slot &&other) noexcept { move_from(other); }

  post_callback_slot &operator=(post_callback_slot &&other) noexcept {
    if (this != &other) {
      reset();
      move_from(other);
    }
    return *this;
  }

  ~post_callback_slot() { reset(); }

  template <operation_id Operation, typename Callback>
  ntl::status set(Callback callback) noexcept {
    using pointer = post_operation_callback<Operation>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A minifilter post-callback must be a captureless noexcept callback "
        "whose callback_data type matches registration::on(operation)");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects, void *completion_context,
                 FLT_POST_OPERATION_FLAGS flags) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      return typed(detail::callback_data_impl<Operation>{data},
                   related_objects{objects}, completion_context,
                   post_operation_flags{flags});
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, typename Callback>
  ntl::status set_normal(Callback callback) noexcept {
    using pointer = normal_post_operation_callback<Operation>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A normal-only minifilter post-callback must be a captureless noexcept "
        "void callback whose callback_data type matches registration::on"
        "(operation)");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects, void *,
                 FLT_POST_OPERATION_FLAGS) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      typed(detail::callback_data_impl<Operation>{data},
            related_objects{objects});
      return post_result::finished;
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    drain_aware_ = false;
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, class Completion, typename Callback>
  ntl::status set_completion_normal(Callback callback) noexcept {
    using pointer =
        normal_completion_post_operation_callback<Operation, Completion>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A normal typed-completion post-callback must be a captureless "
        "noexcept void callback with matching operation and completion types");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects, void *completion_context,
                 FLT_POST_OPERATION_FLAGS) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      typed(detail::callback_data_impl<Operation>{data},
            related_objects{objects},
            detail::completion_access::view<Completion>(completion_context));
      return post_result::finished;
    };
    cleanup_ = &detail::completion_access::destroy<Completion>;
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    drain_aware_ = false;
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, class Completion, typename Callback>
  ntl::status set_completion_draining(Callback callback) noexcept {
    using pointer =
        draining_completion_post_operation_callback<Operation, Completion>;
    static_assert(
        std::is_convertible_v<Callback, pointer>,
        "A drain-aware typed-completion post-callback must be a captureless "
        "noexcept void callback with matching operation and completion types");

    pointer value = callback;
    if (!value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new pointer(value);
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                 PCFLT_RELATED_OBJECTS objects, void *completion_context,
                 FLT_POST_OPERATION_FLAGS flags) noexcept {
      const auto typed = *static_cast<pointer *>(object);
      typed(detail::callback_data_impl<Operation>{data},
            related_objects{objects},
            detail::completion_access::view<Completion>(completion_context),
            post_operation_flags{flags});
      return post_result::finished;
    };
    cleanup_ = &detail::completion_access::destroy<Completion>;
    destroy_ = [](void *object) noexcept {
      delete static_cast<pointer *>(object);
    };
    drain_aware_ = true;
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, typename Immediate, typename Safe>
  ntl::status set_normal_safe(Immediate immediate, Safe safe) noexcept {
    using immediate_pointer =
        normal_immediate_post_operation_callback<Operation>;
    using safe_pointer = normal_safe_post_operation_callback<Operation>;
    static_assert(
        std::is_convertible_v<Immediate, immediate_pointer>,
        "A flags-less immediate post-callback must be a captureless noexcept "
        "callback returning post_continuation for the registered operation");
    static_assert(
        std::is_convertible_v<Safe, safe_pointer>,
        "A flags-less safe post-callback must be a captureless noexcept void "
        "callback for the registered operation");

    struct callback_pair {
      immediate_pointer immediate;
      safe_pointer safe;
    };

    const immediate_pointer immediate_value = immediate;
    const safe_pointer safe_value = safe;
    if (!immediate_value || !safe_value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new callback_pair{immediate_value, safe_value};
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    immediate_invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                           PCFLT_RELATED_OBJECTS objects, void *,
                           FLT_POST_OPERATION_FLAGS) noexcept {
      const auto callbacks = static_cast<callback_pair *>(object);
      return callbacks->immediate(detail::callback_data_impl<Operation>{data},
                                  related_objects{objects});
    };
    safe_invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                      PCFLT_RELATED_OBJECTS objects, void *) noexcept {
      const auto callbacks = static_cast<callback_pair *>(object);
      callbacks->safe(detail::callback_data_impl<Operation>{data},
                      related_objects{objects});
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<callback_pair *>(object);
    };
    drain_aware_ = false;
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, class Completion, typename Immediate,
            typename Safe>
  ntl::status set_completion_safe(Immediate immediate, Safe safe) noexcept {
    using immediate_pointer =
        normal_completion_immediate_post_operation_callback<Operation,
                                                            Completion>;
    using safe_pointer =
        normal_completion_safe_post_operation_callback<Operation, Completion>;
    static_assert(
        std::is_convertible_v<Immediate, immediate_pointer>,
        "A typed immediate post-callback must be a captureless noexcept "
        "callback returning post_continuation with matching types");
    static_assert(
        std::is_convertible_v<Safe, safe_pointer>,
        "A typed safe post-callback must be a captureless noexcept void "
        "callback with matching operation and completion types");

    struct callback_pair {
      immediate_pointer immediate;
      safe_pointer safe;
    };

    const immediate_pointer immediate_value = immediate;
    const safe_pointer safe_value = safe;
    if (!immediate_value || !safe_value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new callback_pair{immediate_value, safe_value};
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    immediate_invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                           PCFLT_RELATED_OBJECTS objects,
                           void *completion_context,
                           FLT_POST_OPERATION_FLAGS) noexcept {
      const auto callbacks = static_cast<callback_pair *>(object);
      return callbacks->immediate(
          detail::callback_data_impl<Operation>{data}, related_objects{objects},
          detail::completion_access::view<Completion>(completion_context));
    };
    safe_invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                      PCFLT_RELATED_OBJECTS objects,
                      void *completion_context) noexcept {
      const auto callbacks = static_cast<callback_pair *>(object);
      callbacks->safe(
          detail::callback_data_impl<Operation>{data}, related_objects{objects},
          detail::completion_access::view<Completion>(completion_context));
    };
    cleanup_ = &detail::completion_access::destroy<Completion>;
    destroy_ = [](void *object) noexcept {
      delete static_cast<callback_pair *>(object);
    };
    drain_aware_ = false;
    return STATUS_SUCCESS;
  }

  template <operation_id Operation, typename Immediate, typename Safe>
  ntl::status set_safe(Immediate immediate, Safe safe) noexcept {
    using immediate_pointer = immediate_post_operation_callback<Operation>;
    using safe_pointer = safe_post_operation_callback<Operation>;
    static_assert(
        std::is_convertible_v<Immediate, immediate_pointer>,
        "A minifilter immediate post-callback must be a captureless noexcept "
        "callback whose callback_data type matches registration::on"
        "(operation)");
    static_assert(
        std::is_convertible_v<Safe, safe_pointer>,
        "A minifilter safe post-callback must be a captureless noexcept "
        "callback whose callback_data type matches registration::on"
        "(operation)");

    struct callback_pair {
      immediate_pointer immediate;
      safe_pointer safe;
    };

    const immediate_pointer immediate_value = immediate;
    const safe_pointer safe_value = safe;
    if (!immediate_value || !safe_value)
      return STATUS_INVALID_PARAMETER;

    try {
      object_ = new callback_pair{immediate_value, safe_value};
    } catch (...) {
      return STATUS_INSUFFICIENT_RESOURCES;
    }

    immediate_invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                           PCFLT_RELATED_OBJECTS objects,
                           void *completion_context,
                           FLT_POST_OPERATION_FLAGS flags) noexcept {
      const auto callbacks = static_cast<callback_pair *>(object);
      return callbacks->immediate(detail::callback_data_impl<Operation>{data},
                                  related_objects{objects}, completion_context,
                                  post_operation_flags{flags});
    };
    safe_invoke_ = [](void *object, PFLT_CALLBACK_DATA data,
                      PCFLT_RELATED_OBJECTS objects,
                      void *completion_context) noexcept {
      const auto callbacks = static_cast<callback_pair *>(object);
      callbacks->safe(detail::callback_data_impl<Operation>{data},
                      related_objects{objects}, completion_context);
    };
    destroy_ = [](void *object) noexcept {
      delete static_cast<callback_pair *>(object);
    };
    return STATUS_SUCCESS;
  }

  explicit operator bool() const noexcept {
    return invoke_ != nullptr || immediate_invoke_ != nullptr;
  }

  bool has_safe_continuation() const noexcept {
    return immediate_invoke_ != nullptr && safe_invoke_ != nullptr;
  }

  bool invokes_during_draining() const noexcept { return drain_aware_; }

  post_result invoke(PFLT_CALLBACK_DATA data, PCFLT_RELATED_OBJECTS objects,
                     void *completion_context,
                     FLT_POST_OPERATION_FLAGS flags) const noexcept {
    const post_result result =
        invoke_(object_, data, objects, completion_context, flags);
    cleanup(completion_context);
    return result;
  }

  post_continuation
  invoke_immediate(PFLT_CALLBACK_DATA data, PCFLT_RELATED_OBJECTS objects,
                   void *completion_context,
                   FLT_POST_OPERATION_FLAGS flags) const noexcept {
    return immediate_invoke_(object_, data, objects, completion_context, flags);
  }

  void invoke_safe(PFLT_CALLBACK_DATA data, PCFLT_RELATED_OBJECTS objects,
                   void *completion_context) const noexcept {
    safe_invoke_(object_, data, objects, completion_context);
    cleanup(completion_context);
  }

  void cleanup(void *completion_context) const noexcept {
    if (cleanup_)
      cleanup_(completion_context);
  }

  void reset() noexcept {
    if (destroy_)
      destroy_(object_);
    object_ = nullptr;
    invoke_ = nullptr;
    immediate_invoke_ = nullptr;
    safe_invoke_ = nullptr;
    cleanup_ = nullptr;
    destroy_ = nullptr;
    drain_aware_ = true;
  }

private:
  using invoke_function = post_result (*)(void *, PFLT_CALLBACK_DATA,
                                          PCFLT_RELATED_OBJECTS, void *,
                                          FLT_POST_OPERATION_FLAGS) noexcept;
  using immediate_invoke_function =
      post_continuation (*)(void *, PFLT_CALLBACK_DATA, PCFLT_RELATED_OBJECTS,
                            void *, FLT_POST_OPERATION_FLAGS) noexcept;
  using safe_invoke_function = void (*)(void *, PFLT_CALLBACK_DATA,
                                        PCFLT_RELATED_OBJECTS, void *) noexcept;
  using cleanup_function = void (*)(void *) noexcept;
  using destroy_function = void (*)(void *) noexcept;

  void move_from(post_callback_slot &other) noexcept {
    object_ = other.object_;
    invoke_ = other.invoke_;
    immediate_invoke_ = other.immediate_invoke_;
    safe_invoke_ = other.safe_invoke_;
    cleanup_ = other.cleanup_;
    destroy_ = other.destroy_;
    drain_aware_ = other.drain_aware_;
    other.object_ = nullptr;
    other.invoke_ = nullptr;
    other.immediate_invoke_ = nullptr;
    other.safe_invoke_ = nullptr;
    other.cleanup_ = nullptr;
    other.destroy_ = nullptr;
    other.drain_aware_ = true;
  }

  void *object_ = nullptr;
  invoke_function invoke_ = nullptr;
  immediate_invoke_function immediate_invoke_ = nullptr;
  safe_invoke_function safe_invoke_ = nullptr;
  cleanup_function cleanup_ = nullptr;
  destroy_function destroy_ = nullptr;
  bool drain_aware_ = true;
};

/** @brief Sparse callback storage for one registered major operation. */
struct operation_callback_slot {
  pre_callback_slot pre;
  post_callback_slot post;
};

template <operation_id Operation, typename Callback>
inline constexpr bool is_pre_callback_v =
    std::is_convertible_v<Callback, pre_operation_callback<Operation>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_normal_pre_callback_v =
    std::is_convertible_v<Callback, normal_pre_operation_callback<Operation>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_post_callback_v =
    std::is_convertible_v<Callback, post_operation_callback<Operation>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_normal_post_callback_v =
    std::is_convertible_v<Callback, normal_post_operation_callback<Operation>>;

template <operation_id Operation, class Completion, typename Callback>
inline constexpr bool is_completion_pre_callback_v = std::is_convertible_v<
    Callback, completion_pre_operation_callback<Operation, Completion>>;

template <operation_id Operation, class Completion, typename Callback>
inline constexpr bool is_normal_completion_post_callback_v =
    std::is_convertible_v<Callback, normal_completion_post_operation_callback<
                                        Operation, Completion>>;

template <operation_id Operation, class Completion, typename Callback>
inline constexpr bool is_draining_completion_post_callback_v =
    std::is_convertible_v<Callback, draining_completion_post_operation_callback<
                                        Operation, Completion>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_immediate_post_callback_v =
    std::is_convertible_v<Callback,
                          immediate_post_operation_callback<Operation>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_safe_post_callback_v =
    std::is_convertible_v<Callback, safe_post_operation_callback<Operation>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_normal_immediate_post_callback_v =
    std::is_convertible_v<Callback,
                          normal_immediate_post_operation_callback<Operation>>;

template <operation_id Operation, typename Callback>
inline constexpr bool is_normal_safe_post_callback_v =
    std::is_convertible_v<Callback,
                          normal_safe_post_operation_callback<Operation>>;

template <operation_id Operation, class Completion, typename Callback>
inline constexpr bool is_normal_completion_immediate_post_callback_v =
    std::is_convertible_v<Callback,
                          normal_completion_immediate_post_operation_callback<
                              Operation, Completion>>;

template <operation_id Operation, class Completion, typename Callback>
inline constexpr bool is_normal_completion_safe_post_callback_v =
    std::is_convertible_v<
        Callback,
        normal_completion_safe_post_operation_callback<Operation, Completion>>;

} // namespace detail

/**
 * @brief Owns the callback tables consumed by FltRegisterFilter.
 *
 * The object is moved into ntl::flt::driver when filtering starts, so all
 * native callback tables and operation-typed callback slots remain alive until
 * the filter is unregistered.
 */
class registration {
  friend class driver;
  friend FLT_PREOP_CALLBACK_STATUS FLTAPI detail::pre_operation_trampoline(
      PFLT_CALLBACK_DATA, PCFLT_RELATED_OBJECTS, PVOID *) noexcept;
  friend FLT_POSTOP_CALLBACK_STATUS FLTAPI detail::post_operation_trampoline(
      PFLT_CALLBACK_DATA, PCFLT_RELATED_OBJECTS, PVOID,
      FLT_POST_OPERATION_FLAGS) noexcept;
  friend FLT_POSTOP_CALLBACK_STATUS FLTAPI
