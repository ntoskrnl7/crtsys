  ntl::status try_on_with_completion(
      read_write_operation_tag<Value> major_function, Pre pre, Post post,
      SafePost safe_post,
      operation_flags flags = operation_flags::none) noexcept {
    assert_read_write_operation<Value>();
    return try_on_completion_safe_impl<Value, Completion>(
        major_function.native_value, std::move(pre), std::move(post),
        std::move(safe_post), flags | operation_flags::skip_paging_io);
  }

