struct communication_connection_public_state {
  template <typename T> static const void *type_key() noexcept {
    static const unsigned char key = 0;
    return &key;
  }

  std::uint64_t id = 0;
  HANDLE process_id = nullptr;
  std::atomic<std::uint64_t> session_id{0};
  std::atomic<bool> connected{true};
  mutable std::mutex state_lock;
  std::shared_ptr<void> user_state;
  const void *user_state_type = nullptr;
};

inline NTSTATUS guarded_copy(void *destination, const void *source,
                             std::size_t bytes) noexcept {
  if (bytes == 0)
    return STATUS_SUCCESS;
  if (!destination || !source)
    return STATUS_INVALID_PARAMETER;

  __try {
    RtlCopyMemory(destination, source, bytes);
  } __except (EXCEPTION_EXECUTE_HANDLER) {
    return GetExceptionCode();
  }
  return STATUS_SUCCESS;
}
} // namespace detail

/** @brief Action taken when one reliable session queue reaches its limit. */
enum class communication_overflow_policy {
  /** @brief Reject the new record and preserve every queued record. */
  reject_newest,
  /** @brief Remove the oldest record that is not currently being delivered. */
  drop_oldest,
};

/**
 * @brief Copyable, non-owning identity for one connected user-mode client.
 *
 * The facade remains safe to inspect after disconnect. `connected()` becomes
 * false and targeted sends return STATUS_NOT_FOUND. Application state may be
 * retained by a copied facade until the last copy is destroyed.
 */
class communication_connection {
public:
  communication_connection() noexcept = default;

  /** @brief Reports whether the client port is still connected. */
  bool connected() const noexcept { return state_ && state_->connected.load(); }

  /** @brief Returns the endpoint-local connection ID. */
  std::uint64_t id() const noexcept { return state_ ? state_->id : 0; }

  /** @brief Returns the process that opened the Filter Manager port. */
  HANDLE process_id() const noexcept {
    return state_ ? state_->process_id : nullptr;
  }

  /** @brief Returns the currently attached reconnectable session ID. */
  std::uint64_t session_id() const noexcept {
    return state_ ? state_->session_id.load() : 0;
  }

  /** @brief Replaces application-owned typed state for this connection. */
  template <typename T> void state(std::shared_ptr<T> value) {
    if (!state_)
      throw ntl::exception(STATUS_INVALID_HANDLE,
                           "The minifilter connection is empty");
    std::shared_ptr<void> previous;
    {
      std::lock_guard<std::mutex> guard(state_->state_lock);
      previous = std::move(state_->user_state);
      state_->user_state = std::move(value);
      state_->user_state_type =
          state_->user_state
              ? detail::communication_connection_public_state::type_key<T>()
              : nullptr;
    }
    previous.reset();
  }

  /** @brief Returns typed application state, or empty on a type mismatch. */
  template <typename T> std::shared_ptr<T> state() const {
    if (!state_)
      return {};
    std::lock_guard<std::mutex> guard(state_->state_lock);
    if (!state_->user_state ||
        state_->user_state_type !=
            detail::communication_connection_public_state::type_key<T>())
      return {};
    return std::static_pointer_cast<T>(state_->user_state);
  }

  /** @brief Clears application-owned state without affecting the connection. */
  void clear_state() noexcept {
    if (!state_)
      return;
    std::shared_ptr<void> previous;
    {
      std::lock_guard<std::mutex> guard(state_->state_lock);
      previous = std::move(state_->user_state);
      state_->user_state_type = nullptr;
    }
    previous.reset();
  }

private:
  friend class communication_context;
  friend class communication_publisher;
  friend struct detail::communication_server_state;
  explicit communication_connection(
      std::shared_ptr<detail::communication_connection_public_state>
          state) noexcept
      : state_(std::move(state)) {}

  std::shared_ptr<detail::communication_connection_public_state> state_;
};

/** @brief Identifies the typed channel represented by a stored record. */
enum class communication_record_kind {
  notification,
  stream,
};

/** @brief Immutable serialized record passed to persistence hooks. */
struct communication_record_view {
  ntl::rpc::session_token session{};
  std::uint64_t session_id = 0;
  std::uint32_t channel_id = 0;
  std::uint64_t sequence = 0;
  communication_record_kind kind = communication_record_kind::notification;
  const unsigned char *data = nullptr;
  std::size_t size = 0;
};

/** @brief Receives records restored by an application persistence hook. */
class communication_restore_sink {
public:
  virtual ~communication_restore_sink() = default;

  /** @brief Adds one serialized record to the reconnecting session. */
  virtual ntl::status add(std::uint32_t channel_id, std::uint64_t sequence,
                          communication_record_kind kind, const void *data,
                          std::size_t size) noexcept = 0;
};

/**
 * @brief Optional external storage for reliable minifilter deliveries.
 * @note The transport performs no storage I/O unless a store is explicitly
 * installed. Hooks run at PASSIVE_LEVEL without the communication server's
 * connection or session mutex held.
 */
class communication_notification_store {
public:
  virtual ~communication_notification_store() = default;

  /** @brief Persists a record before it becomes visible to the client. */
  virtual ntl::status persist(const communication_record_view &) noexcept {
    return ntl::status::ok();
  }

  /** @brief Removes one externally stored record after an explicit ACK. */
  virtual ntl::status acknowledge(const ntl::rpc::session_token &,
                                  std::uint32_t, std::uint64_t) noexcept {
    return ntl::status::ok();
  }

  /**
   * @brief Atomically removes records covered by one transport batch ACK.
   * @note Stores that enable batch delivery must override this operation. The
   * default accepts one record only because sequential deletion could leave
   * external state partially committed after an intermediate failure.
   */
  virtual ntl::status acknowledge_batch(const ntl::rpc::session_token &session,
                                        std::uint32_t channel_id,
                                        const std::uint64_t *sequences,
                                        std::size_t count) noexcept {
    if (!sequences || count == 0)
      return ntl::status{STATUS_INVALID_PARAMETER};
    return count == 1 ? acknowledge(session, channel_id, sequences[0])
                      : ntl::status{STATUS_NOT_SUPPORTED};
  }

  /** @brief Restores records when an in-memory session is unavailable. */
  virtual ntl::status restore(const ntl::rpc::session_token &,
                              communication_restore_sink &) noexcept {
    return ntl::status{STATUS_NOT_FOUND};
  }

  /** @brief Erases external state for an explicitly closed session. */
  virtual void erase_session(const ntl::rpc::session_token &) noexcept {}
};

/** @brief Limits and security applied to one communication server port. */
class communication_port_options {
public:
  /** @brief Sets the maximum simultaneous Filter Manager connections. */
  communication_port_options &max_connections(LONG value) noexcept {
    max_connections_ = value;
    return *this;
  }

  /** @brief Sets the maximum pending asynchronous calls per connection. */
  communication_port_options &max_pending_async(std::size_t value) noexcept {
    max_pending_async_ = value;
    return *this;
  }

  /** @brief Sets the maximum reconnectable sessions retained by the port. */
  communication_port_options &max_sessions(std::size_t value) noexcept {
    max_sessions_ = value;
    return *this;
  }

  /** @brief Sets the maximum queued reliable records per session. */
  communication_port_options &max_reliable_records(std::size_t value) noexcept {
    max_reliable_records_ = value;
    return *this;
  }

  /** @brief Sets the maximum serialized reliable bytes per session. */
  communication_port_options &max_reliable_bytes(std::size_t value) noexcept {
    max_reliable_bytes_ = value;
    return *this;
  }

  /** @brief Selects the action taken when a reliable queue is full. */
  communication_port_options &
  reliable_overflow(communication_overflow_policy value) noexcept {
    reliable_overflow_ = value;
    return *this;
  }

  /** @brief Sets the pinned-memory quotas applied independently per client. */
  communication_port_options &
  region_limits(ntl::ipc::region_limits value) noexcept {
    region_limits_ = value;
    return *this;
  }

  /**
   * @brief Uses a caller-owned security descriptor instead of the Filter
   * Manager default descriptor.
   * @note The descriptor must remain valid until driver.start() returns.
   */
  communication_port_options &
  security_descriptor(PSECURITY_DESCRIPTOR value) noexcept {
    security_descriptor_ = value;
    return *this;
  }

  LONG max_connections() const noexcept { return max_connections_; }
  std::size_t max_pending_async() const noexcept { return max_pending_async_; }
  std::size_t max_sessions() const noexcept { return max_sessions_; }
  std::size_t max_reliable_records() const noexcept {
    return max_reliable_records_;
  }
  std::size_t max_reliable_bytes() const noexcept {
    return max_reliable_bytes_;
  }
  communication_overflow_policy reliable_overflow() const noexcept {
    return reliable_overflow_;
  }
  ntl::ipc::region_limits shared_region_limits() const noexcept {
    return region_limits_;
  }
  PSECURITY_DESCRIPTOR security_descriptor() const noexcept {
    return security_descriptor_;
  }

private:
  LONG max_connections_ = 8;
  std::size_t max_pending_async_ = 64;
  std::size_t max_sessions_ = 64;
  std::size_t max_reliable_records_ = 256;
  std::size_t max_reliable_bytes_ = 4 * 1024 * 1024;
  communication_overflow_policy reliable_overflow_ =
      communication_overflow_policy::reject_newest;
  ntl::ipc::region_limits region_limits_{};
  PSECURITY_DESCRIPTOR security_descriptor_ = nullptr;
};

/**
 * @brief Context supplied to one app-to-minifilter typed method callback.
 *
 * The object is valid only for the current callback. Shared-memory lookups
 * retain the selected MDL until the returned pinned_buffer is destroyed.
 */
class communication_context {
public:
  /** @brief Returns the process that issued FilterSendMessage. */
  HANDLE requestor_process_id() const noexcept { return process_id_; }

  /** @brief Resolves a pointer-free range registered by this connection. */
  [[nodiscard]] ntl::result<ntl::ipc::pinned_buffer>
  try_resolve(ntl::ipc::buffer_token token,
              ntl::ipc::region_access required) const noexcept;

  /** @brief Returns the native client port for specialized Filter Manager use.
   */
  PFLT_PORT native_port() const noexcept;

  /** @brief Reports a cooperative cancellation request for an async call. */
  bool cancellation_requested() const noexcept;

  /** @brief Returns the reconnectable session handling this callback. */
  std::uint64_t session_id() const noexcept;

  /** @brief Returns a safe copyable identity for this client connection. */
  communication_connection connection() const noexcept;

private:
  friend struct detail::communication_server_state;
  communication_context(
      detail::communication_connection_state *connection, HANDLE process_id,
      detail::communication_async_state *async = nullptr) noexcept
      : connection_(connection), process_id_(process_id), async_(async) {}

  detail::communication_connection_state *connection_ = nullptr;
  HANDLE process_id_ = nullptr;
  detail::communication_async_state *async_ = nullptr;
};

