class communication_async_operation {
public:
  communication_async_operation(
      std::shared_ptr<communication_client_lifetime> client,
      std::uint64_t request_id)
      : client_(std::move(client)), request_id_(request_id),
        event_(::CreateEventW(nullptr, TRUE, FALSE, nullptr)) {
    if (!event_)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL minifilter async event creation failed");
  }
  communication_async_operation(const communication_async_operation &) = delete;
  communication_async_operation &
  operator=(const communication_async_operation &) = delete;
  ~communication_async_operation() {
    if (!ready_noexcept())
      (void)cancel_noexcept();
  }

  bool ready() const {
    const DWORD wait = ::WaitForSingleObject(event_.get(), 0);
    if (wait == WAIT_OBJECT_0)
      return true;
    if (wait == WAIT_TIMEOUT)
      return false;
    throw std::system_error(static_cast<int>(::GetLastError()),
                            std::system_category(),
                            "NTL minifilter async wait failed");
  }

  bool wait_for(std::chrono::milliseconds timeout) {
    const auto count = timeout.count();
    const DWORD milliseconds =
        count <= 0 ? 0
        : count >= static_cast<decltype(count)>((INFINITE)-1)
            ? (INFINITE)-1
            : static_cast<DWORD>(count);
    const DWORD wait = ::WaitForSingleObject(event_.get(), milliseconds);
    if (wait == WAIT_OBJECT_0)
      return true;
    if (wait == WAIT_TIMEOUT)
      return false;
    throw std::system_error(static_cast<int>(::GetLastError()),
                            std::system_category(),
                            "NTL minifilter async wait failed");
  }

  void wait() {
    const DWORD wait = ::WaitForSingleObject(event_.get(), INFINITE);
    if (wait != WAIT_OBJECT_0)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL minifilter async wait failed");
  }

  bool cancel() {
    if (ready())
      return false;
    return client_ ? client_->state()->cancel(request_id_) : false;
  }

  bool cancel_noexcept() noexcept {
    try {
      return cancel();
    } catch (...) {
      return false;
    }
  }

  HANDLE completion_event() const noexcept { return event_.get(); }

  void attach_cancellation_registration(
      std::shared_ptr<void> registration) noexcept {
    cancellation_registration_ = std::move(registration);
  }

  void complete(std::int32_t status, const void *payload,
                std::size_t payload_size) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (completed_)
      return;
    try {
      output_.resize(payload_size);
      if (payload_size)
        std::memcpy(output_.data(), payload, payload_size);
      status_ = status;
    } catch (...) {
      transport_result_ = E_OUTOFMEMORY;
      output_.clear();
    }
    completed_ = true;
    ::SetEvent(event_.get());
  }

  void fail(HRESULT result) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (completed_)
      return;
    transport_result_ = result;
    completed_ = true;
    ::SetEvent(event_.get());
  }

  const std::vector<unsigned char> &output() {
    wait();
    std::lock_guard<std::mutex> guard(lock_);
    if (FAILED(transport_result_))
      throw communication_error(transport_result_,
                                "NTL minifilter async transport failed");
    if (status_ < 0)
      throw communication_error(HRESULT_FROM_NT(status_),
                                "NTL minifilter async method failed");
    return output_;
  }

private:
  bool ready_noexcept() const noexcept {
    return ::WaitForSingleObject(event_.get(), 0) == WAIT_OBJECT_0;
  }

  std::shared_ptr<communication_client_lifetime> client_;
  std::uint64_t request_id_ = 0;
  ntl::unique_handle event_;
  mutable std::mutex lock_;
  std::vector<unsigned char> output_;
  HRESULT transport_result_ = S_OK;
  std::int32_t status_ = 0;
  bool completed_ = false;
  std::shared_ptr<void> cancellation_registration_;
};

class communication_receive_operation {
public:
  communication_receive_operation(
      std::shared_ptr<communication_client_lifetime> client,
      std::uint64_t waiter_id)
      : client_(std::move(client)), waiter_id_(waiter_id),
        event_(::CreateEventW(nullptr, TRUE, FALSE, nullptr)) {
    if (!event_)
      throw std::system_error(
          static_cast<int>(::GetLastError()), std::system_category(),
          "NTL minifilter notification event creation failed");
  }

  ~communication_receive_operation() {
    if (client_)
      client_->state()->unregister_receive(waiter_id_);
  }

  bool ready() const noexcept {
    return ::WaitForSingleObject(event_.get(), 0) == WAIT_OBJECT_0;
  }
  HANDLE completion_event() const noexcept { return event_.get(); }
  std::uint64_t id() const noexcept { return waiter_id_; }
  bool wait_for(std::chrono::milliseconds timeout) const noexcept {
    const auto count = timeout.count();
    const DWORD wait =
        count<0 ? INFINITE : count>(std::numeric_limits<DWORD>::max)()
            ? (std::numeric_limits<DWORD>::max)()
            : static_cast<DWORD>(count);
    return ::WaitForSingleObject(event_.get(), wait) == WAIT_OBJECT_0;
  }
  void wait() const noexcept {
    (void)::WaitForSingleObject(event_.get(), INFINITE);
  }

  bool cancel() {
    if (!client_)
      return false;
    client_->state()->unregister_receive(waiter_id_);
    fail(HRESULT_FROM_WIN32(ERROR_OPERATION_ABORTED));
    return true;
  }
  bool cancel_noexcept() noexcept {
    try {
      return cancel();
    } catch (...) {
      return false;
    }
  }

  void complete(const communication_inbound_header &header,
                const void *payload) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (completed_)
      return;
    try {
      header_ = header;
      payload_.resize(header.payload_size);
      if (header.payload_size)
        std::memcpy(payload_.data(), payload, header.payload_size);
    } catch (...) {
      result_ = E_OUTOFMEMORY;
      payload_.clear();
    }
    completed_ = true;
    ::SetEvent(event_.get());
  }

  void fail(HRESULT result) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (completed_)
      return;
    result_ = result;
    completed_ = true;
    ::SetEvent(event_.get());
  }

  std::pair<communication_inbound_header, std::vector<unsigned char>> take() {
    wait();
    std::lock_guard<std::mutex> guard(lock_);
    if (FAILED(result_))
      throw communication_error(result_,
                                "NTL minifilter notification receive failed");
    return {header_, std::move(payload_)};
  }

  void attach_cancellation_registration(std::shared_ptr<void> registration) {
    std::lock_guard<std::mutex> guard(lock_);
    cancellation_registration_ = std::move(registration);
  }

private:
  std::shared_ptr<communication_client_lifetime> client_;
  std::uint64_t waiter_id_ = 0;
  ntl::unique_handle event_;
  mutable std::mutex lock_;
  communication_inbound_header header_{};
  std::vector<unsigned char> payload_;
  HRESULT result_ = S_OK;
  bool completed_ = false;
  std::shared_ptr<void> cancellation_registration_;
};

inline communication_client_state::~communication_client_state() {
  for (auto &receiver : receivers_) {
    if (!receiver.joinable())
      continue;
    if (receiver.get_id() == std::this_thread::get_id())
      receiver.detach();
    else
      receiver.join();
  }
}

inline void communication_client_state::shutdown() noexcept {
  if (!preserve_session_.load() && port_ && *port_) {
    ntl::rpc::session_info current{};
    {
      std::lock_guard<std::mutex> guard(session_lock_);
      current = session_;
      session_ = {};
    }
    if (current.valid()) {
      try {
        const auto request = make_port_request(
            communication_operation::close_session, 0, nullptr, 0);
        DWORD returned = 0;
        (void)FilterSendMessage(
            port_->get(), const_cast<unsigned char *>(request.data()),
            static_cast<DWORD>(request.size()), nullptr, 0, &returned);
      } catch (...) {
      }
    }
  }
  stopping_.store(true);
  if (port_ && *port_) {
    (void)::CancelIoEx(port_->get(), nullptr);
    // Closing the communication port is the documented final cancellation
    // mechanism for pending FilterGetMessage calls. CancelIoEx alone is not
    // sufficient on every Filter Manager/OS combination.
    port_->reset();
  }
  for (auto &receiver : receivers_) {
    if (receiver.joinable() && receiver.get_id() != std::this_thread::get_id())
      receiver.join();
  }
  fail_all(HRESULT_FROM_WIN32(ERROR_OPERATION_ABORTED));
}

inline std::uint64_t communication_client_state::next_request_id() noexcept {
  auto id = next_request_id_.fetch_add(1);
  if (id == 0)
    id = next_request_id_.fetch_add(1);
  return id;
}

inline void communication_client_state::register_operation(
    std::uint64_t id,
    const std::shared_ptr<communication_async_operation> &operation) {
  ensure_receiver();
  std::lock_guard<std::mutex> guard(operations_lock_);
  if (stopping_.load())
    throw std::system_error(
        ERROR_OPERATION_ABORTED, std::system_category(),
        "NTL minifilter completion receiver is not available");
  if (!operations_.emplace(id, operation).second)
    throw std::logic_error("Duplicate NTL minifilter async request ID");
}

inline void
communication_client_state::unregister_operation(std::uint64_t id) noexcept {
  std::lock_guard<std::mutex> guard(operations_lock_);
  operations_.erase(id);
}

inline bool communication_client_state::cancel(std::uint64_t id) {
  communication_async_request cancellation{id};
  const auto request =
      make_port_request(communication_operation::cancel_async, 0, &cancellation,
                        sizeof(cancellation));
  DWORD returned = 0;
  const HRESULT result = FilterSendMessage(
      port_->get(), const_cast<unsigned char *>(request.data()),
      static_cast<DWORD>(request.size()), nullptr, 0, &returned);
  if (FAILED(result))
    throw communication_error(result,
                              "NTL minifilter async cancellation failed");
  return true;
}

inline void communication_client_state::open_session() {
  const auto request =
      make_port_request(communication_operation::open_session, 0, nullptr, 0);
  ntl::rpc::session_info session{};
  DWORD returned = 0;
  send_port_message(port_, request, &session, sizeof(session), returned);
  if (returned != sizeof(session) || !session.valid())
    throw std::runtime_error("NTL minifilter returned an invalid session");
  std::lock_guard<std::mutex> guard(session_lock_);
  session_ = session;
}

inline void
communication_client_state::resume_session(ntl::rpc::session_token token) {
  if (!token.valid())
    throw std::invalid_argument("NTL minifilter session token is invalid");
  const auto request = make_port_request(
      communication_operation::resume_session, 0, &token, sizeof(token));
  ntl::rpc::session_info session{};
  DWORD returned = 0;
  send_port_message(port_, request, &session, sizeof(session), returned);
  if (returned != sizeof(session) || !session.valid() || session.token != token)
    throw std::runtime_error("NTL minifilter returned an invalid session");
  std::lock_guard<std::mutex> guard(session_lock_);
  session_ = session;
}

inline void communication_client_state::preserve_session() {
  ntl::rpc::session_info current{};
  {
    std::lock_guard<std::mutex> guard(session_lock_);
    current = session_;
  }
  if (!current.valid())
    throw std::logic_error("NTL minifilter client has no session");

  const auto request =
      make_port_request(communication_operation::detach_session, 0, nullptr, 0);
  DWORD returned = 0;
  send_port_message(port_, request, nullptr, 0, returned);
  if (returned != 0)
    throw std::runtime_error(
        "NTL minifilter session detach returned output bytes");

  {
    std::lock_guard<std::mutex> guard(session_lock_);
    session_ = {};
  }
  preserve_session_.store(true);
  stopping_.store(true);
  if (port_ && *port_) {
    (void)::CancelIoEx(port_->get(), nullptr);
    port_->reset();
  }
  for (auto &receiver : receivers_) {
    if (receiver.joinable() && receiver.get_id() != std::this_thread::get_id())
      receiver.join();
  }
  fail_all(HRESULT_FROM_WIN32(ERROR_OPERATION_ABORTED));
}

inline void
communication_client_state::subscribe(std::uint32_t id, bool stream,
                                      std::uint32_t max_batch_records) {
  if (id == 0 || max_batch_records == 0 ||
      max_batch_records > ntl::rpc::maximum_batch_records)
    throw std::invalid_argument("NTL minifilter channel ID is invalid");

  // FltSendMessage can deliver immediately after the server records the
  // subscription. Post FilterGetMessage receives first so the initial
  // reliable record cannot time out before this client starts listening.
  ensure_receiver();
  bool was_subscribed = false;
  std::uint32_t previous_batch_records = 0;
  {
    std::lock_guard<std::mutex> guard(receives_lock_);
    auto &subscriptions = stream ? open_streams_ : notification_subscriptions_;
    const auto previous = subscription_batches_.find(id);
    was_subscribed = subscriptions.count(id) != 0;
    if (previous != subscription_batches_.end())
      previous_batch_records = previous->second;
    if (was_subscribed && previous != subscription_batches_.end() &&
        previous->second == max_batch_records)
      return;
    subscriptions.insert(id);
    subscription_batches_[id] = max_batch_records;
  }
  try {
    const communication_subscription_request options{max_batch_records, 0};
    const auto request =
        make_port_request(stream ? communication_operation::open_stream
                                 : communication_operation::subscribe,
                          id, &options, sizeof(options));
    DWORD returned = 0;
    send_port_message(port_, request, nullptr, 0, returned);
    if (returned != 0)
      throw std::runtime_error(
          "NTL minifilter subscription returned output bytes");
  } catch (...) {
    std::lock_guard<std::mutex> guard(receives_lock_);
    auto &subscriptions = stream ? open_streams_ : notification_subscriptions_;
    if (was_subscribed) {
      subscriptions.insert(id);
      subscription_batches_[id] = previous_batch_records;
    } else {
      subscriptions.erase(id);
      subscription_batches_.erase(id);
    }
    throw;
  }
}

inline void communication_client_state::unsubscribe(std::uint32_t id,
                                                    bool stream) {
  {
    std::lock_guard<std::mutex> guard(receives_lock_);
    auto &subscriptions = stream ? open_streams_ : notification_subscriptions_;
    if (subscriptions.erase(id) == 0)
      return;
    subscription_batches_.erase(id);
  }
  const auto request =
      make_port_request(stream ? communication_operation::close_stream
                               : communication_operation::unsubscribe,
                        id, nullptr, 0);
  DWORD returned = 0;
  send_port_message(port_, request, nullptr, 0, returned);
  if (returned != 0)
    throw std::runtime_error(
        "NTL minifilter unsubscription returned output bytes");
}

inline void communication_client_state::acknowledge(std::uint32_t id,
                                                    std::uint64_t sequence) {
  communication_ack_request acknowledgement{sequence};
  const auto request =
      make_port_request(communication_operation::acknowledge, id,
                        &acknowledgement, sizeof(acknowledgement));
  DWORD returned = 0;
  send_port_message(port_, request, nullptr, 0, returned);
  if (returned != 0)
    throw std::runtime_error("NTL minifilter ACK returned output bytes");
}

inline void communication_client_state::acknowledge_batch(
    std::uint32_t id, const std::vector<std::uint64_t> &sequences) {
  if (id == 0 || sequences.empty() ||
      sequences.size() > ntl::rpc::maximum_batch_records)
    throw std::invalid_argument("NTL minifilter batch ACK is invalid");
  communication_ack_batch_header header{
      static_cast<std::uint32_t>(sequences.size()), 0};
  std::vector<unsigned char> payload(sizeof(header) +
                                     sizeof(std::uint64_t) * sequences.size());
  std::memcpy(payload.data(), &header, sizeof(header));
  std::memcpy(payload.data() + sizeof(header), sequences.data(),
              sizeof(std::uint64_t) * sequences.size());
  const auto request =
      make_port_request(communication_operation::acknowledge_batch, id,
                        payload.data(), payload.size());
  DWORD returned = 0;
  send_port_message(port_, request, nullptr, 0, returned);
  if (returned != 0)
    throw std::runtime_error("NTL minifilter batch ACK returned output bytes");
}

inline void communication_client_state::register_receive(
    communication_inbound_kind kind, std::uint32_t id,
    const std::shared_ptr<communication_receive_operation> &operation) {
  ensure_receiver();
  buffered_inbound buffered;
  bool has_buffered = false;
  const auto key = inbound_key(kind, id);
  {
    std::lock_guard<std::mutex> guard(receives_lock_);
    if (stopping_.load())
      throw std::system_error(
          ERROR_OPERATION_ABORTED, std::system_category(),
          "NTL minifilter notification receiver is not available");
    auto found = buffered_.find(key);
    if (found != buffered_.end() && !found->second.empty()) {
      buffered = std::move(found->second.front());
      found->second.pop_front();
      --buffered_count_;
      if (found->second.empty())
        buffered_.erase(found);
      has_buffered = true;
    } else if (kind == communication_inbound_kind::reliable_notification ||
               kind == communication_inbound_kind::stream_record) {
      // A delivery can arrive while subscribe() changes the server between
      // batch and single-record mode. Consume an already buffered batch one
      // record at a time instead of leaving it stranded under the old key.
      const auto batch_key =
          inbound_key(communication_inbound_kind::reliable_batch, id);
      auto batch = buffered_.find(batch_key);
      if (batch != buffered_.end() && !batch->second.empty()) {
        auto &message = batch->second.front();
        communication_batch_header batch_header{};
        communication_batch_record_view
            records[ntl::rpc::maximum_batch_records]{};
        if (!parse_communication_batch(message.payload.data(),
                                       message.payload.size(), batch_header,
                                       records))
          throw std::runtime_error(
              "NTL minifilter buffered batch is invalid");

        buffered.header = message.header;
        buffered.header.kind = kind;
        buffered.header.correlation = records[0].sequence;
        buffered.header.payload_size = records[0].payload_size;
        buffered.payload.assign(records[0].payload,
                                records[0].payload + records[0].payload_size);
        has_buffered = true;

        if (batch_header.count == 1) {
          batch->second.pop_front();
          --buffered_count_;
          if (batch->second.empty())
            buffered_.erase(batch);
        } else {
          const auto consumed = sizeof(communication_batch_header) +
                                sizeof(communication_batch_record_header) +
                                records[0].payload_size;
          message.payload.erase(
              message.payload.begin() + sizeof(communication_batch_header),
              message.payload.begin() + consumed);
          --batch_header.count;
          std::memcpy(message.payload.data(), &batch_header,
                      sizeof(batch_header));
          message.header.payload_size =
              static_cast<std::uint32_t>(message.payload.size());
        }
      }
    } else if (kind == communication_inbound_kind::reliable_batch) {
      // The inverse transition is also legal. A one-record batch preserves
      // the delivery sequence and lets batch users consume a frame that
      // arrived just before the server accepted the new batch limit.
      const auto single_kind = open_streams_.count(id) != 0
                                   ? communication_inbound_kind::stream_record
                                   : communication_inbound_kind::reliable_notification;
      const auto single_key = inbound_key(single_kind, id);
      auto single = buffered_.find(single_key);
      if (single != buffered_.end() && !single->second.empty()) {
        const auto &message = single->second.front();
        if (message.header.correlation == 0 ||
            message.header.payload_size != message.payload.size())
          throw std::runtime_error(
              "NTL minifilter buffered delivery is invalid");
        communication_batch_header batch_header{};
        batch_header.count = 1;
        communication_batch_record_header record{};
        record.sequence = message.header.correlation;
        record.payload_size = message.header.payload_size;
        buffered.header = message.header;
        buffered.header.kind = communication_inbound_kind::reliable_batch;
        buffered.header.correlation = 0;
        buffered.header.payload_size = static_cast<std::uint32_t>(
            sizeof(batch_header) + sizeof(record) + message.payload.size());
        buffered.payload.resize(buffered.header.payload_size);
        std::memcpy(buffered.payload.data(), &batch_header,
                    sizeof(batch_header));
        std::memcpy(buffered.payload.data() + sizeof(batch_header), &record,
                    sizeof(record));
        if (!message.payload.empty())
          std::memcpy(buffered.payload.data() + sizeof(batch_header) +
                          sizeof(record),
                      message.payload.data(), message.payload.size());
        single->second.pop_front();
        --buffered_count_;
        if (single->second.empty())
          buffered_.erase(single);
        has_buffered = true;
      }
    }

    if (!has_buffered) {
      receive_waiters_[key].push_back({operation->id(), operation});
      receive_keys_.emplace(operation->id(), key);
    }
  }
  if (has_buffered)
    operation->complete(buffered.header, buffered.payload.data());
}

inline void communication_client_state::unregister_receive(
    std::uint64_t waiter_id) noexcept {
  std::lock_guard<std::mutex> guard(receives_lock_);
  const auto active = receive_keys_.find(waiter_id);
  if (active == receive_keys_.end())
    return;
  const auto key = active->second;
  receive_keys_.erase(active);

  const auto found = receive_waiters_.find(key);
  if (found == receive_waiters_.end())
    return;
  auto &waiters = found->second;
  for (auto current = waiters.begin(); current != waiters.end();) {
    if (current->id == waiter_id || current->operation.expired())
      current = waiters.erase(current);
    else
      ++current;
  }
  if (waiters.empty())
    receive_waiters_.erase(found);
}

inline void communication_client_state::register_request_handler(
    std::uint32_t id,
    std::shared_ptr<communication_client_request_handler> handler) {
  if (id == 0 || !handler)
    throw std::invalid_argument(
        "NTL minifilter app request handler is invalid");
  {
    std::lock_guard<std::mutex> handler_guard(request_handlers_lock_);
    if (!request_handlers_.emplace(id, std::move(handler)).second)
      throw std::logic_error("Duplicate minifilter app request method ID");
  }
  ensure_receiver();
}

inline void communication_client_state::ensure_receiver() {
  std::lock_guard<std::mutex> guard(receiver_lock_);
  if (stopping_.load())
    throw std::system_error(
        ERROR_OPERATION_ABORTED, std::system_category(),
        "NTL minifilter completion receiver is not available");
  if (receiver_started_)
    return;
  if (!port_ || !*port_)
    throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                            "NTL minifilter port is not connected");
  auto self = shared_from_this();
  const HANDLE receive_port = port_->get();
  try {
    receivers_.reserve(receiver_count);
    for (std::size_t index = 0; index != receiver_count; ++index)
      receivers_.emplace_back(
          [self, receive_port] { self->receiver_loop(receive_port); });
    receiver_started_ = true;
  } catch (...) {
    stopping_.store(true);
    if (port_ && *port_) {
      (void)::CancelIoEx(port_->get(), nullptr);
      port_->reset();
    }
    for (auto &receiver : receivers_) {
      if (receiver.joinable())
        receiver.join();
    }
    receivers_.clear();
    throw;
  }
}

inline void
communication_client_state::receiver_loop(HANDLE receive_port) noexcept {
  struct message_buffer {
    FILTER_MESSAGE_HEADER filter{};
    communication_inbound_header inbound{};
    unsigned char payload[communication_inbound_payload_limit]{};
  };
  static_assert(offsetof(message_buffer, inbound) ==
                    sizeof(FILTER_MESSAGE_HEADER),
                "Filter Manager payload must follow FILTER_MESSAGE_HEADER");

  std::unique_ptr<message_buffer> message(new (std::nothrow) message_buffer{});
  ntl::unique_handle event(::CreateEventW(nullptr, TRUE, FALSE, nullptr));
  if (!message || !event) {
    fail_all(E_OUTOFMEMORY);
    return;
  }
  while (!stopping_.load()) {
    std::memset(message.get(), 0, sizeof(*message));
    OVERLAPPED overlapped{};
    overlapped.hEvent = event.get();
    ::ResetEvent(event.get());

    DWORD received = 0;
    HRESULT result = FilterGetMessage(receive_port, &message->filter,
                                      sizeof(*message), &overlapped);
    if (result == HRESULT_FROM_WIN32(ERROR_IO_PENDING)) {
      const DWORD wait = ::WaitForSingleObject(event.get(), INFINITE);
      if (wait != WAIT_OBJECT_0) {
        fail_all(HRESULT_FROM_WIN32(::GetLastError()));
        return;
      }
      if (!::GetOverlappedResult(receive_port, &overlapped, &received, FALSE)) {
        const DWORD error = ::GetLastError();
        if (stopping_.load() && error == ERROR_OPERATION_ABORTED)
          return;
        fail_all(HRESULT_FROM_WIN32(error));
        return;
      }
      result = S_OK;
    } else if (SUCCEEDED(result) &&
               !::GetOverlappedResult(receive_port, &overlapped, &received,
                                      FALSE)) {
      fail_all(HRESULT_FROM_WIN32(::GetLastError()));
      return;
    }
    if (FAILED(result)) {
      if (!stopping_.load())
        fail_all(result);
      return;
    }

    const auto &inbound = message->inbound;
    if (inbound.magic != communication_magic ||
        inbound.version != communication_version || inbound.id == 0 ||
        (inbound.kind == communication_inbound_kind::async_completion &&
         inbound.correlation == 0) ||
        inbound.kind < communication_inbound_kind::async_completion ||
        inbound.kind > communication_inbound_kind::request ||
        inbound.payload_size > communication_inbound_payload_limit ||
        received < offsetof(message_buffer, payload) ||
        inbound.payload_size > received - offsetof(message_buffer, payload)) {
      fail_all(HRESULT_FROM_WIN32(ERROR_INVALID_DATA));
      return;
    }
    if (inbound.kind == communication_inbound_kind::request)
      dispatch_request(receive_port, message->filter.MessageId, inbound,
                       message->payload);
    else
      dispatch_inbound(inbound, message->payload);
  }
}

inline void communication_client_state::dispatch_request(
    HANDLE port, std::uint64_t message_id,
    const communication_inbound_header &header, const void *payload) noexcept {
  std::shared_ptr<communication_client_request_handler> handler;
  {
    std::lock_guard<std::mutex> guard(request_handlers_lock_);
    const auto found = request_handlers_.find(header.id);
    if (found != request_handlers_.end())
      handler = found->second;
  }

  HRESULT status = HRESULT_FROM_WIN32(ERROR_NOT_SUPPORTED);
  std::vector<unsigned char> output;
  if (handler) {
    if (header.payload_size > handler->request_limit())
      status = HRESULT_FROM_WIN32(ERROR_INSUFFICIENT_BUFFER);
    else
      status = handler->invoke(payload, header.payload_size, output);
  }

  try {
    if (output.size() > communication_inbound_payload_limit)
      status = HRESULT_FROM_WIN32(ERROR_INSUFFICIENT_BUFFER);
    if (FAILED(status))
      output.clear();

    communication_reply_header reply_header{};
    reply_header.status = static_cast<std::int32_t>(status);
    reply_header.payload_size = static_cast<std::uint32_t>(output.size());
    std::vector<unsigned char> reply(sizeof(FILTER_REPLY_HEADER) +
                                     sizeof(reply_header) + output.size());
    auto *const filter_reply =
        reinterpret_cast<PFILTER_REPLY_HEADER>(reply.data());
    filter_reply->Status = S_OK;
    filter_reply->MessageId = message_id;
    std::memcpy(reply.data() + sizeof(FILTER_REPLY_HEADER), &reply_header,
                sizeof(reply_header));
    if (!output.empty())
      std::memcpy(reply.data() + sizeof(FILTER_REPLY_HEADER) +
                      sizeof(reply_header),
                  output.data(), output.size());
    const HRESULT result = FilterReplyMessage(port, filter_reply,
                                              static_cast<DWORD>(reply.size()));
    if (FAILED(result) && !disconnected_result(result))
      fail_all(result);
  } catch (...) {
    fail_all(E_OUTOFMEMORY);
  }
}

inline void communication_client_state::dispatch_inbound(
    const communication_inbound_header &header, const void *payload) noexcept {
  if (header.kind == communication_inbound_kind::async_completion) {
    std::shared_ptr<communication_async_operation> operation;
    {
      std::lock_guard<std::mutex> guard(operations_lock_);
      const auto found = operations_.find(header.correlation);
      if (found != operations_.end()) {
        operation = found->second.lock();
        operations_.erase(found);
      }
    }
    if (operation)
      operation->complete(header.status, payload, header.payload_size);
    return;
  }

  std::uint32_t requested_batch_records = 0;
  communication_inbound_kind requested_single_kind =
      communication_inbound_kind::reliable_notification;
  {
    std::lock_guard<std::mutex> guard(receives_lock_);
    const auto configured = subscription_batches_.find(header.id);
    if (configured != subscription_batches_.end()) {
      requested_batch_records = configured->second;
      if (open_streams_.count(header.id) != 0)
        requested_single_kind = communication_inbound_kind::stream_record;
    }
  }

  if (header.kind == communication_inbound_kind::reliable_batch &&
      requested_batch_records == 1) {
    communication_batch_header batch_header{};
    communication_batch_record_view
        records[ntl::rpc::maximum_batch_records]{};
    if (!parse_communication_batch(payload, header.payload_size, batch_header,
                                   records)) {
      fail_all(HRESULT_FROM_WIN32(ERROR_INVALID_DATA));
      return;
    }
    for (std::uint32_t index = 0; index != batch_header.count; ++index) {
      auto single = header;
      single.kind = requested_single_kind;
      single.correlation = records[index].sequence;
      single.payload_size = records[index].payload_size;
      dispatch_inbound(single, records[index].payload);
      if (stopping_.load())
        return;
    }
    return;
  }

  if ((header.kind == communication_inbound_kind::reliable_notification ||
       header.kind == communication_inbound_kind::stream_record) &&
      requested_batch_records > 1) {
    if (header.correlation == 0) {
      fail_all(HRESULT_FROM_WIN32(ERROR_INVALID_DATA));
      return;
    }
    try {
      communication_batch_header batch_header{};
      batch_header.count = 1;
      communication_batch_record_header record{};
      record.sequence = header.correlation;
      record.payload_size = header.payload_size;
      std::vector<unsigned char> batch(sizeof(batch_header) + sizeof(record) +
                                       header.payload_size);
      std::memcpy(batch.data(), &batch_header, sizeof(batch_header));
      std::memcpy(batch.data() + sizeof(batch_header), &record,
                  sizeof(record));
      if (header.payload_size)
        std::memcpy(batch.data() + sizeof(batch_header) + sizeof(record),
                    payload, header.payload_size);
      auto batch_frame = header;
      batch_frame.kind = communication_inbound_kind::reliable_batch;
      batch_frame.correlation = 0;
      batch_frame.payload_size = static_cast<std::uint32_t>(batch.size());
      dispatch_inbound(batch_frame, batch.data());
    } catch (...) {
      fail_all(E_OUTOFMEMORY);
    }
    return;
  }

  std::shared_ptr<communication_receive_operation> waiter;
  const auto key = inbound_key(header.kind, header.id);
  bool overflow = false;
  {
    std::lock_guard<std::mutex> guard(receives_lock_);
    auto found = receive_waiters_.find(key);
    if (found != receive_waiters_.end()) {
      while (!found->second.empty()) {
        auto entry = std::move(found->second.front());
        found->second.pop_front();
        auto candidate = entry.operation.lock();
        if (!candidate) {
          receive_keys_.erase(entry.id);
          continue;
        }
        const auto active = receive_keys_.find(entry.id);
        if (active == receive_keys_.end() || active->second != key)
          continue;
        receive_keys_.erase(active);
        waiter = std::move(candidate);
        break;
      }
      if (found->second.empty())
        receive_waiters_.erase(found);
    }

    if (!waiter) {
      if (buffered_count_ >= maximum_buffered_messages) {
        overflow = header.kind != communication_inbound_kind::notification;
      } else {
        try {
          buffered_inbound message{};
          message.header = header;
          message.payload.resize(header.payload_size);
          if (header.payload_size)
            std::memcpy(message.payload.data(), payload, header.payload_size);
          buffered_[key].push_back(std::move(message));
          ++buffered_count_;
        } catch (...) {
          overflow = header.kind != communication_inbound_kind::notification;
        }
      }
    }
  }
  if (waiter)
    waiter->complete(header, payload);
  else if (overflow)
    fail_all(HRESULT_FROM_WIN32(ERROR_NOT_ENOUGH_MEMORY));
}

inline void communication_client_state::fail_all(HRESULT result) noexcept {
  const bool was_stopping = stopping_.exchange(true);
  if (!was_stopping && port_ && *port_)
    (void)::CancelIoEx(port_->get(), nullptr);
  std::vector<std::shared_ptr<communication_async_operation>> pending;
  {
    std::lock_guard<std::mutex> guard(operations_lock_);
    for (auto &entry : operations_) {
      if (auto operation = entry.second.lock())
        pending.push_back(std::move(operation));
    }
    operations_.clear();
  }
  for (auto &operation : pending)
    operation->fail(result);

  std::vector<std::shared_ptr<communication_receive_operation>> receives;
  {
    std::lock_guard<std::mutex> guard(receives_lock_);
    for (auto &entry : receive_waiters_) {
      for (auto &waiter : entry.second) {
        if (auto operation = waiter.operation.lock())
          receives.push_back(std::move(operation));
      }
    }
    receive_waiters_.clear();
    receive_keys_.clear();
    buffered_.clear();
    buffered_count_ = 0;
  }
  for (auto &operation : receives)
    operation->fail(result);
}

