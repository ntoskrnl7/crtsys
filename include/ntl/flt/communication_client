template <typename Callback, typename Tuple, std::size_t... Index>
auto invoke_client_callback(Callback &callback, Tuple &arguments,
                            std::index_sequence<Index...>)
    -> decltype(callback(std::get<Index>(arguments)...)) {
  return callback(std::get<Index>(arguments)...);
}

class communication_client_request_handler {
public:
  virtual ~communication_client_request_handler() = default;
  virtual std::size_t request_limit() const noexcept = 0;
  virtual HRESULT invoke(const void *input, std::size_t input_size,
                         std::vector<unsigned char> &output) noexcept = 0;
};

template <typename Method, typename Callback>
class typed_communication_client_request_handler final
    : public communication_client_request_handler {
public:
  explicit typed_communication_client_request_handler(Callback callback)
      : callback_(std::move(callback)) {}

  std::size_t request_limit() const noexcept override {
    return Method::request_size();
  }

  HRESULT invoke(const void *input, std::size_t input_size,
                 std::vector<unsigned char> &output) noexcept override {
    try {
      if (input_size > Method::request_size())
        return HRESULT_FROM_WIN32(ERROR_INSUFFICIENT_BUFFER);
      typename Method::argument_storage arguments{};
      zpp::serializer::memory_view_input_archive archive(
          static_cast<const unsigned char *>(input), input_size,
          Method::decode_allocation());
      deserialize(
          archive, arguments,
          std::make_index_sequence<
              std::tuple_size<typename Method::argument_storage>::value>{});
      if (archive.offset() != input_size)
        return E_INVALIDARG;
      return invoke_result(
          arguments, output,
          typename std::is_void<typename Method::return_type>::type{});
    } catch (const zpp::serializer::out_of_range &) {
      return E_INVALIDARG;
    } catch (const std::bad_alloc &) {
      return E_OUTOFMEMORY;
    } catch (...) {
      return E_FAIL;
    }
  }

private:
  template <typename Archive, typename Tuple, std::size_t... Index>
  static void deserialize(Archive &archive, Tuple &arguments,
                          std::index_sequence<Index...>) {
    archive(std::get<Index>(arguments)...);
  }

  template <typename Tuple>
  HRESULT invoke_result(Tuple &arguments, std::vector<unsigned char> &output,
                        std::true_type) {
    invoke_client_callback(
        callback_, arguments,
        std::make_index_sequence<std::tuple_size<Tuple>::value>{});
    output.clear();
    return S_OK;
  }

  template <typename Tuple>
  HRESULT invoke_result(Tuple &arguments, std::vector<unsigned char> &output,
                        std::false_type) {
    typename Method::return_type value = invoke_client_callback(
        callback_, arguments,
        std::make_index_sequence<std::tuple_size<Tuple>::value>{});
    output.resize(Method::response_size());
    zpp::serializer::memory_view_output_archive archive(output.data(),
                                                        output.size());
    archive(value);
    output.resize(archive.offset());
    return S_OK;
  }

  Callback callback_;
};

class communication_client_state
    : public std::enable_shared_from_this<communication_client_state> {
public:
  explicit communication_client_state(std::shared_ptr<ntl::unique_handle> port)
      : port_(std::move(port)) {}
  communication_client_state(const communication_client_state &) = delete;
  communication_client_state &
  operator=(const communication_client_state &) = delete;
  ~communication_client_state();

  const std::shared_ptr<ntl::unique_handle> &port() const noexcept {
    return port_;
  }
  std::uint64_t next_request_id() noexcept;
  void register_operation(
      std::uint64_t id,
      const std::shared_ptr<communication_async_operation> &operation);
  void unregister_operation(std::uint64_t id) noexcept;
  bool cancel(std::uint64_t id);
  void open_session();
  void resume_session(ntl::rpc::session_token token);
  void preserve_session();
  ntl::rpc::session_info session() const noexcept {
    std::lock_guard<std::mutex> guard(session_lock_);
    return session_;
  }
  void subscribe(std::uint32_t id, bool stream,
                 std::uint32_t max_batch_records = 1);
  void unsubscribe(std::uint32_t id, bool stream);
  void acknowledge(std::uint32_t id, std::uint64_t sequence);
  void acknowledge_batch(std::uint32_t id,
                         const std::vector<std::uint64_t> &sequences);
  void register_receive(
      communication_inbound_kind kind, std::uint32_t id,
      const std::shared_ptr<communication_receive_operation> &operation);
  void unregister_receive(std::uint64_t waiter_id) noexcept;
  void register_request_handler(
      std::uint32_t id,
      std::shared_ptr<communication_client_request_handler> handler);
  void shutdown() noexcept;

private:
  void ensure_receiver();
  void receiver_loop(HANDLE receive_port) noexcept;
  void dispatch_inbound(const communication_inbound_header &header,
                        const void *payload) noexcept;
  void dispatch_request(HANDLE port, std::uint64_t message_id,
                         const communication_inbound_header &header,
                         const void *payload) noexcept;
  void fail_all(HRESULT result) noexcept;

  static constexpr std::size_t receiver_count = 4;

  std::shared_ptr<ntl::unique_handle> port_;
  std::atomic<std::uint64_t> next_request_id_{1};
  std::mutex operations_lock_;
  std::unordered_map<std::uint64_t,
                     std::weak_ptr<communication_async_operation>>
      operations_;
  struct buffered_inbound {
    communication_inbound_header header{};
    std::vector<unsigned char> payload;
  };
  struct receive_waiter_entry {
    std::uint64_t id = 0;
    std::weak_ptr<communication_receive_operation> operation;
  };
  std::mutex receives_lock_;
  std::unordered_map<std::uint64_t, std::deque<receive_waiter_entry>>
      receive_waiters_;
  std::unordered_map<std::uint64_t, std::uint64_t> receive_keys_;
  std::unordered_map<std::uint64_t, std::deque<buffered_inbound>> buffered_;
  std::unordered_set<std::uint32_t> notification_subscriptions_;
  std::unordered_set<std::uint32_t> open_streams_;
  std::unordered_map<std::uint32_t, std::uint32_t> subscription_batches_;
  std::size_t buffered_count_ = 0;
  static constexpr std::size_t maximum_buffered_messages = 256;
  std::mutex request_handlers_lock_;
  std::unordered_map<std::uint32_t,
                     std::shared_ptr<communication_client_request_handler>>
      request_handlers_;
  mutable std::mutex session_lock_;
  ntl::rpc::session_info session_{};
  std::atomic<bool> preserve_session_{false};
  std::mutex receiver_lock_;
  std::vector<std::thread> receivers_;
  bool receiver_started_ = false;
  std::atomic<bool> stopping_{false};
};

