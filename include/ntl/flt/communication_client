/** @brief Result of waiting for one asynchronous minifilter method. */
enum class communication_wait_status { completed, timeout };

/** @brief Move-only owner of one asynchronous minifilter method result. */
template <typename T> class communication_async_call {
public:
  communication_async_call(const communication_async_call &) = delete;
  communication_async_call &
  operator=(const communication_async_call &) = delete;
  communication_async_call(communication_async_call &&) noexcept = default;
  communication_async_call &
  operator=(communication_async_call &&) noexcept = default;

  explicit operator bool() const noexcept { return state_ && !consumed_; }

  /** @brief Reports whether the minifilter has sent the completion message. */
  bool ready() const {
    ensure_valid();
    return state_->ready();
  }

  /** @brief Waits up to timeout for the completion message. */
  communication_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout) ? communication_wait_status::completed
                                     : communication_wait_status::timeout;
  }

  /** @brief Waits without a timeout. */
  void wait() {
    ensure_valid();
    state_->wait();
  }

  /** @brief Requests cooperative cancellation of this method invocation. */
  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  /** @brief Waits, deserializes, and consumes the typed result. */
  T get() {
    ensure_valid();
    const auto &output = state_->output();
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), decode_allocation_);
    T value{};
    archive(value);
    if (archive.offset() != output.size())
      throw std::runtime_error(
          "NTL minifilter async response contains trailing bytes");
    consumed_ = true;
    state_.reset();
    return std::move(value);
  }

private:
  friend class communication_client;
  template <typename U> friend class detail::communication_async_call_awaiter;
  communication_async_call(
      std::shared_ptr<detail::communication_async_operation> state,
      std::size_t decode_allocation)
      : state_(std::move(state)), decode_allocation_(decode_allocation) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL minifilter asynchronous call has no result");
  }

  std::shared_ptr<detail::communication_async_operation> state_;
  std::size_t decode_allocation_ = 0;
  bool consumed_ = false;
};

/** @brief Move-only owner of one asynchronous void minifilter method. */
