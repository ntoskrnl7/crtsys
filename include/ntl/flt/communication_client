#endif

  /** @brief ACKs one reliable delivery after application processing. */
  template <typename Notification>
  void acknowledge(
      const Notification &,
      const ntl::rpc::notification_delivery<typename Notification::payload_type>
          &delivery) const {
    static_assert(ntl::rpc::is_notification<Notification>::value,
                  "communication_client::acknowledge requires a notification");
    if (!lifetime_)
      throw std::logic_error("NTL minifilter client has no connection");
    lifetime_->state()->acknowledge(Notification::id(), delivery.sequence());
  }

  /** @brief ACKs every record in one batch with a single port message. */
  template <typename Notification>
  void acknowledge(
      const Notification &,
      const ntl::rpc::notification_batch<typename Notification::payload_type>
          &batch) const {
    static_assert(ntl::rpc::is_notification<Notification>::value,
                  "communication_client::acknowledge requires a notification");
    if (!lifetime_ || batch.empty())
      throw std::logic_error("NTL minifilter client has no batch to ACK");
    std::vector<std::uint64_t> sequences;
    sequences.reserve(batch.size());
    for (const auto &delivery : batch.values())
      sequences.push_back(delivery.sequence());
    lifetime_->state()->acknowledge_batch(Notification::id(), sequences);
  }

  /** @brief Opens one session-bound typed bidirectional stream. */
  template <typename Stream>
  communication_client_stream<Stream> open_stream(const Stream &channel);

  /** @brief Invokes one shared `ntl::rpc::method` over FilterSendMessage. */
  template <typename Method, typename... Arguments>
  typename Method::return_type invoke(const Method &method,
                                      Arguments &&...arguments) const {
    static_assert(ntl::rpc::is_method<Method>::value,
                  "communication_client::invoke requires ntl::rpc::method");
    static_assert(sizeof...(Arguments) == Method::arity(),
                  "Minifilter method argument count does not match");
    require_method(method);
    using is_void = typename std::is_void<typename Method::return_type>::type;
    return invoke_impl(method, is_void{},
                       std::forward<Arguments>(arguments)...);
  }

  /**
   * @brief Queues one method and completes it through overlapped
   * FilterGetMessage.
   * The returned call keeps the underlying port and completion receiver alive.
   */
  template <typename Method, typename... Arguments>
  communication_async_call<typename Method::return_type>
  invoke_async(const Method &method, Arguments &&...arguments) const {
    static_assert(
        ntl::rpc::is_method<Method>::value,
        "communication_client::invoke_async requires ntl::rpc::method");
    static_assert(sizeof...(Arguments) == Method::arity(),
                  "Minifilter method argument count does not match");
    require_method(method);
    return invoke_async_impl(
        method, typename std::is_void<typename Method::return_type>::type{},
        std::forward<Arguments>(arguments)...);
  }

#if NTL_FLT_HAS_STOP_TOKEN
  /** @brief Cancels the asynchronous method when the stop token fires. */
  template <typename Method, typename... Arguments>
  communication_async_call<typename Method::return_type>
  invoke_async(std::stop_token token, const Method &method,
               Arguments &&...arguments) const {
    auto call = invoke_async(method, std::forward<Arguments>(arguments)...);
    using callback_type =
        std::stop_callback<detail::communication_stop_canceller>;
    auto registration = std::make_shared<callback_type>(
        token, detail::communication_stop_canceller{call.state_});
    call.state_->attach_cancellation_registration(std::move(registration));
    return call;
  }
#endif

  /** @brief Allocates and pins one connection-bound shared-memory region. */
  registered_port_region
  register_shared_region(std::size_t bytes,
                         ntl::ipc::region_access access =
                             ntl::ipc::region_access::driver_read_write) const {
    if (!port_ || !*port_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL minifilter port is not connected");
    if (bytes == 0)
      throw std::invalid_argument(
          "NTL minifilter shared-region size is invalid");

    void *const memory = ::VirtualAlloc(
        nullptr, bytes, MEM_RESERVE | MEM_COMMIT, PAGE_READWRITE);
    if (!memory)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL minifilter shared allocation failed");

    try {
      const auto registration =
          ntl::ipc::region_registration::from(memory, bytes, access);
      const auto request = detail::make_port_request(
          detail::communication_operation::register_region, 0, &registration,
          sizeof(registration));
      ntl::ipc::region_handle region{};
      DWORD returned = 0;
      detail::send_port_message(port_, request, &region, sizeof(region),
                                returned);
      if (returned != sizeof(region) || !region.valid())
        throw std::runtime_error(
            "NTL minifilter returned an invalid shared-region handle");
      return registered_port_region{port_, region, memory, bytes, access};
    } catch (...) {
      ::VirtualFree(memory, 0, MEM_RELEASE);
      throw;
    }
  }

private:
  template <typename Stream> friend class communication_client_stream;

  template <typename Method>
  void require_method_definition(const Method &,
                                 communication_member_kind kind) const {
    static_assert(ntl::rpc::is_method<Method>::value,
                  "require_method requires a method");
    const auto &info = contract_for_validation();
    const auto *member = info.find(Method::id(), kind);
    if (!member || member->request_size != Method::request_size() ||
        member->response_size != Method::response_size() ||
        member->decode_allocation != Method::decode_allocation() ||
        member->schema_hash != Method::schema_hash())
      throw std::runtime_error("NTL minifilter method contract mismatch");
  }

  const communication_contract_info &contract_for_validation() const {
    std::lock_guard<std::mutex> guard(contract_cache_->lock);
    if (!contract_cache_->info)
      contract_cache_->info =
          std::make_shared<communication_contract_info>(query_contract());
    return *contract_cache_->info;
  }
  communication_client(
      std::shared_ptr<ntl::unique_handle> port,
      std::shared_ptr<detail::communication_client_lifetime> lifetime)
      : port_(std::move(port)), lifetime_(std::move(lifetime)) {}

  template <typename Notification, bool Reliable>
  communication_notification_wait<typename Notification::payload_type, Reliable>
  submit_receive(detail::communication_inbound_kind kind, bool stream) const {
    if (!lifetime_ || !port_ || !*port_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL minifilter port is not connected");
    if (!stream)
      require_notification(Notification{});
    const auto &state = lifetime_->state();
    state->subscribe(Notification::id(), stream);
    const auto waiter_id = state->next_request_id();
    auto operation = std::make_shared<detail::communication_receive_operation>(
        lifetime_, waiter_id);
    state->register_receive(kind, Notification::id(), operation);
    return communication_notification_wait<typename Notification::payload_type,
                                           Reliable>(
        std::move(operation), Notification::decode_allocation());
  }

  template <typename Stream>
  communication_notification_wait<typename Stream::record_type, true>
  receive_stream_async() const {
    using notification_type = typename Stream::download_notification_type;
    return submit_receive<notification_type, true>(
        detail::communication_inbound_kind::stream_record, true);
  }

  template <typename Stream>
  communication_batch_wait<typename Stream::record_type>
  receive_stream_batch_async() const {
    using notification_type = typename Stream::download_notification_type;
    return submit_batch<notification_type>(true);
  }

  template <typename Notification>
  communication_batch_wait<typename Notification::payload_type>
  submit_batch(bool stream) const {
    if (!lifetime_ || !port_ || !*port_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL minifilter port is not connected");
    if (!stream)
      require_notification(Notification{});
    const auto &state = lifetime_->state();
    state->subscribe(
        Notification::id(), stream,
        static_cast<std::uint32_t>(Notification::max_batch_records()));
    const auto waiter_id = state->next_request_id();
    auto operation = std::make_shared<detail::communication_receive_operation>(
        lifetime_, waiter_id);
    state->register_receive(detail::communication_inbound_kind::reliable_batch,
                            Notification::id(), operation);
    return communication_batch_wait<typename Notification::payload_type>(
        std::move(operation), Notification::decode_allocation());
  }

#if NTL_FLT_HAS_STOP_TOKEN
  static void attach_receive_stop(
      std::stop_token token,
      const std::shared_ptr<detail::communication_receive_operation> &state) {
    using callback_type =
        std::stop_callback<detail::communication_receive_stop_canceller>;
    auto registration = std::make_shared<callback_type>(
        token, detail::communication_receive_stop_canceller{state});
    state->attach_cancellation_registration(std::move(registration));
  }
#endif

  template <typename Method, typename... Arguments>
  static std::vector<unsigned char>
  serialize_method_arguments(Arguments &&...arguments) {
    using storage = typename Method::argument_storage;
    static_assert(std::is_constructible<storage, Arguments &&...>::value,
                  "Arguments cannot initialize the minifilter method");
    storage values(std::forward<Arguments>(arguments)...);
    return detail::serialize_port_arguments(
        values, std::make_index_sequence<std::tuple_size<storage>::value>{});
  }

  template <typename Method, typename... Arguments>
  void invoke_impl(const Method &, std::true_type,
                   Arguments &&...arguments) const {
    const auto payload = serialize_method_arguments<Method>(
        std::forward<Arguments>(arguments)...);
    if (payload.size() > Method::request_size())
      throw std::length_error(
          "NTL minifilter request exceeded its method limit");
    const auto request =
        detail::make_port_request(detail::communication_operation::invoke,
                                  Method::id(), payload.data(), payload.size());
    DWORD returned = 0;
    detail::send_port_message(port_, request, nullptr, 0, returned);
    if (returned != 0)
      throw std::runtime_error(
          "Void NTL minifilter method returned output bytes");
  }

  template <typename Method, typename... Arguments>
  typename Method::return_type invoke_impl(const Method &, std::false_type,
                                           Arguments &&...arguments) const {
    using return_type = typename Method::return_type;
    static_assert(std::is_default_constructible<return_type>::value,
                  "Minifilter method results must be default constructible");
    if (Method::response_size() >
        static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()))
      throw std::length_error(
          "NTL minifilter response capacity exceeds DWORD capacity");

    const auto payload = serialize_method_arguments<Method>(
        std::forward<Arguments>(arguments)...);
    if (payload.size() > Method::request_size())
      throw std::length_error(
          "NTL minifilter request exceeded its method limit");
    const auto request =
        detail::make_port_request(detail::communication_operation::invoke,
                                  Method::id(), payload.data(), payload.size());
    std::vector<unsigned char> output(Method::response_size());
    DWORD returned = 0;
    detail::send_port_message(port_, request, output.data(),
                              static_cast<DWORD>(output.size()), returned);
    if (returned > output.size())
      throw std::runtime_error(
          "NTL minifilter returned an invalid output size");

    output.resize(returned);
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), Method::decode_allocation());
    return_type value{};
    archive(value);
    if (archive.offset() != output.size())
      throw std::runtime_error(
          "NTL minifilter response contains trailing bytes");
    return std::move(value);
  }

  template <typename Method, typename... Arguments>
  std::shared_ptr<detail::communication_async_operation>
  submit_async(Arguments &&...arguments) const {
    if (!lifetime_ || !port_ || !*port_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL minifilter port is not connected");
    if (Method::response_size() > detail::communication_inbound_payload_limit)
      throw std::length_error(
          "NTL minifilter async response exceeds receiver capacity");

    auto arguments_bytes = serialize_method_arguments<Method>(
        std::forward<Arguments>(arguments)...);
    if (arguments_bytes.size() > Method::request_size())
      throw std::length_error(
          "NTL minifilter request exceeded its method limit");

    const auto &state = lifetime_->state();
    const std::uint64_t request_id = state->next_request_id();
    auto operation = std::make_shared<detail::communication_async_operation>(
        lifetime_, request_id);
    state->register_operation(request_id, operation);

    try {
      detail::communication_async_request async_header{request_id};
      std::vector<unsigned char> payload(sizeof(async_header) +
                                         arguments_bytes.size());
      std::memcpy(payload.data(), &async_header, sizeof(async_header));
      if (!arguments_bytes.empty())
        std::memcpy(payload.data() + sizeof(async_header),
                    arguments_bytes.data(), arguments_bytes.size());
      const auto request = detail::make_port_request(
          detail::communication_operation::invoke_async, Method::id(),
          payload.data(), payload.size());
      DWORD returned = 0;
      detail::send_port_message(port_, request, nullptr, 0, returned);
      if (returned != 0)
        throw std::runtime_error(
            "NTL minifilter async submission returned output bytes");
    } catch (...) {
      state->unregister_operation(request_id);
      operation->fail(HRESULT_FROM_WIN32(ERROR_OPERATION_ABORTED));
      throw;
    }
    return operation;
  }

  template <typename Method, typename... Arguments>
  communication_async_call<typename Method::return_type>
  invoke_async_impl(const Method &, std::false_type,
                    Arguments &&...arguments) const {
    auto operation =
        submit_async<Method>(std::forward<Arguments>(arguments)...);
    return communication_async_call<typename Method::return_type>(
        std::move(operation), Method::decode_allocation());
  }

  template <typename Method, typename... Arguments>
  communication_async_call<void>
  invoke_async_impl(const Method &, std::true_type,
                    Arguments &&...arguments) const {
    return communication_async_call<void>(
        submit_async<Method>(std::forward<Arguments>(arguments)...));
  }

  std::shared_ptr<ntl::unique_handle> port_;
  std::shared_ptr<detail::communication_client_lifetime> lifetime_;
  std::shared_ptr<detail::communication_contract_cache> contract_cache_ =
      std::make_shared<detail::communication_contract_cache>();
};

/** @brief Session-bound facade for one typed bidirectional minifilter stream.
 */
template <typename Stream> class communication_client_stream {
  static_assert(ntl::rpc::is_stream<Stream>::value,
                "communication_client_stream requires ntl::rpc::stream");

public:
  using upload_type = typename Stream::upload_type;
  using record_type = typename Stream::record_type;
  using delivery_type = ntl::rpc::notification_delivery<record_type>;
  using read_wait_type = communication_notification_wait<record_type, true>;
  using batch_type = ntl::rpc::notification_batch<record_type>;
  using batch_wait_type = communication_batch_wait<record_type>;

  communication_client_stream(const communication_client_stream &) = delete;
  communication_client_stream &
  operator=(const communication_client_stream &) = delete;
  communication_client_stream(communication_client_stream &&other) noexcept
      : owner_(std::move(other.owner_)), open_(other.open_) {
    other.open_ = false;
  }
  communication_client_stream &
  operator=(communication_client_stream &&other) noexcept {
    if (this == &other)
      return *this;
    close_noexcept();
    owner_ = std::move(other.owner_);
    open_ = other.open_;
    other.open_ = false;
    return *this;
  }
  ~communication_client_stream() { close_noexcept(); }

  explicit operator bool() const noexcept {
    return open_ && static_cast<bool>(owner_);
  }

  /** @brief Sends one app-to-driver stream record synchronously. */
  void write(const upload_type &value) {
    write_batch(std::vector<upload_type>{value});
  }

  /** @brief Sends a bounded ordered upload batch synchronously. */
  void write_batch(const std::vector<upload_type> &values) {
    ensure_open();
    validate_batch(values.size());
    owner_.invoke(Stream::upload_method(),
                  typename Stream::upload_batch_type(values));
  }

  /** @brief Sends one app-to-driver record asynchronously. */
  communication_async_call<void> write_async(const upload_type &value) {
    return write_batch_async(std::vector<upload_type>{value});
  }

  /** @brief Sends a bounded upload batch asynchronously. */
  communication_async_call<void>
  write_batch_async(const std::vector<upload_type> &values) {
    ensure_open();
    validate_batch(values.size());
    return owner_.invoke_async(Stream::upload_method(),
                               typename Stream::upload_batch_type(values));
  }

#if NTL_FLT_HAS_STOP_TOKEN
  communication_async_call<void> write_async(std::stop_token token,
                                             const upload_type &value) {
    return write_batch_async(token, std::vector<upload_type>{value});
  }
  communication_async_call<void>
  write_batch_async(std::stop_token token,
                    const std::vector<upload_type> &values) {
    ensure_open();
    validate_batch(values.size());
    return owner_.invoke_async(token, Stream::upload_method(),
                               typename Stream::upload_batch_type(values));
  }
#endif

  /** @brief Waits synchronously for one driver-to-app stream record. */
  delivery_type read() {
    ensure_open();
    return read_async().get();
  }

  /** @brief Starts one cancellable driver-to-app stream read. */
  read_wait_type read_async() {
    ensure_open();
    return owner_.template receive_stream_async<Stream>();
  }

  /** @brief Waits for one bounded driver-to-app stream batch. */
  batch_type read_batch() {
    ensure_open();
    return read_batch_async().get();
  }

  /** @brief Starts one cancellable bounded stream batch read. */
  batch_wait_type read_batch_async() {
    ensure_open();
    return owner_.template receive_stream_batch_async<Stream>();
  }

#if NTL_FLT_HAS_STOP_TOKEN
  read_wait_type read_async(std::stop_token token) {
    auto wait = read_async();
    communication_client::attach_receive_stop(token, wait.state_);
    return wait;
  }

  batch_wait_type read_batch_async(std::stop_token token) {
    auto wait = read_batch_async();
    communication_client::attach_receive_stop(token, wait.state_);
    return wait;
  }
#endif

  /** @brief ACKs one processed stream delivery. */
  void acknowledge(const delivery_type &delivery) {
    ensure_open();
    owner_.lifetime_->state()->acknowledge(Stream::id(), delivery.sequence());
  }

  /** @brief ACKs one processed stream batch with a single port message. */
  void acknowledge(const batch_type &batch) {
    ensure_open();
    if (batch.empty())
      throw std::invalid_argument("NTL minifilter stream batch is empty");
    std::vector<std::uint64_t> sequences;
    sequences.reserve(batch.size());
    for (const auto &delivery : batch.values())
      sequences.push_back(delivery.sequence());
    owner_.lifetime_->state()->acknowledge_batch(Stream::id(), sequences);
  }

  /** @brief Closes this stream and discards its queued server records. */
  void close() {
    ensure_open();
    owner_.lifetime_->state()->unsubscribe(Stream::id(), true);
    open_ = false;
    owner_ = {};
  }

private:
  friend class communication_client;
  explicit communication_client_stream(communication_client &owner)
      : owner_(owner), open_(true) {
    owner_.lifetime_->state()->subscribe(Stream::id(), true);
  }

  static void validate_batch(std::size_t count) {
    if (count == 0 || count > Stream::max_batch_records())
      throw std::length_error("NTL minifilter stream batch is out of range");
  }
  void ensure_open() const {
    if (!open_ || !owner_)
      throw std::logic_error("NTL minifilter stream is not open");
  }
  void close_noexcept() noexcept {
    if (!open_ || !owner_)
      return;
    try {
      owner_.lifetime_->state()->unsubscribe(Stream::id(), true);
    } catch (...) {
    }
    owner_ = {};
    open_ = false;
  }

  communication_client owner_;
  bool open_ = false;
};

template <typename Stream>
communication_client_stream<Stream>
communication_client::open_stream(const Stream &) {
  static_assert(ntl::rpc::is_stream<Stream>::value,
                "communication_client::open_stream requires ntl::rpc::stream");
  require_stream(Stream{});
  return communication_client_stream<Stream>(*this);
}

