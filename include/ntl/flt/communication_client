/** @brief Preserves an HRESULT returned by a Filter Manager user API. */
class communication_error : public std::runtime_error {
public:
  communication_error(HRESULT result, const char *message)
      : std::runtime_error(message), result_(result) {}

  /** @brief Returns the original Filter Manager HRESULT. */
  HRESULT result() const noexcept { return result_; }

private:
  HRESULT result_;
};

namespace detail {

template <typename Tuple, std::size_t... Index>
std::vector<unsigned char>
serialize_port_arguments(Tuple &arguments, std::index_sequence<Index...>) {
  std::vector<unsigned char> bytes;
  zpp::serializer::memory_output_archive archive(bytes);
  archive(std::get<Index>(arguments)...);
  return bytes;
}

inline std::vector<unsigned char>
make_port_request(communication_operation operation, std::uint32_t id,
                  const void *payload, std::size_t payload_size) {
  if (payload_size > (std::numeric_limits<std::uint32_t>::max)() ||
      payload_size > (std::numeric_limits<DWORD>::max)() -
                         sizeof(communication_request_header))
    throw std::length_error("NTL minifilter message exceeds DWORD capacity");

  communication_request_header header{};
  header.operation = operation;
  header.id = id;
  header.payload_size = static_cast<std::uint32_t>(payload_size);

  std::vector<unsigned char> request(sizeof(header) + payload_size);
  std::memcpy(request.data(), &header, sizeof(header));
  if (payload_size)
    std::memcpy(request.data() + sizeof(header), payload, payload_size);
  return request;
}

inline void send_port_message(const std::shared_ptr<ntl::unique_handle> &port,
                              const std::vector<unsigned char> &request,
                              void *output, DWORD output_size,
                              DWORD &returned) {
  if (!port || !*port)
    throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                            "NTL minifilter port is not connected");
  returned = 0;
  const HRESULT result = FilterSendMessage(
      port->get(), const_cast<unsigned char *>(request.data()),
      static_cast<DWORD>(request.size()), output, output_size, &returned);
  if (FAILED(result))
    throw communication_error(result, "NTL minifilter message failed");
}

inline bool disconnected_result(HRESULT result) noexcept {
  return result == HRESULT_FROM_WIN32(ERROR_INVALID_HANDLE) ||
         result == HRESULT_FROM_WIN32(ERROR_FILE_NOT_FOUND) ||
         result == HRESULT_FROM_WIN32(ERROR_PIPE_NOT_CONNECTED);
}

struct communication_batch_record_view {
  std::uint64_t sequence = 0;
  const unsigned char *payload = nullptr;
  std::uint32_t payload_size = 0;
};

inline bool parse_communication_batch(
    const void *payload, std::size_t payload_size,
    communication_batch_header &header,
    communication_batch_record_view
        (&records)[ntl::rpc::maximum_batch_records]) noexcept {
  if (!payload || payload_size < sizeof(header))
    return false;

  const auto *const bytes = static_cast<const unsigned char *>(payload);
  std::memcpy(&header, bytes, sizeof(header));
  if (header.version != communication_batch_version || header.count == 0 ||
      header.count > ntl::rpc::maximum_batch_records)
    return false;

  std::size_t offset = sizeof(header);
  for (std::uint32_t index = 0; index != header.count; ++index) {
    if (payload_size - offset < sizeof(communication_batch_record_header))
      return false;
    communication_batch_record_header record{};
    std::memcpy(&record, bytes + offset, sizeof(record));
    offset += sizeof(record);
    if (record.reserved != 0 || record.sequence == 0 ||
        record.payload_size > payload_size - offset)
      return false;
    for (std::uint32_t previous = 0; previous != index; ++previous)
      if (records[previous].sequence == record.sequence)
        return false;
    records[index] =
        {record.sequence, bytes + offset, record.payload_size};
    offset += record.payload_size;
  }
  return offset == payload_size;
}

inline std::uint64_t inbound_key(communication_inbound_kind kind,
                                 std::uint32_t id) noexcept {
  return (static_cast<std::uint64_t>(kind) << 32) | id;
}

