  std::weak_ptr<communication_async_operation> operation;
  void operator()() const noexcept {
    if (auto current = operation.lock())
      (void)current->cancel_noexcept();
  }
};

struct communication_receive_stop_canceller {
  std::weak_ptr<communication_receive_operation> operation;
  void operator()() const noexcept {
    if (auto current = operation.lock())
      (void)current->cancel_noexcept();
  }
};
#endif

