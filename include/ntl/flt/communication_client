/** @brief Move-only owner of one typed minifilter notification receive. */
template <typename Payload, bool Reliable>
class communication_notification_wait {
public:
  using result_type = typename std::conditional<
      Reliable, ntl::rpc::notification_delivery<Payload>, Payload>::type;

  communication_notification_wait(const communication_notification_wait &) =
      delete;
  communication_notification_wait &
  operator=(const communication_notification_wait &) = delete;
  communication_notification_wait(communication_notification_wait &&) noexcept =
      default;
  communication_notification_wait &
  operator=(communication_notification_wait &&) noexcept = default;

  explicit operator bool() const noexcept { return state_ && !consumed_; }
  bool ready() const {
    ensure_valid();
    return state_->ready();
  }
  communication_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout) ? communication_wait_status::completed
                                     : communication_wait_status::timeout;
  }
  void wait() {
    ensure_valid();
    state_->wait();
  }
  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  result_type get() {
    ensure_valid();
    auto received = state_->take();
    auto &header = received.first;
    auto &bytes = received.second;
    zpp::serializer::memory_view_input_archive archive(
        bytes.data(), bytes.size(), decode_allocation_);
    Payload payload{};
    archive(payload);
    if (archive.offset() != bytes.size())
      throw std::runtime_error(
          "NTL minifilter notification contains trailing bytes");
    consumed_ = true;
    state_.reset();
    return make_result(header, std::move(payload),
                       std::integral_constant<bool, Reliable>{});
  }

private:
  friend class communication_client;
  template <typename U, bool R>
  friend class detail::communication_notification_wait_awaiter;
  communication_notification_wait(
      std::shared_ptr<detail::communication_receive_operation> state,
      std::size_t decode_allocation)
      : state_(std::move(state)), decode_allocation_(decode_allocation) {}

  static Payload make_result(const detail::communication_inbound_header &,
                             Payload payload, std::false_type) {
    return payload;
  }
  static ntl::rpc::notification_delivery<Payload>
  make_result(const detail::communication_inbound_header &header,
              Payload payload, std::true_type) {
    if (header.correlation == 0 || header.session_id == 0)
      throw std::runtime_error(
          "NTL minifilter reliable notification has no sequence");
    return ntl::rpc::notification_delivery<Payload>(header.correlation,
                                                    std::move(payload));
  }

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL minifilter notification has no result");
  }

  std::shared_ptr<detail::communication_receive_operation> state_;
  std::size_t decode_allocation_ = 0;
  bool consumed_ = false;
};

/** @brief Move-only owner of one bounded reliable-delivery batch. */
template <typename Payload> class communication_batch_wait {
public:
  using result_type = ntl::rpc::notification_batch<Payload>;

  communication_batch_wait(const communication_batch_wait &) = delete;
  communication_batch_wait &
  operator=(const communication_batch_wait &) = delete;
  communication_batch_wait(communication_batch_wait &&) noexcept = default;
  communication_batch_wait &
  operator=(communication_batch_wait &&) noexcept = default;

  explicit operator bool() const noexcept { return state_ && !consumed_; }
  bool ready() const {
    ensure_valid();
    return state_->ready();
  }
  communication_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout) ? communication_wait_status::completed
                                     : communication_wait_status::timeout;
  }
  void wait() {
    ensure_valid();
    state_->wait();
  }
  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  result_type get() {
    ensure_valid();
    auto received = state_->take();
    const auto &bytes = received.second;
    if (bytes.size() < sizeof(detail::communication_batch_header))
      throw std::runtime_error("NTL minifilter batch header is truncated");
    detail::communication_batch_header header{};
    std::memcpy(&header, bytes.data(), sizeof(header));
    if (header.version != detail::communication_batch_version ||
        header.count == 0 || header.count > ntl::rpc::maximum_batch_records)
      throw std::runtime_error("NTL minifilter batch header is invalid");

    std::vector<ntl::rpc::notification_delivery<Payload>> values;
    values.reserve(header.count);
    std::vector<std::uint64_t> sequences;
    sequences.reserve(header.count);
    std::size_t offset = sizeof(header);
    for (std::uint32_t index = 0; index != header.count; ++index) {
      if (bytes.size() - offset <
          sizeof(detail::communication_batch_record_header))
        throw std::runtime_error("NTL minifilter batch record is truncated");
      detail::communication_batch_record_header record{};
      std::memcpy(&record, bytes.data() + offset, sizeof(record));
      offset += sizeof(record);
      if (record.reserved != 0 || record.sequence == 0 ||
          record.payload_size > bytes.size() - offset)
        throw std::runtime_error("NTL minifilter batch record is invalid");
      if (std::find(sequences.begin(), sequences.end(), record.sequence) !=
          sequences.end())
        throw std::runtime_error(
            "NTL minifilter batch contains duplicate sequences");
      sequences.push_back(record.sequence);
      zpp::serializer::memory_view_input_archive archive(
          bytes.data() + offset, record.payload_size, decode_allocation_);
      Payload payload{};
      archive(payload);
      if (archive.offset() != record.payload_size)
        throw std::runtime_error(
            "NTL minifilter batch payload contains trailing bytes");
      values.emplace_back(record.sequence, std::move(payload));
      offset += record.payload_size;
    }
    if (offset != bytes.size())
      throw std::runtime_error("NTL minifilter batch has trailing bytes");
    consumed_ = true;
    state_.reset();
    return result_type(std::move(values));
  }

private:
  friend class communication_client;
  template <typename Stream> friend class communication_client_stream;
  communication_batch_wait(
      std::shared_ptr<detail::communication_receive_operation> state,
      std::size_t decode_allocation)
      : state_(std::move(state)), decode_allocation_(decode_allocation) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL minifilter batch has no result");
  }

  std::shared_ptr<detail::communication_receive_operation> state_;
  std::size_t decode_allocation_ = 0;
  bool consumed_ = false;
};

/**
 * @brief Owns one user allocation pinned by a minifilter port connection.
 *
 * Destruction unregisters before VirtualFree. Keep this object alive while the
 * driver may use a token or shared ring backed by the allocation.
 */
class registered_port_region {
public:
  registered_port_region() noexcept = default;
  registered_port_region(const registered_port_region &) = delete;
  registered_port_region &operator=(const registered_port_region &) = delete;

  registered_port_region(registered_port_region &&other) noexcept
      : port_(std::move(other.port_)), region_(other.region_),
        memory_(other.memory_), bytes_(other.bytes_), access_(other.access_) {
    other.region_ = {};
    other.memory_ = nullptr;
    other.bytes_ = 0;
    other.access_ = ntl::ipc::region_access::none;
  }

  registered_port_region &operator=(registered_port_region &&other) noexcept {
    if (this == &other)
      return *this;
    reset_noexcept();
    port_ = std::move(other.port_);
    region_ = other.region_;
    memory_ = other.memory_;
    bytes_ = other.bytes_;
    access_ = other.access_;
    other.region_ = {};
    other.memory_ = nullptr;
    other.bytes_ = 0;
    other.access_ = ntl::ipc::region_access::none;
    return *this;
  }

  ~registered_port_region() { reset_noexcept(); }

  explicit operator bool() const noexcept {
    return memory_ != nullptr && region_.valid();
  }
  void *data() const noexcept { return memory_; }
  std::size_t size() const noexcept { return bytes_; }
  ntl::ipc::region_handle handle() const noexcept { return region_; }

  /** @brief Returns the driver access granted to this registered region. */
  ntl::ipc::region_access access() const noexcept { return access_; }

  /** @brief Creates a variable-size lease pool over this registered region. */
  ntl::ipc::shared_buffer_pool
  make_buffer_pool(std::size_t alignment = alignof(void *)) const {
    if (!*this)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL minifilter shared region is not registered");
    return ntl::ipc::shared_buffer_pool{
        ntl::ipc::region_view{region_, memory_, bytes_,
                              access_},
        alignment};
  }

  /** @brief Creates a pointer-free token for a checked local subrange. */
  ntl::ipc::buffer_token token(std::size_t offset, std::size_t length) const {
    if (!*this || length == 0 || offset > bytes_ || length > bytes_ - offset)
      throw std::out_of_range(
          "NTL minifilter shared-region token is out of range");
    return ntl::ipc::buffer_token{region_, static_cast<std::uint64_t>(offset),
                                  static_cast<std::uint64_t>(length)};
  }

  /** @brief Unregisters the MDL before releasing the virtual allocation. */
  void close() {
    if (!memory_)
      return;
    if (region_.valid())
      unregister_region(true);
    release_memory();
  }

private:
  friend class communication_client;

  registered_port_region(std::shared_ptr<ntl::unique_handle> port,
                         ntl::ipc::region_handle region, void *memory,
                         std::size_t bytes,
                         ntl::ipc::region_access access) noexcept
      : port_(std::move(port)), region_(region), memory_(memory),
        bytes_(bytes), access_(access) {}

  void unregister_region(bool report_failure) {
    if (!port_ || !*port_ || !region_.valid()) {
      region_ = {};
      return;
    }

    const auto request = detail::make_port_request(
        detail::communication_operation::unregister_region, 0, &region_,
        sizeof(region_));
    DWORD returned = 0;
    const HRESULT result = FilterSendMessage(
        port_->get(), const_cast<unsigned char *>(request.data()),
        static_cast<DWORD>(request.size()), nullptr, 0, &returned);
    if (FAILED(result) && !detail::disconnected_result(result)) {
      if (report_failure)
        throw communication_error(
            result, "NTL minifilter shared-region unregistration failed");
      return;
    }
    region_ = {};
  }

  void release_memory() noexcept {
    if (memory_)
      ::VirtualFree(memory_, 0, MEM_RELEASE);
    memory_ = nullptr;
    bytes_ = 0;
    access_ = ntl::ipc::region_access::none;
    region_ = {};
    port_.reset();
  }

  void reset_noexcept() noexcept {
    try {
      if (region_.valid())
        unregister_region(false);
    } catch (...) {
    }
    if (!region_.valid()) {
      release_memory();
      return;
    }

    // A failed unregister on a still-connected port means the driver may
    // retain an MDL. Preserve the virtual allocation until process teardown
    // instead of releasing pages that could still be accessed by the kernel.
    port_.reset();
    memory_ = nullptr;
    bytes_ = 0;
    access_ = ntl::ipc::region_access::none;
    region_ = {};
  }

  std::shared_ptr<ntl::unique_handle> port_;
  ntl::ipc::region_handle region_{};
  void *memory_ = nullptr;
  std::size_t bytes_ = 0;
  ntl::ipc::region_access access_ = ntl::ipc::region_access::none;
};

/** @brief Typed user-mode owner of one Filter Manager client port handle. */
class communication_client {
public:
  communication_client() = default;

  /** @brief Connects to a named minifilter communication server port. */
  static communication_client connect(const std::wstring &name) {
    HANDLE native = INVALID_HANDLE_VALUE;
    const HRESULT result = FilterConnectCommunicationPort(
        name.c_str(), 0, nullptr, 0, nullptr, &native);
    if (FAILED(result))
      throw communication_error(result,
                                "NTL minifilter port connection failed");
    auto port = std::make_shared<ntl::unique_handle>(native);
    auto state = std::make_shared<detail::communication_client_state>(port);
    communication_client client(
        port, std::make_shared<detail::communication_client_lifetime>(
                  std::move(state)));
    client.lifetime_->state()->open_session();
    return client;
  }

  /** @brief Reconnects a port to a retained reliable-delivery session. */
  static communication_client resume(const std::wstring &name,
                                     ntl::rpc::session_token token) {
    HANDLE native = INVALID_HANDLE_VALUE;
    const HRESULT result = FilterConnectCommunicationPort(
        name.c_str(), 0, nullptr, 0, nullptr, &native);
    if (FAILED(result))
      throw communication_error(result,
                                "NTL minifilter port reconnection failed");
    auto port = std::make_shared<ntl::unique_handle>(native);
    auto state = std::make_shared<detail::communication_client_state>(port);
    communication_client client(
        port, std::make_shared<detail::communication_client_lifetime>(state));
    state->resume_session(token);
    return client;
  }

  explicit operator bool() const noexcept { return port_ && *port_; }
  HANDLE native_handle() const noexcept {
    return port_ ? port_->get() : nullptr;
  }

  /** @brief Returns the current reconnectable session identity. */
  ntl::rpc::session_info session() const noexcept {
    return lifetime_ ? lifetime_->state()->session() : ntl::rpc::session_info{};
  }

  /**
   * @brief Registers one typed handler for driver-originated requests.
   * @note Up to four handlers can run concurrently because the client keeps
   * multiple FilterGetMessage operations pending to avoid receive gaps.
   */
  template <typename Method, typename Callback>
  communication_client &on_request(const Method &, Callback callback) {
    static_assert(ntl::rpc::is_method<Method>::value,
                  "communication_client::on_request requires a method");
    if (!lifetime_)
      throw std::logic_error("NTL minifilter client has no connection");
    require_client_method(Method{});
    using handler_type = detail::typed_communication_client_request_handler<
        Method, typename std::decay<Callback>::type>;
    lifetime_->state()->register_request_handler(
        Method::id(), std::make_shared<handler_type>(std::move(callback)));
    return *this;
  }

  /**
   * @brief Detaches and preserves this session for a later resume().
   * @note This closes the current client connection and cancels its pending
   * operations. The returned token is the only way to resume the retained
   * reliable queue.
   */
  ntl::rpc::session_token preserve_session() {
    if (!lifetime_)
      throw std::logic_error("NTL minifilter client has no session");
    const auto current = lifetime_->state()->session();
    if (!current.valid())
      throw std::logic_error("NTL minifilter client has no session");
    lifetime_->state()->preserve_session();
    return current.token;
  }

  /** @brief Queries immutable wire and application contract metadata. */
  communication_contract_info query_contract() const {
    const auto request = detail::make_port_request(
        detail::communication_operation::query_contract, 0, nullptr, 0);
    std::vector<unsigned char> output(ntl::rpc::contract_response_size);
    DWORD returned = 0;
    detail::send_port_message(port_, request, output.data(),
                              static_cast<DWORD>(output.size()), returned);
    if (returned > output.size())
      throw std::runtime_error(
          "NTL minifilter returned invalid contract metadata");
    output.resize(returned);
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), ntl::rpc::default_decode_allocation);
    communication_contract_info info;
    archive(info);
    if (archive.offset() != output.size())
      throw std::runtime_error(
          "NTL minifilter contract contains trailing bytes");
    const auto &members = info.members();
    if (!std::is_sorted(
            members.begin(), members.end(),
            [](const communication_contract_member &left,
               const communication_contract_member &right) {
              return left.id < right.id ||
                     (left.id == right.id &&
                      static_cast<std::uint16_t>(left.kind) <
                          static_cast<std::uint16_t>(right.kind));
            }) ||
        std::adjacent_find(
            members.begin(), members.end(),
            [](const communication_contract_member &left,
               const communication_contract_member &right) {
              return left.id == right.id && left.kind == right.kind;
            }) != members.end() ||
        info.schema_hash() != communication_schema_hash(members))
      throw std::runtime_error(
          "NTL minifilter contract has invalid schema metadata");
    return info;
  }

  /** @brief Verifies one app-to-driver method and all advertised limits. */
  template <typename Method> void require_method(const Method &method) const {
    require_method_definition(method,
                              communication_member_kind::app_to_driver_method);
  }

  /** @brief Verifies one driver-to-app method and all advertised limits. */
  template <typename Method>
  void require_client_method(const Method &method) const {
    require_method_definition(method,
                              communication_member_kind::driver_to_app_method);
  }

  /** @brief Verifies one reliable/best-effort notification channel. */
  template <typename Notification>
  void require_notification(const Notification &) const {
    static_assert(ntl::rpc::is_notification<Notification>::value,
                  "require_notification requires a notification");
    const auto &info = contract_for_validation();
    const auto *member =
        info.find(Notification::id(), communication_member_kind::notification);
    if (!member || member->response_size != Notification::response_size() ||
        member->decode_allocation != Notification::decode_allocation() ||
        member->max_batch_records != Notification::max_batch_records() ||
        member->priority !=
            static_cast<std::uint32_t>(Notification::priority()) ||
        member->schema_hash != Notification::schema_hash())
      throw std::runtime_error("NTL minifilter notification contract mismatch");
  }

  /** @brief Verifies one bidirectional stream and all advertised limits. */
  template <typename Stream> void require_stream(const Stream &) const {
    static_assert(ntl::rpc::is_stream<Stream>::value,
                  "require_stream requires a stream");
    const auto &info = contract_for_validation();
    const auto *member =
        info.find(Stream::id(), communication_member_kind::stream);
    if (!member || member->request_size != Stream::upload_size() ||
        member->response_size != Stream::download_size() ||
        member->decode_allocation != Stream::decode_allocation() ||
        member->max_batch_records != Stream::max_batch_records() ||
        member->priority != static_cast<std::uint32_t>(Stream::priority()) ||
        member->schema_hash != Stream::schema_hash())
      throw std::runtime_error("NTL minifilter stream contract mismatch");
  }

  /** @brief Rejects an incompatible protocol, version, or capability set. */
  void require_contract(std::uint32_t contract_version,
                        std::uint64_t capabilities = 0) const {
    const auto &info = contract_for_validation();
    if (info.protocol_version() != detail::communication_version)
      throw std::runtime_error("NTL minifilter protocol version mismatch");
    if (info.contract_version() != contract_version)
      throw std::runtime_error("NTL minifilter contract version mismatch");
    if ((info.capability_mask() & capabilities) != capabilities)
      throw std::runtime_error("NTL minifilter capabilities are unavailable");
  }

  /** @brief Waits synchronously for one best-effort typed notification. */
  template <typename Notification>
  typename Notification::payload_type
  receive(const Notification &channel) const {
    return receive_async(channel).get();
  }

  /** @brief Starts a cancellable best-effort notification receive. */
  template <typename Notification>
  communication_notification_wait<typename Notification::payload_type, false>
  receive_async(const Notification &) const {
    static_assert(
        ntl::rpc::is_notification<Notification>::value,
        "communication_client::receive_async requires a notification");
    return submit_receive<Notification, false>(
        detail::communication_inbound_kind::notification, false);
  }

  /** @brief Waits for one sequence-numbered replayable notification. */
  template <typename Notification>
  ntl::rpc::notification_delivery<typename Notification::payload_type>
  receive_reliable(const Notification &channel) const {
    return receive_reliable_async(channel).get();
  }

  /** @brief Starts a cancellable replayable notification receive. */
  template <typename Notification>
  communication_notification_wait<typename Notification::payload_type, true>
  receive_reliable_async(const Notification &) const {
    static_assert(ntl::rpc::is_notification<Notification>::value,
                  "receive_reliable_async requires a notification");
    return submit_receive<Notification, true>(
        detail::communication_inbound_kind::reliable_notification, false);
  }

  /** @brief Waits for one bounded batch from a reliable channel. */
  template <typename Notification>
  ntl::rpc::notification_batch<typename Notification::payload_type>
  receive_reliable_batch(const Notification &channel) const {
    return receive_reliable_batch_async(channel).get();
  }

  /** @brief Starts a cancellable bounded reliable-channel batch receive. */
  template <typename Notification>
  communication_batch_wait<typename Notification::payload_type>
  receive_reliable_batch_async(const Notification &) const {
    static_assert(ntl::rpc::is_notification<Notification>::value,
                  "receive_reliable_batch_async requires a notification");
    return submit_batch<Notification>(false);
  }

#if NTL_FLT_HAS_STOP_TOKEN
  /** @brief Binds a best-effort notification receive to a stop token. */
  template <typename Notification>
  communication_notification_wait<typename Notification::payload_type, false>
  receive_async(std::stop_token token, const Notification &channel) const {
    auto wait = receive_async(channel);
    attach_receive_stop(token, wait.state_);
    return wait;
  }

  /** @brief Binds a reliable notification receive to a stop token. */
  template <typename Notification>
  communication_notification_wait<typename Notification::payload_type, true>
  receive_reliable_async(std::stop_token token,
                         const Notification &channel) const {
    auto wait = receive_reliable_async(channel);
    attach_receive_stop(token, wait.state_);
    return wait;
  }

  /** @brief Binds a reliable batch receive to a stop token. */
  template <typename Notification>
  communication_batch_wait<typename Notification::payload_type>
  receive_reliable_batch_async(std::stop_token token,
                               const Notification &channel) const {
    auto wait = receive_reliable_batch_async(channel);
    attach_receive_stop(token, wait.state_);
    return wait;
