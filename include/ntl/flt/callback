/** @brief Typed pre-operation callback used by registration::on(). */
template <operation_id Operation>
using pre_operation_callback =
    pre_result (*)(detail::callback_data_impl<Operation> data,
                   related_objects objects, void *&completion_context) noexcept;

/**
 * @brief Context-free pre-operation callback for normal-completion-only use.
 *
 * Pair this callback with normal_post_operation_callback. Because no native
 * CompletionContext is exposed, NTL can safely omit the post callback while
 * Filter Manager is draining the instance.
 */
template <operation_id Operation>
using normal_pre_operation_callback =
    pre_result (*)(detail::callback_data_impl<Operation> data,
                   related_objects objects) noexcept;

/** @brief Typed post-operation callback used by registration::on(). */
template <operation_id Operation>
using post_operation_callback = post_result (*)(
    detail::callback_data_impl<Operation> data, related_objects objects,
    void *completion_context, post_operation_flags flags) noexcept;

/**
 * @brief Post-operation callback invoked only after normal I/O completion.
 *
 * NTL does not invoke this callback when FLTFL_POST_OPERATION_DRAINING is set.
 * It always returns FLT_POSTOP_FINISHED_PROCESSING to Filter Manager after the
 * callback returns. Use post_operation_callback when draining or pending
 * completion must be handled explicitly.
 */
template <operation_id Operation>
using normal_post_operation_callback =
    void (*)(detail::callback_data_impl<Operation> data,
             related_objects objects) noexcept;

/**
 * @brief Normal-completion post work that may request a safe continuation.
 *
 * NTL does not invoke this callback while the instance drains. Return
 * post_continuation::when_safe to run the paired normal_safe_post_callback at
 * IRQL <= APC_LEVEL, or post_continuation::finished when no safe work remains.
 */
template <operation_id Operation>
using normal_immediate_post_operation_callback =
    post_continuation (*)(detail::callback_data_impl<Operation> data,
                          related_objects objects) noexcept;

/** @brief Flags-less safe continuation invoked at IRQL <= APC_LEVEL. */
template <operation_id Operation>
using normal_safe_post_operation_callback =
    void (*)(detail::callback_data_impl<Operation> data,
             related_objects objects) noexcept;

/** @brief Pre-operation callback that constructs typed completion state. */
template <operation_id Operation, class Completion>
using completion_pre_operation_callback = pre_result (*)(
    detail::callback_data_impl<Operation> data, related_objects objects,
    completion_slot<Completion> &completion) noexcept;

/**
 * @brief Typed post callback invoked only for a normally completed operation.
 *
 * NTL destroys the completion state after this callback. During draining the
 * callback is skipped and the state is destroyed directly.
 */
template <operation_id Operation, class Completion>
using normal_completion_post_operation_callback = void (*)(
    detail::callback_data_impl<Operation> data, related_objects objects,
    completion_ref<Completion> completion) noexcept;

/**
 * @brief Typed post callback that also receives draining notifications.
 *
 * NTL destroys the completion state after this callback returns. The callback
 * must perform only cleanup and return promptly when flags.draining() is true.
 */
template <operation_id Operation, class Completion>
using draining_completion_post_operation_callback = void (*)(
    detail::callback_data_impl<Operation> data, related_objects objects,
    completion_ref<Completion> completion, post_operation_flags flags) noexcept;

/**
 * @brief Typed normal-completion work that may request a safe continuation.
 *
 * The completion view remains valid through the paired safe callback. NTL
 * destroys the state after immediate completion, after safe completion, or
 * directly if safe processing cannot be scheduled.
 */
template <operation_id Operation, class Completion>
using normal_completion_immediate_post_operation_callback =
    post_continuation (*)(detail::callback_data_impl<Operation> data,
                          related_objects objects,
                          completion_ref<Completion> completion) noexcept;

/** @brief Typed safe continuation invoked at IRQL <= APC_LEVEL. */
template <operation_id Operation, class Completion>
using normal_completion_safe_post_operation_callback = void (*)(
    detail::callback_data_impl<Operation> data, related_objects objects,
    completion_ref<Completion> completion) noexcept;

/**
 * @brief Immediate portion of a mixed direct/safe post-operation callback.
 *
 * This callback runs first under the native post-operation IRQL contract.
 * Return post_continuation::when_safe only when the registered safe callback
 * must run. Return post_continuation::finished after completing all work or
 * when no safe continuation is needed.
 */
template <operation_id Operation>
using immediate_post_operation_callback = post_continuation (*)(
    detail::callback_data_impl<Operation> data, related_objects objects,
    void *completion_context, post_operation_flags flags) noexcept;

/**
 * @brief Post-operation work that NTL dispatches through
 * FltDoCompletionProcessingWhenSafe.
 *
 * The callback runs at IRQL <= APC_LEVEL and cannot request another pending
 * completion. NTL resumes completion processing after it returns.
 */
template <operation_id Operation>
using safe_post_operation_callback =
    void (*)(detail::callback_data_impl<Operation> data,
             related_objects objects, void *completion_context) noexcept;

} // namespace ntl::flt
