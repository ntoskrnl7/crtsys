template <typename Tag> struct operation_tag_traits;

template <operation_id Operation>
struct operation_tag_traits<operation_tag<Operation>> {
  static constexpr operation_id value = Operation;
};

template <operation_id Operation>
struct operation_tag_traits<read_write_operation_tag<Operation>> {
  static constexpr operation_id value = Operation;
};

/**
 * @brief Non-owning mutable callback data for exactly one major operation.
 * @tparam Operation Major operation selected by registration::on().
 *
 * The operation is part of the C++ type. parameters() therefore exposes only
 * the FLT_PARAMETERS member valid for that registration.
 */
template <operation_id Operation> class callback_data_impl {
public:
  /** @brief Parameter view associated with this callback operation. */
  using parameters_type = operation_parameters_t<Operation>;

  /** @brief Compile-time operation identifier. */
  static constexpr operation_id operation = Operation;

  /** @brief Wraps callback data owned by Filter Manager. */
  explicit callback_data_impl(PFLT_CALLBACK_DATA value) noexcept
      : value_(value) {}

  /** @brief Returns the operation selected by registration::on(). */
  constexpr operation_id major_function() const noexcept { return Operation; }

  /** @brief Returns the native minor-function identifier. */
  UCHAR minor_function() const noexcept {
    return value_ && value_->Iopb ? value_->Iopb->MinorFunction : 0xff;
  }

  /** @brief Returns the IRP flags copied into the Filter Manager IOPB. */
  ULONG irp_flags() const noexcept {
    return value_ && value_->Iopb ? value_->Iopb->IrpFlags : 0;
  }

  /** @brief Returns the operation-specific SL_* flags. */
  UCHAR operation_flags() const noexcept {
    return value_ && value_->Iopb ? value_->Iopb->OperationFlags : 0;
  }

  /** @brief Returns the target kernel FILE_OBJECT facade. */
  ntl::file target_file() const noexcept {
    return ntl::file{value_ && value_->Iopb ? value_->Iopb->TargetFileObject
                                            : nullptr};
  }

  /** @brief Returns the minifilter instance receiving this operation. */
  flt::instance target_instance() const noexcept {
    return flt::instance{value_ && value_->Iopb ? value_->Iopb->TargetInstance
                                                : nullptr};
  }

  /** @brief Returns the requestor processor mode. */
  KPROCESSOR_MODE requestor_mode() const noexcept {
    return value_ ? value_->RequestorMode : KernelMode;
  }

  /** @brief Returns true for an IRP-based operation. */
  bool is_irp_operation() const noexcept {
    return value_ && FLT_IS_IRP_OPERATION(value_);
  }

  /** @brief Returns true for a fast-I/O operation. */
  bool is_fast_io_operation() const noexcept {
    return value_ && FLT_IS_FASTIO_OPERATION(value_);
  }

  /** @brief Returns true for a file-system-filter callback operation. */
  bool is_fsfilter_operation() const noexcept {
    return value_ && FLT_IS_FS_FILTER_OPERATION(value_);
  }

  /** @brief Returns the current I/O completion status. */
  ntl::status io_status() const noexcept {
    return value_ ? value_->IoStatus.Status : STATUS_INVALID_PARAMETER;
  }

  /** @brief Returns the current I/O completion information value. */
  ULONG_PTR information() const noexcept {
    return value_ ? value_->IoStatus.Information : 0;
  }

  /**
   * @brief Updates the operation's native I/O completion result.
   *
   * This is valid in both pre-operation completion and post-operation failure
   * paths. It does not dirty operation parameters.
   */
  void set_io_status(ntl::status value,
                     ULONG_PTR information = 0) noexcept {
    if (!value_)
      return;
    value_->IoStatus.Status = value;
    value_->IoStatus.Information = information;
  }

  /**
   * @brief Completes the operation in a pre-operation callback.
   * @param value Completion status.
   * @param information Operation-specific completion information.
   *
   * Return pre_result::complete from the callback after calling this method.
   */
  void complete(ntl::status value, ULONG_PTR information = 0) noexcept {
    set_io_status(value, information);
  }

  /** @brief Marks native I/O parameter modifications as dirty. */
  void mark_dirty() noexcept {
    if (value_)
      FltSetCallbackDataDirty(value_);
  }

  /**
   * @brief Queries cached Filter Manager name information.
   * @param options FLT_FILE_NAME_* format and query-method flags.
   * @return Owned name information, or the Filter Manager failure status.
   * @note Call only where FltGetFileNameInformation is legal, normally at
   * IRQL <= APC_LEVEL. The returned owner releases the reference.
   */
  ntl::result<name_information>
  try_query_name(FLT_FILE_NAME_OPTIONS options) const noexcept {
    if (!value_)
      return ntl::unexpected(STATUS_INVALID_PARAMETER);

    PFLT_FILE_NAME_INFORMATION information = nullptr;
    const NTSTATUS result =
        FltGetFileNameInformation(value_, options, &information);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(name_information{information});
  }

  /**
   * @brief Returns the only parameter view legal for this callback type.
   *
   * A create callback returns create_parameters, a write callback returns
   * write_parameters, and no read/write/create cross-accessor exists.
   */
  parameters_type parameters() const noexcept {
    return parameters_type{value_};
  }

  /**
   * @brief Returns the native Filter Manager I/O parameter block.
   * @note This explicit escape hatch bypasses compile-time union selection.
   */
  PFLT_IO_PARAMETER_BLOCK native_iopb() const noexcept {
    return value_ ? value_->Iopb : nullptr;
  }

  /** @brief Returns the native callback-data pointer. */
  PFLT_CALLBACK_DATA native() const noexcept { return value_; }

private:
  PFLT_CALLBACK_DATA value_ = nullptr;
};

template <const auto &Operation>
inline constexpr operation_id operation_value_v = operation_tag_traits<
    std::remove_cv_t<std::remove_reference_t<decltype(Operation)>>>::value;

} // namespace detail

