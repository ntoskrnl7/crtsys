#pragma once

#ifndef _NTDDK_
#include <wdm.h>
#endif

#include <mutex>

namespace ntl {
namespace detail {
namespace spin_lock {
extern NPAGED_LOOKASIDE_LIST lookaside;
}
} // namespace detail

/**
 * @brief std::mutex-compatible wrapper over KSPIN_LOCK.
 */
class spin_lock {
public:
  /**
   * @brief Allocates and initializes a KSPIN_LOCK.
   */
  spin_lock() {
    lock_ = reinterpret_cast<PKSPIN_LOCK>(
        ExAllocateFromNPagedLookasideList(&ntl::detail::spin_lock::lookaside));
    KeInitializeSpinLock(lock_);
  }
  /**
   * @brief Frees the backing KSPIN_LOCK storage.
   */
  ~spin_lock() {
    if (lock_)
      ExFreeToNPagedLookasideList(&ntl::detail::spin_lock::lookaside, lock_);
  }
  spin_lock(const spin_lock &) = delete;
  spin_lock &operator=(const spin_lock &) = delete;

  /**
   * @brief Attempts to acquire the spin lock.
   */
  _NODISCARD bool try_lock() {
    KIRQL old_irql = PASSIVE_LEVEL;
    KeRaiseIrql(DISPATCH_LEVEL, &old_irql);
    if (KeTryToAcquireSpinLockAtDpcLevel(lock_) == TRUE) {
      old_irql_ = old_irql;
      acquired_at_dpc_level_ = false;
      return true;
    }
    KeLowerIrql(old_irql);
    return false;
  }

  /**
   * @brief Acquires the spin lock and raises IRQL as required by WDK.
   */
  void lock() {
    KeAcquireSpinLock(lock_, &old_irql_);
    acquired_at_dpc_level_ = false;
  }
  /**
   * @brief Releases the spin lock and restores the saved IRQL.
   */
  void unlock() {
    if (acquired_at_dpc_level_) {
      unlock_from_dpc_level();
      return;
    }
    KeReleaseSpinLock(lock_, old_irql_);
  }

  /**
   * @brief Acquires the spin lock when already running at DISPATCH_LEVEL.
   */
  void lock_at_dpc_level() {
    KeAcquireSpinLockAtDpcLevel(lock_);
    acquired_at_dpc_level_ = true;
  }
  /**
   * @brief Releases a spin lock acquired at DISPATCH_LEVEL.
   */
  void unlock_from_dpc_level() {
    KeReleaseSpinLockFromDpcLevel(lock_);
    acquired_at_dpc_level_ = false;
  }

  /**
   * @brief Tests whether the spin lock appears available.
   */
  bool test() { return KeTestSpinLock(lock_); }

  using native_handle_type = PKSPIN_LOCK;

  /**
   * @brief Returns the native KSPIN_LOCK pointer.
   */
  _NODISCARD native_handle_type native_handle() { return lock_; }

private:
  PKSPIN_LOCK lock_ = nullptr;
  KIRQL old_irql_ = PASSIVE_LEVEL;
  bool acquired_at_dpc_level_ = false;
};

struct at_dpc_level_lock_t {
  /**
   * @brief Tag type for constructing a lock guard at DISPATCH_LEVEL.
   */
  explicit at_dpc_level_lock_t() = default;
};

inline constexpr at_dpc_level_lock_t at_dpc_level_lock{};

template <class Lockable> class unique_lock;

template <> class unique_lock<spin_lock> : public std::unique_lock<spin_lock> {
public:
  using lock_type = spin_lock;
  using type = std::unique_lock<lock_type>;
  using type::type;

  /**
   * @brief Creates an empty spin-lock guard.
   */
  unique_lock() noexcept : lockable_(nullptr), owns_(false) {}

  /**
   * @brief Acquires a spin lock.
   */
  explicit unique_lock(lock_type &lockable)
      : lockable_(_STD addressof(lockable)),
        owns_(false) { // construct and lock
    lockable_->lock();
    owns_ = true;
  }

  /**
   * @brief Adopts an already-acquired spin lock.
   */
  unique_lock(lock_type &lockable, std::adopt_lock_t)
      : std::unique_lock<lock_type>(lockable, std::adopt_lock),
        lockable_(nullptr), owns_(false) {
  } // construct and assume already locked

  /**
   * @brief Creates a guard without acquiring the spin lock.
   */
  unique_lock(lock_type &lockable, std::defer_lock_t) noexcept
      : std::unique_lock<lock_type>(lockable, std::defer_lock),
        lockable_(nullptr), owns_(false) {} // construct but don't lock

  /**
   * @brief Attempts to acquire the spin lock.
   */
  unique_lock(lock_type &lockable, std::try_to_lock_t)
      : std::unique_lock<lock_type>(lockable, std::try_to_lock),
        lockable_(nullptr), owns_(false) {} // construct and try to lock

  /**
   * @brief Acquires a spin lock while already at DISPATCH_LEVEL.
   */
  unique_lock(lock_type &lockable, at_dpc_level_lock_t)
      : std::unique_lock<lock_type>(lockable, std::defer_lock),
        lockable_(std::addressof(lockable)), owns_(false) {
    lockable.lock_at_dpc_level();
    owns_ = true;
  } // construct and lock at dpc

  /**
   * @brief Move-assigns lock ownership.
   */
  unique_lock &operator=(unique_lock &&other) {
    if (this != _STD addressof(other)) {
      if (owns_)
        lockable_->unlock();
      else if (std::unique_lock<lock_type>::owns_lock())
        std::unique_lock<lock_type>::unlock();
      lockable_ = other.lockable_;
      owns_ = other.owns_;
      other.lockable_ = nullptr;
      other.owns_ = false;
      std::unique_lock<lock_type>::operator=(
          std::forward<std::unique_lock<lock_type>>(other));
    }
    return *this;
  }

  /**
   * @brief Releases the owned spin lock.
   */
  ~unique_lock() noexcept {
    if (owns_)
      lockable_->unlock();
  }

  unique_lock(const unique_lock &) = delete;
  unique_lock &operator=(const unique_lock &) = delete;

  /**
   * @brief Returns true when this guard owns the lock.
   */
  _NODISCARD bool owns_lock() const noexcept {
    if (owns_)
      return true;
    return type::owns_lock();
  }

  /**
   * @brief Returns true when this guard owns the lock.
   */
  explicit operator bool() const noexcept {
    if (owns_)
      return true;
    return type::owns_lock();
  }

private:
  bool owns_;
  lock_type *lockable_;
};
} // namespace ntl
