#include "except"
#include "pool_allocator"

#include <cstddef>
#include <memory>
#include <new>
#include <type_traits>
#include <utility>

namespace ntl {
namespace detail {

constexpr bool lookaside_options_supported(pool_option options) noexcept {
  return !has_pool_option(options, pool_option::use_quota) &&
         !has_pool_option(options, pool_option::uninitialized) &&
         !has_pool_option(options, pool_option::session) &&
         !has_pool_option(options, pool_option::special_pool);
}

constexpr POOL_TYPE to_lookaside_pool_type(pool_kind kind,
                                           pool_option options) noexcept {
  const bool cache_aligned =
      has_pool_option(options, pool_option::cache_aligned);

  switch (kind) {
  case pool_kind::nonpaged:
    return cache_aligned ? NonPagedPoolNxCacheAligned : NonPagedPoolNx;
  case pool_kind::paged:
    return cache_aligned ? PagedPoolCacheAligned : PagedPool;
  case pool_kind::nonpaged_execute:
    return cache_aligned ? NonPagedPoolCacheAligned : NonPagedPoolExecute;
  }

  return NonPagedPoolNx;
}

constexpr ULONG to_lookaside_flags(pool_option options) noexcept {
  return has_pool_option(options, pool_option::raise_on_failure)
             ? EX_LOOKASIDE_LIST_EX_FLAGS_RAISE_ON_FAIL
             : 0;
}

constexpr bool lookaside_depth_supported(USHORT depth) noexcept {
  return depth == 0 ||
         (depth >= EX_MAXIMUM_LOOKASIDE_DEPTH_BASE &&
          depth <= EX_MAXIMUM_LOOKASIDE_DEPTH_LIMIT);
}

} // namespace detail

/**
 * @brief Fixed-size object cache backed by LOOKASIDE_LIST_EX.
 * @tparam T Cached object type.
 * @tparam Kind Pool kind used for backing allocations.
 * @tparam Options Supported pool options for the lookaside list.
 * @tparam Tag Native pool tag.
 */
template <class T, pool_kind Kind = pool_kind::nonpaged,
          pool_option Options = pool_option::none,
          ULONG Tag = default_pool_tag>
class lookaside_list {
  static_assert(!std::is_void<T>::value,
                "ntl::lookaside_list<T> requires an object type");
  static_assert(!std::is_array<T>::value,
                "ntl::lookaside_list<T> does not manage arrays");
  static_assert(alignof(T) <= MEMORY_ALLOCATION_ALIGNMENT,
                "ntl::lookaside_list supports WDK pool alignment only");
  static_assert(detail::lookaside_options_supported(Options),
                "ntl::lookaside_list supports only none, cache_aligned, and "
                "raise_on_failure options");

public:
  /**
   * @brief Deleter that returns objects to their owning lookaside list.
   */
  class deleter {
  public:
    /**
     * @brief Creates an empty deleter.
     */
    constexpr deleter() noexcept : list_(nullptr) {}
    /**
     * @brief Creates a deleter bound to a lookaside list.
     */
    explicit constexpr deleter(lookaside_list &list) noexcept : list_(&list) {}

    /**
     * @brief Destroys and returns an object to the owning lookaside list.
     */
    void operator()(T *pointer) const noexcept {
      if (pointer && list_) {
        list_->destroy(pointer);
      }
    }

  private:
    lookaside_list *list_;
  };

  /**
   * @brief Unique pointer type that returns objects to this lookaside list.
   */
  using pointer = std::unique_ptr<T, deleter>;

  /**
   * @brief Initializes the lookaside list.
   * @param depth Optional WDK lookaside depth, or 0 for the system default.
   */
  explicit lookaside_list(USHORT depth = 0) {
    if (!detail::lookaside_depth_supported(depth)) {
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "lookaside depth must be 0 or within the WDK "
                           "EX_MAXIMUM_LOOKASIDE_DEPTH range.");
    }

    const NTSTATUS status = ExInitializeLookasideListEx(
        &list_, nullptr, nullptr,
        detail::to_lookaside_pool_type(Kind, Options),
        detail::to_lookaside_flags(Options), sizeof(T), Tag, depth);
    if (!NT_SUCCESS(status)) {
      throw ntl::exception(status, "ExInitializeLookasideListEx failed.");
    }
  }

  /**
   * @brief Deletes the lookaside list.
   */
  ~lookaside_list() { ExDeleteLookasideListEx(&list_); }

  lookaside_list(const lookaside_list &) = delete;
  lookaside_list &operator=(const lookaside_list &) = delete;
  lookaside_list(lookaside_list &&) = delete;
  lookaside_list &operator=(lookaside_list &&) = delete;

  /**
   * @brief Allocates raw storage for one T from the lookaside list.
   */
  [[nodiscard]] T *allocate() noexcept {
    return static_cast<T *>(ExAllocateFromLookasideListEx(&list_));
  }

  /**
   * @brief Returns raw storage to the lookaside list.
   */
  void free(T *pointer) noexcept {
    if (pointer) {
      ExFreeToLookasideListEx(&list_, pointer);
    }
  }

  /**
   * @brief Constructs T in lookaside storage and returns an RAII pointer.
   */
  template <class... Args> [[nodiscard]] pointer make(Args &&...args) {
    T *const storage = allocate();
    if (!storage) {
      throw std::bad_alloc();
    }

    try {
      return pointer{new (storage) T(std::forward<Args>(args)...),
                     deleter{*this}};
    } catch (...) {
      free(storage);
      throw;
    }
  }

  /**
   * @brief Destroys T and returns its storage to the lookaside list.
   */
  void destroy(T *pointer) noexcept {
    if (!pointer) {
      return;
    }

    pointer->~T();
    free(pointer);
  }

  /**
   * @brief Flushes cached entries from the lookaside list.
   */
  void flush() noexcept { ExFlushLookasideListEx(&list_); }

  /**
   * @brief Returns the native LOOKASIDE_LIST_EX pointer.
   */
  LOOKASIDE_LIST_EX *native_handle() noexcept { return &list_; }
  /**
   * @brief Returns the native LOOKASIDE_LIST_EX pointer.
   */
  const LOOKASIDE_LIST_EX *native_handle() const noexcept { return &list_; }

  /**
   * @brief Returns the pool kind encoded in this lookaside list type.
   */
  static constexpr pool_kind kind() noexcept { return Kind; }
  /**
   * @brief Returns the pool options encoded in this lookaside list type.
   */
  static constexpr pool_option options() noexcept { return Options; }
  /**
   * @brief Returns the pool tag encoded in this lookaside list type.
   */
  static constexpr ULONG tag() noexcept { return Tag; }

private:
  LOOKASIDE_LIST_EX list_{};
};

} // namespace ntl
