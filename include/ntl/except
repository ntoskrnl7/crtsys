#pragma once

#include "status"

#include <exception>
#include <ntstatus.h>
#include <string>
#include <tuple>
#include <utility>

namespace ntl {
/**
 * @brief C++ exception type carrying an NTSTATUS value.
 */
class exception : public std::exception {
public:
  /**
   * @brief Creates an exception from a native NTSTATUS value.
   */
  explicit exception(NTSTATUS status, const std::string &message)
      : status_(status), message_(message) {}
  /**
   * @brief Creates an exception from an ntl::status value.
   */
  explicit exception(status status, const std::string &message)
      : status_(status), message_(message) {}

  /**
   * @brief Returns the stored NTSTATUS wrapper.
   */
  const status &get_status() const { return status_; }
  /**
   * @brief Returns the diagnostic message.
   */
  const char *what() const noexcept override { return message_.c_str(); }

private:
  status status_;
  std::string message_;
};

namespace seh {
/**
 * @brief Executes a callable under __try/__except.
 * @param f Callable to execute.
 * @param args Arguments forwarded to the callable.
 * @return {true, 0} on normal completion, or {false, exception_code}.
 */
template <class Fn, class... Args>
inline std::tuple<bool, unsigned long> try_except(Fn &&f, Args &&... args) {
  auto code = [&]() -> unsigned long {
    __try {
      f(std::forward<Args>(args)...);
    } __except (EXCEPTION_EXECUTE_HANDLER) {
      return GetExceptionCode();
    }
    return 0;
  }();
  if (code)
    return {false, code};
  return {true, 0};
}
} // namespace seh
} // namespace ntl
