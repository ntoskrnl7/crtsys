/** @brief Describes whether the NTL dispatcher must complete an IRP. */
enum class dispatch_result {
  complete,
  pending,
};

/**
 * @brief Decodes a CTL_CODE value passed to an IRP_MJ_DEVICE_CONTROL handler.
 */
struct code {
  /**
   * @brief Wraps a native CTL_CODE value.
   */
  code(ULONG code) : value(code) {}

  /**
   * @brief Returns the CTL_CODE device type field.
   */
  auto device_type() const { return DEVICE_TYPE_FROM_CTL_CODE(value); }
  /**
   * @brief Returns the CTL_CODE transfer method field.
   */
  auto method() const { return METHOD_FROM_CTL_CODE(value); }
  /**
   * @brief Returns the CTL_CODE function field.
   */
  auto function() const { return IoGetFunctionCodeFromCtlCode(value); }
  bool operator==(const code &rhs) const { return value == rhs.value; }
  bool operator==(ULONG rhs) const { return value == rhs; }
  bool operator==(int rhs) const { return value == static_cast<ULONG>(rhs); }

  ULONG value;
};

/**
 * @brief Read-only input buffer view for device-control dispatchers.
 */
struct in_buffer {
  /**
   * @brief Creates an input-buffer view.
   */
  in_buffer(const void *ptr, size_t size) : ptr(ptr), size(size) {}

  /**
   * @brief Returns true when at least bytes bytes are readable.
   */
  bool can_read(size_t bytes) const noexcept {
    return ptr != nullptr && size >= bytes;
  }

  /**
   * @brief Interprets the input as a trivially-copyable object if it fits.
   * @return Pointer to the object view, or nullptr when the buffer is too small.
   */
  template <class T> const T *as() const noexcept {
    static_assert(std::is_trivially_copyable<T>::value,
                  "ntl::device_control::in_buffer::as requires a "
                  "trivially-copyable type");
    if (!can_read(sizeof(T)))
      return nullptr;
    return reinterpret_cast<const T *>(ptr);
  }

  const void *ptr;
  size_t size;
};

/**
 * @brief Writable output buffer view for device-control dispatchers.
 */
struct out_buffer {
  /**
   * @brief Creates an output-buffer view.
   */
  out_buffer(void *ptr, size_t size) : ptr(ptr), size(size) {}

  /**
   * @brief Returns true when at least bytes bytes are writable.
   */
  bool can_write(size_t bytes) const noexcept {
    return ptr != nullptr && size >= bytes;
  }

  /**
   * @brief Clears the reported output size.
   */
  void clear() noexcept { size = 0; }

  /**
   * @brief Interprets the output as a trivially-copyable object if it fits.
   * @return Pointer to the object view, or nullptr when the buffer is too small.
   */
  template <class T> T *as() noexcept {
    static_assert(std::is_trivially_copyable<T>::value,
                  "ntl::device_control::out_buffer::as requires a "
                  "trivially-copyable type");
    if (!can_write(sizeof(T)))
      return nullptr;
    return reinterpret_cast<T *>(ptr);
  }

  /**
   * @brief Copies raw bytes into the output buffer and reports that byte count.
   * @return true when the bytes were copied; false when the buffer is too small.
   */
  bool write_bytes(const void *source, size_t bytes) noexcept {
    if (source == nullptr || !can_write(bytes)) {
      clear();
      return false;
    }
    std::memcpy(ptr, source, bytes);
    size = bytes;
    return true;
  }

  /**
   * @brief Writes a trivially-copyable object and reports sizeof(T) bytes.
   * @return true when the object was copied; false when the buffer is too small.
   */
  template <class T> bool write(const T &value) noexcept {
    static_assert(std::is_trivially_copyable<T>::value,
                  "ntl::device_control::out_buffer::write requires a "
                  "trivially-copyable type");
    return write_bytes(&value, sizeof(T));
  }

  void *ptr;
  size_t size;
};

using dispatch_fn = std::function<void(const device_control::code &,
                                       const device_control::in_buffer &,
                                       device_control::out_buffer &)>;

/**
 * @brief Advanced device-control callback that may retain an IRP.
 *
 * Returning pending transfers completion responsibility to the callback. The
 * callback must arrange exactly one later IoCompleteRequest call and keep all
 * METHOD_* buffers valid by retaining the IRP until that completion.
 */
using pending_dispatch_fn =
    std::function<dispatch_result(irp &, const device_control::code &,
                                  const device_control::in_buffer &,
                                  device_control::out_buffer &)>;
} // namespace device_control
} // namespace ntl

namespace ntl {
namespace detail {
namespace device {
struct dispatchers_t {
  create::dispatch_fn on_create;
  close::dispatch_fn on_close;
  cleanup::dispatch_fn on_cleanup;
  device_control::dispatch_fn on_device_control;
  device_control::pending_dispatch_fn on_pending_device_control;
};

template <typename Extension> struct extension_data_t;

template <> struct extension_data_t<void> { dispatchers_t dispatchers; };

template <typename Extension> struct extension_data_t {
  dispatchers_t dispatchers;
  Extension data;
};

template <typename T> class extension_t;

template <> class extension_t<void> {
public:
  extension_t() : device_(nullptr) {}
  extension_t(PDEVICE_OBJECT device) : device_(device) {}

  extension_data_t<void> *get_context() {
    return reinterpret_cast<extension_data_t<void> *>(device_->DeviceExtension);
  }

private:
  PDEVICE_OBJECT device_;
};

template <typename Extension> class extension_t {
public:
  extension_t() : device_(nullptr) {}
  extension_t(PDEVICE_OBJECT device) : device_(device) {}

  extension_data_t<Extension> *get_context() {
    return reinterpret_cast<extension_data_t<Extension> *>(
        device_->DeviceExtension);
  }

  Extension &extension() { return get_context()->data; }

private:
  PDEVICE_OBJECT device_;
};
} // namespace device
} // namespace detail

using device_type = DEVICE_TYPE;

class device_options {
  friend class driver;

public:
  /**
   * @brief Creates default FILE_DEVICE_UNKNOWN, non-exclusive options.
   */
  device_options() : type_(FILE_DEVICE_UNKNOWN), exclusive_(false) {}

  /**
   * @brief Sets the device name without the "\\Device\\" prefix.
   */
  device_options &name(const std::wstring &name) {
    name_ = name;
    return *this;
  }
  /**
   * @brief Sets the WDM device type.
   */
  device_options &type(device_type type) {
    type_ = type;
    return *this;
  }
  /**
   * @brief Sets whether the device is exclusive.
   */
  device_options &exclusive(bool exclusive = true) {
    exclusive_ = exclusive;
    return *this;
  }

  /**
   * @brief Returns the configured device name.
   */
  const std::wstring &name() const { return name_; }
  /**
   * @brief Returns the configured device type.
   */
  device_type type() const { return type_; }
  /**
   * @brief Returns whether the device is exclusive.
   */
  bool is_exclusive() const { return exclusive_; }

  /**
   * @brief Creates a named legacy/control device with an explicit ACL.
   * @param sddl SDDL string applied by IoCreateDeviceSecure.
   * @param class_guid Project-owned device setup class GUID.
   * @note Secure creation is valid only for named legacy/control devices or
   * raw PDOs. Do not use it to create a WDM FDO.
   */
  device_options &security_descriptor(const std::wstring &sddl,
                                      const GUID &class_guid) {
    security_descriptor_ = sddl;
    class_guid_ = class_guid;
    secure_ = true;
    return *this;
  }

  /** @brief Returns whether explicit secure device creation is enabled. */
  bool has_security_descriptor() const noexcept { return secure_; }

private:
  std::wstring name_;
  device_type type_;
  bool exclusive_;
  std::wstring security_descriptor_;
  GUID class_guid_{};
  bool secure_ = false;
};

/**
 * @brief Owns a WDM DEVICE_OBJECT and its C++ dispatch callbacks.
 * @tparam Extension Optional device extension payload type.
 */
template <typename Extension>
class device : public detail::device::extension_t<Extension> {
  friend class device_dispatch_invoker;
  friend class driver;

protected:
  device(PDEVICE_OBJECT device, const device_options &opts)
      : detail::device::extension_t<Extension>(device), object_(device),
        name_(opts.name()) {}

private:
  device(const device &) = delete;

public:
  /**
   * @brief Creates an empty device owner.
   */
  device() : object_(nullptr) {}

  /**
   * @brief Transfers device ownership from another object.
   */
  device(device &&other)
      : detail::device::extension_t<Extension>(other.object_) {
    *this = std::move(other);
  }

  /**
   * @brief Transfers device ownership from another object.
   */
  device &operator=(device &&rhs) {
    object_ = rhs.detach();
    name_.swap(rhs.name_);
    return *this;
  }

  /**
   * @brief Deletes the owned DEVICE_OBJECT.
   */
  ~device() {
    auto obj = detach();
    if (obj) {
      if (obj->DeviceExtension)
        detail::device::extension_t<Extension>::get_context()
            ->~extension_data_t();
      IoDeleteDevice(obj);
    }
  }

protected:
  detail::device::dispatchers_t &dispatchers() {
    return detail::device::extension_t<Extension>::get_context()->dispatchers;
  }

public:
  /**
   * @brief Registers an IRP_MJ_CREATE callback.
   */
  device &on_create(create::dispatch_fn &&f) {
    dispatchers().on_create = f;
    return *this;
  }

  /**
   * @brief Registers an IRP_MJ_CLOSE callback.
   */
  device &on_close(close::dispatch_fn &&f) {
    dispatchers().on_close = f;
    return *this;
  }

  /**
   * @brief Registers an IRP_MJ_CLEANUP callback.
   * @note Use this callback to release requests retained for one file object
   * before its final close dispatch.
   */
  device &on_cleanup(cleanup::dispatch_fn &&f) {
    dispatchers().on_cleanup = std::move(f);
    return *this;
  }

  /**
   * @brief Registers an IRP_MJ_DEVICE_CONTROL callback.
   */
  device &on_device_control(device_control::dispatch_fn &&f) {
    dispatchers().on_pending_device_control = {};
    dispatchers().on_device_control = f;
    return *this;
  }

  /**
   * @brief Registers an IRP_MJ_DEVICE_CONTROL callback that may pend requests.
   * @note This is a low-level ownership surface. Prefer a higher-level helper
   * such as ntl::rpc::server when possible.
   */
  device &on_pending_device_control(device_control::pending_dispatch_fn &&f) {
    dispatchers().on_device_control = {};
    dispatchers().on_pending_device_control = std::move(f);
    return *this;
  }

  /**
   * @brief Returns the NTL device name.
   */
  const std::wstring &name() const {
    if (!object_)
      throw std::runtime_error("invalid device object.");
    return name_;
  }

  /**
   * @brief Returns the native device type.
   */
  device_type type() const {
    if (!object_)
      throw std::runtime_error("invalid device object.");
    return object_->DeviceType;
  }

  /**
   * @brief Releases ownership of the native DEVICE_OBJECT.
   */
  PDEVICE_OBJECT detach() {
    return reinterpret_cast<PDEVICE_OBJECT>(
        InterlockedExchangePointer(reinterpret_cast<PVOID *>(&object_), NULL));
  }

private:
  PDEVICE_OBJECT object_;
  std::wstring name_;
};
} // namespace ntl
