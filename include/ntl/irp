#pragma once

#ifndef _NTDDK_
#include <wdm.h>
#endif

namespace ntl {
/**
 * @brief Non-owning view over a WDM IRP.
 */
class irp {
public:
  /**
   * @brief Wraps a native PIRP without taking ownership.
   */
  explicit irp(PIRP irp) noexcept : irp_(irp) {}

  /**
   * @brief Returns the native PIRP.
   */
  PIRP get() const noexcept { return irp_; }
  /**
   * @brief Returns the native PIRP.
   */
  PIRP operator->() const noexcept { return irp_; }

  /**
   * @brief Returns the current stack location.
   */
  PIO_STACK_LOCATION stack_location() const noexcept {
    return IoGetCurrentIrpStackLocation(irp_);
  }

  /**
   * @brief Returns the current major function.
   */
  UCHAR major_function() const noexcept {
    return stack_location()->MajorFunction;
  }

  /**
   * @brief Returns IoStatus.Status.
   */
  NTSTATUS status() const noexcept { return irp_->IoStatus.Status; }
  /**
   * @brief Sets IoStatus.Status.
   */
  void status(NTSTATUS value) noexcept { irp_->IoStatus.Status = value; }

  /**
   * @brief Returns IoStatus.Information.
   */
  ULONG_PTR information() const noexcept {
    return irp_->IoStatus.Information;
  }

  /**
   * @brief Sets IoStatus.Information.
   */
  void information(ULONG_PTR value) noexcept {
    irp_->IoStatus.Information = value;
  }

  /**
   * @brief Sets the IRP status and information fields together.
   * @param status_value NTSTATUS to return from the dispatch path.
   * @param information_value IoStatus.Information value for bytes/results.
   * @note This does not call IoCompleteRequest. The NTL dispatch invoker
   * completes the IRP after the registered callback returns.
   */
  void set_result(NTSTATUS status_value,
                  ULONG_PTR information_value = 0) noexcept {
    status(status_value);
    information(information_value);
  }

  /**
   * @brief Marks the IRP as successful.
   * @param information_value IoStatus.Information value for bytes/results.
   */
  void succeed(ULONG_PTR information_value = 0) noexcept {
    set_result(STATUS_SUCCESS, information_value);
  }

  /**
   * @brief Marks the IRP as failed and clears IoStatus.Information.
   * @param status_value Failure NTSTATUS to return from the dispatch path.
   */
  void fail(NTSTATUS status_value) noexcept { set_result(status_value, 0); }

private:
  PIRP irp_;
};
} // namespace ntl
