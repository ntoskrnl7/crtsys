/**
 * @brief Constructs an object in kernel pool and returns a pool_ptr.
 */
template <class T, class... Args>
[[nodiscard]] pool_ptr<T> make_pool(pool_kind kind, pool_option options,
                                    ULONG tag, Args &&...args) {
  static_assert(!std::is_void<T>::value,
                "ntl::make_pool<T> requires an object type");
  static_assert(!std::is_array<T>::value,
                "ntl::make_pool<T> does not construct arrays");
  static_assert(alignof(T) <= MEMORY_ALLOCATION_ALIGNMENT,
                "ntl::make_pool supports WDK pool alignment only");

  void *const storage =
      detail::allocate_pool_bytes(sizeof(T), alignof(T), kind, options, tag);
  if (!storage) {
    throw std::bad_alloc();
  }

  try {
    return pool_ptr<T>{new (storage) T(std::forward<Args>(args)...),
                       pool_deleter<T>{tag, kind}};
  } catch (...) {
    detail::free_pool_bytes(storage, kind, tag);
    throw;
  }
}

