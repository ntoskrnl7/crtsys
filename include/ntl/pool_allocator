 */
template <class T, std::size_t N, class... Args>
[[nodiscard]] ntl::result<pool_ptr<T>>
try_make_pool(pool_kind kind, const char (&tag)[N], Args &&...args) {
  return try_make_pool<T>(kind, pool_option::none, pool_tag(tag),
                          std::forward<Args>(args)...);
}

/**
 * @brief Constructs an object in nonpaged pool using a string-literal tag and
 * result.
 */
template <class T, std::size_t N, class... Args>
[[nodiscard]] ntl::result<pool_ptr<T>> try_make_pool(const char (&tag)[N],
                                                     Args &&...args) {
  return try_make_pool<T>(pool_kind::nonpaged, pool_option::none, pool_tag(tag),
                          std::forward<Args>(args)...);
}

/**
 * @brief STL allocator backed by WDK pool allocation APIs.
 * @tparam T Allocated object type.
 * @tparam Kind Pool kind used for allocations.
 * @tparam Options Pool allocation options.
 * @tparam Tag Native pool tag.
 */
template <class T, pool_kind Kind = pool_kind::nonpaged,
          pool_option Options = pool_option::none, ULONG Tag = default_pool_tag>
class pool_allocator {
public:
  using value_type = T;
  using size_type = std::size_t;
  using difference_type = std::ptrdiff_t;
  using propagate_on_container_move_assignment = std::true_type;
  using is_always_equal = std::true_type;

  template <class U> struct rebind {
    using other = pool_allocator<U, Kind, Options, Tag>;
  };

  /**
   * @brief Creates a stateless pool allocator.
   */
  pool_allocator() noexcept = default;

  /**
   * @brief Converts from another value_type with the same pool policy.
   */
  template <class U>
  pool_allocator(const pool_allocator<U, Kind, Options, Tag> &) noexcept {}

  /**
   * @brief Allocates storage for count objects.
   */
  [[nodiscard]] T *allocate(size_type count) {
    static_assert(alignof(T) <= MEMORY_ALLOCATION_ALIGNMENT,
                  "ntl::pool_allocator supports WDK pool alignment only");

    if (count > max_size()) {
      throw std::bad_array_new_length();
    }
    detail::diagnose_stl_pool_irql("STL pool allocation");

    void *const pointer = detail::allocate_pool_bytes(
        count * sizeof(T), alignof(T), Kind, Options, Tag);
    if (!pointer) {
      throw std::bad_alloc();
    }

    return static_cast<T *>(pointer);
  }

  /**
   * @brief Frees storage allocated by this allocator.
   */
  void deallocate(T *pointer, size_type) noexcept {
    detail::diagnose_stl_pool_irql("STL pool release");
    detail::free_pool_bytes(pointer, Kind, Tag);
  }

  /**
   * @brief Returns the largest count this allocator can request.
   */
  [[nodiscard]] constexpr size_type max_size() const noexcept {
    return (std::numeric_limits<size_type>::max)() / sizeof(T);
  }

  /**
   * @brief Returns the pool kind encoded in this allocator type.
   */
  static constexpr pool_kind kind() noexcept { return Kind; }
  /**
   * @brief Returns the pool options encoded in this allocator type.
   */
  static constexpr pool_option options() noexcept { return Options; }
  /**
   * @brief Returns the pool tag encoded in this allocator type.
   */
  static constexpr ULONG tag() noexcept { return Tag; }
};

/**
 * @brief Compares allocator policies.
 */
template <class T, class U, pool_kind LKind, pool_option LOptions, ULONG LTag,
          pool_kind RKind, pool_option ROptions, ULONG RTag>
constexpr bool
operator==(const pool_allocator<T, LKind, LOptions, LTag> &,
           const pool_allocator<U, RKind, ROptions, RTag> &) noexcept {
  return LKind == RKind && LOptions == ROptions && LTag == RTag;
}

/**
 * @brief Compares allocator policies.
 */
template <class T, class U, pool_kind LKind, pool_option LOptions, ULONG LTag,
          pool_kind RKind, pool_option ROptions, ULONG RTag>
constexpr bool
operator!=(const pool_allocator<T, LKind, LOptions, LTag> &lhs,
           const pool_allocator<U, RKind, ROptions, RTag> &rhs) noexcept {
  return !(lhs == rhs);
}

/**
 * @brief Convenience alias for nonpaged pool STL allocators.
 */
template <class T, ULONG Tag = default_pool_tag>
using nonpaged_pool_allocator =
    pool_allocator<T, pool_kind::nonpaged, pool_option::none, Tag>;

/**
 * @brief Convenience alias for paged pool STL allocators.
 */
template <class T, ULONG Tag = default_pool_tag>
using paged_pool_allocator =
    pool_allocator<T, pool_kind::paged, pool_option::none, Tag>;

namespace pmr {

/**
 * @brief PMR memory_resource backed by WDK pool allocation APIs.
 */
class pool_resource : public std::pmr::memory_resource {
public:
  /**
   * @brief Creates a PMR pool resource with a native pool tag.
   */
  explicit pool_resource(pool_kind kind = pool_kind::nonpaged,
                         pool_option options = pool_option::none,
                         ULONG tag = default_pool_tag) noexcept
      : kind_(kind), options_(options), tag_(tag) {}

  /**
   * @brief Creates a PMR pool resource with a string-literal tag.
   */
  template <std::size_t N>
  explicit pool_resource(pool_kind kind, pool_option options,
                         const char (&tag)[N]) noexcept
      : pool_resource(kind, options, pool_tag(tag)) {}

  /**
   * @brief Creates a PMR pool resource with no extra options.
   */
  template <std::size_t N>
  explicit pool_resource(pool_kind kind, const char (&tag)[N]) noexcept
      : pool_resource(kind, pool_option::none, pool_tag(tag)) {}

  /**
   * @brief Returns the pool kind used by this resource.
   */
  pool_kind kind() const noexcept { return kind_; }
  /**
   * @brief Returns the pool options used by this resource.
   */
  pool_option options() const noexcept { return options_; }
  /**
   * @brief Returns the pool tag used by this resource.
   */
  ULONG tag() const noexcept { return tag_; }

private:
  void *do_allocate(std::size_t bytes, std::size_t alignment) override {
    detail::diagnose_stl_pool_irql("PMR pool allocation");

    void *const pointer =
        detail::allocate_pool_bytes(bytes, alignment, kind_, options_, tag_);
    if (!pointer) {
      throw std::bad_alloc();
    }

    return pointer;
  }

  void do_deallocate(void *pointer, std::size_t, std::size_t) override {
    detail::diagnose_stl_pool_irql("PMR pool release");
    detail::free_pool_bytes(pointer, kind_, tag_);
  }

  bool
  do_is_equal(const std::pmr::memory_resource &other) const noexcept override {
    return this == &other;
  }

  pool_kind kind_;
  pool_option options_;
  ULONG tag_;
};

/**
 * @brief Returns a process-local nonpaged PMR pool resource.
 */
inline std::pmr::memory_resource *nonpaged_pool_resource() noexcept {
  static pool_resource resource{pool_kind::nonpaged};
  return &resource;
}

/**
 * @brief Returns a process-local paged PMR pool resource.
 */
inline std::pmr::memory_resource *paged_pool_resource() noexcept {
  static pool_resource resource{pool_kind::paged};
  return &resource;
}

