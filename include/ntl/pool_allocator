/**
 * @brief Deleter for pool_ptr and pool_buffer.
 * @tparam T Object type stored in pool.
 */
template <class T> class pool_deleter {
public:
  /**
   * @brief Creates a deleter that frees with a native pool tag.
   */
  constexpr pool_deleter(ULONG tag = default_pool_tag,
                         pool_kind kind = pool_kind::nonpaged) noexcept
      : tag_(tag), kind_(kind) {}

  /**
   * @brief Creates a deleter that frees with a string-literal tag.
   */
  template <std::size_t N>
  constexpr pool_deleter(const char (&tag)[N],
                         pool_kind kind = pool_kind::nonpaged) noexcept
      : tag_(pool_tag(tag)), kind_(kind) {}

  /**
   * @brief Destroys the object and frees its pool allocation.
   */
  void operator()(T *pointer) const noexcept {
    if (!pointer) {
      return;
    }
    if (!detail::validate_raw_pool_irql(kind_, "pool object destruction"))
      return;

    pointer->~T();
    detail::free_pool_bytes(pointer, kind_, tag_);
  }

  /**
   * @brief Returns the pool tag used for deallocation.
   */
  constexpr ULONG tag() const noexcept { return tag_; }
  /**
   * @brief Returns the pool kind used for deallocation.
   */
  constexpr pool_kind kind() const noexcept { return kind_; }

private:
  ULONG tag_;
  pool_kind kind_;
};

template <> class pool_deleter<void> {
public:
  /**
   * @brief Creates a byte-buffer deleter that frees with a native pool tag.
   */
  constexpr pool_deleter(ULONG tag = default_pool_tag,
                         pool_kind kind = pool_kind::nonpaged) noexcept
      : tag_(tag), kind_(kind) {}

  /**
   * @brief Creates a byte-buffer deleter that frees with a string-literal tag.
   */
  template <std::size_t N>
  constexpr pool_deleter(const char (&tag)[N],
                         pool_kind kind = pool_kind::nonpaged) noexcept
      : tag_(pool_tag(tag)), kind_(kind) {}

  /**
   * @brief Frees the raw pool allocation.
   */
  void operator()(void *pointer) const noexcept {
    detail::free_pool_bytes(pointer, kind_, tag_);
  }

  /**
   * @brief Returns the pool tag used for deallocation.
   */
  constexpr ULONG tag() const noexcept { return tag_; }
  /**
   * @brief Returns the pool kind used for deallocation.
   */
  constexpr pool_kind kind() const noexcept { return kind_; }

private:
  ULONG tag_;
  pool_kind kind_;
};

/**
 * @brief unique_ptr alias for objects allocated from kernel pool.
 */
template <class T> using pool_ptr = std::unique_ptr<T, pool_deleter<T>>;

/**
 * @brief unique_ptr alias for untyped pool buffers.
 */
using pool_buffer = pool_ptr<void>;

/**
 * @brief Allocates a raw byte buffer and returns it as RAII pool_buffer.
 */
inline pool_buffer make_pool_buffer(std::size_t bytes,
                                    pool_kind kind = pool_kind::nonpaged,
                                    pool_option options = pool_option::none,
                                    ULONG tag = default_pool_tag) noexcept {
  return pool_buffer{allocate_pool(bytes, kind, options, tag),
                     pool_deleter<void>{tag, kind}};
}

/**
 * @brief Allocates a raw byte buffer and returns NTSTATUS on allocation
 * failure.
 */
[[nodiscard]] inline ntl::result<pool_buffer>
try_make_pool_buffer(std::size_t bytes, pool_kind kind = pool_kind::nonpaged,
                     pool_option options = pool_option::none,
                     ULONG tag = default_pool_tag) noexcept {
  const auto irql_status = ntl::require_pool_irql(kind);
  if (!irql_status.is_ok())
    return ntl::unexpected(static_cast<NTSTATUS>(irql_status));

  void *const storage = allocate_pool(bytes, kind, options, tag);
  if (!storage)
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);

  return pool_buffer{storage, pool_deleter<void>{tag, kind}};
}

