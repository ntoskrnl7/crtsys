namespace ntl {

enum class pool_kind {
  /// NonPagedPoolNx on legacy WDKs, or POOL_FLAG_NON_PAGED with Pool2.
  nonpaged,
  /// PagedPool on legacy WDKs, or POOL_FLAG_PAGED with Pool2.
  paged,
  /// Executable nonpaged pool for code/data paths that explicitly require it.
  nonpaged_execute,
};

/**
 * @brief Returns the highest IRQL allowed by the native pool kind.
 */
inline KIRQL maximum_pool_irql(pool_kind kind) noexcept {
  return kind == pool_kind::paged ? APC_LEVEL : DISPATCH_LEVEL;
}

/**
 * @brief Returns whether raw allocation or release is legal at the current
 * IRQL for the selected pool kind.
 */
inline bool is_pool_irql_valid(pool_kind kind) noexcept {
  return KeGetCurrentIrql() <= maximum_pool_irql(kind);
}

/**
 * @brief Validates the native WDK IRQL contract for a pool kind.
 */
inline ntl::status require_pool_irql(pool_kind kind) noexcept {
  return is_pool_irql_valid(kind) ? ntl::status{STATUS_SUCCESS}
                                  : ntl::status{STATUS_INVALID_DEVICE_STATE};
}

/**
 * @brief Returns whether an STL or PMR pool operation is in its supported
 * execution context.
 *
 * Raw WDK pool allocation has a wider native IRQL contract. Generic STL and
 * PMR operations remain PASSIVE_LEVEL-only because they may also construct,
 * destroy, move, compare, invoke user code, or throw.
 */
inline bool is_pool_allocator_irql_valid() noexcept {
  return KeGetCurrentIrql() == PASSIVE_LEVEL;
}

/**
 * @brief Validates the PASSIVE_LEVEL contract of STL and PMR pool
 * operations.
 */
inline ntl::status require_pool_allocator_irql() noexcept {
  return is_pool_allocator_irql_valid()
             ? ntl::status{STATUS_SUCCESS}
             : ntl::status{STATUS_INVALID_DEVICE_STATE};
}

enum class pool_option : unsigned long long {
  /// No additional allocation option.
  none = 0,
  /// Charge the allocation quota when supported by the target WDK path.
  use_quota = 1ull << 0,
  /// Request uninitialized memory when ExAllocatePool2 is available.
  uninitialized = 1ull << 1,
  /// Request session pool when ExAllocatePool2 is available.
  session = 1ull << 2,
  /// Request cache-aligned pool.
  cache_aligned = 1ull << 3,
  /// Raise on allocation failure when the target WDK path supports it.
  raise_on_failure = 1ull << 4,
  /// Request special pool when ExAllocatePool2 is available.
  special_pool = 1ull << 5,
};

/**
 * @brief Combines two pool option sets.
 */
constexpr pool_option operator|(pool_option lhs, pool_option rhs) noexcept {
  return static_cast<pool_option>(static_cast<unsigned long long>(lhs) |
                                  static_cast<unsigned long long>(rhs));
}

/**
 * @brief Intersects two pool option sets.
 */
constexpr pool_option operator&(pool_option lhs, pool_option rhs) noexcept {
  return static_cast<pool_option>(static_cast<unsigned long long>(lhs) &
                                  static_cast<unsigned long long>(rhs));
}

/**
 * @brief Inverts a pool option set.
 */
constexpr pool_option operator~(pool_option value) noexcept {
  return static_cast<pool_option>(~static_cast<unsigned long long>(value));
}

/**
 * @brief Adds options to an existing pool option set.
 */
constexpr pool_option &operator|=(pool_option &lhs, pool_option rhs) noexcept {
  lhs = lhs | rhs;
  return lhs;
}

/**
 * @brief Keeps only matching options in an existing pool option set.
 */
constexpr pool_option &operator&=(pool_option &lhs, pool_option rhs) noexcept {
  lhs = lhs & rhs;
  return lhs;
}

/**
 * @brief Tests whether a pool option set contains an option.
 */
constexpr bool has_pool_option(pool_option options,
                               pool_option option) noexcept {
  return (static_cast<unsigned long long>(options & option) != 0);
}

/**
 * @brief Builds a native pool tag from four characters.
 */
constexpr ULONG pool_tag(char a, char b, char c, char d) noexcept {
  return static_cast<ULONG>(static_cast<unsigned char>(a)) |
         (static_cast<ULONG>(static_cast<unsigned char>(b)) << 8) |
         (static_cast<ULONG>(static_cast<unsigned char>(c)) << 16) |
         (static_cast<ULONG>(static_cast<unsigned char>(d)) << 24);
}

/**
 * @brief Builds a native pool tag from a four-character string literal.
 */
template <std::size_t N>
constexpr ULONG pool_tag(const char (&tag)[N]) noexcept {
  static_assert(N == 5,
                "pool tag string literal must contain exactly four characters");
  return pool_tag(tag[0], tag[1], tag[2], tag[3]);
}

/// Default NTL pool tag used by raw pool helpers and allocators.
inline constexpr ULONG default_pool_tag = pool_tag("NTLp");

namespace detail {

#if defined(POOL_FLAG_NON_PAGED) && defined(NTDDI_VERSION) &&                  \
    defined(NTDDI_WIN10_VB) && (NTDDI_VERSION >= NTDDI_WIN10_VB)
#define NTL_HAS_EX_ALLOCATE_POOL2 1
#else
#define NTL_HAS_EX_ALLOCATE_POOL2 0
#endif

#if NTL_HAS_EX_ALLOCATE_POOL2
inline constexpr bool pool_uses_ex_allocate_pool2 = true;
#else
inline constexpr bool pool_uses_ex_allocate_pool2 = false;
#endif

inline bool pool_alignment_supported(std::size_t alignment) noexcept {
  return alignment <= MEMORY_ALLOCATION_ALIGNMENT;
}

inline bool validate_raw_pool_irql(pool_kind kind,
                                   const char *operation) noexcept {
  if (ntl::is_pool_irql_valid(kind))
    return true;

#if DBG
  DbgPrintEx(DPFLTR_IHVDRIVER_ID, DPFLTR_WARNING_LEVEL,
             "[ntl] %s rejected at IRQL %lu for %s pool.\n", operation,
             static_cast<unsigned long>(KeGetCurrentIrql()),
             kind == pool_kind::paged ? "paged" : "nonpaged");
#else
  UNREFERENCED_PARAMETER(operation);
#endif
  return false;
}

inline void diagnose_stl_pool_irql(const char *operation) noexcept {
  if (ntl::is_pool_allocator_irql_valid())
    return;

#if DBG
  DbgPrintEx(DPFLTR_IHVDRIVER_ID, DPFLTR_WARNING_LEVEL,
             "[ntl] %s requires PASSIVE_LEVEL (current IRQL=%lu).\n", operation,
             static_cast<unsigned long>(KeGetCurrentIrql()));
#else
  UNREFERENCED_PARAMETER(operation);
#endif
}

#if NTL_HAS_EX_ALLOCATE_POOL2
inline POOL_FLAGS to_pool_flags(pool_kind kind, pool_option options) noexcept {
  POOL_FLAGS flags{};

  switch (kind) {
  case pool_kind::nonpaged:
    flags |= POOL_FLAG_NON_PAGED;
    break;
  case pool_kind::paged:
    flags |= POOL_FLAG_PAGED;
    break;
  case pool_kind::nonpaged_execute:
    flags |= POOL_FLAG_NON_PAGED_EXECUTE;
    break;
  }

  if (has_pool_option(options, pool_option::use_quota)) {
    flags |= POOL_FLAG_USE_QUOTA;
  }
  if (has_pool_option(options, pool_option::uninitialized)) {
    flags |= POOL_FLAG_UNINITIALIZED;
  }
  if (has_pool_option(options, pool_option::session)) {
    flags |= POOL_FLAG_SESSION;
  }
  if (has_pool_option(options, pool_option::cache_aligned)) {
    flags |= POOL_FLAG_CACHE_ALIGNED;
  }
  if (has_pool_option(options, pool_option::raise_on_failure)) {
    flags |= POOL_FLAG_RAISE_ON_FAILURE;
  }
  if (has_pool_option(options, pool_option::special_pool)) {
    flags |= POOL_FLAG_SPECIAL_POOL;
  }

  return flags;
}
#else
inline bool to_legacy_pool_type(pool_kind kind, pool_option options,
                                POOL_TYPE &pool_type) noexcept {
  if (has_pool_option(options, pool_option::use_quota) ||
      has_pool_option(options, pool_option::uninitialized) ||
      has_pool_option(options, pool_option::session) ||
      has_pool_option(options, pool_option::special_pool)) {
    return false;
  }

  const bool cache_aligned =
      has_pool_option(options, pool_option::cache_aligned);

  switch (kind) {
  case pool_kind::nonpaged:
    pool_type = cache_aligned ? NonPagedPoolNxCacheAligned : NonPagedPoolNx;
    break;
  case pool_kind::paged:
    pool_type = cache_aligned ? PagedPoolCacheAligned : PagedPool;
    break;
  case pool_kind::nonpaged_execute:
    pool_type = cache_aligned ? NonPagedPoolCacheAligned : NonPagedPoolExecute;
    break;
  }

#if defined(POOL_RAISE_IF_ALLOCATION_FAILURE)
  if (has_pool_option(options, pool_option::raise_on_failure)) {
    pool_type =
        static_cast<POOL_TYPE>(pool_type | POOL_RAISE_IF_ALLOCATION_FAILURE);
  }
#else
  if (has_pool_option(options, pool_option::raise_on_failure)) {
    return false;
  }
#endif

  return true;
}
#endif

inline void *allocate_pool_bytes(std::size_t bytes, std::size_t alignment,
                                 pool_kind kind, pool_option options,
                                 ULONG tag) noexcept {
  if (!validate_raw_pool_irql(kind, "raw pool allocation") ||
      !pool_alignment_supported(alignment)) {
    return nullptr;
  }

  const auto allocation_size = bytes == 0 ? std::size_t{1} : bytes;

#if NTL_HAS_EX_ALLOCATE_POOL2
  return ExAllocatePool2(to_pool_flags(kind, options), allocation_size, tag);
#else
  POOL_TYPE pool_type{};
  if (!to_legacy_pool_type(kind, options, pool_type)) {
    return nullptr;
  }

#ifdef _MSC_VER
#pragma warning(push)
#pragma warning(disable : 4996) // Legacy WDK fallback when ExAllocatePool2 is absent.
#endif
  return ExAllocatePoolWithTag(pool_type, allocation_size, tag);
#ifdef _MSC_VER
#pragma warning(pop)
#endif
#endif
}

inline void free_pool_bytes(void *pointer, pool_kind kind, ULONG tag) noexcept {
  if (!pointer) {
    return;
  }
  if (!validate_raw_pool_irql(kind, "raw pool release"))
    return;

#if NTL_HAS_EX_ALLOCATE_POOL2
  ExFreePool2(pointer, tag, nullptr, 0);
#else
  ExFreePoolWithTag(pointer, tag);
#endif
}

} // namespace detail

/**
 * @brief Allocates raw bytes from kernel pool.
 * @return Pointer to the allocated bytes, or nullptr on failure.
 */
inline void *allocate_pool(std::size_t bytes,
                           pool_kind kind = pool_kind::nonpaged,
                           pool_option options = pool_option::none,
                           ULONG tag = default_pool_tag) noexcept {
  return detail::allocate_pool_bytes(bytes, MEMORY_ALLOCATION_ALIGNMENT, kind,
                                     options, tag);
}

/**
 * @brief Allocates raw bytes from kernel pool and returns NTSTATUS on failure.
 * @return Successful result containing the allocated pointer, or
 * STATUS_INSUFFICIENT_RESOURCES.
 *
 * The caller owns the returned pointer and must release it with free_pool using
 * the same tag. Prefer make_pool_buffer when RAII ownership is practical.
 */
[[nodiscard]] inline ntl::result<void *>
try_allocate_pool(std::size_t bytes, pool_kind kind = pool_kind::nonpaged,
                  pool_option options = pool_option::none,
                  ULONG tag = default_pool_tag) noexcept {
  const auto irql_status = ntl::require_pool_irql(kind);
  if (!irql_status.is_ok())
    return ntl::unexpected(static_cast<NTSTATUS>(irql_status));

  void *const storage = allocate_pool(bytes, kind, options, tag);
  if (!storage)
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);

  return ntl::ok(storage);
}

/**
 * @brief Allocates raw bytes from kernel pool using a string-literal tag.
 */
template <std::size_t N>
inline void *allocate_pool(std::size_t bytes, pool_kind kind,
                           pool_option options, const char (&tag)[N]) noexcept {
