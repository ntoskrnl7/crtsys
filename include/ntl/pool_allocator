/**
 * @brief Constructs an object in kernel pool and returns NTSTATUS on allocation
 * failure.
 *
 * Object-construction exceptions still propagate after freeing the temporary
 * pool storage; only pool allocation failure is represented as NTSTATUS.
 */
template <class T, class... Args>
[[nodiscard]] ntl::result<pool_ptr<T>>
try_make_pool(pool_kind kind, pool_option options, ULONG tag, Args &&...args) {
  static_assert(!std::is_void<T>::value,
                "ntl::try_make_pool<T> requires an object type");
  static_assert(!std::is_array<T>::value,
                "ntl::try_make_pool<T> does not construct arrays");
  static_assert(alignof(T) <= MEMORY_ALLOCATION_ALIGNMENT,
                "ntl::try_make_pool supports WDK pool alignment only");

  const auto irql_status = ntl::require_pool_irql(kind);
  if (!irql_status.is_ok())
    return ntl::unexpected(static_cast<NTSTATUS>(irql_status));

  void *const storage =
      detail::allocate_pool_bytes(sizeof(T), alignof(T), kind, options, tag);
  if (!storage)
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);

  try {
    return pool_ptr<T>{new (storage) T(std::forward<Args>(args)...),
                       pool_deleter<T>{tag, kind}};
  } catch (...) {
    detail::free_pool_bytes(storage, kind, tag);
    throw;
  }
}

