/**
 * @brief Move-only reference to a request found in a manual queue.
 *
 * WdfIoQueueFindRequest adds a framework-object reference but does not give
 * the driver ownership of the request. This type releases that reference
 * automatically. Use io_queue::try_retrieve() to take the request out of the
 * queue before processing or completing it.
 */
class found_request {
public:
  /** @brief Creates an empty search result. */
  found_request() noexcept = default;

  found_request(const found_request &) = delete;
  found_request &operator=(const found_request &) = delete;

  /** @brief Transfers the framework-object reference. */
  found_request(found_request &&other) noexcept
      : handle_(std::exchange(other.handle_, nullptr)) {}

  /** @brief Releases any current reference and takes another one. */
  found_request &operator=(found_request &&other) noexcept {
    if (this != &other) {
      reset();
      handle_ = std::exchange(other.handle_, nullptr);
    }
    return *this;
  }

  /** @brief Releases the reference returned by WdfIoQueueFindRequest. */
  ~found_request() { reset(); }

  /** @brief Releases the held framework-object reference. */
  void reset() noexcept {
    if (handle_) {
      // KMDF 1.15 declares the diagnostic file parameter as mutable PCHAR,
      // so its WdfObjectDereference macro conflicts with /Zc:strictStrings.
      WdfObjectDereferenceActual(reinterpret_cast<WDFOBJECT>(handle_), nullptr,
                                 __LINE__, const_cast<PCHAR>(__FILE__));
    }
    handle_ = nullptr;
  }

  /** @brief Returns the referenced request handle for another queue query. */
  WDFREQUEST native_handle() const noexcept { return handle_; }

  /** @brief Returns true while a referenced request is held. */
  explicit operator bool() const noexcept { return handle_ != nullptr; }

private:
  friend class io_queue;

  /** @brief Takes ownership of a reference returned by WdfIoQueueFindRequest.
   */
  explicit found_request(WDFREQUEST handle) noexcept : handle_(handle) {}

  WDFREQUEST handle_ = nullptr;
};

/** @brief Non-owning facade for a WDFQUEUE handle. */
class io_queue {
public:
  /** @brief Creates an empty queue facade. */
  io_queue() noexcept = default;

  /** @brief Wraps a WDF queue handle without taking ownership. */
  explicit io_queue(WDFQUEUE handle) noexcept : handle_(handle) {}

  /**
   * @brief Creates an I/O queue for a device.
   * @return Non-owning queue facade or WdfIoQueueCreate failure status.
   */
  static ntl::result<io_queue>
  try_create(const device &owner, io_queue_config &config,
             object_attributes *attributes = nullptr) noexcept;

  /**
   * @brief Retrieves the next request from a manually dispatched queue.
   * @return A driver-owned request or the exact KMDF failure status.
   */
  ntl::result<request> try_retrieve_next() const noexcept {
    WDFREQUEST native_request = WDF_NO_HANDLE;
    const NTSTATUS result =
        WdfIoQueueRetrieveNextRequest(handle_, &native_request);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(request{native_request});
  }

  /**
   * @brief Retrieves the next queued request associated with a file object.
   * @return A driver-owned request or the exact KMDF failure status.
   */
  ntl::result<request> try_retrieve_for(const file &owner) const noexcept {
    WDFREQUEST native_request = WDF_NO_HANDLE;
    const NTSTATUS result = WdfIoQueueRetrieveRequestByFileObject(
        handle_, owner.native_object(), &native_request);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(request{native_request});
  }

  /**
   * @brief Finds a request without removing it from a manual queue.
   * @param after Previous search result, or null to start at the queue head.
   * @param owner Optional file-object filter.
   * @param parameters Optional initialized storage for request parameters.
   * @return A referenced search result or the exact KMDF failure status.
   */
  ntl::result<found_request>
  try_find(const found_request *after = nullptr, const file *owner = nullptr,
           request_parameters *parameters = nullptr) const noexcept {
    WDFREQUEST native_request = WDF_NO_HANDLE;
    const NTSTATUS result = WdfIoQueueFindRequest(
        handle_, after ? after->native_handle() : WDF_NO_HANDLE,
        owner ? owner->native_object() : WDF_NO_HANDLE,
        parameters ? parameters->native() : nullptr, &native_request);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(found_request{native_request});
  }

  /**
   * @brief Removes a previously found request from a manual queue.
   * @return A driver-owned request or the exact KMDF failure status.
   * @note The search reference is released whether retrieval succeeds or
   * fails. A STATUS_NOT_FOUND result means cancellation or another consumer
   * won the race.
   */
  ntl::result<request> try_retrieve(found_request &&found) const noexcept {
    WDFREQUEST native_request = WDF_NO_HANDLE;
    const NTSTATUS result = WdfIoQueueRetrieveFoundRequest(
        handle_, found.native_handle(), &native_request);
    found.reset();
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(request{native_request});
  }

  /** @brief Starts dispatching requests from this queue. */
  void start() const noexcept { WdfIoQueueStart(handle_); }

  /** @brief Stops dispatching asynchronously without a completion callback. */
  void stop() const noexcept {
    WdfIoQueueStop(handle_, WDF_NO_EVENT_CALLBACK, nullptr);
  }

  /**
   * @brief Stops dispatching asynchronously and invokes a typed callback.
   * @tparam Callback Non-capturing `void(io_queue, void*) noexcept` callback.
   */
  template <auto Callback> void stop(void *context = nullptr) const noexcept {
    WdfIoQueueStop(handle_, queue_state_callback<Callback>(), context);
  }

  /** @brief Stops dispatching and waits for delivered requests to complete. */
  void stop_and_wait() const noexcept { WdfIoQueueStopSynchronously(handle_); }

  /** @brief Drains requests asynchronously without a completion callback. */
  void drain() const noexcept {
    WdfIoQueueDrain(handle_, WDF_NO_EVENT_CALLBACK, nullptr);
  }

  /**
   * @brief Drains requests asynchronously and invokes a typed callback.
   * @tparam Callback Non-capturing `void(io_queue, void*) noexcept` callback.
   */
  template <auto Callback> void drain(void *context = nullptr) const noexcept {
    WdfIoQueueDrain(handle_, queue_state_callback<Callback>(), context);
  }

  /** @brief Drains queued requests and waits for delivered requests. */
  void drain_and_wait() const noexcept {
    WdfIoQueueDrainSynchronously(handle_);
  }

  /** @brief Purges requests asynchronously without a completion callback. */
  void purge() const noexcept {
    WdfIoQueuePurge(handle_, WDF_NO_EVENT_CALLBACK, nullptr);
  }

  /**
   * @brief Purges requests asynchronously and invokes a typed callback.
   * @tparam Callback Non-capturing `void(io_queue, void*) noexcept` callback.
   */
  template <auto Callback> void purge(void *context = nullptr) const noexcept {
    WdfIoQueuePurge(handle_, queue_state_callback<Callback>(), context);
  }

  /** @brief Cancels queued requests and waits for delivered requests. */
  void purge_and_wait() const noexcept {
    WdfIoQueuePurgeSynchronously(handle_);
  }

  /** @brief Stops and purges without a completion callback. */
  void stop_and_purge() const noexcept {
    WdfIoQueueStopAndPurge(handle_, WDF_NO_EVENT_CALLBACK, nullptr);
  }

  /**
   * @brief Stops and purges asynchronously and invokes a typed callback.
   * @tparam Callback Non-capturing `void(io_queue, void*) noexcept` callback.
   */
  template <auto Callback>
  void stop_and_purge(void *context = nullptr) const noexcept {
    WdfIoQueueStopAndPurge(handle_, queue_state_callback<Callback>(), context);
  }

  /** @brief Stops, purges, and waits for delivered requests. */
  void stop_and_purge_and_wait() const noexcept {
    WdfIoQueueStopAndPurgeSynchronously(handle_);
  }

  /** @brief Returns native queue state and optional request counts. */
  WDF_IO_QUEUE_STATE state(ULONG *queued_requests = nullptr,
                           ULONG *driver_requests = nullptr) const noexcept {
    return WdfIoQueueGetState(handle_, queued_requests, driver_requests);
  }

  /** @brief Returns the native WDF queue handle. */
  WDFQUEUE native_handle() const noexcept { return handle_; }

  /** @brief Returns the WDF device that owns this queue. */
  device owner() const noexcept { return device{WdfIoQueueGetDevice(handle_)}; }

  /** @brief Returns true when a native handle is present. */
  explicit operator bool() const noexcept { return handle_ != WDF_NO_HANDLE; }

private:
  template <auto Callback>
  static PFN_WDF_IO_QUEUE_STATE queue_state_callback() noexcept {
    return +[](WDFQUEUE native_queue, WDFCONTEXT context) noexcept {
      detail::invoke_callback<Callback>(io_queue{native_queue}, context);
    };
  }

  WDFQUEUE handle_ = WDF_NO_HANDLE;
};

/** @brief Initializes and configures WDF_IO_QUEUE_CONFIG. */
class io_queue_config {
public:
  /** @brief Creates a queue configuration. */
  explicit io_queue_config(WDF_IO_QUEUE_DISPATCH_TYPE dispatch,
                           bool default_queue = true) noexcept {
    if (default_queue)
      WDF_IO_QUEUE_CONFIG_INIT_DEFAULT_QUEUE(&value_, dispatch);
    else
      WDF_IO_QUEUE_CONFIG_INIT(&value_, dispatch);
  }

  /** @brief Registers a typed EvtIoDeviceControl callback. */
  template <auto Callback> io_queue_config &on_device_control() noexcept {
    value_.EvtIoDeviceControl = +[](WDFQUEUE native_queue,
                                    WDFREQUEST native_request,
                                    size_t output_length, size_t input_length,
                                    ULONG control_code) noexcept {
      detail::invoke_callback<Callback>(io_queue{native_queue},
                                        request{native_request}, output_length,
                                        input_length, control_code);
    };
    return *this;
  }

  /** @brief Registers a typed EvtIoInternalDeviceControl callback. */
  template <auto Callback>
  io_queue_config &on_internal_device_control() noexcept {
    value_.EvtIoInternalDeviceControl =
        +[](WDFQUEUE native_queue, WDFREQUEST native_request,
            size_t output_length, size_t input_length,
            ULONG control_code) noexcept {
          detail::invoke_callback<Callback>(
              io_queue{native_queue}, request{native_request}, output_length,
              input_length, control_code);
        };
    return *this;
  }

  /** @brief Registers a typed EvtIoRead callback. */
  template <auto Callback> io_queue_config &on_read() noexcept {
    value_.EvtIoRead = +[](WDFQUEUE native_queue, WDFREQUEST native_request,
                           size_t length) noexcept {
      detail::invoke_callback<Callback>(io_queue{native_queue},
                                        request{native_request}, length);
    };
    return *this;
  }

  /** @brief Registers a typed EvtIoWrite callback. */
  template <auto Callback> io_queue_config &on_write() noexcept {
    value_.EvtIoWrite = +[](WDFQUEUE native_queue, WDFREQUEST native_request,
                            size_t length) noexcept {
      detail::invoke_callback<Callback>(io_queue{native_queue},
                                        request{native_request}, length);
    };
    return *this;
  }

  /** @brief Registers a typed EvtIoDefault callback. */
  template <auto Callback> io_queue_config &on_default() noexcept {
    value_.EvtIoDefault =
        +[](WDFQUEUE native_queue, WDFREQUEST native_request) noexcept {
          detail::invoke_callback<Callback>(io_queue{native_queue},
                                            request{native_request});
        };
    return *this;
  }

  /** @brief Registers a typed EvtIoStop callback. */
  template <auto Callback> io_queue_config &on_stop() noexcept {
    value_.EvtIoStop = +[](WDFQUEUE native_queue, WDFREQUEST native_request,
                           ULONG action_flags) noexcept {
      detail::invoke_callback<Callback>(io_queue{native_queue},
                                        request{native_request}, action_flags);
    };
    return *this;
  }

  /** @brief Registers a typed EvtIoResume callback. */
  template <auto Callback> io_queue_config &on_resume() noexcept {
    value_.EvtIoResume =
        +[](WDFQUEUE native_queue, WDFREQUEST native_request) noexcept {
          detail::invoke_callback<Callback>(io_queue{native_queue},
                                            request{native_request});
        };
    return *this;
  }

  /** @brief Registers a typed EvtIoCanceledOnQueue callback. */
  template <auto Callback> io_queue_config &on_canceled() noexcept {
    value_.EvtIoCanceledOnQueue =
        +[](WDFQUEUE native_queue, WDFREQUEST native_request) noexcept {
          detail::invoke_callback<Callback>(io_queue{native_queue},
                                            request{native_request});
        };
    return *this;
  }

  /** @brief Sets the queue power-management policy. */
  io_queue_config &power_managed(WDF_TRI_STATE value) noexcept {
    value_.PowerManaged = value;
    return *this;
  }

  /** @brief Configures whether zero-length requests reach callbacks. */
  io_queue_config &allow_zero_length(bool enabled = true) noexcept {
    value_.AllowZeroLengthRequests = enabled ? TRUE : FALSE;
    return *this;
  }

  /** @brief Limits requests presented by a parallel queue. */
  io_queue_config &parallel_requests(ULONG count) noexcept {
    value_.Settings.Parallel.NumberOfPresentedRequests = count;
    return *this;
  }

  /** @brief Returns the mutable native queue configuration. */
  PWDF_IO_QUEUE_CONFIG native() noexcept { return &value_; }

private:
  WDF_IO_QUEUE_CONFIG value_{};
};

inline ntl::result<io_queue>
io_queue::try_create(const device &owner, io_queue_config &config,
                     object_attributes *attributes) noexcept {
  WDFQUEUE handle = WDF_NO_HANDLE;
  const NTSTATUS result =
      WdfIoQueueCreate(owner.native_handle(), config.native(),
                       attributes ? attributes->native() : nullptr, &handle);
  if (!NT_SUCCESS(result))
    return ntl::unexpected(result);
  return ntl::ok(io_queue{handle});
}
