/** @brief Builder for a standard, class, vendor, or feature USB setup packet.
 */
class usb_control_setup_packet {
public:
  /** @brief Creates a standard USB control-transfer setup packet. */
  static usb_control_setup_packet
  standard(WDF_USB_BMREQUEST_DIRECTION direction,
           WDF_USB_BMREQUEST_RECIPIENT recipient, BYTE request, USHORT value,
           USHORT index) noexcept {
    usb_control_setup_packet packet;
    WDF_USB_CONTROL_SETUP_PACKET_INIT(&packet.value_, direction, recipient,
                                      request, value, index);
    return packet;
  }

  /** @brief Creates a class-specific USB control-transfer setup packet. */
  static usb_control_setup_packet
  class_request(WDF_USB_BMREQUEST_DIRECTION direction,
                WDF_USB_BMREQUEST_RECIPIENT recipient, BYTE request,
                USHORT value, USHORT index) noexcept {
    usb_control_setup_packet packet;
    WDF_USB_CONTROL_SETUP_PACKET_INIT_CLASS(&packet.value_, direction,
                                            recipient, request, value, index);
    return packet;
  }

  /** @brief Creates a vendor-specific USB control-transfer setup packet. */
  static usb_control_setup_packet vendor(WDF_USB_BMREQUEST_DIRECTION direction,
                                         WDF_USB_BMREQUEST_RECIPIENT recipient,
                                         BYTE request, USHORT value,
                                         USHORT index) noexcept {
    usb_control_setup_packet packet;
    WDF_USB_CONTROL_SETUP_PACKET_INIT_VENDOR(&packet.value_, direction,
                                             recipient, request, value, index);
    return packet;
  }

  /** @brief Creates a SET_FEATURE or CLEAR_FEATURE setup packet. */
  static usb_control_setup_packet feature(WDF_USB_BMREQUEST_RECIPIENT recipient,
                                          USHORT selector, USHORT index,
                                          bool set) noexcept {
    usb_control_setup_packet packet;
    WDF_USB_CONTROL_SETUP_PACKET_INIT_FEATURE(
        &packet.value_, recipient, selector, index, set ? TRUE : FALSE);
    return packet;
  }

  /** @brief Creates a GET_STATUS setup packet. */
  static usb_control_setup_packet
  get_status(WDF_USB_BMREQUEST_RECIPIENT recipient, USHORT index) noexcept {
    usb_control_setup_packet packet;
    WDF_USB_CONTROL_SETUP_PACKET_INIT_GET_STATUS(&packet.value_, recipient,
                                                 index);
    return packet;
  }

  /** @brief Returns the mutable native setup packet. */
  PWDF_USB_CONTROL_SETUP_PACKET native() noexcept { return &value_; }

  /** @brief Returns the native setup packet. */
  const WDF_USB_CONTROL_SETUP_PACKET &native_value() const noexcept {
    return value_;
  }

private:
  WDF_USB_CONTROL_SETUP_PACKET value_{};
};

/** @brief Borrowed storage descriptor for synchronous WDF USB operations. */
class usb_memory_descriptor {
public:
  /** @brief Describes caller-owned contiguous storage. */
  static usb_memory_descriptor buffer(void *data, ULONG size_bytes) noexcept {
    usb_memory_descriptor descriptor;
    WDF_MEMORY_DESCRIPTOR_INIT_BUFFER(&descriptor.value_, data, size_bytes);
    return descriptor;
  }

  /** @brief Describes an MDL and the usable byte count. */
  static usb_memory_descriptor mdl(PMDL value, ULONG size_bytes) noexcept {
    usb_memory_descriptor descriptor;
    WDF_MEMORY_DESCRIPTOR_INIT_MDL(&descriptor.value_, value, size_bytes);
    return descriptor;
  }

  /**
   * @brief Describes a WDF memory object and optional range.
   * @note The memory_offset object must outlive the synchronous call.
   */
  static usb_memory_descriptor
  from_memory(memory value, memory_offset *offset = nullptr) noexcept {
    usb_memory_descriptor descriptor;
    WDF_MEMORY_DESCRIPTOR_INIT_HANDLE(&descriptor.value_, value.native_handle(),
                                      offset ? offset->native() : nullptr);
    return descriptor;
  }

  /** @brief Returns the mutable native memory descriptor. */
  PWDF_MEMORY_DESCRIPTOR native() noexcept { return &value_; }

private:
  WDF_MEMORY_DESCRIPTOR value_{};
};

/** @brief Value wrapper for WDF_USB_DEVICE_INFORMATION. */
class usb_device_information {
public:
  /** @brief Initializes an empty device-information result. */
  usb_device_information() noexcept {
    WDF_USB_DEVICE_INFORMATION_INIT(&value_);
  }

  /** @brief Returns the USB stack and controller information. */
  const USBD_VERSION_INFORMATION &usbd_version() const noexcept {
    return value_.UsbdVersionInformation;
  }

  /** @brief Returns WDF_USB_DEVICE_TRAIT_* flags. */
  ULONG traits() const noexcept { return value_.Traits; }

  /** @brief Reports whether the device is self powered. */
  bool is_self_powered() const noexcept {
    return (traits() & WDF_USB_DEVICE_TRAIT_SELF_POWERED) != 0;
  }

  /** @brief Reports whether the device supports remote wake. */
  bool is_remote_wake_capable() const noexcept {
    return (traits() & WDF_USB_DEVICE_TRAIT_REMOTE_WAKE_CAPABLE) != 0;
  }

  /** @brief Reports whether the device is operating at high speed. */
  bool is_high_speed() const noexcept {
    return (traits() & WDF_USB_DEVICE_TRAIT_AT_HIGH_SPEED) != 0;
  }

  /** @brief Returns the mutable native information structure. */
  PWDF_USB_DEVICE_INFORMATION native() noexcept { return &value_; }

private:
  WDF_USB_DEVICE_INFORMATION value_{};
};

/** @brief Value wrapper for WDF_USB_PIPE_INFORMATION. */
class usb_pipe_information {
public:
  /** @brief Initializes an empty pipe-information result. */
  usb_pipe_information() noexcept { WDF_USB_PIPE_INFORMATION_INIT(&value_); }

  /** @brief Returns the endpoint's maximum packet size. */
  ULONG maximum_packet_size() const noexcept {
    return value_.MaximumPacketSize;
  }

  /** @brief Returns the endpoint address from the descriptor. */
  UCHAR endpoint_address() const noexcept { return value_.EndpointAddress; }

  /** @brief Returns the endpoint polling interval. */
  UCHAR interval() const noexcept { return value_.Interval; }

  /** @brief Returns the alternate-setting index. */
  UCHAR setting_index() const noexcept { return value_.SettingIndex; }

  /** @brief Returns the control, bulk, interrupt, or isochronous pipe type. */
  WDF_USB_PIPE_TYPE type() const noexcept { return value_.PipeType; }

  /** @brief Returns the framework's maximum transfer size. */
  ULONG maximum_transfer_size() const noexcept {
    return value_.MaximumTransferSize;
  }

  /** @brief Reports whether the endpoint transfers data to the host. */
  bool is_in() const noexcept {
    return WDF_USB_PIPE_DIRECTION_IN(value_.EndpointAddress) != FALSE;
  }

  /** @brief Reports whether the endpoint transfers data from the host. */
  bool is_out() const noexcept {
    return WDF_USB_PIPE_DIRECTION_OUT(value_.EndpointAddress) != FALSE;
  }

  /** @brief Returns the mutable native pipe-information structure. */
  PWDF_USB_PIPE_INFORMATION native() noexcept { return &value_; }

private:
  WDF_USB_PIPE_INFORMATION value_{};
};

