/** @brief Non-owning facade for a WDFUSBDEVICE. */
class usb_device {
public:
  /** @brief Creates an empty USB-device facade. */
  usb_device() noexcept = default;

  /** @brief Wraps a native USB device without taking ownership. */
  explicit usb_device(WDFUSBDEVICE object) noexcept : object_(object) {}

  /** @brief Creates and opens a WDF USB device at PASSIVE_LEVEL. */
  static ntl::result<usb_device>
  try_create(const device &owner, usb_device_create_config &config,
             object_attributes *attributes = nullptr) noexcept {
    WDFUSBDEVICE object = WDF_NO_HANDLE;
    const NTSTATUS result = WdfUsbTargetDeviceCreateWithParameters(
        owner.native_handle(), config.native(),
        attributes ? attributes->native() : nullptr, &object);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(usb_device{object});
  }

  /** @brief Creates a USB device with the Windows 8+ client contract. */
  static ntl::result<usb_device>
  try_create(const device &owner,
             object_attributes *attributes = nullptr) noexcept {
    usb_device_create_config config;
    return try_create(owner, config, attributes);
  }

  /** @brief Retrieves USB stack information at IRQL <= DISPATCH_LEVEL. */
  ntl::result<usb_device_information> try_information() const noexcept {
    usb_device_information information;
    const NTSTATUS result =
        WdfUsbTargetDeviceRetrieveInformation(object_, information.native());
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(information);
  }

  /** @brief Returns the USB device descriptor at PASSIVE_LEVEL. */
  USB_DEVICE_DESCRIPTOR descriptor() const noexcept {
    USB_DEVICE_DESCRIPTOR value{};
    WdfUsbTargetDeviceGetDeviceDescriptor(object_, &value);
    return value;
  }

  /** @brief Selects a USB configuration at PASSIVE_LEVEL. */
  ntl::status
  try_select(usb_select_config &config,
             object_attributes *pipe_attributes = nullptr) const noexcept {
    return WdfUsbTargetDeviceSelectConfig(
        object_, pipe_attributes ? pipe_attributes->native() : nullptr,
        config.native());
  }

  /** @brief Returns the number of USB interfaces at IRQL <= DISPATCH_LEVEL. */
  UCHAR interface_count() const noexcept {
    return WdfUsbTargetDeviceGetNumInterfaces(object_);
  }

  /** @brief Returns an interface by zero-based index. */
  usb_interface interface_at(UCHAR index) const noexcept;

  /**
   * @brief Formats, but does not send, a USB control request.
   * @note Valid at IRQL <= DISPATCH_LEVEL. Send the request to target().
   */
  template <class Request>
  ntl::status
  try_format_control(const Request &request, usb_control_setup_packet &setup,
                     memory transfer = {},
                     memory_offset *offset = nullptr) const noexcept {
    return WdfUsbTargetDeviceFormatRequestForControlTransfer(
        object_, request.native_handle(), setup.native(),
        transfer.native_handle(), offset ? offset->native() : nullptr);
  }

  /** @brief Sends a USB control transfer synchronously at PASSIVE_LEVEL. */
  ntl::status
  try_control_transfer(usb_control_setup_packet &setup,
                       usb_memory_descriptor *transfer = nullptr,
                       ULONG *bytes_transferred = nullptr,
                       send_options *options = nullptr) const noexcept {
    return WdfUsbTargetDeviceSendControlTransferSynchronously(
        object_, WDF_NO_HANDLE, options ? options->native() : nullptr,
        setup.native(), transfer ? transfer->native() : nullptr,
        bytes_transferred);
  }

  /** @brief Reports whether the USB target is connected at PASSIVE_LEVEL. */
  ntl::status try_check_connected() const noexcept {
    return WdfUsbTargetDeviceIsConnectedSynchronous(object_);
  }

  /** @brief Returns the generic I/O target used to send USB requests. */
  io_target target() const noexcept {
    return io_target{WdfUsbTargetDeviceGetIoTarget(object_)};
  }

  /** @brief Returns the native WDF USB device. */
  WDFUSBDEVICE native_object() const noexcept { return object_; }

  /** @brief Returns true when a native USB device is present. */
  explicit operator bool() const noexcept { return object_ != WDF_NO_HANDLE; }

private:
  WDFUSBDEVICE object_ = WDF_NO_HANDLE;
};

