/** @brief Non-owning facade for a WDFUSBINTERFACE. */
class usb_interface {
public:
  /** @brief Creates an empty USB-interface facade. */
  usb_interface() noexcept = default;

  /** @brief Wraps a native USB interface without taking ownership. */
  explicit usb_interface(WDFUSBINTERFACE object) noexcept : object_(object) {}

  /** @brief Returns the descriptor interface number. */
  BYTE number() const noexcept {
    return WdfUsbInterfaceGetInterfaceNumber(object_);
  }

  /** @brief Returns the number of alternate settings. */
  BYTE setting_count() const noexcept {
    return WdfUsbInterfaceGetNumSettings(object_);
  }

  /** @brief Returns the active alternate-setting index. */
  BYTE configured_setting() const noexcept {
    return WdfUsbInterfaceGetConfiguredSettingIndex(object_);
  }

  /** @brief Returns the number of endpoints in an alternate setting. */
  BYTE endpoint_count(UCHAR setting_index) const noexcept {
    return WdfUsbInterfaceGetNumEndpoints(object_, setting_index);
  }

  /** @brief Returns an interface descriptor for an alternate setting. */
  USB_INTERFACE_DESCRIPTOR descriptor(UCHAR setting_index) const noexcept {
    USB_INTERFACE_DESCRIPTOR value{};
    WdfUsbInterfaceGetDescriptor(object_, setting_index, &value);
    return value;
  }

  /** @brief Selects an alternate setting at PASSIVE_LEVEL. */
  ntl::status
  try_select(usb_interface_setting &setting,
             object_attributes *pipe_attributes = nullptr) const noexcept {
    return WdfUsbInterfaceSelectSetting(
        object_, pipe_attributes ? pipe_attributes->native() : nullptr,
        setting.native());
  }

  /** @brief Returns the number of pipes in the selected setting. */
  BYTE configured_pipe_count() const noexcept {
    return WdfUsbInterfaceGetNumConfiguredPipes(object_);
  }

  /** @brief Returns a configured pipe and optionally fills its information. */
  usb_pipe pipe_at(UCHAR index,
                   usb_pipe_information *information = nullptr) const noexcept;

  /** @brief Returns the native WDF USB interface. */
  WDFUSBINTERFACE native_object() const noexcept { return object_; }

  /** @brief Returns true when a native USB interface is present. */
  explicit operator bool() const noexcept { return object_ != WDF_NO_HANDLE; }

private:
  WDFUSBINTERFACE object_ = WDF_NO_HANDLE;
};

/** @brief Builder for a KMDF USB continuous reader. */
class usb_continuous_reader_config {
public:
  /**
   * @brief Creates a reader configuration with a typed completion callback.
   * @tparam Callback Non-capturing
   * `void(usb_pipe, memory, size_t, void*) noexcept` callback.
   */
  template <auto Callback>
  static usb_continuous_reader_config
  with_completion(size_t transfer_length, void *context = nullptr) noexcept {
    usb_continuous_reader_config config;
    WDF_USB_CONTINUOUS_READER_CONFIG_INIT(
        &config.value_,
        +[](WDFUSBPIPE native_pipe, WDFMEMORY native_memory, size_t transferred,
            WDFCONTEXT native_context) noexcept {
          detail::invoke_usb_reader_completion<Callback>(
              native_pipe, native_memory, transferred, native_context);
        },
        context, transfer_length);
    return config;
  }

  /** @brief Reserves bytes before and after each transfer buffer. */
  usb_continuous_reader_config &padding(size_t header,
                                        size_t trailer) noexcept {
    value_.HeaderLength = header;
    value_.TrailerLength = trailer;
    return *this;
  }

  /** @brief Selects the number of concurrent reads; zero uses WDF's default. */
  usb_continuous_reader_config &pending_reads(UCHAR count) noexcept {
    value_.NumPendingReads = count;
    return *this;
  }

  /** @brief Applies attributes to framework-created reader buffers. */
  usb_continuous_reader_config &
  buffer_attributes(object_attributes &attributes) noexcept {
    value_.BufferAttributes = attributes.native();
    return *this;
  }

  /**
   * @brief Registers a PASSIVE_LEVEL reader-failure callback.
   * @tparam Callback Non-capturing
   * `bool(usb_pipe, ntl::status, USBD_STATUS) noexcept` callback.
   */
  template <auto Callback> usb_continuous_reader_config &on_failure() noexcept {
    value_.EvtUsbTargetPipeReadersFailed =
        +[](WDFUSBPIPE native_pipe, NTSTATUS status,
            USBD_STATUS usbd_status) noexcept -> BOOLEAN {
      return detail::invoke_usb_reader_failure<Callback>(native_pipe, status,
                                                         usbd_status);
    };
    return *this;
  }

  /** @brief Returns the mutable native reader configuration. */
  PWDF_USB_CONTINUOUS_READER_CONFIG native() noexcept { return &value_; }

private:
  WDF_USB_CONTINUOUS_READER_CONFIG value_{};
};

/** @brief Non-owning facade for a WDFUSBPIPE. */
class usb_pipe {
public:
  /** @brief Creates an empty USB-pipe facade. */
  usb_pipe() noexcept = default;

  /** @brief Wraps a native USB pipe without taking ownership. */
  explicit usb_pipe(WDFUSBPIPE object) noexcept : object_(object) {}

  /** @brief Returns current pipe information. */
  usb_pipe_information information() const noexcept {
    usb_pipe_information value;
    WdfUsbTargetPipeGetInformation(object_, value.native());
    return value;
  }

  /** @brief Reports whether this is an input endpoint. */
  bool is_in() const noexcept {
    return WdfUsbTargetPipeIsInEndpoint(object_) != FALSE;
  }

  /** @brief Reports whether this is an output endpoint. */
  bool is_out() const noexcept {
    return WdfUsbTargetPipeIsOutEndpoint(object_) != FALSE;
  }

  /** @brief Returns the control, bulk, interrupt, or isochronous pipe type. */
  WDF_USB_PIPE_TYPE type() const noexcept {
    return WdfUsbTargetPipeGetType(object_);
  }

  /** @brief Disables WDF's maximum-packet-size buffer check. */
  void allow_partial_packets() const noexcept {
    WdfUsbTargetPipeSetNoMaximumPacketSizeCheck(object_);
  }

  /**
   * @brief Formats, but does not send, an input-pipe read request.
   * @note Valid at IRQL <= DISPATCH_LEVEL. Send the request to target().
   */
  template <class Request>
  ntl::status try_format_read(const Request &request, memory output = {},
                              memory_offset *offset = nullptr) const noexcept {
    return WdfUsbTargetPipeFormatRequestForRead(
        object_, request.native_handle(), output.native_handle(),
        offset ? offset->native() : nullptr);
  }

  /**
   * @brief Formats, but does not send, an output-pipe write request.
   * @note Valid at IRQL <= DISPATCH_LEVEL. Send the request to target().
   */
  template <class Request>
  ntl::status try_format_write(const Request &request, memory input = {},
                               memory_offset *offset = nullptr) const noexcept {
    return WdfUsbTargetPipeFormatRequestForWrite(
        object_, request.native_handle(), input.native_handle(),
        offset ? offset->native() : nullptr);
  }

  /** @brief Reads synchronously from an input pipe at PASSIVE_LEVEL. */
  ntl::status try_read(usb_memory_descriptor *output = nullptr,
                       ULONG *bytes_read = nullptr,
                       send_options *options = nullptr) const noexcept {
    return WdfUsbTargetPipeReadSynchronously(
        object_, WDF_NO_HANDLE, options ? options->native() : nullptr,
        output ? output->native() : nullptr, bytes_read);
  }

  /** @brief Writes synchronously to an output pipe at PASSIVE_LEVEL. */
  ntl::status try_write(usb_memory_descriptor *input = nullptr,
                        ULONG *bytes_written = nullptr,
                        send_options *options = nullptr) const noexcept {
    return WdfUsbTargetPipeWriteSynchronously(
        object_, WDF_NO_HANDLE, options ? options->native() : nullptr,
        input ? input->native() : nullptr, bytes_written);
  }

  /** @brief Configures an input-pipe continuous reader. */
  ntl::status
  try_configure_reader(usb_continuous_reader_config &config) const noexcept {
    return WdfUsbTargetPipeConfigContinuousReader(object_, config.native());
  }

  /** @brief Aborts pending pipe requests synchronously at PASSIVE_LEVEL. */
  ntl::status try_abort(send_options *options = nullptr) const noexcept {
    return WdfUsbTargetPipeAbortSynchronously(
        object_, WDF_NO_HANDLE, options ? options->native() : nullptr);
  }

  /** @brief Resets the pipe synchronously at PASSIVE_LEVEL. */
  ntl::status try_reset(send_options *options = nullptr) const noexcept {
    return WdfUsbTargetPipeResetSynchronously(
        object_, WDF_NO_HANDLE, options ? options->native() : nullptr);
  }

  /** @brief Starts this pipe I/O target, including a configured reader. */
  ntl::status try_start() const noexcept { return target().try_start(); }

  /** @brief Stops this pipe I/O target using the supplied request policy. */
  void stop(WDF_IO_TARGET_SENT_IO_ACTION action) const noexcept {
    target().stop(action);
  }

  /** @brief Purges this pipe I/O target using the supplied request policy. */
  void purge(WDF_IO_TARGET_PURGE_IO_ACTION action) const noexcept {
    target().purge(action);
  }

  /** @brief Returns the generic target used to send formatted requests. */
  io_target target() const noexcept {
    return io_target{WdfUsbTargetPipeGetIoTarget(object_)};
  }

  /** @brief Returns the native WDF USB pipe. */
  WDFUSBPIPE native_object() const noexcept { return object_; }

  /** @brief Returns true when a native USB pipe is present. */
  explicit operator bool() const noexcept { return object_ != WDF_NO_HANDLE; }

private:
  WDFUSBPIPE object_ = WDF_NO_HANDLE;
};

inline usb_interface usb_select_config::configured_interface() const noexcept {
  return usb_interface{value_.Types.SingleInterface.ConfiguredUsbInterface};
}

inline usb_interface usb_device::interface_at(UCHAR index) const noexcept {
  return usb_interface{WdfUsbTargetDeviceGetInterface(object_, index)};
}

inline usb_pipe
usb_interface::pipe_at(UCHAR index,
                       usb_pipe_information *information) const noexcept {
  return usb_pipe{WdfUsbInterfaceGetConfiguredPipe(
      object_, index, information ? information->native() : nullptr)};
}

namespace detail {
template <auto Callback>
void invoke_usb_reader_completion(WDFUSBPIPE pipe, WDFMEMORY buffer,
                                  size_t transferred,
                                  WDFCONTEXT context) noexcept {
  invoke_callback<Callback>(usb_pipe{pipe}, memory{buffer}, transferred,
                            context);
}

template <auto Callback>
BOOLEAN invoke_usb_reader_failure(WDFUSBPIPE pipe, NTSTATUS status,
                                  USBD_STATUS usbd_status) noexcept {
  return invoke_boolean_callback<Callback>(usb_pipe{pipe}, ntl::status{status},
                                           usbd_status)
             ? TRUE
             : FALSE;
}
