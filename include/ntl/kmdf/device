/**
 * @brief Non-owning facade for a WDFDEVICE handle.
 */
class device {
public:
  /**
   * @brief Creates an empty device facade.
   */
  device() noexcept = default;

  /**
   * @brief Wraps a WDF device handle without taking ownership.
   * @param handle Native WDF device handle.
   */
  explicit device(WDFDEVICE handle) noexcept : handle_(handle) {}

  /**
   * @brief Creates a symbolic link for the device.
   * @param link_name Native symbolic-link name.
   * @return WdfDeviceCreateSymbolicLink status.
   */
  ntl::status
  try_create_symbolic_link(PCUNICODE_STRING link_name) const noexcept {
    return WdfDeviceCreateSymbolicLink(handle_, link_name);
  }

  /**
   * @brief Creates a symbolic link for the device.
   * @param link_name Symbolic-link name, for example \\DosDevices\\Sample.
   * @return WdfDeviceCreateSymbolicLink status.
   */
  ntl::status try_create_symbolic_link(const std::wstring &link_name) const {
    ntl::unicode_string native_name(link_name);
    return try_create_symbolic_link(&*native_name);
  }

  /**
   * @brief Registers a PnP device interface.
   * @param interface_class Device interface class GUID.
   * @param reference Optional native reference string.
   * @return WdfDeviceCreateDeviceInterface status.
   */
  ntl::status
  try_create_interface(const GUID &interface_class,
                       PCUNICODE_STRING reference = nullptr) const noexcept {
    return WdfDeviceCreateDeviceInterface(handle_, &interface_class, reference);
  }

  /**
   * @brief Registers a named PnP device interface.
   * @param interface_class Device interface class GUID.
   * @param reference Reference string without path separators.
   * @return WdfDeviceCreateDeviceInterface status.
   */
  ntl::status try_create_interface(const GUID &interface_class,
                                   const std::wstring &reference) const {
    ntl::unicode_string native_reference(reference);
    return try_create_interface(interface_class, &*native_reference);
  }

  /**
   * @brief Opens a device-instance registry key at PASSIVE_LEVEL.
   * @param key_type PLUGPLAY_REGKEY_* flags accepted by KMDF.
   * @param desired_access Requested registry access rights.
   * @param attributes Optional WDF attributes for the key object.
   */
  ntl::result<registry_key> try_open_registry_key(
      ULONG key_type, ACCESS_MASK desired_access = KEY_READ,
      object_attributes *attributes = nullptr) const noexcept {
    return registry_key::try_open_device(handle_, key_type, desired_access,
                                         attributes);
  }

  /** @brief Queries a legacy DEVICE_REGISTRY_PROPERTY at PASSIVE_LEVEL. */
  ntl::result<std::vector<std::uint8_t>>
  try_query_property(DEVICE_REGISTRY_PROPERTY property) const {
    return query_device_property(handle_, property);
  }

  /** @brief Queries a DEVPROPKEY into owned storage at PASSIVE_LEVEL. */
  ntl::result<device_property_value>
  try_query_property(const DEVPROPKEY &property,
                     LCID locale = LOCALE_NEUTRAL) const {
    return query_device_property(handle_, property, locale);
  }

  /**
   * @brief Enables or disables a registered device interface.
   */
  void
  set_interface_state(const GUID &interface_class, bool enabled,
                      PCUNICODE_STRING reference = nullptr) const noexcept {
    WdfDeviceSetDeviceInterfaceState(handle_, &interface_class, reference,
                                     enabled ? TRUE : FALSE);
  }

  /**
   * @brief Marks a non-PnP control device as initialized.
   */
  void finish_initializing() const noexcept {
    WdfControlFinishInitializing(handle_);
  }

  /** @brief Returns this device's constructed C++ context. */
  template <class T> T &context() const noexcept {
    return detail::get_context<T>(reinterpret_cast<WDFOBJECT>(handle_));
  }

  /** @brief Returns this device's C++ context, or nullptr when absent. */
  template <class T> T *try_context() const noexcept {
    return detail::try_get_context<T>(reinterpret_cast<WDFOBJECT>(handle_));
  }

  /** @brief Allocates and constructs an additional typed device context. */
  template <class T, class... Args>
  ntl::result<T *> try_emplace_context(Args &&...args) const noexcept {
    return object{reinterpret_cast<WDFOBJECT>(handle_)}
        .template try_emplace_context<T>(std::forward<Args>(args)...);
  }

  /** @brief Returns the device's default I/O target. */
  io_target default_io_target() const noexcept;

  /**
   * @brief Returns the native WDF device handle.
   */
  WDFDEVICE native_handle() const noexcept { return handle_; }

  /**
   * @brief Returns true when a native handle is present.
   */
  explicit operator bool() const noexcept { return handle_ != WDF_NO_HANDLE; }

private:
  WDFDEVICE handle_ = WDF_NO_HANDLE;
};

