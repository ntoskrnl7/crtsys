/**
 * @brief Non-owning facade for a WDFDEVICE handle.
 */
class device {
public:
  /**
   * @brief Creates an empty device facade.
   */
  device() noexcept = default;

  /**
   * @brief Wraps a WDF device handle without taking ownership.
   * @param handle Native WDF device handle.
   */
  explicit device(WDFDEVICE handle) noexcept : handle_(handle) {}

  /**
   * @brief Creates a symbolic link for the device.
   * @param link_name Native symbolic-link name.
   * @return WdfDeviceCreateSymbolicLink status.
   */
  ntl::status
  try_create_symbolic_link(PCUNICODE_STRING link_name) const noexcept {
    return WdfDeviceCreateSymbolicLink(handle_, link_name);
  }

  /**
   * @brief Creates a symbolic link for the device.
   * @param link_name Symbolic-link name, for example \\DosDevices\\Sample.
   * @return WdfDeviceCreateSymbolicLink status.
   */
  ntl::status try_create_symbolic_link(const std::wstring &link_name) const {
    ntl::unicode_string native_name(link_name);
    return try_create_symbolic_link(&*native_name);
  }

  /**
   * @brief Registers a PnP device interface.
   * @param interface_class Device interface class GUID.
   * @param reference Optional native reference string.
   * @return WdfDeviceCreateDeviceInterface status.
   */
  ntl::status
  try_create_interface(const GUID &interface_class,
                       PCUNICODE_STRING reference = nullptr) const noexcept {
    return WdfDeviceCreateDeviceInterface(handle_, &interface_class, reference);
  }

  /**
   * @brief Registers a named PnP device interface.
   * @param interface_class Device interface class GUID.
   * @param reference Reference string without path separators.
   * @return WdfDeviceCreateDeviceInterface status.
   */
  ntl::status try_create_interface(const GUID &interface_class,
                                   const std::wstring &reference) const {
    ntl::unicode_string native_reference(reference);
    return try_create_interface(interface_class, &*native_reference);
  }

  /**
   * @brief Assigns the embedded MOF resource used by custom WMI
   * providers.
   * @param resource_name Name of the driver's MOFDATA
   * resource.
   * @return WdfDeviceAssignMofResourceName status.
   * @note
   * Call this before creating custom WMI provider instances.
   */
  ntl::status
  try_assign_mof_resource(PCUNICODE_STRING resource_name) const noexcept {
    return WdfDeviceAssignMofResourceName(handle_, resource_name);
  }

  /** @brief Assigns a named embedded MOF resource. */
  ntl::status try_assign_mof_resource(const std::wstring &resource_name) const {
    UNICODE_STRING native_name{};
    RtlInitUnicodeString(&native_name, resource_name.c_str());
    return try_assign_mof_resource(&native_name);
  }

  /**
   * @brief Opens a device-instance registry key at PASSIVE_LEVEL.
   * @param key_type PLUGPLAY_REGKEY_* flags accepted by KMDF.
   * @param desired_access Requested registry access rights.
   * @param attributes Optional WDF attributes for the key object.
   */
  ntl::result<registry_key> try_open_registry_key(
      ULONG key_type, ACCESS_MASK desired_access = KEY_READ,
      object_attributes *attributes = nullptr) const noexcept {
    return registry_key::try_open_device(handle_, key_type, desired_access,
                                         attributes);
  }

  /** @brief Queries a legacy DEVICE_REGISTRY_PROPERTY at PASSIVE_LEVEL. */
  ntl::result<std::vector<std::uint8_t>>
  try_query_property(DEVICE_REGISTRY_PROPERTY property) const {
    return query_device_property(handle_, property);
  }

  /** @brief Queries a DEVPROPKEY into owned storage at PASSIVE_LEVEL. */
  ntl::result<device_property_value>
  try_query_property(const DEVPROPKEY &property,
                     LCID locale = LOCALE_NEUTRAL) const {
    return query_device_property(handle_, property, locale);
  }

  /**
   * @brief Enables or disables a registered device interface.
   */
  void
  set_interface_state(const GUID &interface_class, bool enabled,
                      PCUNICODE_STRING reference = nullptr) const noexcept {
    WdfDeviceSetDeviceInterfaceState(handle_, &interface_class, reference,
                                     enabled ? TRUE : FALSE);
  }

  /** @brief Retrieves the framework device name at PASSIVE_LEVEL. */
  ntl::result<string> try_name() const noexcept {
    auto value = string::try_create();
    if (!value)
      return ntl::unexpected(value.status());
    const NTSTATUS result =
        WdfDeviceRetrieveDeviceName(handle_, value->native_object());
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return value;
  }

  /** @brief Retrieves one registered device-interface string. */
  ntl::result<string>
  try_interface_string(const GUID &interface_class,
                       PCUNICODE_STRING reference = nullptr) const noexcept {
    auto value = string::try_create();
    if (!value)
      return ntl::unexpected(value.status());
    const NTSTATUS result = WdfDeviceRetrieveDeviceInterfaceString(
        handle_, &interface_class, reference, value->native_object());
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return value;
  }

  /**
   * @brief Marks a non-PnP control device as initialized.
   */
  void finish_initializing() const noexcept {
    WdfControlFinishInitializing(handle_);
  }

  /** @brief Returns this device's constructed C++ context. */
  template <class T> T &context() const noexcept {
    return detail::get_context<T>(reinterpret_cast<WDFOBJECT>(handle_));
  }

  /** @brief Returns this device's C++ context, or nullptr when absent. */
  template <class T> T *try_context() const noexcept {
    return detail::try_get_context<T>(reinterpret_cast<WDFOBJECT>(handle_));
  }

  /** @brief Allocates and constructs an additional typed device context. */
  template <class T, class... Args>
  ntl::result<T *> try_emplace_context(Args &&...args) const noexcept {
    return object{reinterpret_cast<WDFOBJECT>(handle_)}
        .template try_emplace_context<T>(std::forward<Args>(args)...);
  }

  /** @brief Returns the device's default I/O target. */
  io_target default_io_target() const noexcept;

  /** @brief Returns the device's default I/O queue, when configured. */
  io_queue default_queue() const noexcept;

  /** @brief Routes one request type to a non-default queue. */
  ntl::status try_route_requests(const io_queue &queue,
                                 WDF_REQUEST_TYPE type) const noexcept;

  /** @brief Prevents the device from entering its idle power state. */
  ntl::status try_stop_idle(bool wait_for_d0 = false) const noexcept {
    return WdfDeviceStopIdleNoTrack(handle_, wait_for_d0 ? TRUE : FALSE);
  }

  /** @brief Releases one successful try_stop_idle() reference. */
  void resume_idle() const noexcept { WdfDeviceResumeIdleNoTrack(handle_); }

  /** @brief Returns the current framework PnP state. */
  WDF_DEVICE_PNP_STATE pnp_state() const noexcept {
    return WdfDeviceGetDevicePnpState(handle_);
  }

  /** @brief Returns the current framework device-power state. */
  WDF_DEVICE_POWER_STATE power_state() const noexcept {
    return WdfDeviceGetDevicePowerState(handle_);
  }

  /** @brief Returns the current framework power-policy state. */
  WDF_DEVICE_POWER_POLICY_STATE power_policy_state() const noexcept {
    return WdfDeviceGetDevicePowerPolicyState(handle_);
  }

  /** @brief Returns the system power action currently in progress. */
  POWER_ACTION system_power_action() const noexcept {
    return WdfDeviceGetSystemPowerAction(handle_);
  }

  /** @brief Returns the current PnP device-state flags. */
  WDF_DEVICE_STATE state() const noexcept {
    WDF_DEVICE_STATE value{};
    WDF_DEVICE_STATE_INIT(&value);
    WdfDeviceGetDeviceState(handle_, &value);
    return value;
  }

  /** @brief Replaces the PnP device-state flags. */
  void state(WDF_DEVICE_STATE &value) const noexcept {
    WdfDeviceSetDeviceState(handle_, &value);
  }

  /** @brief Reports a framework device failure. */
  void set_failed(WDF_DEVICE_FAILED_ACTION action) const noexcept {
    WdfDeviceSetFailed(handle_, action);
  }

  /** @brief Completes a pending wake request with the supplied status. */
  ntl::status indicate_wake_status(NTSTATUS value) const noexcept {
    return WdfDeviceIndicateWakeStatus(handle_, value);
  }

  /** @brief Returns the WDM functional device object. */
  PDEVICE_OBJECT wdm_device_object() const noexcept {
    return WdfDeviceWdmGetDeviceObject(handle_);
  }

  /** @brief Returns the WDM device object attached below this device. */
  PDEVICE_OBJECT wdm_attached_device_object() const noexcept {
    return WdfDeviceWdmGetAttachedDevice(handle_);
  }

  /** @brief Returns the WDM physical device object. */
  PDEVICE_OBJECT wdm_physical_device_object() const noexcept {
    return WdfDeviceWdmGetPhysicalDevice(handle_);
  }

  /** @brief Returns the current WDM device characteristics. */
  ULONG characteristics() const noexcept {
    return WdfDeviceGetCharacteristics(handle_);
  }

  /** @brief Sets and optionally clears WDM device characteristics. */
  void characteristics(ULONG set_flags, ULONG clear_flags = 0) const noexcept {
    const ULONG value = (characteristics() | set_flags) & ~clear_flags;
    WdfDeviceSetCharacteristics(handle_, value);
  }

  /** @brief Returns the current DMA alignment requirement. */
  ULONG alignment_requirement() const noexcept {
    return WdfDeviceGetAlignmentRequirement(handle_);
  }

  /** @brief Sets the DMA alignment requirement. */
  void alignment_requirement(ULONG value) const noexcept {
    WdfDeviceSetAlignmentRequirement(handle_, value);
  }

  /** @brief Registers a typed driver-defined interface on this device. */
  template <class Interface>
  ntl::status try_add_query_interface(
      query_interface_config<Interface> &config) const noexcept;

  /**
   * @brief Queries a typed driver-defined interface from the lower
   * stack.
   * @param interface_type Interface contract GUID.
   * @param
   * version Requested interface version.
   * @param specific_data Optional
   * provider-specific query data.
   * @param initial_value Optional
   * caller-initialized import-interface value.
   */
  template <class Interface>
  ntl::result<queried_interface<Interface>>
  try_query_interface(const GUID &interface_type, USHORT version,
                      void *specific_data = nullptr,
                      Interface initial_value = Interface{}) const noexcept;

  /** @brief Adds an already-created statically enumerated PDO to this FDO. */
  ntl::status try_add_static_child(const pdo &child) const noexcept;

  /** @brief Publishes bus information for children enumerated by this FDO. */
  const device &
  bus_information(PNP_BUS_INFORMATION &information) const noexcept {
    WdfDeviceSetBusInformationForChildren(handle_, &information);
    return *this;
  }

  /**
   * @brief Returns the native WDF device handle.
   */
  WDFDEVICE native_handle() const noexcept { return handle_; }

  /**
   * @brief Returns true when a native handle is present.
   */
  explicit operator bool() const noexcept { return handle_ != WDF_NO_HANDLE; }

private:
  WDFDEVICE handle_ = WDF_NO_HANDLE;
};

/** @brief Move-only RAII reference that keeps a KMDF device out of idle. */
class device_idle_reference {
public:
  device_idle_reference(const device_idle_reference &) = delete;
  device_idle_reference &operator=(const device_idle_reference &) = delete;

  /** @brief Transfers an acquired idle reference. */
  device_idle_reference(device_idle_reference &&other) noexcept
      : owner_(std::exchange(other.owner_, device{})) {}

  /** @brief Releases any current reference and transfers another. */
  device_idle_reference &operator=(device_idle_reference &&other) noexcept {
    if (this != &other) {
      reset();
      owner_ = std::exchange(other.owner_, device{});
    }
    return *this;
  }

  /** @brief Releases the idle reference. */
  ~device_idle_reference() { reset(); }

  /** @brief Acquires a device idle reference. */
  static ntl::result<device_idle_reference>
  try_acquire(device owner, bool wait_for_d0 = false) noexcept {
    const ntl::status result = owner.try_stop_idle(wait_for_d0);
    if (result.is_err())
      return ntl::unexpected(static_cast<NTSTATUS>(result));
    return ntl::ok(device_idle_reference{owner});
  }

  /** @brief Releases the reference before destruction. */
  void reset() noexcept {
    if (owner_)
      owner_.resume_idle();
    owner_ = device{};
  }

  /** @brief Returns the device held out of idle. */
  device owner() const noexcept { return owner_; }

private:
  explicit device_idle_reference(device owner) noexcept : owner_(owner) {}
  device owner_{};
};

