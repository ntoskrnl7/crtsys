/**
 * @brief Non-owning facade for DeviceInit supplied to EvtDriverDeviceAdd.
 *
 * The framework owns this initialization object and deletes it after the
 * callback returns when WdfDeviceCreate has not consumed it. This wrapper
 * therefore never calls WdfDeviceInitFree.
 */
class device_init {
public:
  /**
   * @brief Wraps DeviceInit supplied to EvtDriverDeviceAdd.
   * @param value Framework-owned initialization object.
   */
  explicit device_init(PWDFDEVICE_INIT value) noexcept : value_(value) {}

  device_init(const device_init &) = delete;
  device_init &operator=(const device_init &) = delete;

  /** @brief Transfers this non-owning facade from another wrapper. */
  device_init(device_init &&other) noexcept
      : value_(std::exchange(other.value_, nullptr)) {}

  /** @brief Rebinds this facade to another wrapper's initialization object. */
  device_init &operator=(device_init &&other) noexcept {
    if (this != &other)
      value_ = std::exchange(other.value_, nullptr);
    return *this;
  }

  /**
   * @brief Sets the WDM device type.
   * @param type FILE_DEVICE_* value.
   * @return This initialization facade.
   */
  device_init &device_type(ULONG type) noexcept {
    WdfDeviceInitSetDeviceType(value_, type);
    return *this;
  }

  /**
   * @brief Sets the WDF I/O buffering model.
   * @param type WDF device I/O type.
   * @return This initialization facade.
   */
  device_init &io_type(WDF_DEVICE_IO_TYPE type) noexcept {
    WdfDeviceInitSetIoType(value_, type);
    return *this;
  }

  /** @brief Applies separate read/write/control buffering policies. */
  device_init &io_type(WDF_IO_TYPE_CONFIG &config) noexcept {
    WdfDeviceInitSetIoTypeEx(value_, &config);
    return *this;
  }

  /** @brief Assigns an optional native device name. */
  ntl::status try_assign_name(PCUNICODE_STRING name) noexcept {
    return WdfDeviceInitAssignName(value_, name);
  }

  /** @brief Assigns an optional native device name. */
  ntl::status try_assign_name(const std::wstring &name) {
    ntl::unicode_string native_name(name);
    return try_assign_name(&*native_name);
  }

  /** @brief Assigns an SDDL security descriptor before device creation. */
  ntl::status try_assign_sddl(PCUNICODE_STRING sddl) noexcept {
    return WdfDeviceInitAssignSDDLString(value_, sddl);
  }

  /** @brief Assigns a device setup class. */
  device_init &device_class(const GUID &value) noexcept {
    WdfDeviceInitSetDeviceClass(value_, &value);
    return *this;
  }

  /** @brief Assigns WDM DEVICE_OBJECT characteristics. */
  device_init &characteristics(ULONG value, bool exclusive = false) noexcept {
    WdfDeviceInitSetCharacteristics(value_, value, exclusive ? TRUE : FALSE);
    return *this;
  }

  /**
   * @brief Configures exclusive access.
   * @param enabled True to allow only one open file object.
   * @return This initialization facade.
   */
  device_init &exclusive(bool enabled = true) noexcept {
    WdfDeviceInitSetExclusive(value_, enabled ? TRUE : FALSE);
    return *this;
  }

  /**
   * @brief Marks the device as a filter FDO.
   * @return This initialization facade.
   */
  device_init &filter() noexcept {
    WdfFdoInitSetFilter(value_);
    return *this;
  }

  /**
   * @brief Configures power-policy ownership.
   * @param enabled True when this driver owns device power policy.
   * @return This initialization facade.
   */
  device_init &power_policy_owner(bool enabled = true) noexcept {
    WdfDeviceInitSetPowerPolicyOwnership(value_, enabled ? TRUE : FALSE);
    return *this;
  }

  /**
   * @brief Marks the device power path as pageable.
   * @return This initialization facade.
   */
  device_init &power_pageable() noexcept {
    WdfDeviceInitSetPowerPageable(value_);
    return *this;
  }

  /**
   * @brief Marks the device power path as nonpageable.
   * @return This initialization facade.
   */
  device_init &power_not_pageable() noexcept {
    WdfDeviceInitSetPowerNotPageable(value_);
    return *this;
  }

  /** @brief Marks this device as requiring inrush power sequencing. */
  device_init &power_inrush() noexcept {
    WdfDeviceInitSetPowerInrush(value_);
    return *this;
  }

  /** @brief Selects release-hardware ordering after prepare-hardware failure.
   */
  device_init &release_hardware_order_on_failure(
      WDF_RELEASE_HARDWARE_ORDER_ON_FAILURE order) noexcept {
    WdfDeviceInitSetReleaseHardwareOrderOnFailure(value_, order);
    return *this;
  }

  /** @brief Configures WDM remove-lock behavior for the device stack. */
  device_init &remove_lock_options(ULONG flags) noexcept {
    WDF_REMOVE_LOCK_OPTIONS options{};
    WDF_REMOVE_LOCK_OPTIONS_INIT(&options, flags);
    WdfDeviceInitSetRemoveLockOptions(value_, &options);
    return *this;
  }

  /** @brief Returns the physical device object supplied for this FDO. */
  PDEVICE_OBJECT physical_device_object() const noexcept {
    return WdfFdoInitWdmGetPhysicalDevice(value_);
  }

  /** @brief Applies FDO resource-filter callbacks before device creation. */
  template <class Callbacks>
  device_init &fdo_events(Callbacks &callbacks) noexcept {
    WdfFdoInitSetEventCallbacks(value_, callbacks.native());
    return *this;
  }

  /**
   * @brief Applies PnP and power callbacks before device creation.
   * @param callbacks Initialized callback configuration.
   * @return This initialization facade.
   */
  template <class Callbacks>
  device_init &pnp_power(Callbacks &callbacks) noexcept {
    WdfDeviceInitSetPnpPowerEventCallbacks(value_, callbacks.native());
    return *this;
  }

  /**
   * @brief Applies power-policy callbacks before device creation.
   * @param callbacks Initialized callback configuration.
   * @return This initialization facade.
   */
  template <class Callbacks>
  device_init &power_policy(Callbacks &callbacks) noexcept {
    WdfDeviceInitSetPowerPolicyEventCallbacks(value_, callbacks.native());
    return *this;
  }

  /**
   * @brief Configures the FDO's framework-created default child list.
   * @param config Typed child-identification and address configuration.
   * @param attributes Optional attributes for the default child-list object.
   * @return This initialization facade.
   */
  template <class Identification, class Address>
  device_init &
  default_child_list(child_list_config<Identification, Address> &config,
                     object_attributes *attributes = nullptr) noexcept;

  /**
   * @brief Registers a typed EvtIoInCallerContext callback.
   * @tparam Callback Non-capturing `void(device, request) noexcept` callback.
   * @return This initialization facade.
   */
  template <auto Callback> device_init &on_io_in_caller_context() noexcept {
    WdfDeviceInitSetIoInCallerContextCallback(
        value_,
        +[](WDFDEVICE native_device, WDFREQUEST native_request) noexcept {
          detail::invoke_callback<Callback>(device{native_device},
                                            request{native_request});
        });
    return *this;
  }

  /**
   * @brief Applies attributes to WDF request objects created for this device.
   * @param attributes Request object attributes.
   * @return This initialization facade.
   */
  device_init &request_attributes(object_attributes &attributes) noexcept {
    WdfDeviceInitSetRequestAttributes(value_, attributes.native());
    return *this;
  }

  /**
   * @brief Applies typed file-object callbacks before device creation.
   * @param config Typed file-object configuration.
   * @param attributes Optional attributes for each WDF file object.
   * @return This initialization facade.
   */
  template <class Context>
  device_init &file_objects(file_config<Context> &config) noexcept;

  /**
   * @brief Creates the PnP device and preserves NTSTATUS on failure.
   * @param attributes Optional WDF object attributes.
   * @return Non-owning device facade or WdfDeviceCreate failure status.
   */
  ntl::result<device>
  try_create(object_attributes *attributes = nullptr) noexcept {
    if (!value_)
      return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

    WDFDEVICE handle = WDF_NO_HANDLE;
    const NTSTATUS result = WdfDeviceCreate(
        &value_, attributes ? attributes->native() : nullptr, &handle);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(device{handle});
  }

  /**
   * @brief Creates a PnP device with a managed C++ context.
   * @tparam Context Context object constructed in WDF-owned storage.
   * @param attributes Optional WDF object attributes.
   * @param args Arguments passed to the context constructor.
   * @return Device facade or WdfDeviceCreate failure status.
   *
   * Context construction and destruction must be noexcept. WDF invokes the
   * destructor when the device object is destroyed.
   */
  template <class Context, class... Args>
  ntl::result<device> try_create(object_attributes *attributes,
                                 Args &&...args) noexcept {
    if (!value_)
      return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

    object_attributes local_attributes;
    object_attributes &effective = attributes ? *attributes : local_attributes;
    effective.template prepare_context<Context>();

    WDFDEVICE handle = WDF_NO_HANDLE;
    const NTSTATUS result =
        WdfDeviceCreate(&value_, effective.native(), &handle);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);

    effective.template construct_context<Context>(
        reinterpret_cast<WDFOBJECT>(handle), std::forward<Args>(args)...);
    return ntl::ok(device{handle});
  }

  /** @brief Creates a PnP device with a default-constructed C++ context. */
  template <class Context> ntl::result<device> try_create() noexcept {
    return try_create<Context>(nullptr);
  }

  /**
   * @brief Creates the PnP device and throws on failure.
   * @param attributes Optional WDF object attributes.
   * @return Non-owning device facade.
   * @throw ntl::exception when WdfDeviceCreate fails.
   */
  device create(object_attributes *attributes = nullptr) {
    auto created = try_create(attributes);
    if (!created)
      throw ntl::exception(created.status(), "WdfDeviceCreate failed.");
    return std::move(created).value();
  }

  /** @brief Creates a device with a managed context and throws on failure. */
  template <class Context, class... Args>
  device create(object_attributes *attributes, Args &&...args) {
    auto created = try_create<Context>(attributes, std::forward<Args>(args)...);
    if (!created)
      throw ntl::exception(created.status(), "WdfDeviceCreate failed.");
    return std::move(created).value();
  }

  /** @brief Creates a device with a default-constructed managed context. */
  template <class Context> device create() { return create<Context>(nullptr); }

  /** @brief Returns the currently wrapped initialization pointer. */
  PWDFDEVICE_INIT native_handle() const noexcept { return value_; }

protected:
  /** @brief Returns the storage consumed by WdfDeviceCreate. */
  PWDFDEVICE_INIT *native_handle_address() noexcept { return &value_; }

private:
  PWDFDEVICE_INIT value_;
};

/**
 * @brief Owns a PWDFDEVICE_INIT allocated for a KMDF control device.
 *
 * WdfDeviceCreate consumes the pointer on success. If creation is not
 * attempted or fails without consuming it, the destructor calls
 * WdfDeviceInitFree.
 */
class control_device_init {
public:
  /**
   * @brief Allocates a control-device initialization object.
   * @param driver WDF driver that will own the control device.
   * @param sddl Security descriptor string for the control device.
   * @return Owned initialization object or STATUS_INSUFFICIENT_RESOURCES.
   */
  template <class Driver>
  static ntl::result<control_device_init>
  try_allocate(const Driver &driver, PCUNICODE_STRING sddl) noexcept {
    PWDFDEVICE_INIT value =
        WdfControlDeviceInitAllocate(driver.native_handle(), sddl);
    if (!value)
      return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
    return ntl::ok(control_device_init{value});
  }

  control_device_init(const control_device_init &) = delete;
  control_device_init &operator=(const control_device_init &) = delete;

  /**
   * @brief Transfers ownership from another initialization wrapper.
   */
  control_device_init(control_device_init &&other) noexcept
      : value_(std::exchange(other.value_, nullptr)) {}

  /**
   * @brief Releases any current initialization object and takes another.
   */
  control_device_init &operator=(control_device_init &&other) noexcept {
    if (this != &other) {
      reset();
      value_ = std::exchange(other.value_, nullptr);
    }
    return *this;
  }

  /**
   * @brief Frees an unconsumed control-device initialization object.
   */
  ~control_device_init() { reset(); }

  /**
   * @brief Assigns a native device name.
   * @param name Native device name.
   * @return WdfDeviceInitAssignName status.
   */
  ntl::status assign_name(PCUNICODE_STRING name) noexcept {
    return WdfDeviceInitAssignName(value_, name);
  }

  /**
   * @brief Assigns a native device name.
   * @param name Device name, for example \\Device\\Sample.
   * @return WdfDeviceInitAssignName status.
   */
  ntl::status assign_name(const std::wstring &name) {
    ntl::unicode_string native_name(name);
    return assign_name(&*native_name);
  }

  /**
   * @brief Sets the WDM device type.
   * @param type FILE_DEVICE_* value.
   * @return This initialization object.
   */
  control_device_init &device_type(ULONG type) noexcept {
    WdfDeviceInitSetDeviceType(value_, type);
    return *this;
  }

  /**
   * @brief Sets the WDF I/O buffering model.
   * @param type WDF device I/O type.
   * @return This initialization object.
   */
  control_device_init &io_type(WDF_DEVICE_IO_TYPE type) noexcept {
    WdfDeviceInitSetIoType(value_, type);
    return *this;
  }

  /**
   * @brief Registers a typed control-device shutdown notification.
   * @tparam Callback Non-capturing `void(device) noexcept` callback.
   */
  template <auto Callback>
  control_device_init &on_shutdown(UCHAR flags) noexcept {
    WdfControlDeviceInitSetShutdownNotification(
        value_,
        +[](WDFDEVICE native_device) noexcept {
          detail::invoke_callback<Callback>(device{native_device});
        },
        flags);
    return *this;
  }

  /**
   * @brief Applies typed file-object callbacks before control-device creation.
   * @param config Typed file-object configuration.
   * @param attributes Optional attributes for each WDF file object.
   * @return This initialization object.
   */
  template <class Context>
  control_device_init &file_objects(file_config<Context> &config) noexcept;

  /**
   * @brief Creates the WDF device and preserves NTSTATUS on failure.
   * @param attributes Optional WDF object attributes.
   * @return Non-owning device facade or WdfDeviceCreate failure status.
   */
  ntl::result<device>
  try_create(object_attributes *attributes = nullptr) noexcept {
    if (!value_)
      return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

    WDFDEVICE handle = WDF_NO_HANDLE;
    const NTSTATUS result = WdfDeviceCreate(
        &value_, attributes ? attributes->native() : nullptr, &handle);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);
    return ntl::ok(device{handle});
  }

  /**
   * @brief Creates a control device with a managed C++ context.
   * @tparam Context Context object constructed in WDF-owned storage.
   * @param attributes Optional WDF object attributes.
   * @param args Arguments passed to the context constructor.
   * @return Device facade or WdfDeviceCreate failure status.
   */
  template <class Context, class... Args>
  ntl::result<device> try_create(object_attributes *attributes,
                                 Args &&...args) noexcept {
    if (!value_)
      return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);

    object_attributes local_attributes;
    object_attributes &effective = attributes ? *attributes : local_attributes;
    effective.template prepare_context<Context>();

    WDFDEVICE handle = WDF_NO_HANDLE;
    const NTSTATUS result =
        WdfDeviceCreate(&value_, effective.native(), &handle);
    if (!NT_SUCCESS(result))
      return ntl::unexpected(result);

    effective.template construct_context<Context>(
        reinterpret_cast<WDFOBJECT>(handle), std::forward<Args>(args)...);
    return ntl::ok(device{handle});
  }

  /** @brief Creates a control device with a default C++ context. */
  template <class Context> ntl::result<device> try_create() noexcept {
    return try_create<Context>(nullptr);
  }

  /**
   * @brief Creates the WDF device and throws on failure.
   * @param attributes Optional WDF object attributes.
   * @return Non-owning device facade.
   * @throw ntl::exception when WdfDeviceCreate fails.
   */
  device create(object_attributes *attributes = nullptr) {
    auto created = try_create(attributes);
    if (!created)
      throw ntl::exception(created.status(), "WdfDeviceCreate failed.");
    return std::move(created).value();
  }

  /** @brief Creates a control device with context and throws on failure. */
  template <class Context, class... Args>
  device create(object_attributes *attributes, Args &&...args) {
    auto created = try_create<Context>(attributes, std::forward<Args>(args)...);
    if (!created)
      throw ntl::exception(created.status(), "WdfDeviceCreate failed.");
    return std::move(created).value();
  }

  /** @brief Creates a control device with a default C++ context. */
  template <class Context> device create() { return create<Context>(nullptr); }

  /**
   * @brief Returns the native initialization pointer.
   */
  PWDFDEVICE_INIT native_handle() const noexcept { return value_; }

private:
  explicit control_device_init(PWDFDEVICE_INIT value) noexcept
      : value_(value) {}

  void reset() noexcept {
    if (value_)
      WdfDeviceInitFree(value_);
    value_ = nullptr;
  }

  PWDFDEVICE_INIT value_ = nullptr;
};
} // namespace ntl::kmdf
