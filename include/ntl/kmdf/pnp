/** @brief Identifies whether a resource descriptor came from the raw or
 * translated list. */
enum class resource_origin { raw, translated };

/** @brief Physical address range assigned to a memory or port resource. */
struct address_resource {
  PHYSICAL_ADDRESS start{};
  ULONGLONG length = 0;
};

/** @brief Interrupt assignment independent of the native descriptor union
 * layout. */
struct interrupt_resource {
  bool message_signaled = false;
  resource_origin origin = resource_origin::translated;
  ULONG level = 0;
  USHORT group = 0;
  ULONG vector = 0;
  KAFFINITY affinity = 0;
  USHORT message_count = 0;
};

/** @brief DMA channel assignment independent of legacy and DMA v3 layouts. */
struct dma_resource {
  bool version_3 = false;
  ULONG channel = 0;
  ULONG port_or_request_line = 0;
  UCHAR transfer_width = 0;
};

/** @brief Connection resource identity used by GPIO, serial, and
 * function-config resources. */
struct connection_resource {
  UCHAR connection_class = 0;
  UCHAR connection_type = 0;
  std::uint64_t id = 0;
};

/** @brief Non-owning typed facade for one CM_PARTIAL_RESOURCE_DESCRIPTOR. */
class resource_descriptor {
public:
  /** @brief Creates an empty descriptor facade. */
  resource_descriptor() noexcept = default;

  /** @brief Wraps a native descriptor without taking ownership. */
  resource_descriptor(PCM_PARTIAL_RESOURCE_DESCRIPTOR descriptor,
                      resource_origin origin) noexcept
      : descriptor_(descriptor), origin_(origin) {}

  /** @brief Returns the CM_RESOURCE_TYPE value. */
  UCHAR type() const noexcept {
    return descriptor_ ? descriptor_->Type : CmResourceTypeNull;
  }

  /** @brief Returns the native sharing disposition. */
  CM_SHARE_DISPOSITION share_disposition() const noexcept {
    return descriptor_ ? static_cast<CM_SHARE_DISPOSITION>(
                             descriptor_->ShareDisposition)
                       : CmResourceShareUndetermined;
  }

  /** @brief Returns the type-specific CM_RESOURCE_* flags. */
  USHORT flags() const noexcept { return descriptor_ ? descriptor_->Flags : 0; }

  /** @brief Returns the list from which this descriptor originated. */
  resource_origin origin() const noexcept { return origin_; }

  /** @brief Returns a memory range when this is a memory descriptor. */
  std::optional<address_resource> memory() const noexcept {
    if (!descriptor_)
      return std::nullopt;

    if (descriptor_->Type == CmResourceTypeMemory)
      return address_resource{descriptor_->u.Memory.Start,
                              descriptor_->u.Memory.Length};

    if (descriptor_->Type != CmResourceTypeMemoryLarge)
      return std::nullopt;

    const USHORT large_type = descriptor_->Flags & CM_RESOURCE_MEMORY_LARGE;
    if (large_type != CM_RESOURCE_MEMORY_LARGE_40 &&
        large_type != CM_RESOURCE_MEMORY_LARGE_48 &&
        large_type != CM_RESOURCE_MEMORY_LARGE_64) {
      return std::nullopt;
    }

    ULONGLONG start = 0;
    const ULONGLONG length = RtlCmDecodeMemIoResource(descriptor_, &start);
    PHYSICAL_ADDRESS physical_start{};
    physical_start.QuadPart = static_cast<LONGLONG>(start);
    return address_resource{physical_start, length};
  }

  /** @brief Returns a port range when this is a port descriptor. */
  std::optional<address_resource> port() const noexcept {
    if (!descriptor_ || descriptor_->Type != CmResourceTypePort)
      return std::nullopt;
    return address_resource{descriptor_->u.Port.Start,
                            descriptor_->u.Port.Length};
  }

  /** @brief Returns a normalized interrupt assignment. */
  std::optional<interrupt_resource> interrupt() const noexcept {
    if (!descriptor_ || descriptor_->Type != CmResourceTypeInterrupt)
      return std::nullopt;

    interrupt_resource result{};
    result.message_signaled =
        (descriptor_->Flags & CM_RESOURCE_INTERRUPT_MESSAGE) != 0;
    result.origin = origin_;

    if (!result.message_signaled) {
      result.level = descriptor_->u.Interrupt.Level;
#if defined(NT_PROCESSOR_GROUPS)
      result.group = descriptor_->u.Interrupt.Group;
#endif
      result.vector = descriptor_->u.Interrupt.Vector;
      result.affinity = descriptor_->u.Interrupt.Affinity;
      return result;
    }

    if (origin_ == resource_origin::raw) {
#if defined(NT_PROCESSOR_GROUPS)
      result.group = descriptor_->u.MessageInterrupt.Raw.Group;
#endif
      result.message_count = descriptor_->u.MessageInterrupt.Raw.MessageCount;
      result.vector = descriptor_->u.MessageInterrupt.Raw.Vector;
      result.affinity = descriptor_->u.MessageInterrupt.Raw.Affinity;
    } else {
      result.level = descriptor_->u.MessageInterrupt.Translated.Level;
#if defined(NT_PROCESSOR_GROUPS)
      result.group = descriptor_->u.MessageInterrupt.Translated.Group;
#endif
      result.vector = descriptor_->u.MessageInterrupt.Translated.Vector;
      result.affinity = descriptor_->u.MessageInterrupt.Translated.Affinity;
    }
    return result;
  }

  /** @brief Returns a normalized DMA channel assignment. */
  std::optional<dma_resource> dma() const noexcept {
    if (!descriptor_ || descriptor_->Type != CmResourceTypeDma)
      return std::nullopt;

    dma_resource result{};
    result.version_3 = (descriptor_->Flags & CM_RESOURCE_DMA_V3) != 0;
    if (result.version_3) {
      result.channel = descriptor_->u.DmaV3.Channel;
      result.port_or_request_line = descriptor_->u.DmaV3.RequestLine;
      result.transfer_width = descriptor_->u.DmaV3.TransferWidth;
    } else {
      result.channel = descriptor_->u.Dma.Channel;
      result.port_or_request_line = descriptor_->u.Dma.Port;
    }
    return result;
  }

  /** @brief Returns a normalized connection identity. */
  std::optional<connection_resource> connection() const noexcept {
    if (!descriptor_ || descriptor_->Type != CmResourceTypeConnection)
      return std::nullopt;
    return connection_resource{
        descriptor_->u.Connection.Class, descriptor_->u.Connection.Type,
        (static_cast<std::uint64_t>(descriptor_->u.Connection.IdHighPart)
         << 32) |
            descriptor_->u.Connection.IdLowPart};
  }

  /** @brief Returns the native descriptor for uncommon resource types. */
  PCM_PARTIAL_RESOURCE_DESCRIPTOR native() const noexcept {
    return descriptor_;
  }

  /** @brief Returns true when a native descriptor is present. */
  explicit operator bool() const noexcept { return descriptor_ != nullptr; }

private:
  PCM_PARTIAL_RESOURCE_DESCRIPTOR descriptor_ = nullptr;
  resource_origin origin_ = resource_origin::translated;
};

/** @brief Non-owning iterable facade for a KMDF resource list. */
class resource_list {
public:
  /** @brief Wraps a native resource list without taking ownership. */
  explicit resource_list(
      WDFCMRESLIST handle,
      resource_origin origin = resource_origin::translated) noexcept
      : handle_(handle), origin_(origin) {}

  /** @brief Returns the number of resource descriptors. */
  ULONG size() const noexcept { return WdfCmResourceListGetCount(handle_); }

  /** @brief Returns a typed descriptor, or an empty facade for an invalid
   * index. */
  resource_descriptor at(ULONG index) const noexcept {
    return resource_descriptor{WdfCmResourceListGetDescriptor(handle_, index),
                               origin_};
  }

  /** @brief Returns a typed descriptor by index. */
  resource_descriptor operator[](ULONG index) const noexcept {
    return at(index);
  }

  /** @brief Input iterator over typed resource descriptors. */
  class iterator {
  public:
    using iterator_category = std::input_iterator_tag;
    using value_type = resource_descriptor;
    using difference_type = std::ptrdiff_t;
    using pointer = void;
    using reference = resource_descriptor;

    iterator() noexcept = default;
    iterator(const resource_list *list, ULONG index) noexcept
        : list_(list), index_(index) {}

    resource_descriptor operator*() const noexcept { return list_->at(index_); }
    iterator &operator++() noexcept {
      ++index_;
      return *this;
    }
    iterator operator++(int) noexcept {
      iterator previous = *this;
      ++*this;
      return previous;
    }
    friend bool operator==(const iterator &left,
                           const iterator &right) noexcept {
      return left.list_ == right.list_ && left.index_ == right.index_;
    }
    friend bool operator!=(const iterator &left,
                           const iterator &right) noexcept {
      return !(left == right);
    }

  private:
    const resource_list *list_ = nullptr;
    ULONG index_ = 0;
  };

  /** @brief Returns an iterator to the first descriptor. */
  iterator begin() const noexcept { return iterator{this, 0}; }

  /** @brief Returns an iterator one past the final descriptor. */
  iterator end() const noexcept { return iterator{this, size()}; }

  /** @brief Returns the native resource-list handle. */
  WDFCMRESLIST native_handle() const noexcept { return handle_; }

  /** @brief Returns whether this is the raw or translated list. */
  resource_origin origin() const noexcept { return origin_; }

private:
  WDFCMRESLIST handle_;
  resource_origin origin_;
};

/**
 * @brief Initializes and configures WDF_PNPPOWER_EVENT_CALLBACKS.
 *
 * Typed callbacks receive non-owning NTL facades. Native WDF configuration
 * remains available through native().
 */
class pnp_power_callbacks {
public:
  /** @brief Initializes all PnP and power callbacks to WDF defaults. */
  pnp_power_callbacks() noexcept { WDF_PNPPOWER_EVENT_CALLBACKS_INIT(&value_); }

  /**
   * @brief Registers EvtDevicePrepareHardware.
   * @tparam Callback Typed noexcept callback.
   * @return This callback configuration.
   */
  template <auto Callback> pnp_power_callbacks &on_prepare_hardware() noexcept {
    value_.EvtDevicePrepareHardware =
        +[](WDFDEVICE native_device, WDFCMRESLIST native_raw,
            WDFCMRESLIST native_translated) noexcept -> NTSTATUS {
      return detail::invoke_status_callback<Callback>(
          device{native_device},
          resource_list{native_raw, resource_origin::raw},
          resource_list{native_translated, resource_origin::translated});
    };
    return *this;
  }

