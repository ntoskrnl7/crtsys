/** @brief Configures runtime-idle behavior while the system remains in S0. */
class idle_policy {
public:
  /** @brief Initializes the policy with WDF defaults for the stated capability.
   */
  explicit idle_policy(
      WDF_POWER_POLICY_S0_IDLE_CAPABILITIES capability) noexcept {
    WDF_DEVICE_POWER_POLICY_IDLE_SETTINGS_INIT(&value_, capability);
  }

  /** @brief Selects the device power state entered while idle. */
  idle_policy &device_state(DEVICE_POWER_STATE state) noexcept {
    value_.DxState = state;
    return *this;
  }

  /** @brief Sets the idle timeout and how WDF interprets it. */
  idle_policy &timeout(ULONG milliseconds,
                       WDF_POWER_POLICY_IDLE_TIMEOUT_TYPE type =
                           DriverManagedIdleTimeout) noexcept {
    value_.IdleTimeout = milliseconds;
    value_.IdleTimeoutType = type;
    return *this;
  }

  /** @brief Configures whether users may override idle policy. */
  idle_policy &
  user_control(WDF_POWER_POLICY_S0_IDLE_USER_CONTROL control) noexcept {
    value_.UserControlOfIdleSettings = control;
    return *this;
  }

  /** @brief Explicitly enables or disables runtime idle. */
  idle_policy &enabled(bool enabled) noexcept {
    value_.Enabled = enabled ? WdfTrue : WdfFalse;
    return *this;
  }

  /** @brief Restores WDF's default runtime-idle enablement policy. */
  idle_policy &use_default_enablement() noexcept {
    value_.Enabled = WdfUseDefault;
    return *this;
  }

  /** @brief Configures whether an idle device powers up on system wake. */
  idle_policy &power_up_on_system_wake(WDF_TRI_STATE value) noexcept {
    value_.PowerUpIdleDeviceOnSystemWake = value;
    return *this;
  }

  /** @brief Configures whether S0 idle excludes D3cold. */
  idle_policy &exclude_d3_cold(WDF_TRI_STATE value) noexcept {
    value_.ExcludeD3Cold = value;
    return *this;
  }

  /** @brief Applies this policy to a device and preserves WDF's NTSTATUS. */
  ntl::status try_apply(device target) noexcept {
    return WdfDeviceAssignS0IdleSettings(target.native_handle(), &value_);
  }

  /** @brief Returns the mutable native settings for uncommon fields. */
  PWDF_DEVICE_POWER_POLICY_IDLE_SETTINGS native() noexcept { return &value_; }

private:
  WDF_DEVICE_POWER_POLICY_IDLE_SETTINGS value_{};
};

/** @brief Configures device wake behavior while the system is in Sx. */
class wake_policy {
public:
  /** @brief Initializes the policy with WDF defaults. */
  wake_policy() noexcept {
    WDF_DEVICE_POWER_POLICY_WAKE_SETTINGS_INIT(&value_);
  }

  /** @brief Selects the device power state used while armed for wake. */
  wake_policy &device_state(DEVICE_POWER_STATE state) noexcept {
    value_.DxState = state;
    return *this;
  }

  /** @brief Configures whether users may override wake policy. */
  wake_policy &
  user_control(WDF_POWER_POLICY_SX_WAKE_USER_CONTROL control) noexcept {
    value_.UserControlOfWakeSettings = control;
    return *this;
  }

  /** @brief Explicitly enables or disables wake from Sx. */
  wake_policy &enabled(bool enabled) noexcept {
    value_.Enabled = enabled ? WdfTrue : WdfFalse;
    return *this;
  }

  /** @brief Restores WDF's default wake enablement policy. */
  wake_policy &use_default_enablement() noexcept {
    value_.Enabled = WdfUseDefault;
    return *this;
  }

  /** @brief Arms this parent when one of its children is armed for wake. */
  wake_policy &arm_for_armed_children(bool enabled = true) noexcept {
    value_.ArmForWakeIfChildrenAreArmedForWake = enabled ? TRUE : FALSE;
    return *this;
  }

  /** @brief Propagates successful parent wake indication to child devices. */
  wake_policy &indicate_child_wake(bool enabled = true) noexcept {
    value_.IndicateChildWakeOnParentWake = enabled ? TRUE : FALSE;
    return *this;
  }

  /** @brief Applies this policy to a device and preserves WDF's NTSTATUS. */
  ntl::status try_apply(device target) noexcept {
    return WdfDeviceAssignSxWakeSettings(target.native_handle(), &value_);
  }

  /** @brief Returns the mutable native settings for uncommon fields. */
  PWDF_DEVICE_POWER_POLICY_WAKE_SETTINGS native() noexcept { return &value_; }

private:
  WDF_DEVICE_POWER_POLICY_WAKE_SETTINGS value_{};
};
} // namespace ntl::kmdf
