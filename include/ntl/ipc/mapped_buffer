/**
 * @brief Non-owning view of an already locked MDL.
 *
 * The caller keeps the MDL and its described pages alive until every returned
 * mapping is closed. This type records ownership; it does not make an unsafe
 * kernel-pool MDL suitable for exposure to an untrusted process.
 */
class borrowed_mdl_view {
public:
  constexpr borrowed_mdl_view() noexcept = default;
  explicit constexpr borrowed_mdl_view(PMDL mdl) noexcept : mdl_(mdl) {}
  explicit constexpr operator bool() const noexcept { return mdl_ != nullptr; }
  PMDL native() const noexcept { return mdl_; }
  std::size_t size() const noexcept {
    return mdl_ ? static_cast<std::size_t>(MmGetMdlByteCount(mdl_)) : 0;
  }

private:
  PMDL mdl_ = nullptr;
};

/** Per-client limits for user VADs retained by a connection. */
struct process_connection_limits {
  std::size_t max_mappings = 256;
  std::size_t max_mapped_bytes = 512u * 1024u * 1024u;
};

namespace detail {
class mapped_mdl_state;
using retained_cleanup_routine =
    ntl::status (*)(std::shared_ptr<void> &) noexcept;

/**
 * Reports whether mapping the complete MDL exposes exactly the requested
 * pages, with no leading/trailing bytes outside the logical range.
 */
inline bool mdl_mapping_is_page_isolated(PMDL mdl, std::size_t offset,
                                         std::size_t length) noexcept {
  if (!mdl || offset != 0 || length == 0 ||
      length != static_cast<std::size_t>(MmGetMdlByteCount(mdl)) ||
      MmGetMdlByteOffset(mdl) != 0)
    return false;
  return length % PAGE_SIZE == 0;
}

inline bool mdl_describes_resident_pages(PMDL mdl) noexcept {
  return mdl &&
         (mdl->MdlFlags &
          (MDL_PAGES_LOCKED | MDL_SOURCE_IS_NONPAGED_POOL | MDL_PARTIAL)) != 0;
}

inline bool mdl_mapping_charge(PMDL mdl, std::size_t &bytes) noexcept {
  if (!mdl)
    return false;
  const auto byte_count = static_cast<std::uint64_t>(MmGetMdlByteCount(mdl));
  const auto byte_offset = static_cast<std::uint64_t>(MmGetMdlByteOffset(mdl));
  if (byte_count == 0)
    return false;
  const auto pages =
      (byte_offset + byte_count + PAGE_SIZE - 1u) / PAGE_SIZE;
  const auto span = pages * PAGE_SIZE;
  if (span > static_cast<std::uint64_t>(SIZE_MAX))
    return false;
  bytes = static_cast<std::size_t>(span);
  return true;
}

inline bool isolated_page_charge(std::size_t bytes,
                                 std::size_t &charge) noexcept {
  if (bytes == 0)
    return false;
  const auto span =
      ((static_cast<std::uint64_t>(bytes) + PAGE_SIZE - 1u) / PAGE_SIZE) *
      PAGE_SIZE;
  if (span > static_cast<std::uint64_t>(SIZE_MAX))
    return false;
  charge = static_cast<std::size_t>(span);
  return true;
}

inline std::atomic<std::uint64_t> connection_generation_seed{0};
inline constexpr ULONG mapped_state_pool_tag = ntl::pool_tag("mMpN");
inline constexpr ULONG page_buffer_pool_tag = ntl::pool_tag("bMpN");

inline std::uint64_t next_connection_generation() noexcept {
  for (;;) {
    const auto value =
        connection_generation_seed.fetch_add(1, std::memory_order_relaxed) + 1;
    if (value != 0)
      return value;
  }
}

struct process_connection_state {
  process_connection_state(ntl::unique_object<PEPROCESS> process_value,
                           HANDLE process_id_value,
                           process_connection_limits limits_value,
                           std::uint64_t generation_value) noexcept
      : process(std::move(process_value)), process_id(process_id_value),
        limits(limits_value), generation(generation_value) {
    KeInitializeEvent(&mapping_attempts_idle, NotificationEvent, TRUE);
  }

  process_connection_state(const process_connection_state &) = delete;
  process_connection_state &
  operator=(const process_connection_state &) = delete;
  ~process_connection_state();

  ntl::result<std::pair<std::uint64_t, std::uint64_t>>
  register_mapping(const std::shared_ptr<mapped_mdl_state> &mapping) noexcept;
  bool begin_mapping_attempt() noexcept;
  void end_mapping_attempt() noexcept;
  void unregister_mapping(std::uint64_t id,
                          const mapped_mdl_state *expected) noexcept;
  ntl::status close_all() noexcept;
  std::size_t mapping_count() const noexcept;
  bool accepts_mappings() const noexcept;
  std::uint64_t current_generation() const noexcept;

  ntl::unique_object<PEPROCESS> process;
  HANDLE process_id = nullptr;
  std::mutex close_lock;
  mutable std::mutex lock;
  std::unordered_map<std::uint64_t, std::shared_ptr<mapped_mdl_state>> mappings;
  process_connection_limits limits{};
  std::size_t mapped_bytes = 0;
  std::uint64_t next_id = 0;
  std::uint64_t generation = 0;
  std::size_t active_mapping_attempts = 0;
  KEVENT mapping_attempts_idle{};
  bool accepting = true;
  bool close_started = false;
  std::atomic<NTSTATUS> rundown_status{STATUS_SUCCESS};
  std::atomic<bool> rundown_complete{false};
};
} // namespace detail

/**
 * @brief Connection-scoped owner of process mappings and disconnect rundown.
 *
 * Capture this while handling the intended client's connect/create request.
 * close() rejects new mappings and synchronously unmaps every registered view.
 */
class process_connection {
public:
  process_connection() noexcept = default;

  [[nodiscard]] static ntl::result<process_connection>
  try_capture_current_process(process_connection_limits limits = {}) noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);
    if (limits.max_mappings == 0 || limits.max_mapped_bytes == 0)
      return ntl::unexpected(STATUS_INVALID_PARAMETER);
    PEPROCESS process = PsGetCurrentProcess();
    if (!process)
      return ntl::unexpected(STATUS_INVALID_CID);
    ObReferenceObject(process);
    ntl::unique_object<PEPROCESS> process_owner{process};
    const HANDLE process_id = detail::query_process_id(process);
    if (!process_id)
      return ntl::unexpected(STATUS_INVALID_CID);
    try {
      auto state = std::make_shared<detail::process_connection_state>(
          std::move(process_owner), process_id, limits,
          detail::next_connection_generation());
      return ntl::ok(process_connection{std::move(state)});
    } catch (...) {
      return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
    }
  }

  explicit operator bool() const noexcept {
    return static_cast<bool>(state_) && static_cast<bool>(state_->process);
  }

  PEPROCESS process() const noexcept {
    return state_ ? state_->process.get() : nullptr;
  }
  HANDLE process_id() const noexcept {
    return state_ ? state_->process_id : nullptr;
  }
  std::size_t mapping_count() const noexcept {
    return state_ ? state_->mapping_count() : 0;
  }
  bool accepts_mappings() const noexcept {
    return state_ && state_->accepts_mappings();
  }
  std::uint64_t generation() const noexcept {
    return state_ ? state_->current_generation() : 0;
  }

  /** @brief Rejects new mappings and synchronously removes every live view. */
  ntl::status close() noexcept {
    return state_ ? state_->close_all() : ntl::status{STATUS_SUCCESS};
  }

private:
  friend class mapped_buffer_view;
  friend ntl::result<mapped_buffer_view>
  try_map_mdl(borrowed_mdl_view, std::size_t, std::size_t, process_connection &,
              map_access, MEMORY_CACHING_TYPE) noexcept;
  friend ntl::result<mapped_buffer_view>
  detail_try_map_mdl_retained(PMDL, std::size_t, std::size_t,
                              process_connection &, map_access,
                              MEMORY_CACHING_TYPE, std::shared_ptr<void>,
                              detail::retained_cleanup_routine) noexcept;

  explicit process_connection(
      std::shared_ptr<detail::process_connection_state> state) noexcept
      : state_(std::move(state)) {}

  std::shared_ptr<detail::process_connection_state> state_;
};

namespace detail {

struct map_call_context {
  PMDL mdl = nullptr;
  MEMORY_CACHING_TYPE cache = MmCached;
  ULONG priority = NormalPagePriority;
  void *address = nullptr;
};

inline NTSTATUS NTAPI map_call(void *opaque) noexcept {
  auto *const context = static_cast<map_call_context *>(opaque);
  const auto guarded = ntl::seh::try_except([&]() {
    context->address =
        MmMapLockedPagesSpecifyCache(context->mdl, UserMode, context->cache,
                                     nullptr, FALSE, context->priority);
  });
  if (!std::get<0>(guarded))
    return static_cast<NTSTATUS>(std::get<1>(guarded));
  return context->address ? STATUS_SUCCESS : STATUS_INSUFFICIENT_RESOURCES;
}

struct unmap_call_context {
  PMDL mdl = nullptr;
  void *address = nullptr;
};

inline NTSTATUS NTAPI unmap_call(void *opaque) noexcept {
  auto *const context = static_cast<unmap_call_context *>(opaque);
  const auto guarded = ntl::seh::try_except(
      [&]() { MmUnmapLockedPages(context->address, context->mdl); });
  return std::get<0>(guarded) ? STATUS_SUCCESS
                              : static_cast<NTSTATUS>(std::get<1>(guarded));
}

class mapped_mdl_state : public std::enable_shared_from_this<mapped_mdl_state> {
public:
  mapped_mdl_state(PEPROCESS process, PMDL mdl, void *address,
                   std::size_t mapped_bytes, std::size_t mapping_charge_bytes,
                   map_access native_access,
                   std::weak_ptr<process_connection_state> connection,
                   std::shared_ptr<void> keepalive,
                   retained_cleanup_routine retained_cleanup) noexcept
      : process_(process), mdl_(mdl), address_(address),
        mapped_bytes_(mapped_bytes),
        mapping_charge_bytes_(mapping_charge_bytes),
        native_access_(native_access),
        connection_(std::move(connection)), keepalive_(std::move(keepalive)),
        retained_cleanup_(retained_cleanup) {
    ObReferenceObject(process_);
    KeInitializeEvent(&close_event_, NotificationEvent, TRUE);
  }

  mapped_mdl_state(const mapped_mdl_state &) = delete;
  mapped_mdl_state &operator=(const mapped_mdl_state &) = delete;

  ~mapped_mdl_state() {
    NT_ASSERT(KeGetCurrentIrql() == PASSIVE_LEVEL);
    (void)close();
    if (process_)
      ObDereferenceObject(process_);
  }

  void identity(std::uint64_t id, std::uint64_t generation) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    id_ = id;
    generation_ = generation;
  }

  ntl::status close() noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return STATUS_INVALID_DEVICE_STATE;

    void *address = nullptr;
    PMDL mdl = nullptr;
    std::uint64_t id = 0;
    for (;;) {
      bool wait = false;
      {
        std::lock_guard<std::mutex> guard(lock_);
        if (closing_) {
          wait = true;
        } else if (!address_) {
          return close_status_;
        } else {
          closing_ = true;
          KeClearEvent(&close_event_);
          address = address_;
          mdl = mdl_;
          id = id_;
        }
      }
      if (!wait)
        break;
      (void)KeWaitForSingleObject(&close_event_, Executive, KernelMode, FALSE,
                                  nullptr);
    }

    unmap_call_context context{mdl, address};
    NTSTATUS status =
        detail::invoke_in_process(process_, &unmap_call, &context);
    if (status == STATUS_PROCESS_IS_TERMINATING) {
      if (PsGetCurrentProcess() == process_) {
        // The current address space is still usable for this call even though
        // the exit rundown can no longer be acquired.
        status = unmap_call(&context);
      } else {
        // Do not release the MDL/pages until process teardown has removed the
        // user VAD. EPROCESS is a waitable dispatcher object.
        status = KeWaitForSingleObject(process_, Executive, KernelMode, FALSE,
                                       nullptr);
      }
    }

    {
      std::lock_guard<std::mutex> guard(lock_);
      if (!NT_SUCCESS(status)) {
        closing_ = false;
        KeSetEvent(&close_event_, IO_NO_INCREMENT, FALSE);
        return status;
      }
      address_ = nullptr;
      mdl_ = nullptr;
    }

    // Copy-back/owned-MDL cleanup runs only after the user mapping is gone.
    NTSTATUS cleanup_status = STATUS_SUCCESS;
    if (retained_cleanup_)
      cleanup_status = static_cast<NTSTATUS>(retained_cleanup_(keepalive_));
    else
      keepalive_.reset();
    if (const auto connection = connection_.lock())
      connection->unregister_mapping(id, this);
    {
      std::lock_guard<std::mutex> guard(lock_);
      close_status_ = cleanup_status;
      closing_ = false;
      KeSetEvent(&close_event_, IO_NO_INCREMENT, FALSE);
    }
    return NT_SUCCESS(cleanup_status) ? status : cleanup_status;
  }

  mapped_buffer_descriptor
  descriptor(std::size_t offset, std::size_t length,
             map_access logical_access) const noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (!address_ || closing_ || id_ == 0 || generation_ == 0 || length == 0 ||
        offset > mapped_bytes_ || length > mapped_bytes_ - offset)
      return {};
    if (logical_access != map_access::read &&
        logical_access != map_access::read_write)
      return {};
    if (logical_access == map_access::read_write &&
        native_access_ != map_access::read_write)
      return {};
    const auto address = reinterpret_cast<std::uintptr_t>(
        static_cast<unsigned char *>(address_) + offset);
    return mapped_buffer_descriptor{id_,
                                    generation_,
                                    static_cast<std::uint64_t>(address),
                                    static_cast<std::uint64_t>(length),
                                    static_cast<std::uint32_t>(logical_access),
                                    0};
  }

  void *address(std::size_t offset, std::size_t length) const noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (!address_ || closing_ || length == 0 || offset > mapped_bytes_ ||
        length > mapped_bytes_ - offset)
      return nullptr;
    return static_cast<unsigned char *>(address_) + offset;
  }

  std::size_t mapped_bytes() const noexcept { return mapped_bytes_; }
  std::size_t mapping_charge_bytes() const noexcept {
    return mapping_charge_bytes_;
  }

  bool is_open() const noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    return address_ != nullptr;
  }

private:
  PEPROCESS process_ = nullptr;
  mutable std::mutex lock_;
  PMDL mdl_ = nullptr;
  void *address_ = nullptr;
  bool closing_ = false;
  ntl::status close_status_{STATUS_SUCCESS};
  KEVENT close_event_{};
  std::size_t mapped_bytes_ = 0;
  std::size_t mapping_charge_bytes_ = 0;
  map_access native_access_ = map_access::read;
  std::uint64_t id_ = 0;
  std::uint64_t generation_ = 0;
  std::weak_ptr<process_connection_state> connection_;
  std::shared_ptr<void> keepalive_;
  retained_cleanup_routine retained_cleanup_ = nullptr;
};

inline process_connection_state::~process_connection_state() {
  if (!rundown_complete.load(std::memory_order_acquire)) {
    NT_ASSERT(KeGetCurrentIrql() == PASSIVE_LEVEL);
    if (KeGetCurrentIrql() == PASSIVE_LEVEL) {
      (void)close_all();
      if (!rundown_complete.load(std::memory_order_acquire) && process) {
        // A live target-process VAD may not outlive this registry or a
        // borrowed MDL. MmUnmapLockedPages has no normal failure return; if
        // an exceptional teardown path nevertheless left one installed,
        // retain every backing object until process teardown removes the VAD,
        // then make one final close pass. This is intentionally fail-safe
        // rather than releasing request-owned memory underneath user mode.
        (void)KeWaitForSingleObject(process.get(), Executive, KernelMode,
                                    FALSE, nullptr);
        (void)close_all();
      }
      NT_ASSERT(rundown_complete.load(std::memory_order_acquire));
    }
  }
}

inline ntl::result<std::pair<std::uint64_t, std::uint64_t>>
process_connection_state::register_mapping(
    const std::shared_ptr<mapped_mdl_state> &mapping) noexcept {
  if (!mapping)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  try {
    std::lock_guard<std::mutex> guard(lock);
    if (!accepting)
      return ntl::unexpected(STATUS_DELETE_PENDING);
    const auto charge = mapping->mapping_charge_bytes();
    if (mappings.size() >= limits.max_mappings ||
        mapped_bytes > limits.max_mapped_bytes ||
        charge > limits.max_mapped_bytes - mapped_bytes)
      return ntl::unexpected(STATUS_QUOTA_EXCEEDED);
    do {
      if (++next_id == 0)
        ++next_id;
    } while (mappings.find(next_id) != mappings.end());
    const auto inserted = mappings.emplace(next_id, mapping);
    if (!inserted.second)
      return ntl::unexpected(STATUS_OBJECT_NAME_COLLISION);
    mapped_bytes += charge;
    mapping->identity(next_id, generation);
    return ntl::ok(std::make_pair(next_id, generation));
  } catch (...) {
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

inline bool process_connection_state::begin_mapping_attempt() noexcept {
  std::lock_guard<std::mutex> guard(lock);
  if (!accepting || active_mapping_attempts == SIZE_MAX)
    return false;
  if (active_mapping_attempts++ == 0)
    KeClearEvent(&mapping_attempts_idle);
  return true;
}

inline void process_connection_state::end_mapping_attempt() noexcept {
  std::lock_guard<std::mutex> guard(lock);
  NT_ASSERT(active_mapping_attempts != 0);
  if (active_mapping_attempts != 0 && --active_mapping_attempts == 0)
    KeSetEvent(&mapping_attempts_idle, IO_NO_INCREMENT, FALSE);
}

inline void process_connection_state::unregister_mapping(
    std::uint64_t id, const mapped_mdl_state *expected) noexcept {
  std::lock_guard<std::mutex> guard(lock);
  const auto found = mappings.find(id);
  if (found != mappings.end() && found->second.get() == expected) {
    const auto bytes = found->second->mapping_charge_bytes();
    mappings.erase(found);
    mapped_bytes = bytes <= mapped_bytes ? mapped_bytes - bytes : 0;
  }
}

inline ntl::status process_connection_state::close_all() noexcept {
  if (rundown_complete.load(std::memory_order_acquire)) {
    return ntl::status{rundown_status.load(std::memory_order_relaxed)};
  }
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return STATUS_INVALID_DEVICE_STATE;
  std::lock_guard<std::mutex> close_guard(close_lock);
  if (rundown_complete.load(std::memory_order_acquire))
    return ntl::status{rundown_status.load(std::memory_order_relaxed)};
  {
    std::lock_guard<std::mutex> guard(lock);
    if (!close_started) {
      close_started = true;
      accepting = false;
      if (++generation == 0)
        ++generation;
    }
  }
  // A mapping can already have passed its initial accepting check while its
  // user VAD is not yet in the registry. Wait until every such attempt either
  // registers or rejects and unmaps before declaring disconnect complete.
  (void)KeWaitForSingleObject(&mapping_attempts_idle, Executive, KernelMode,
                              FALSE, nullptr);

  for (;;) {
    std::shared_ptr<mapped_mdl_state> item;
    {
      std::lock_guard<std::mutex> guard(lock);
      if (mappings.empty()) {
        mapped_bytes = 0;
        rundown_complete.store(true, std::memory_order_release);
        return ntl::status{rundown_status.load(std::memory_order_relaxed)};
      }
      item = mappings.begin()->second;
    }
    const auto status = item->close();
    if (!status.is_ok()) {
      NTSTATUS expected = STATUS_SUCCESS;
      (void)rundown_status.compare_exchange_strong(
          expected, static_cast<NTSTATUS>(status), std::memory_order_relaxed);
      // A cleanup failure occurs after unregister and must not prevent the
      // remaining mappings from closing. An open item means unmap made no
      // progress, so retrying the same registry entry would spin forever.
      if (item->is_open())
        return ntl::status{rundown_status.load(std::memory_order_relaxed)};
    }
  }
}

inline std::size_t process_connection_state::mapping_count() const noexcept {
  std::lock_guard<std::mutex> guard(lock);
  return mappings.size();
}

inline bool process_connection_state::accepts_mappings() const noexcept {
  std::lock_guard<std::mutex> guard(lock);
  return accepting;
}

inline std::uint64_t
process_connection_state::current_generation() const noexcept {
  std::lock_guard<std::mutex> guard(lock);
  return generation;
}

