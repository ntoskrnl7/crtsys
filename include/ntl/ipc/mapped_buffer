/** Page-isolated nonpaged storage suitable for a user mapping. */
class page_buffer {
public:
  page_buffer(const page_buffer &) = delete;
  page_buffer &operator=(const page_buffer &) = delete;

  ~page_buffer() {
    NT_ASSERT(KeGetCurrentIrql() <= DISPATCH_LEVEL);
    if (system_address_)
      MmUnmapLockedPages(system_address_, mdl_);
    if (mdl_) {
      MmFreePagesFromMdl(mdl_);
      ExFreePool(mdl_);
    }
  }

  [[nodiscard]] static ntl::result<std::shared_ptr<page_buffer>>
  try_create(std::size_t bytes, MEMORY_CACHING_TYPE cache = MmCached) noexcept {
    if (bytes == 0 || bytes > static_cast<std::size_t>(MAXULONG))
      return ntl::unexpected(STATUS_INVALID_PARAMETER);
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);
    PHYSICAL_ADDRESS low{};
    PHYSICAL_ADDRESS high{};
    PHYSICAL_ADDRESS skip{};
    high.QuadPart = MAXLONGLONG;
    ULONG flags = 0;
#ifdef MM_ALLOCATE_FULLY_REQUIRED
    flags |= MM_ALLOCATE_FULLY_REQUIRED;
#endif
#ifdef MM_ALLOCATE_NO_EXECUTE
    flags |= MM_ALLOCATE_NO_EXECUTE;
#endif
    PMDL mdl = MmAllocatePagesForMdlEx(low, high, skip, bytes, cache, flags);
    if (!mdl || MmGetMdlByteCount(mdl) < bytes) {
      if (mdl) {
        MmFreePagesFromMdl(mdl);
        ExFreePool(mdl);
      }
      return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
    }
    void *const address =
        MmMapLockedPagesSpecifyCache(mdl, KernelMode, cache, nullptr, FALSE,
                                     NormalPagePriority | MdlMappingNoExecute);
    if (!address) {
      MmFreePagesFromMdl(mdl);
      ExFreePool(mdl);
      return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
    }
    RtlZeroMemory(address, MmGetMdlByteCount(mdl));
    void *const owner_storage = ntl::allocate_pool(
        sizeof(page_buffer), ntl::pool_kind::nonpaged, ntl::pool_option::none,
        detail::page_buffer_pool_tag);
    if (!owner_storage) {
      MmUnmapLockedPages(address, mdl);
      MmFreePagesFromMdl(mdl);
      ExFreePool(mdl);
      return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
    }
    auto *const owner =
        new (owner_storage) page_buffer(mdl, address, bytes, cache);
    try {
      using allocator =
          ntl::nonpaged_pool_allocator<page_buffer,
                                       detail::page_buffer_pool_tag>;
      return ntl::ok(std::shared_ptr<page_buffer>(
          owner, ntl::pool_deleter<page_buffer>{detail::page_buffer_pool_tag},
          allocator{}));
    } catch (...) {
      return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
    }
  }

  void *data() const noexcept { return system_address_; }
  std::size_t size() const noexcept { return bytes_; }
  PMDL native_mdl() const noexcept { return mdl_; }
  MEMORY_CACHING_TYPE cache_type() const noexcept { return cache_; }

private:
  page_buffer(PMDL mdl, void *address, std::size_t bytes,
              MEMORY_CACHING_TYPE cache) noexcept
      : mdl_(mdl), system_address_(address), bytes_(bytes), cache_(cache) {}
  PMDL mdl_ = nullptr;
  void *system_address_ = nullptr;
  std::size_t bytes_ = 0;
  MEMORY_CACHING_TYPE cache_ = MmCached;
};

/** @brief Copyable weak logical view invalidated by owner close/disconnect. */
class mapped_buffer_view {
public:
  mapped_buffer_view() noexcept = default;

  explicit operator bool() const noexcept {
    return target_address() != nullptr;
  }
  void *target_address() const noexcept {
    const auto state = state_.lock();
    return state ? state->address(offset_, length_) : nullptr;
  }

  bool is_open() const noexcept {
    const auto state = state_.lock();
    return state && state->address(offset_, length_) != nullptr;
  }

  /** Explicitly unmaps the shared mapping; all copied views become invalid. */
  ntl::status close() const noexcept {
    const auto state = state_.lock();
    return state ? state->close() : ntl::status{STATUS_SUCCESS};
  }
  std::size_t size() const noexcept { return length_; }
  map_access access() const noexcept { return access_; }
  mapped_buffer_descriptor descriptor() const noexcept {
    const auto state = state_.lock();
    return state ? state->descriptor(offset_, length_, access_)
                 : mapped_buffer_descriptor{};
  }
  ntl::result<mapped_buffer_view> subview(std::size_t offset,
                                          std::size_t length) const noexcept {
    return subview(offset, length, access_);
  }
  ntl::result<mapped_buffer_view> subview(std::size_t offset,
                                          std::size_t length,
                                          map_access access) const noexcept {
    if (length == 0 || offset > length_ || length > length_ - offset ||
        state_.expired() ||
        (access != map_access::read && access != map_access::read_write) ||
        (access == map_access::read_write && access_ != map_access::read_write))
      return ntl::unexpected(STATUS_INVALID_PARAMETER);
    return ntl::ok(
        mapped_buffer_view{state_, offset_ + offset, length, access});
  }

private:
  friend class mapped_io_buffers_builder;
  friend ntl::result<mapped_buffer_view>
  detail_try_map_mdl_retained(PMDL, std::size_t, std::size_t,
                              process_connection &, map_access,
                              MEMORY_CACHING_TYPE, std::shared_ptr<void>,
                              detail::retained_cleanup_routine) noexcept;
  mapped_buffer_view(std::weak_ptr<detail::mapped_mdl_state> state,
                     std::size_t offset, std::size_t length,
                     map_access access) noexcept
      : state_(std::move(state)), offset_(offset), length_(length),
        access_(access) {}
  std::weak_ptr<detail::mapped_mdl_state> state_;
  std::size_t offset_ = 0;
  std::size_t length_ = 0;
  map_access access_ = map_access::read;
};

[[nodiscard]] inline ntl::result<mapped_buffer_view>
detail_try_map_mdl_retained(
    PMDL mdl, std::size_t offset, std::size_t length,
    process_connection &connection, map_access access,
    MEMORY_CACHING_TYPE cache, std::shared_ptr<void> keepalive,
    detail::retained_cleanup_routine retained_cleanup = nullptr) noexcept {
  if (!detail::mdl_describes_resident_pages(mdl) || !connection ||
      length == 0 ||
      (access != map_access::read && access != map_access::read_write) ||
      offset > static_cast<std::size_t>(MmGetMdlByteCount(mdl)) ||
      length > static_cast<std::size_t>(MmGetMdlByteCount(mdl)) - offset)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  if (KeGetCurrentIrql() != PASSIVE_LEVEL)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);
  std::size_t mapping_charge_bytes = 0;
  if (!detail::mdl_mapping_charge(mdl, mapping_charge_bytes))
    return ntl::unexpected(STATUS_INVALID_BUFFER_SIZE);

  auto connection_state = connection.state_;
  if (!connection_state || !connection_state->begin_mapping_attempt())
    return ntl::unexpected(STATUS_DELETE_PENDING);
  struct mapping_attempt_guard {
    std::shared_ptr<detail::process_connection_state> state;
    ~mapping_attempt_guard() {
      if (state)
        state->end_mapping_attempt();
    }
  } attempt{connection_state};

  detail::map_call_context call{mdl, cache, NormalPagePriority, nullptr};
  call.priority |= MdlMappingNoExecute;
  if (access == map_access::read)
    call.priority |= MdlMappingNoWrite;
  const NTSTATUS mapped =
      detail::invoke_in_process(connection_state->process.get(),
                                &detail::map_call, &call);
  if (!NT_SUCCESS(mapped))
    return ntl::unexpected(mapped);

  try {
    auto owner = std::allocate_shared<detail::mapped_mdl_state>(
        ntl::nonpaged_pool_allocator<detail::mapped_mdl_state,
                                     detail::mapped_state_pool_tag>{},
        connection_state->process.get(), mdl, call.address,
        MmGetMdlByteCount(mdl), mapping_charge_bytes, access,
        connection_state, std::move(keepalive), retained_cleanup);
    const auto registered = connection_state->register_mapping(owner);
    if (!registered) {
      (void)owner->close();
      return ntl::unexpected(registered.status());
    }
    return ntl::ok(mapped_buffer_view{owner, offset, length, access});
  } catch (...) {
    detail::unmap_call_context cleanup{mdl, call.address};
    (void)detail::invoke_in_process(connection_state->process.get(),
                                    &detail::unmap_call, &cleanup);
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

/**
 * @brief Maps a caller-owned, already locked MDL.
 *
 * This low-level API maps the MDL's page span. The target process can address
 * leading/trailing page padding even when the returned logical view is smaller.
 */
[[nodiscard]] inline ntl::result<mapped_buffer_view>
try_map_mdl(borrowed_mdl_view borrowed, std::size_t offset, std::size_t length,
            process_connection &connection,
            map_access access = map_access::read_write,
            MEMORY_CACHING_TYPE cache = MmCached) noexcept {
  return detail_try_map_mdl_retained(borrowed.native(), offset, length,
                                     connection, access, cache, {});
}

/** @brief Maps page-isolated NTL storage and retains it until unmap. */
[[nodiscard]] inline ntl::result<mapped_buffer_view>
try_map_page_buffer(const std::shared_ptr<page_buffer> &buffer,
                    std::size_t offset, std::size_t length,
                    process_connection &connection,
                    map_access access = map_access::read_write) noexcept {
  if (!buffer)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  return detail_try_map_mdl_retained(buffer->native_mdl(), offset, length,
                                     connection, access, buffer->cache_type(),
                                     buffer);
}

/** @brief Maps and retains an NTL-owned user-page MDL. */
[[nodiscard]] inline ntl::result<mapped_buffer_view>
try_map_owned_mdl(const std::shared_ptr<ntl::mdl> &descriptor,
                  std::size_t offset, std::size_t length,
                  process_connection &connection,
                  map_access access = map_access::read_write,
                  MEMORY_CACHING_TYPE cache = MmCached) noexcept {
  if (!descriptor || !*descriptor)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  return detail_try_map_mdl_retained(descriptor->get(), offset, length,
                                     connection, access, cache, descriptor);
}

/** @brief Input/output presentation that owns every underlying mapping. */
class mapped_io_buffers {
public:
  mapped_io_buffers() noexcept = default;
  mapped_io_buffers(const mapped_io_buffers &) = delete;
  mapped_io_buffers &operator=(const mapped_io_buffers &) = delete;
  mapped_io_buffers(mapped_io_buffers &&) noexcept = default;
  mapped_io_buffers &operator=(mapped_io_buffers &&other) noexcept {
    if (this == &other)
      return *this;
    (void)close();
    if (input_ || output_ || control_input_ || input_owner_ || output_owner_ ||
        control_input_owner_) {
      NT_ASSERT(FALSE);
      return *this;
    }
    input_ = std::move(other.input_);
    output_ = std::move(other.output_);
    control_input_ = std::move(other.control_input_);
    input_owner_ = std::move(other.input_owner_);
    output_owner_ = std::move(other.output_owner_);
    control_input_owner_ = std::move(other.control_input_owner_);
    return *this;
  }
  ~mapped_io_buffers() { (void)close(); }

  const mapped_buffer_view *input() const noexcept {
    return input_ ? &*input_ : nullptr;
  }
  const mapped_buffer_view *output() const noexcept {
    return output_ ? &*output_ : nullptr;
  }
  /** IOCTL header/control input when a direct MDL is also present. */
  const mapped_buffer_view *control_input() const noexcept {
    return control_input_ ? &*control_input_ : nullptr;
  }

  /** Reports whether any underlying target-process VAD is still installed. */
  bool has_open_mappings() const noexcept {
    const auto open = [](const auto &owner) noexcept {
      return owner && owner->is_open();
    };
    return open(input_owner_) || open(output_owner_) ||
           open(control_input_owner_);
  }

  ntl::status close() noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return STATUS_INVALID_DEVICE_STATE;
    NTSTATUS first_failure = STATUS_SUCCESS;
    if (input_owner_) {
      const auto status = input_owner_->close();
      if (!status.is_ok())
        first_failure = static_cast<NTSTATUS>(status);
    }
    if (output_owner_ && output_owner_ != input_owner_) {
      const auto status = output_owner_->close();
      if (first_failure == STATUS_SUCCESS && !status.is_ok())
        first_failure = static_cast<NTSTATUS>(status);
    }
    if (control_input_owner_ && control_input_owner_ != input_owner_ &&
        control_input_owner_ != output_owner_) {
      const auto status = control_input_owner_->close();
      if (first_failure == STATUS_SUCCESS && !status.is_ok())
        first_failure = static_cast<NTSTATUS>(status);
    }
    const auto clear_if_closed = [](auto &view, auto &owner) noexcept {
      if (!owner || !view || !view->is_open()) {
        view.reset();
        owner.reset();
      }
    };
    clear_if_closed(input_, input_owner_);
    clear_if_closed(output_, output_owner_);
    clear_if_closed(control_input_, control_input_owner_);
    return first_failure;
  }

private:
  friend class mapped_io_buffers_builder;
  std::optional<mapped_buffer_view> input_;
  std::optional<mapped_buffer_view> output_;
  std::optional<mapped_buffer_view> control_input_;
  std::shared_ptr<detail::mapped_mdl_state> input_owner_;
  std::shared_ptr<detail::mapped_mdl_state> output_owner_;
  std::shared_ptr<detail::mapped_mdl_state> control_input_owner_;
};

class mapped_io_buffers_builder {
public:
  mapped_io_buffers_builder &input(mapped_buffer_view value) noexcept {
    value_.input_owner_ = value.state_.lock();
    value_.input_.emplace(std::move(value));
    return *this;
  }
  mapped_io_buffers_builder &output(mapped_buffer_view value) noexcept {
    value_.output_owner_ = value.state_.lock();
    value_.output_.emplace(std::move(value));
    return *this;
  }
  mapped_io_buffers_builder &control_input(mapped_buffer_view value) noexcept {
    value_.control_input_owner_ = value.state_.lock();
    value_.control_input_.emplace(std::move(value));
    return *this;
  }
  mapped_io_buffers build() noexcept { return std::move(value_); }

private:
  mapped_io_buffers value_;
};

