namespace ntl::ipc {

/** @brief Policy for kernel buffers that cannot safely be mapped in place. */
enum class kernel_buffer_policy {
  copy_to_isolated_pages,
  reject,
};

/** Policy for page padding around caller-owned user MDLs. */
enum class user_mdl_policy {
  /** Copy a partial-page MDL through isolated, fully zeroed pages. */
  isolate_partial_pages,
  /** Trusted-service opt-in: map the MDL even when page padding is visible. */
  allow_page_padding_exposure,
};

/** @brief Controls access and safe fallback behavior for one IRP export. */
struct map_io_options {
  map_access input_access = map_access::read;
  map_access output_access = map_access::read_write;
  kernel_buffer_policy kernel_buffers =
      kernel_buffer_policy::copy_to_isolated_pages;
  user_mdl_policy user_mdls = user_mdl_policy::isolate_partial_pages;
  /** Maximum isolated staging storage for one logical buffer. */
  std::size_t max_staging_bytes = 16u * 1024u * 1024u;
  /** Paging I/O cannot safely wait on a user-mode service by default. */
  bool allow_paging_io = false;
};

namespace detail {

inline constexpr UCHAR user_fs_request_minor = 0x00;
inline constexpr UCHAR kernel_call_minor = 0x04;

struct probe_call_context {
  ntl::mdl *descriptor = nullptr;
  KPROCESSOR_MODE mode = UserMode;
  LOCK_OPERATION operation = IoReadAccess;
};

inline NTSTATUS NTAPI probe_call(void *opaque) noexcept {
  auto *context = static_cast<probe_call_context *>(opaque);
  const auto locked = context->descriptor->probe_and_lock_pages(
      context->mode, context->operation);
  return locked ? STATUS_SUCCESS : static_cast<NTSTATUS>(locked.status());
}

inline ntl::status guarded_copy(void *destination, const void *source,
                                std::size_t bytes) noexcept {
  if (bytes == 0)
    return STATUS_SUCCESS;
  if (!destination || !source)
    return STATUS_INVALID_PARAMETER;
  NTSTATUS status = STATUS_SUCCESS;
  const auto guarded = ntl::seh::try_except(
      [&]() { RtlCopyMemory(destination, source, bytes); });
  if (!std::get<0>(guarded))
    status = static_cast<NTSTATUS>(std::get<1>(guarded));
  return status;
}

struct copy_call_context {
  void *destination = nullptr;
  const void *source = nullptr;
  std::size_t bytes = 0;
};

inline NTSTATUS NTAPI copy_call(void *opaque) noexcept {
  auto *context = static_cast<copy_call_context *>(opaque);
  return static_cast<NTSTATUS>(
      guarded_copy(context->destination, context->source, context->bytes));
}

inline ntl::status guarded_copy_in_process(PEPROCESS process, void *destination,
                                           const void *source,
                                           std::size_t bytes) noexcept {
  if (!process)
    return guarded_copy(destination, source, bytes);
  copy_call_context context{destination, source, bytes};
  return invoke_in_process(process, &copy_call, &context);
}

class staged_io_buffer {
public:
  staged_io_buffer(std::shared_ptr<page_buffer> pages, void *original,
                   std::size_t copy_back_bytes,
                   ntl::unique_object<PEPROCESS> process) noexcept
      : pages_(std::move(pages)), original_(original),
        copy_back_bytes_(copy_back_bytes), process_(std::move(process)) {}

  ~staged_io_buffer() { (void)finalize(); }

  ntl::status finalize() noexcept {
    if (finalized_)
      return final_status_;
    finalized_ = true;
    if (copy_back_bytes_ && pages_ && original_)
      final_status_ = guarded_copy_in_process(process_.get(), original_,
                                              pages_->data(),
                                              copy_back_bytes_);
    return final_status_;
  }

  const std::shared_ptr<page_buffer> &pages() const noexcept { return pages_; }

private:
  std::shared_ptr<page_buffer> pages_;
  void *original_ = nullptr;
  std::size_t copy_back_bytes_ = 0;
  ntl::unique_object<PEPROCESS> process_;
  bool finalized_ = false;
  ntl::status final_status_{STATUS_SUCCESS};
};

inline ntl::status
finalize_staged_mapping(std::shared_ptr<void> &retained) noexcept {
  if (!retained)
    return STATUS_SUCCESS;
  auto staged = std::static_pointer_cast<staged_io_buffer>(retained);
  const auto status = staged->finalize();
  retained.reset();
  return status;
}

inline ntl::result<std::shared_ptr<staged_io_buffer>>
make_staging(void *original, std::size_t bytes, std::size_t copy_in_bytes,
             std::size_t copy_back_bytes,
             PEPROCESS copy_process = nullptr) noexcept {
  if (!original || bytes == 0 || copy_in_bytes > bytes ||
      copy_back_bytes > bytes)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  auto pages = page_buffer::try_create(bytes);
  if (!pages)
    return ntl::unexpected(pages.status());
  ntl::unique_object<PEPROCESS> process;
  if (copy_process) {
    ObReferenceObject(copy_process);
    process.reset(copy_process);
  }
  if (copy_in_bytes) {
    const auto copied = guarded_copy_in_process(process.get(), (*pages)->data(),
                                                original, copy_in_bytes);
    if (!copied.is_ok())
      return ntl::unexpected(static_cast<NTSTATUS>(copied));
  }
  try {
    return ntl::ok(std::make_shared<staged_io_buffer>(
        *pages, original, copy_back_bytes, std::move(process)));
  } catch (...) {
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

inline ntl::result<mapped_buffer_view>
map_user_range(void *address, std::size_t bytes, LOCK_OPERATION operation,
               KPROCESSOR_MODE mode, PEPROCESS requestor_process,
               process_connection &connection, map_access access) noexcept {
  if (!address || bytes == 0 || bytes > MAXULONG)
    return ntl::unexpected(STATUS_INVALID_PARAMETER);
  auto native = ntl::mdl::allocate(address, static_cast<ULONG>(bytes));
  if (!native)
    return ntl::unexpected(native.status());
  probe_call_context context{&*native, mode, operation};
  const NTSTATUS locked =
      mode == UserMode
          ? detail::invoke_in_process(requestor_process, &probe_call, &context)
          : probe_call(&context);
  if (!NT_SUCCESS(locked))
    return ntl::unexpected(locked);
  try {
    auto owner = std::make_shared<ntl::mdl>(std::move(*native));
    return try_map_owned_mdl(owner, 0, bytes, connection, access);
  } catch (...) {
    return ntl::unexpected(STATUS_INSUFFICIENT_RESOURCES);
  }
}

inline ntl::result<mapped_buffer_view>
map_irp_user_range(PIRP irp, void *address, std::size_t bytes,
                   LOCK_OPERATION operation, process_connection &connection,
                   map_access access) noexcept {
  if (irp->RequestorMode == KernelMode)
    return map_user_range(address, bytes, operation, KernelMode, nullptr,
                          connection, access);
  void *requestor_opaque = nullptr;
  const NTSTATUS referenced =
      reference_requestor_process(irp, &requestor_opaque);
  if (!NT_SUCCESS(referenced))
    return ntl::unexpected(referenced);
  auto *requestor = static_cast<PEPROCESS>(requestor_opaque);
  ntl::unique_object<PEPROCESS> owner{requestor};
  return map_user_range(address, bytes, operation, UserMode, requestor,
                        connection, access);
}

inline ntl::result<mapped_buffer_view>
map_kernel_range(void *address, std::size_t bytes,
                 std::size_t copy_in_bytes, std::size_t copy_back_bytes,
                 process_connection &connection, map_access access,
                 kernel_buffer_policy policy,
                 PEPROCESS copy_process = nullptr) noexcept {
  if (policy == kernel_buffer_policy::reject)
    return ntl::unexpected(STATUS_NOT_SUPPORTED);
  auto staged = make_staging(address, bytes, copy_in_bytes, copy_back_bytes,
                             copy_process);
  if (!staged)
    return ntl::unexpected(staged.status());
  auto mapped = detail_try_map_mdl_retained(
      (*staged)->pages()->native_mdl(), 0, bytes, connection, access, MmCached,
      std::static_pointer_cast<void>(*staged), &finalize_staged_mapping);
  return mapped;
}

