#pragma once

#include "status"

#include <ntddk.h>

namespace ntl {
/**
 * @brief Named KIRQL levels used by NTL helpers.
 */
enum irql : KIRQL {
  passive = PASSIVE_LEVEL,
  low = passive,
  apc = APC_LEVEL,
  dispatch = DISPATCH_LEVEL,
  dpc = dispatch,
#if defined(_X86_) || defined(_AMD64_)
  cmci = CMCI_LEVEL,
#endif
  clock = CLOCK_LEVEL,
  ipi = IPI_LEVEL,
#if !defined(_X86_) 
  drs = DRS_LEVEL,
#endif  
  power = POWER_LEVEL,
  profile = PROFILE_LEVEL,
#if defined(_X86_)
  clock1 = CLOCK1_LEVEL,
  clock2 = CLOCK2_LEVEL,
#endif
  high = HIGH_LEVEL
};

struct to_dpc_level_t {
  /**
   * @brief Tag type for raising to DISPATCH_LEVEL.
   */
  explicit to_dpc_level_t() = default;
};

struct to_synch_level_t {
  /**
   * @brief Tag type for raising to SYNCH_LEVEL.
   */
  explicit to_synch_level_t() = default;
};

inline constexpr to_dpc_level_t to_dpc_level{};
inline constexpr to_synch_level_t to_synch_level{};

/**
 * @brief Raises IRQL and restores the previous level when destroyed.
 */
class raised_irql {
public:
  /**
   * @brief Raises the current processor to DISPATCH_LEVEL.
   */
  raised_irql(to_dpc_level_t) : old_irql_(KeRaiseIrqlToDpcLevel()) {}
  /**
   * @brief Raises the current processor to SYNCH_LEVEL.
   */
  raised_irql(to_synch_level_t) : old_irql_(KeRaiseIrqlToSynchLevel()) {}
  /**
   * @brief Raises the current processor to an explicit IRQL.
   */
  raised_irql(irql irql) { KeRaiseIrql(static_cast<KIRQL>(irql), &old_irql_); }

  /**
   * @brief Restores the previous IRQL.
   */
  ~raised_irql() { KeLowerIrql(old_irql_); }

  raised_irql(const raised_irql &) = delete;
  raised_irql &operator=(const raised_irql &) = delete;

  /**
   * @brief Returns the IRQL that was active before construction.
   */
  irql old() const { return static_cast<irql>(old_irql_); }

private:
  KIRQL old_irql_;
};

/**
 * @brief Raises to an explicit KIRQL and returns an RAII guard.
 */
inline raised_irql raise_irql(KIRQL irql) {
  return raised_irql{static_cast<ntl::irql>(irql)};
}

/**
 * @brief Raises to DISPATCH_LEVEL and returns an RAII guard.
 */
inline raised_irql raise_irql_to_dpc_level() {
  return raised_irql{to_dpc_level};
}

/**
 * @brief Raises to SYNCH_LEVEL and returns an RAII guard.
 */
inline raised_irql raise_irql_to_synch_level() {
  return raised_irql{to_synch_level};
}

/**
 * @brief Returns the current processor IRQL.
 */
inline ntl::irql current_irql() {
  return static_cast<ntl::irql>(KeGetCurrentIrql());
}

/**
 * @brief Returns true when the current processor is running at PASSIVE_LEVEL.
 */
inline bool is_passive_level() noexcept {
  return current_irql() == ntl::irql::passive;
}

/**
 * @brief Returns true when the current processor IRQL is at or below maximum.
 */
inline bool is_irql_at_most(ntl::irql maximum) noexcept {
  return static_cast<KIRQL>(current_irql()) <= static_cast<KIRQL>(maximum);
}

/**
 * @brief Requires PASSIVE_LEVEL and returns STATUS_INVALID_DEVICE_STATE otherwise.
 */
inline ntl::status require_passive_level() noexcept {
  return is_passive_level() ? ntl::status::ok()
                            : ntl::status{STATUS_INVALID_DEVICE_STATE};
}

/**
 * @brief Requires current IRQL to be at or below maximum.
 */
inline ntl::status require_irql_at_most(ntl::irql maximum) noexcept {
  return is_irql_at_most(maximum) ? ntl::status::ok()
                                  : ntl::status{STATUS_INVALID_DEVICE_STATE};
}
} // namespace ntl
