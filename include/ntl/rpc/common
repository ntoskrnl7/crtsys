/** @brief Preserves comma-containing types inside RPC macros. */
#define NTL_RPC_ARG_PACK(...) __VA_ARGS__

/** @brief Declares a larger response limit without changing the return type. */
#define NTL_RPC_BOUNDED_RESPONSE(_bytes_, ...)                                 \
  ntl::rpc::bounded_response<__VA_ARGS__, (_bytes_)>

/** @brief Declares response, request, and decode-allocation method limits. */
#define NTL_RPC_METHOD_LIMITS(_response_bytes_, _request_bytes_,               \
                              _decode_bytes_, ...)                             \
  ntl::rpc::method_limits<__VA_ARGS__, (_response_bytes_),                    \
                          (_request_bytes_), (_decode_bytes_)>

/** @brief Maps line-based convenience IDs into the vendor IOCTL range. */
#define NTL_RPC_DETAIL_LINE_ID (0x800ul + (__LINE__ % 0x7FEul))
