/** @brief Identifies why an RPC server contract was rejected. */
enum class contract_mismatch_reason {
  query_unavailable,
  protocol_version,
  contract_version,
  transport_features,
  capabilities,
  method,
};

/** @brief Reports an application or transport contract incompatibility. */
class contract_mismatch : public std::runtime_error {
public:
  /** @brief Creates an incompatibility error with diagnostic values. */
  contract_mismatch(contract_mismatch_reason reason, const char *message,
                    std::uint64_t expected = 0,
                    std::uint64_t actual = 0)
      : std::runtime_error(message), reason_(reason), expected_(expected),
        actual_(actual) {}

  /** @brief Returns the failed compatibility rule. */
  contract_mismatch_reason reason() const noexcept { return reason_; }

  /** @brief Returns the required version, feature mask, or method ID. */
  std::uint64_t expected() const noexcept { return expected_; }

  /** @brief Returns the server value, or zero for a missing method. */
  std::uint64_t actual() const noexcept { return actual_; }

private:
  contract_mismatch_reason reason_;
  std::uint64_t expected_;
  std::uint64_t actual_;
};

/** @brief Declares the server contract required by one client. */
class contract_requirements {
public:
  /** @brief Requires an exact application contract version. */
  contract_requirements &contract_version(std::uint32_t version) noexcept {
    has_contract_version_ = true;
    contract_version_ = version;
    return *this;
  }

  /** @brief Requires all selected NTL transport features. */
  contract_requirements &transport_features(std::uint64_t features) noexcept {
    transport_features_ = features;
    return *this;
  }

  /** @brief Requires all selected application-defined capability bits. */
  contract_requirements &capabilities(std::uint64_t capabilities) noexcept {
    capabilities_ = capabilities;
    return *this;
  }

  /** @brief Requires one typed method to be present on the server. */
  template <typename Method>
  contract_requirements &method(const Method &) {
    static_assert(is_method<Method>::value,
                  "contract_requirements::method requires an RPC method");
    method_ids_.push_back(static_cast<std::uint32_t>(Method::id()));
    return *this;
  }

private:
  bool has_contract_version_ = false;
  std::uint32_t contract_version_ = 0;
  std::uint64_t transport_features_ = 0;
  std::uint64_t capabilities_ = 0;
  std::vector<std::uint32_t> method_ids_;

  friend class client;
};

/** @brief Result of a bounded wait on one asynchronous RPC call. */
enum class async_wait_status {
  completed,
  timeout,
};

namespace detail {

class async_operation {
public:
  async_operation(std::shared_ptr<ntl::unique_handle> handle,
                  unsigned long code, std::vector<unsigned char> input,
                  std::size_t output_size)
      : handle_(std::move(handle)), input_(std::move(input)),
        output_(output_size), event_(::CreateEventW(nullptr, TRUE, FALSE,
                                                    nullptr)) {
    if (!handle_ || !*handle_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL RPC device is not open");
    if (!event_)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC event creation failed");
    if (input_.size() > static_cast<std::size_t>(
                            (std::numeric_limits<DWORD>::max)()) ||
        output_.size() > static_cast<std::size_t>(
                             (std::numeric_limits<DWORD>::max)()))
      throw std::length_error(
          "NTL RPC asynchronous buffer exceeds DWORD capacity");

    overlapped_.hEvent = event_.get();
    DWORD returned = 0;
    const BOOL succeeded = ::DeviceIoControl(
        handle_->get(), code, input_.empty() ? nullptr : input_.data(),
        static_cast<DWORD>(input_.size()),
        output_.empty() ? nullptr : output_.data(),
        static_cast<DWORD>(output_.size()), &returned, &overlapped_);
    if (succeeded) {
      completed_ = true;
      returned_ = returned;
      if (returned_ <= output_.size())
        output_.resize(returned_);
      else
        error_ = ERROR_INVALID_DATA;
      return;
    }

    const DWORD error = ::GetLastError();
    if (error != ERROR_IO_PENDING)
      throw std::system_error(static_cast<int>(error), std::system_category(),
                              "NTL RPC overlapped DeviceIoControl failed");
  }

  async_operation(const async_operation &) = delete;
  async_operation &operator=(const async_operation &) = delete;

  ~async_operation() {
    if (!ready_noexcept()) {
      (void)::CancelIoEx(handle_->get(), &overlapped_);
      (void)observe_completion(true);
    }
  }

  bool ready() const {
    {
      std::lock_guard<std::mutex> guard(lock_);
      if (completed_)
        return true;
    }

    const DWORD wait = ::WaitForSingleObject(event_.get(), 0);
    if (wait == WAIT_OBJECT_0)
      return true;
    if (wait == WAIT_TIMEOUT)
      return false;
    throw std::system_error(static_cast<int>(::GetLastError()),
                            std::system_category(),
                            "NTL RPC asynchronous wait failed");
  }

  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    if (ready()) {
      (void)observe_completion(true);
      return async_wait_status::completed;
    }

    const auto count = timeout.count();
    const DWORD wait_ms =
        count <= 0
            ? 0
            : count >= static_cast<decltype(count)>((INFINITE) - 1)
                  ? (INFINITE) - 1
                  : static_cast<DWORD>(count);
    const DWORD wait = ::WaitForSingleObject(event_.get(), wait_ms);
    if (wait == WAIT_TIMEOUT)
      return async_wait_status::timeout;
    if (wait != WAIT_OBJECT_0)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC asynchronous wait failed");

    (void)observe_completion(true);
    return async_wait_status::completed;
  }

  void wait() { (void)observe_completion(true); }

  bool cancel() {
    if (::CancelIoEx(handle_->get(), &overlapped_))
      return true;
    const DWORD error = ::GetLastError();
    if (error == ERROR_NOT_FOUND)
      return false;
    throw std::system_error(static_cast<int>(error), std::system_category(),
                            "NTL RPC cancellation failed");
  }

  const std::vector<unsigned char> &output() {
    (void)observe_completion(true);
    std::lock_guard<std::mutex> guard(lock_);
    if (error_ != ERROR_SUCCESS)
      throw std::system_error(static_cast<int>(error_),
                              std::system_category(),
                              "NTL RPC asynchronous call failed");
    return output_;
  }

private:
  bool ready_noexcept() const noexcept {
    {
      std::lock_guard<std::mutex> guard(lock_);
      if (completed_)
        return true;
    }
    return ::WaitForSingleObject(event_.get(), 0) == WAIT_OBJECT_0;
  }

  bool observe_completion(bool wait) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (completed_)
      return true;

    DWORD returned = 0;
    if (!::GetOverlappedResult(handle_->get(), &overlapped_, &returned,
                               wait ? TRUE : FALSE)) {
      const DWORD error = ::GetLastError();
      if (!wait && error == ERROR_IO_INCOMPLETE)
        return false;
      error_ = error;
    } else {
      error_ = ERROR_SUCCESS;
      returned_ = returned;
      if (returned_ <= output_.size())
        output_.resize(returned_);
      else
        error_ = ERROR_INVALID_DATA;
    }
    completed_ = true;
    return true;
  }

  std::shared_ptr<ntl::unique_handle> handle_;
  std::vector<unsigned char> input_;
  std::vector<unsigned char> output_;
  ntl::unique_handle event_;
  OVERLAPPED overlapped_{};
  mutable std::mutex lock_;
  DWORD returned_ = 0;
  DWORD error_ = ERROR_SUCCESS;
  bool completed_ = false;
};

} // namespace detail

/** @brief Move-only owner of one asynchronous typed RPC invocation. */
template <typename T> class async_call {
public:
  async_call(const async_call &) = delete;
  async_call &operator=(const async_call &) = delete;
  async_call(async_call &&) noexcept = default;
  async_call &operator=(async_call &&) noexcept = default;

  /** @brief Returns true until get() consumes the result. */
  explicit operator bool() const noexcept { return state_ && !consumed_; }

  /** @brief Reports whether the underlying DeviceIoControl has completed. */
  bool ready() const {
    ensure_valid();
    return state_->ready();
  }

  /** @brief Waits up to timeout for completion. */
  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout);
  }

  /** @brief Waits without a timeout. */
  void wait() {
    ensure_valid();
    state_->wait();
  }

  /** @brief Requests cancellation with CancelIoEx for only this call. */
  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  /** @brief Waits, deserializes, and consumes the typed result. */
  T get() {
    ensure_valid();
    const auto &output = state_->output();
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), decode_allocation_);
    T value{};
    archive(value);
    if (archive.offset() != output.size())
      throw std::runtime_error("NTL RPC response contains trailing bytes");
    consumed_ = true;
    state_.reset();
    return std::move(value);
  }

private:
  friend class client;
  async_call(std::shared_ptr<detail::async_operation> state,
             std::size_t decode_allocation)
      : state_(std::move(state)), decode_allocation_(decode_allocation) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL RPC asynchronous call has no result");
  }

  std::shared_ptr<detail::async_operation> state_;
  std::size_t decode_allocation_;
  bool consumed_ = false;
};

/** @brief Move-only owner of an asynchronous void RPC invocation. */
template <> class async_call<void> {
public:
  async_call(const async_call &) = delete;
  async_call &operator=(const async_call &) = delete;
  async_call(async_call &&) noexcept = default;
  async_call &operator=(async_call &&) noexcept = default;

  explicit operator bool() const noexcept { return state_ && !consumed_; }

  bool ready() const {
    ensure_valid();
    return state_->ready();
  }

  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout);
  }

  void wait() {
    ensure_valid();
    state_->wait();
  }

  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  /** @brief Waits for completion and consumes a void result. */
  void get() {
    ensure_valid();
    if (!state_->output().empty())
      throw std::runtime_error("void NTL RPC method returned output bytes");
    consumed_ = true;
    state_.reset();
  }

private:
  friend class client;
  explicit async_call(std::shared_ptr<detail::async_operation> state)
      : state_(std::move(state)) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL RPC asynchronous call has no result");
  }

  std::shared_ptr<detail::async_operation> state_;
  bool consumed_ = false;
};

/** @brief Move-only owner of one pending typed kernel notification. */
template <typename T> using notification_wait = async_call<T>;

/** @brief Owns a user-mode handle to an NTL RPC device. */
class client {
public:
  /**
   * @brief Opens an NTL RPC device.
   * @param rpc_name Kernel device name without the `\\Device\\` prefix.
   */
  explicit client(const std::wstring &rpc_name)
      : handle_(std::make_shared<ntl::unique_handle>(::CreateFileW(
            (L"\\\\?\\Global\\GLOBALROOT\\Device\\" + rpc_name).c_str(),
            GENERIC_READ | GENERIC_WRITE, 0, NULL, OPEN_EXISTING,
            FILE_FLAG_OVERLAPPED, NULL))) {}

  client(const client &) = delete;
  client &operator=(const client &) = delete;
  client(client &&) noexcept = default;
  client &operator=(client &&) noexcept = default;

  /** @brief Returns true when the RPC device was opened successfully. */
  explicit operator bool() const noexcept {
    return handle_ && static_cast<bool>(*handle_);
  }

  /**
   * @brief Queries wire, capability, and method metadata from the server.
   * @return Immutable metadata published when the server started.
   */
  contract_info query_contract() const {
    std::vector<unsigned char> output(contract_response_size);
    const std::vector<unsigned char> input;
    DWORD returned = 0;
    try {
      call(control_code(contract_query_id), input, output.data(),
           static_cast<DWORD>(output.size()), returned);
    } catch (const std::system_error &error) {
      const auto code = static_cast<DWORD>(error.code().value());
      if (code == ERROR_INVALID_FUNCTION || code == ERROR_NOT_SUPPORTED) {
        throw contract_mismatch(
            contract_mismatch_reason::query_unavailable,
            "NTL RPC server does not support contract discovery");
      }
      throw;
    }

    if (returned > output.size())
      throw std::runtime_error(
          "NTL RPC contract query returned an invalid output size");

    output.resize(returned);
    try {
      zpp::serializer::memory_view_input_archive archive(
          output.data(), output.size(), contract_response_size);
      contract_info info;
      archive(info);
      if (archive.offset() != output.size())
        throw std::runtime_error(
            "NTL RPC contract response contains trailing bytes");
      const auto &methods = info.method_ids();
      if (!std::is_sorted(methods.begin(), methods.end()) ||
          std::adjacent_find(methods.begin(), methods.end()) != methods.end())
        throw std::runtime_error(
            "NTL RPC contract response has an invalid method table");
      return info;
    } catch (const zpp::serializer::out_of_range &) {
      throw std::runtime_error("NTL RPC contract response is malformed");
    }
  }

  /**
   * @brief Queries and validates the server before application RPC calls.
   * @param requirements Application and transport requirements.
   * @return The validated server metadata for optional inspection.
   */
  contract_info
  require_contract(const contract_requirements &requirements) const {
    auto info = query_contract();
    if (info.protocol_version() != current_protocol_version) {
      throw contract_mismatch(contract_mismatch_reason::protocol_version,
                              "NTL RPC protocol version mismatch",
                              current_protocol_version,
                              info.protocol_version());
    }
    if (requirements.has_contract_version_ &&
        info.contract_version() != requirements.contract_version_) {
      throw contract_mismatch(contract_mismatch_reason::contract_version,
                              "NTL RPC application contract version mismatch",
                              requirements.contract_version_,
                              info.contract_version());
    }
    if ((info.transport_feature_mask() & requirements.transport_features_) !=
        requirements.transport_features_) {
      throw contract_mismatch(contract_mismatch_reason::transport_features,
                              "NTL RPC transport feature is unavailable",
                              requirements.transport_features_,
                              info.transport_feature_mask());
    }
    if ((info.capability_mask() & requirements.capabilities_) !=
        requirements.capabilities_) {
      throw contract_mismatch(contract_mismatch_reason::capabilities,
                              "NTL RPC application capability is unavailable",
                              requirements.capabilities_,
                              info.capability_mask());
    }
    for (const auto id : requirements.method_ids_) {
      if (!info.supports_method(id)) {
        throw contract_mismatch(contract_mismatch_reason::method,
                                "NTL RPC method is unavailable", id, 0);
      }
    }
    return info;
  }

  /**
   * @brief Invokes a typed RPC method.
   * @param rpc_method Shared method descriptor.
   * @param args Serializable method arguments.
   * @return Deserialized method result, or no value for a void method.
   */
  template <typename Method, typename... Arguments>
  typename Method::return_type invoke(const Method &rpc_method,
                                      Arguments &&...args) {
    static_assert(is_method<Method>::value,
                  "ntl::rpc::client::invoke requires an ntl::rpc::method");
    static_assert(sizeof...(Arguments) == Method::arity(),
                  "RPC argument count does not match the method signature");

    using is_void =
        typename std::is_void<typename Method::return_type>::type;
    return invoke_impl(rpc_method, is_void{},
                       std::forward<Arguments>(args)...);
  }

  /**
   * @brief Starts a typed RPC invocation with overlapped DeviceIoControl.
   * @return An object that owns the request buffers and supports wait/cancel.
   */
  template <typename Method, typename... Arguments>
  async_call<typename Method::return_type>
  invoke_async(const Method &rpc_method, Arguments &&...args) {
    static_assert(is_method<Method>::value,
                  "ntl::rpc::client::invoke_async requires an ntl::rpc::method");
    static_assert(sizeof...(Arguments) == Method::arity(),
                  "RPC argument count does not match the method signature");
    static_assert(Method::response_size() <=
                      static_cast<std::size_t>(
                          (std::numeric_limits<DWORD>::max)()),
                  "NTL RPC response capacity exceeds DWORD capacity");
    (void)rpc_method;

    auto input =
        serialize_method_arguments<Method>(std::forward<Arguments>(args)...);
    if (input.size() > Method::request_size())
      throw std::length_error("NTL RPC request exceeded its method limit");

    auto state = std::make_shared<detail::async_operation>(
        handle_, Method::code(), std::move(input), Method::response_size());
    return make_async_call<Method>(std::move(state),
                                   typename std::is_void<
                                       typename Method::return_type>::type{});
  }

  /**
   * @brief Waits for and returns one typed kernel notification.
   * @note Each successful receive consumes one notification. Start another
   * receive before asking the driver to publish the next event.
   */
  template <typename Notification>
  typename Notification::payload_type receive(const Notification &channel) {
    return receive_async(channel).get();
  }

  /**
   * @brief Queues a cancellable overlapped receive for one notification.
   * @return An owner that keeps its IRP buffers and device handle alive.
   */
  template <typename Notification>
  notification_wait<typename Notification::payload_type>
  receive_async(const Notification &channel) {
    static_assert(
        is_notification<Notification>::value,
        "ntl::rpc::client::receive_async requires an ntl::rpc::notification");
    static_assert(
        std::is_default_constructible<
            typename Notification::payload_type>::value,
        "NTL RPC notification payloads must be default constructible");
    static_assert(Notification::response_size() <=
                      static_cast<std::size_t>(
                          (std::numeric_limits<DWORD>::max)()),
                  "NTL RPC notification capacity exceeds DWORD capacity");
    (void)channel;

    detail::notification_wait_request request{Notification::id()};
    std::vector<unsigned char> input(sizeof(request));
    std::memcpy(input.data(), &request, sizeof(request));
    auto state = std::make_shared<detail::async_operation>(
        handle_, notification_control_code(), std::move(input),
        Notification::response_size());
    return notification_wait<typename Notification::payload_type>(
        std::move(state), Notification::decode_allocation());
  }

private:
  template <typename Tuple, std::size_t... Index>
  static std::vector<unsigned char>
  serialize_arguments(Tuple &arguments, std::index_sequence<Index...>) {
    std::vector<unsigned char> bytes;
    zpp::serializer::memory_output_archive archive(bytes);
    archive(std::get<Index>(arguments)...);
    return bytes;
  }

  template <typename Method, typename... Arguments>
  static std::vector<unsigned char>
  serialize_method_arguments(Arguments &&...args) {
    using storage = typename Method::argument_storage;
    static_assert(std::is_constructible<storage, Arguments &&...>::value,
                  "RPC arguments cannot initialize the method signature");
    storage arguments(std::forward<Arguments>(args)...);
    return serialize_arguments(
        arguments,
        std::make_index_sequence<std::tuple_size<storage>::value>{});
  }

  static void ensure_dword_size(std::size_t size, const char *description) {
    if (size > static_cast<std::size_t>(
                   (std::numeric_limits<DWORD>::max)())) {
      throw std::length_error(description);
    }
  }

  void call(unsigned long code, const std::vector<unsigned char> &input,
             void *output, DWORD output_size, DWORD &returned) const {
    if (!handle_ || !*handle_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL RPC device is not open");

    ensure_dword_size(input.size(), "NTL RPC input exceeds DWORD capacity");
    ntl::unique_handle event(::CreateEventW(nullptr, TRUE, FALSE, nullptr));
    if (!event)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC event creation failed");

    OVERLAPPED overlapped{};
    overlapped.hEvent = event.get();
    if (!::DeviceIoControl(
            handle_->get(), code,
            input.empty() ? nullptr
                          : const_cast<unsigned char *>(input.data()),
            static_cast<DWORD>(input.size()), output, output_size, &returned,
            &overlapped)) {
      const DWORD error = ::GetLastError();
      if (error != ERROR_IO_PENDING)
        throw std::system_error(static_cast<int>(error),
                                std::system_category(),
                                "NTL RPC DeviceIoControl failed");
      if (!::GetOverlappedResult(handle_->get(), &overlapped, &returned,
                                 TRUE))
        throw std::system_error(static_cast<int>(::GetLastError()),
                                std::system_category(),
                                "NTL RPC DeviceIoControl completion failed");
    }
  }

  template <typename Method>
  static async_call<typename Method::return_type>
  make_async_call(std::shared_ptr<detail::async_operation> state,
                  std::false_type) {
    return async_call<typename Method::return_type>(
        std::move(state), Method::decode_allocation());
  }

  template <typename Method>
  static async_call<typename Method::return_type>
  make_async_call(std::shared_ptr<detail::async_operation> state,
                  std::true_type) {
    return async_call<void>(std::move(state));
  }

  template <typename Method, typename... Arguments>
  void invoke_impl(const Method &, std::true_type, Arguments &&...args) {
    const auto input =
        serialize_method_arguments<Method>(std::forward<Arguments>(args)...);
    if (input.size() > Method::request_size())
      throw std::length_error("NTL RPC request exceeded its method limit");
    DWORD returned = 0;
    call(Method::code(), input, nullptr, 0, returned);
    if (returned != 0)
      throw std::runtime_error("void NTL RPC method returned output bytes");
  }

  template <typename Method, typename... Arguments>
  typename Method::return_type invoke_impl(const Method &, std::false_type,
                                           Arguments &&...args) {
    using return_type = typename Method::return_type;
    static_assert(std::is_default_constructible<return_type>::value,
                  "NTL RPC return types must be default constructible");
    static_assert(Method::response_size() <=
                      static_cast<std::size_t>(
                          (std::numeric_limits<DWORD>::max)()),
                  "NTL RPC response capacity exceeds DWORD capacity");

    const auto input =
        serialize_method_arguments<Method>(std::forward<Arguments>(args)...);
    if (input.size() > Method::request_size())
      throw std::length_error("NTL RPC request exceeded its method limit");
    std::vector<unsigned char> output(Method::response_size());
    DWORD returned = 0;
    call(Method::code(), input, output.data(),
         static_cast<DWORD>(output.size()), returned);

    if (returned > output.size())
      throw std::runtime_error("NTL RPC returned an invalid output size");

    output.resize(returned);
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), Method::decode_allocation());
    return_type value{};
    archive(value);
    if (archive.offset() != output.size())
      throw std::runtime_error("NTL RPC response contains trailing bytes");
    return std::move(value);
  }

private:
  std::shared_ptr<ntl::unique_handle> handle_;
};

