/** @brief Identifies why an RPC server contract was rejected. */
enum class contract_mismatch_reason {
  query_unavailable,
  protocol_version,
  contract_version,
  transport_features,
  capabilities,
  method,
};

/** @brief Reports an application or transport contract incompatibility. */
class contract_mismatch : public std::runtime_error {
public:
  /** @brief Creates an incompatibility error with diagnostic values. */
  contract_mismatch(contract_mismatch_reason reason, const char *message,
                    std::uint64_t expected = 0, std::uint64_t actual = 0)
      : std::runtime_error(message), reason_(reason), expected_(expected),
        actual_(actual) {}

  /** @brief Returns the failed compatibility rule. */
  contract_mismatch_reason reason() const noexcept { return reason_; }

  /** @brief Returns the required version, feature mask, or method ID. */
  std::uint64_t expected() const noexcept { return expected_; }

  /** @brief Returns the server value, or zero for a missing method. */
  std::uint64_t actual() const noexcept { return actual_; }

private:
  contract_mismatch_reason reason_;
  std::uint64_t expected_;
  std::uint64_t actual_;
};

/** @brief Declares the server contract required by one client. */
class contract_requirements {
public:
  /** @brief Requires an exact application contract version. */
  contract_requirements &contract_version(std::uint32_t version) noexcept {
    has_contract_version_ = true;
    contract_version_ = version;
    return *this;
  }

  /** @brief Requires all selected NTL transport features. */
  contract_requirements &transport_features(std::uint64_t features) noexcept {
    transport_features_ = features;
    return *this;
  }

  /** @brief Requires all selected application-defined capability bits. */
  contract_requirements &capabilities(std::uint64_t capabilities) noexcept {
    capabilities_ = capabilities;
    return *this;
  }

  /** @brief Requires one typed method to be present on the server. */
  template <typename Method> contract_requirements &method(const Method &) {
    static_assert(is_method<Method>::value,
                  "contract_requirements::method requires an RPC method");
    method_ids_.push_back(static_cast<std::uint32_t>(Method::id()));
    return *this;
  }

private:
  bool has_contract_version_ = false;
  std::uint32_t contract_version_ = 0;
  std::uint64_t transport_features_ = 0;
  std::uint64_t capabilities_ = 0;
  std::vector<std::uint32_t> method_ids_;

  friend class client;
};

/** @brief Result of a bounded wait on one asynchronous RPC call. */
enum class async_wait_status {
  completed,
  timeout,
};

namespace detail {

template <typename T> class async_call_awaiter;

struct completed_error_operation_t {};

class async_operation {
public:
  async_operation(std::shared_ptr<ntl::unique_handle> handle,
                  unsigned long code, std::vector<unsigned char> input,
                  std::size_t output_size)
      : handle_(std::move(handle)), input_(std::move(input)),
        output_(output_size),
        event_(::CreateEventW(nullptr, TRUE, FALSE, nullptr)) {
    if (!handle_ || !*handle_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL RPC device is not open");
    if (!event_)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC event creation failed");
    if (input_.size() >
            static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()) ||
        output_.size() >
            static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()))
      throw std::length_error(
          "NTL RPC asynchronous buffer exceeds DWORD capacity");

    overlapped_.hEvent = event_.get();
    DWORD returned = 0;
    const BOOL succeeded = ::DeviceIoControl(
        handle_->get(), code, input_.empty() ? nullptr : input_.data(),
        static_cast<DWORD>(input_.size()),
        output_.empty() ? nullptr : output_.data(),
        static_cast<DWORD>(output_.size()), &returned, &overlapped_);
    if (succeeded) {
      completed_ = true;
      returned_ = returned;
      if (returned_ <= output_.size())
        output_.resize(returned_);
      else
        error_ = ERROR_INVALID_DATA;
      return;
    }

    const DWORD error = ::GetLastError();
    if (error != ERROR_IO_PENDING)
      throw std::system_error(static_cast<int>(error), std::system_category(),
                              "NTL RPC overlapped DeviceIoControl failed");
  }

  async_operation(std::shared_ptr<ntl::unique_handle> handle,
                  completed_error_operation_t, DWORD error)
      : handle_(std::move(handle)),
        event_(::CreateEventW(nullptr, TRUE, TRUE, nullptr)), error_(error),
        completed_(true) {
    if (!handle_ || !*handle_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL RPC device is not open");
    if (!event_)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC event creation failed");
  }

  async_operation(const async_operation &) = delete;
  async_operation &operator=(const async_operation &) = delete;

  ~async_operation() {
    if (!ready_noexcept()) {
      (void)::CancelIoEx(handle_->get(), &overlapped_);
      (void)observe_completion(true);
    }
  }

  bool ready() const {
    {
      std::lock_guard<std::mutex> guard(lock_);
      if (completed_)
        return true;
    }

    const DWORD wait = ::WaitForSingleObject(event_.get(), 0);
    if (wait == WAIT_OBJECT_0)
      return true;
    if (wait == WAIT_TIMEOUT)
      return false;
    throw std::system_error(static_cast<int>(::GetLastError()),
                            std::system_category(),
                            "NTL RPC asynchronous wait failed");
  }

  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    if (ready()) {
      (void)observe_completion(true);
      return async_wait_status::completed;
    }

    const auto count = timeout.count();
    const DWORD wait_ms = count <= 0 ? 0
                          : count >= static_cast<decltype(count)>((INFINITE)-1)
                              ? (INFINITE)-1
                              : static_cast<DWORD>(count);
    const DWORD wait = ::WaitForSingleObject(event_.get(), wait_ms);
    if (wait == WAIT_TIMEOUT)
      return async_wait_status::timeout;
    if (wait != WAIT_OBJECT_0)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC asynchronous wait failed");

    (void)observe_completion(true);
    return async_wait_status::completed;
  }

  void wait() { (void)observe_completion(true); }

  bool cancel() {
    if (::CancelIoEx(handle_->get(), &overlapped_))
      return true;
    const DWORD error = ::GetLastError();
    if (error == ERROR_NOT_FOUND)
      return false;
    throw std::system_error(static_cast<int>(error), std::system_category(),
                            "NTL RPC cancellation failed");
  }

  /** @brief Requests cancellation without propagating callback exceptions. */
  bool cancel_noexcept() noexcept {
    if (::CancelIoEx(handle_->get(), &overlapped_))
      return true;
    return false;
  }

  /** @brief Returns the event signaled when the overlapped request completes.
   */
  HANDLE completion_event() const noexcept { return event_.get(); }

  /** @brief Keeps a type-erased cancellation registration alive. */
  void attach_cancellation_registration(
      std::shared_ptr<void> registration) noexcept {
    cancellation_registration_ = std::move(registration);
  }

  const std::vector<unsigned char> &output() {
    (void)observe_completion(true);
    std::lock_guard<std::mutex> guard(lock_);
    if (error_ != ERROR_SUCCESS)
      throw std::system_error(static_cast<int>(error_), std::system_category(),
                              "NTL RPC asynchronous call failed");
    return output_;
  }

private:
  bool ready_noexcept() const noexcept {
    {
      std::lock_guard<std::mutex> guard(lock_);
      if (completed_)
        return true;
    }
    return ::WaitForSingleObject(event_.get(), 0) == WAIT_OBJECT_0;
  }

  bool observe_completion(bool wait) noexcept {
    std::lock_guard<std::mutex> guard(lock_);
    if (completed_)
      return true;

    DWORD returned = 0;
    if (!::GetOverlappedResult(handle_->get(), &overlapped_, &returned,
                               wait ? TRUE : FALSE)) {
      const DWORD error = ::GetLastError();
      if (!wait && error == ERROR_IO_INCOMPLETE)
        return false;
      error_ = error;
    } else {
      error_ = ERROR_SUCCESS;
      returned_ = returned;
      if (returned_ <= output_.size())
        output_.resize(returned_);
      else
        error_ = ERROR_INVALID_DATA;
    }
    completed_ = true;
    return true;
  }

  std::shared_ptr<ntl::unique_handle> handle_;
  std::vector<unsigned char> input_;
  std::vector<unsigned char> output_;
  ntl::unique_handle event_;
  OVERLAPPED overlapped_{};
  mutable std::mutex lock_;
  DWORD returned_ = 0;
  DWORD error_ = ERROR_SUCCESS;
  bool completed_ = false;
  // Keep this member in every language mode. A conditional std::stop_callback
  // member would give C++14 and C++20 translation units different class
  // layouts when both are linked into one application.
  std::shared_ptr<void> cancellation_registration_;
};

#if NTL_RPC_HAS_STOP_TOKEN
struct stop_canceller {
  std::weak_ptr<async_operation> operation;

  void operator()() const noexcept {
    if (auto current = operation.lock())
      (void)current->cancel_noexcept();
  }
};

inline void
attach_stop_token(std::stop_token token,
                  const std::shared_ptr<async_operation> &operation) {
  using callback_type = std::stop_callback<stop_canceller>;
  auto registration = std::make_shared<callback_type>(
      token, stop_canceller{std::weak_ptr<async_operation>(operation)});
  operation->attach_cancellation_registration(std::move(registration));
}
#endif

