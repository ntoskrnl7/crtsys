/** @brief Move-only owner of one asynchronous typed RPC invocation. */
template <typename T> class async_call {
public:
  async_call(const async_call &) = delete;
  async_call &operator=(const async_call &) = delete;
  async_call(async_call &&) noexcept = default;
  async_call &operator=(async_call &&) noexcept = default;

  /** @brief Returns true until get() consumes the result. */
  explicit operator bool() const noexcept { return state_ && !consumed_; }

  /** @brief Reports whether the underlying DeviceIoControl has completed. */
  bool ready() const {
    ensure_valid();
    return state_->ready();
  }

  /** @brief Waits up to timeout for completion. */
  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout);
  }

  /** @brief Waits without a timeout. */
  void wait() {
    ensure_valid();
    state_->wait();
  }

  /** @brief Requests cancellation with CancelIoEx for only this call. */
  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  /** @brief Waits, deserializes, and consumes the typed result. */
  T get() {
    ensure_valid();
    const auto &output = state_->output();
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), decode_allocation_);
    T value{};
    archive(value);
    if (archive.offset() != output.size())
      throw std::runtime_error("NTL RPC response contains trailing bytes");
    consumed_ = true;
    state_.reset();
    return std::move(value);
  }

private:
  friend class client;
  template <typename U> friend class detail::async_call_awaiter;
  async_call(std::shared_ptr<detail::async_operation> state,
             std::size_t decode_allocation)
      : state_(std::move(state)), decode_allocation_(decode_allocation) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL RPC asynchronous call has no result");
  }

  std::shared_ptr<detail::async_operation> state_;
  std::size_t decode_allocation_;
  bool consumed_ = false;
};

/** @brief Move-only owner of an asynchronous void RPC invocation. */
template <> class async_call<void> {
public:
  async_call(const async_call &) = delete;
  async_call &operator=(const async_call &) = delete;
  async_call(async_call &&) noexcept = default;
  async_call &operator=(async_call &&) noexcept = default;

  explicit operator bool() const noexcept { return state_ && !consumed_; }

  bool ready() const {
    ensure_valid();
    return state_->ready();
  }

  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout);
  }

  void wait() {
    ensure_valid();
    state_->wait();
  }

  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  /** @brief Waits for completion and consumes a void result. */
  void get() {
    ensure_valid();
    if (!state_->output().empty())
      throw std::runtime_error("void NTL RPC method returned output bytes");
    consumed_ = true;
    state_.reset();
  }

private:
  friend class client;
  template <typename U> friend class detail::async_call_awaiter;
  explicit async_call(std::shared_ptr<detail::async_operation> state)
      : state_(std::move(state)) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL RPC asynchronous call has no result");
  }

  std::shared_ptr<detail::async_operation> state_;
  bool consumed_ = false;
};

/** @brief Move-only owner of one pending typed kernel notification. */
template <typename T> using notification_wait = async_call<T>;

/** @brief Move-only owner of one pending bounded reliable batch receive. */
class reliable_batch_wait {
public:
  reliable_batch_wait(const reliable_batch_wait &) = delete;
  reliable_batch_wait &operator=(const reliable_batch_wait &) = delete;
  reliable_batch_wait(reliable_batch_wait &&) noexcept = default;
  reliable_batch_wait &operator=(reliable_batch_wait &&) noexcept = default;

  explicit operator bool() const noexcept { return state_ && !consumed_; }

  bool ready() const {
    ensure_valid();
    return state_->ready();
  }

  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    ensure_valid();
    return state_->wait_for(timeout);
  }

  void wait() {
    ensure_valid();
    state_->wait();
  }

  bool cancel() {
    ensure_valid();
    return state_->cancel();
  }

  /** @brief Waits, validates the fixed-width frame, and consumes the batch. */
  reliable_batch get() {
    ensure_valid();
    const auto &output = state_->output();
    if (output.size() < sizeof(detail::reliable_batch_header))
      throw std::runtime_error("NTL RPC batch header is truncated");

    detail::reliable_batch_header batch_header{};
    std::memcpy(&batch_header, output.data(), sizeof(batch_header));
    if (batch_header.version != detail::reliable_batch_version ||
        batch_header.count == 0 || batch_header.count > max_records_)
      throw std::runtime_error("NTL RPC batch header is invalid");

    std::vector<reliable_batch_item> items;
    items.reserve(batch_header.count);
    std::size_t offset = sizeof(batch_header);
    for (std::uint32_t index = 0; index < batch_header.count; ++index) {
      if (output.size() - offset < sizeof(detail::reliable_batch_record_header))
        throw std::runtime_error("NTL RPC batch record header is truncated");
      detail::reliable_batch_record_header record{};
      std::memcpy(&record, output.data() + offset, sizeof(record));
      offset += sizeof(record);
      if (record.id == 0 || record.sequence == 0 || record.size == 0 ||
          record.size > output.size() - offset)
        throw std::runtime_error("NTL RPC batch record is invalid");
      std::vector<unsigned char> bytes(record.size);
      std::memcpy(bytes.data(), output.data() + offset, record.size);
      offset += record.size;
      items.emplace_back(record.id, record.sequence, std::move(bytes));
    }
    if (offset != output.size())
      throw std::runtime_error("NTL RPC batch contains trailing bytes");

    consumed_ = true;
    state_.reset();
    return reliable_batch(std::move(items));
  }

private:
  friend class client;
  template <typename Notification> friend class notification_batch_wait;
  reliable_batch_wait(std::shared_ptr<detail::async_operation> state,
                      std::uint32_t max_records)
      : state_(std::move(state)), max_records_(max_records) {}

  void ensure_valid() const {
    if (!state_ || consumed_)
      throw std::logic_error("NTL RPC batch wait has no result");
  }

  std::shared_ptr<detail::async_operation> state_;
  std::uint32_t max_records_ = 0;
  bool consumed_ = false;
};

/** @brief Typed wrapper over a bounded single-channel reliable batch. */
template <typename Notification> class notification_batch_wait {
public:
  using payload_type = typename Notification::payload_type;
  using batch_type = notification_batch<payload_type>;

  notification_batch_wait(const notification_batch_wait &) = delete;
  notification_batch_wait &operator=(const notification_batch_wait &) = delete;
  notification_batch_wait(notification_batch_wait &&) noexcept = default;
  notification_batch_wait &
  operator=(notification_batch_wait &&) noexcept = default;

  explicit operator bool() const noexcept { return static_cast<bool>(wait_); }
  bool ready() const { return wait_.ready(); }
  async_wait_status wait_for(std::chrono::milliseconds timeout) {
    return wait_.wait_for(timeout);
  }
  void wait() { wait_.wait(); }
  bool cancel() { return wait_.cancel(); }

  batch_type get() {
    auto raw = wait_.get();
    std::vector<notification_delivery<payload_type>> values;
    values.reserve(raw.size());
    for (const auto &item : raw.items())
      values.push_back(item.decode(Notification{}));
    return batch_type(std::move(values));
  }

private:
  friend class client;
  explicit notification_batch_wait(reliable_batch_wait wait)
      : wait_(std::move(wait)) {}

  reliable_batch_wait wait_;
};

/**
 * @brief Owns one user allocation registered and pinned by an RPC session.
 *
 * Destruction unregisters the region before releasing its virtual address.
 * Keep this object alive while any buffer_token or shared_ring over its memory
 * can still be used by the driver.
 */
class registered_region {
public:
  registered_region() noexcept = default;
  registered_region(const registered_region &) = delete;
  registered_region &operator=(const registered_region &) = delete;

  registered_region(registered_region &&other) noexcept
      : handle_(std::move(other.handle_)), session_(other.session_),
        region_(other.region_), memory_(other.memory_), bytes_(other.bytes_) {
    other.session_ = {};
    other.region_ = {};
    other.memory_ = nullptr;
    other.bytes_ = 0;
  }

  registered_region &operator=(registered_region &&other) noexcept {
    if (this == &other)
      return *this;
    reset_noexcept();
    handle_ = std::move(other.handle_);
    session_ = other.session_;
    region_ = other.region_;
    memory_ = other.memory_;
    bytes_ = other.bytes_;
    other.session_ = {};
    other.region_ = {};
    other.memory_ = nullptr;
    other.bytes_ = 0;
    return *this;
  }

  /** @brief Unregisters the MDL before releasing the user allocation. */
  ~registered_region() { reset_noexcept(); }

  /** @brief Reports whether allocation and kernel registration both exist. */
  explicit operator bool() const noexcept {
    return memory_ != nullptr && region_.valid();
  }

  /** @brief Returns the page-aligned user mapping. */
  void *data() const noexcept { return memory_; }

  /** @brief Returns the allocated and registered byte count. */
  std::size_t size() const noexcept { return bytes_; }

  /** @brief Returns the kernel-assigned region identity. */
  ntl::ipc::region_handle handle() const noexcept { return region_; }

  /** @brief Creates a checked pointer-free token for a subrange. */
  ntl::ipc::buffer_token token(std::size_t offset, std::size_t length) const {
    if (!*this || length == 0 || offset > bytes_ || length > bytes_ - offset)
      throw std::out_of_range("NTL RPC shared-region token is out of range");
    return ntl::ipc::buffer_token{region_,
                                  static_cast<std::uint64_t>(offset),
                                  static_cast<std::uint64_t>(length)};
  }

  /**
   * @brief Explicitly unregisters and releases the region, reporting failures.
   * @note If the session was already closed, the server has already unpinned
   * the range; ERROR_NOT_FOUND and invalid-handle errors are treated as closed.
   */
  void close() {
    if (!memory_)
      return;
    if (region_.valid())
      unregister_region(true);
    release_memory();
  }

private:
  friend class client;

  registered_region(std::shared_ptr<ntl::unique_handle> handle,
                    session_token session, ntl::ipc::region_handle region,
                    void *memory, std::size_t bytes) noexcept
      : handle_(std::move(handle)), session_(session), region_(region),
        memory_(memory), bytes_(bytes) {}

  void unregister_region(bool report_failure) {
    if (!handle_ || !*handle_ || !session_.valid() || !region_.valid()) {
      region_ = {};
      return;
    }

    detail::region_control_request request{};
    request.version = detail::session_control_version;
    request.operation = detail::session_control_operation::unregister_region;
    request.token = session_;
    request.region = region_;

    ntl::unique_handle event(::CreateEventW(nullptr, TRUE, FALSE, nullptr));
    if (!event) {
      if (report_failure)
        throw std::system_error(static_cast<int>(::GetLastError()),
                                std::system_category(),
                                "NTL RPC shared-region close event failed");
      return;
    }

    OVERLAPPED overlapped{};
    overlapped.hEvent = event.get();
    DWORD returned = 0;
    BOOL completed = ::DeviceIoControl(
        handle_->get(), session_control_code(), &request, sizeof(request),
        nullptr, 0, &returned, &overlapped);
    DWORD error = completed ? ERROR_SUCCESS : ::GetLastError();
    if (!completed && error == ERROR_IO_PENDING) {
      completed = ::GetOverlappedResult(handle_->get(), &overlapped, &returned,
                                        TRUE);
      error = completed ? ERROR_SUCCESS : ::GetLastError();
    }

    if (!completed && error != ERROR_NOT_FOUND &&
        error != ERROR_INVALID_HANDLE && error != ERROR_FILE_NOT_FOUND) {
      if (report_failure)
        throw std::system_error(static_cast<int>(error), std::system_category(),
                                "NTL RPC shared-region unregistration failed");
      return;
    }
    region_ = {};
  }

  void release_memory() noexcept {
    if (memory_)
      ::VirtualFree(memory_, 0, MEM_RELEASE);
    memory_ = nullptr;
    bytes_ = 0;
    session_ = {};
    handle_.reset();
  }

  void reset_noexcept() noexcept {
    try {
      if (region_.valid())
        unregister_region(false);
    } catch (...) {
    }
    if (!region_.valid()) {
      release_memory();
      return;
    }

    // Do not release pages that may still be pinned by the driver. The virtual
    // allocation intentionally remains reserved until process teardown if a
    // live shared file handle prevented the best-effort unregister request
    // from completing. Explicit close() reports this condition to the caller.
    handle_.reset();
    memory_ = nullptr;
    bytes_ = 0;
    session_ = {};
    region_ = {};
  }

  std::shared_ptr<ntl::unique_handle> handle_;
  session_token session_{};
  ntl::ipc::region_handle region_{};
  void *memory_ = nullptr;
  std::size_t bytes_ = 0;
};

/** @brief Owns a user-mode handle to an NTL RPC device. */
class client {
public:
  /**
   * @brief Opens an NTL RPC device.
   * @param rpc_name Kernel device name without the `\\Device\\` prefix.
   */
  explicit client(const std::wstring &rpc_name)
      : handle_(std::make_shared<ntl::unique_handle>(::CreateFileW(
            (L"\\\\?\\Global\\GLOBALROOT\\Device\\" + rpc_name).c_str(),
            GENERIC_READ | GENERIC_WRITE, 0, NULL, OPEN_EXISTING,
            FILE_FLAG_OVERLAPPED, NULL))) {}

  client(const client &) = delete;
  client &operator=(const client &) = delete;
  client(client &&other) noexcept
      : handle_(std::move(other.handle_)), session_(other.session_) {
    other.session_ = {};
  }

  client &operator=(client &&other) noexcept {
    if (this != &other) {
      handle_ = std::move(other.handle_);
      session_ = other.session_;
      other.session_ = {};
    }
    return *this;
  }

  /** @brief Returns true when the RPC device was opened successfully. */
  explicit operator bool() const noexcept {
    return handle_ && static_cast<bool>(*handle_);
  }

  /**
   * @brief Queries wire, capability, and method metadata from the server.
   * @return Immutable metadata published when the server started.
   */
  contract_info query_contract() const {
    std::vector<unsigned char> output(contract_response_size);
    const std::vector<unsigned char> input;
    DWORD returned = 0;
    try {
      call(control_code(contract_query_id), input, output.data(),
           static_cast<DWORD>(output.size()), returned);
    } catch (const std::system_error &error) {
      const auto code = static_cast<DWORD>(error.code().value());
      if (code == ERROR_INVALID_FUNCTION || code == ERROR_NOT_SUPPORTED) {
        throw contract_mismatch(
            contract_mismatch_reason::query_unavailable,
            "NTL RPC server does not support contract discovery");
      }
      throw;
    }

    if (returned > output.size())
      throw std::runtime_error(
          "NTL RPC contract query returned an invalid output size");

    output.resize(returned);
    try {
      zpp::serializer::memory_view_input_archive archive(
          output.data(), output.size(), contract_response_size);
      contract_info info;
      archive(info);
      if (archive.offset() != output.size())
        throw std::runtime_error(
            "NTL RPC contract response contains trailing bytes");
      const auto &methods = info.method_ids();
      if (!std::is_sorted(methods.begin(), methods.end()) ||
          std::adjacent_find(methods.begin(), methods.end()) != methods.end())
        throw std::runtime_error(
            "NTL RPC contract response has an invalid method table");
      return info;
    } catch (const zpp::serializer::out_of_range &) {
      throw std::runtime_error("NTL RPC contract response is malformed");
    }
  }

  /**
   * @brief Queries and validates the server before application RPC calls.
   * @param requirements Application and transport requirements.
   * @return The validated server metadata for optional inspection.
   */
  contract_info
  require_contract(const contract_requirements &requirements) const {
    auto info = query_contract();
    if (info.protocol_version() != current_protocol_version) {
      throw contract_mismatch(contract_mismatch_reason::protocol_version,
                              "NTL RPC protocol version mismatch",
                              current_protocol_version,
                              info.protocol_version());
    }
    if (requirements.has_contract_version_ &&
        info.contract_version() != requirements.contract_version_) {
      throw contract_mismatch(contract_mismatch_reason::contract_version,
                              "NTL RPC application contract version mismatch",
                              requirements.contract_version_,
                              info.contract_version());
    }
    if ((info.transport_feature_mask() & requirements.transport_features_) !=
        requirements.transport_features_) {
      throw contract_mismatch(contract_mismatch_reason::transport_features,
                              "NTL RPC transport feature is unavailable",
                              requirements.transport_features_,
                              info.transport_feature_mask());
    }
    if ((info.capability_mask() & requirements.capabilities_) !=
        requirements.capabilities_) {
      throw contract_mismatch(contract_mismatch_reason::capabilities,
                              "NTL RPC application capability is unavailable",
                              requirements.capabilities_,
                              info.capability_mask());
    }
    for (const auto id : requirements.method_ids_) {
      if (!info.supports_method(id)) {
        throw contract_mismatch(contract_mismatch_reason::method,
                                "NTL RPC method is unavailable", id, 0);
      }
    }
    return info;
  }

  /**
   * @brief Creates a reconnectable session on this device handle.
   * @return The opaque reconnect token and endpoint-local session ID.
   * @note Preserve only the token when reconnecting from another handle. The
   * numeric ID is useful while this server instance remains loaded.
   */
  session_info start_session() {
    session_ = session_command(detail::session_control_operation::create, {});
    return session_;
  }

  /**
   * @brief Reattaches this device handle to a disconnected session.
   * @param token Opaque token returned by `start_session()`.
   */
  session_info resume_session(session_token token) {
    if (!token.valid())
      throw std::invalid_argument("NTL RPC session token is invalid");
    session_ =
        session_command(detail::session_control_operation::resume, token);
    return session_;
  }

  /** @brief Returns true after this handle creates or resumes a session. */
  bool has_session() const noexcept { return session_.valid(); }

  /** @brief Returns the session attached to this device handle. */
  const session_info &session() const noexcept { return session_; }

  /**
   * @brief Explicitly closes this session and discards server-side replay
   * state.
   * @note Closing the device handle without calling this function merely
   * disconnects the session so that its token can resume it.
   */
  void close_session() {
    require_session();
    session_command(detail::session_control_operation::close, session_.token);
    session_ = {};
  }

  /** @brief Subscribes this session to a reliable notification channel. */
  template <typename Notification> void subscribe(const Notification &channel) {
    static_assert(is_notification<Notification>::value,
                  "client::subscribe requires an ntl::rpc::notification");
    (void)channel;
    require_session();
    session_command(detail::session_control_operation::subscribe,
                    session_.token, Notification::id());
  }

  /** @brief Stops future reliable deliveries for one channel. */
  template <typename Notification>
  void unsubscribe(const Notification &channel) {
    static_assert(is_notification<Notification>::value,
                  "client::unsubscribe requires an ntl::rpc::notification");
    (void)channel;
    require_session();
    session_command(detail::session_control_operation::unsubscribe,
                    session_.token, Notification::id());
  }

  /** @brief Removes one successfully processed reliable delivery. */
  template <typename Notification>
  void
  acknowledge(const Notification &channel,
              const notification_delivery<typename Notification::payload_type>
                  &delivery) {
    acknowledge(channel, delivery.sequence());
  }

  /** @brief Removes one reliable delivery by its sequence number. */
  template <typename Notification>
  void acknowledge(const Notification &channel, std::uint64_t sequence) {
    static_assert(is_notification<Notification>::value,
                  "client::acknowledge requires an ntl::rpc::notification");
    (void)channel;
    require_session();
    if (sequence == 0)
      throw std::invalid_argument(
          "NTL RPC notification sequence must be nonzero");
    session_command(detail::session_control_operation::acknowledge,
                    session_.token, Notification::id(), sequence);
  }

  /**
   * @brief Allocates and registers one session-bound shared-memory region.
   * @param bytes Region size, limited by the server quota and MDL ULONG length.
   * @param access Driver access to grant after probing the user pages.
   * @return Move-only owner that unregisters before VirtualFree.
   */
  registered_region
  register_shared_region(std::size_t bytes,
                         ntl::ipc::region_access access =
                             ntl::ipc::region_access::driver_read_write) {
    require_session();
    if (bytes == 0 ||
        bytes > static_cast<std::size_t>((std::numeric_limits<ULONG>::max)()) ||
        access == ntl::ipc::region_access::none ||
        !ntl::ipc::has_access(ntl::ipc::region_access::driver_read_write,
                              access))
      throw std::invalid_argument("NTL RPC shared-region request is invalid");

    void *const memory =
        ::VirtualAlloc(nullptr, bytes, MEM_RESERVE | MEM_COMMIT, PAGE_READWRITE);
    if (!memory)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC shared-region allocation failed");

    detail::region_control_request request{};
    request.version = detail::session_control_version;
    request.operation = detail::session_control_operation::register_region;
    request.token = session_.token;
    request.registration = ntl::ipc::region_registration::from(
        memory, bytes, access);

    detail::region_control_response response{};
    DWORD returned = 0;
    try {
      std::vector<unsigned char> input(sizeof(request));
      std::memcpy(input.data(), &request, sizeof(request));
      call(session_control_code(), input, &response,
           static_cast<DWORD>(sizeof(response)), returned);
      if (returned != sizeof(response) || !response.region.valid())
        throw std::runtime_error(
            "NTL RPC server returned an invalid shared-region response");
    } catch (...) {
      ::VirtualFree(memory, 0, MEM_RELEASE);
      throw;
    }

    return registered_region{handle_, session_.token, response.region, memory,
                             bytes};
  }

  /** @brief ACKs a typed single-channel batch in delivery order. */
  template <typename Notification>
  void acknowledge(
      const Notification &channel,
      const notification_batch<typename Notification::payload_type> &batch) {
    for (const auto &delivery : batch.values())
      acknowledge(channel, delivery);
  }

  /** @brief ACKs one channel-tagged item returned by an any-channel batch. */
  void acknowledge(const reliable_batch_item &item) {
    require_session();
    if (item.id() == 0 || item.sequence() == 0)
      throw std::invalid_argument("NTL RPC batch ACK identity is invalid");
    session_command(detail::session_control_operation::acknowledge,
                    session_.token, item.id(), item.sequence());
  }

  /** @brief ACKs every item in order; earlier ACKs remain committed on error.
   */
  void acknowledge(const reliable_batch &batch) {
    for (const auto &item : batch.items())
      acknowledge(item);
  }

  /**
   * @brief Opens one typed stream on the current reconnectable session.

   * * @note Call start_session() or resume_session() first. Opening subscribes

   * * the download direction; uploads use the same session-bound device
   * handle.
   */
  template <typename Stream> void open_stream(const Stream &channel) {
    static_assert(is_stream<Stream>::value,
                  "client::open_stream requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    session_command(detail::session_control_operation::subscribe,
                    session_.token, Stream::id());
  }

  /**
   * @brief Closes one typed stream after all delivered records are
   * ACKed.
   * @note Cancel or drain pending reads and writes before closing
   * the stream.
   */
  template <typename Stream> void close_stream(const Stream &channel) {
    static_assert(is_stream<Stream>::value,
                  "client::close_stream requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    session_command(detail::session_control_operation::unsubscribe,
                    session_.token, Stream::id());
  }

  /** @brief Sends one typed app-to-driver stream chunk synchronously. */
  template <typename Stream>
  void write(const Stream &channel, const typename Stream::upload_type &value) {
    static_assert(is_stream<Stream>::value,
                  "client::write requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    std::vector<typename Stream::upload_type> values{value};
    invoke(Stream::upload_method(),
           typename Stream::upload_batch_type(std::move(values)));
  }

  /** @brief Sends a bounded ordered group of stream chunks in one request. */
  template <typename Stream>
  void write_batch(const Stream &channel,
                   const std::vector<typename Stream::upload_type> &values) {
    static_assert(is_stream<Stream>::value,
                  "client::write_batch requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    validate_stream_batch<Stream>(values.size());
    invoke(Stream::upload_method(), typename Stream::upload_batch_type(values));
  }

  /** @brief Sends one typed app-to-driver stream chunk asynchronously. */
  template <typename Stream>
  async_call<void> write_async(const Stream &channel,
                               const typename Stream::upload_type &value) {
    static_assert(is_stream<Stream>::value,
                  "client::write_async requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    std::vector<typename Stream::upload_type> values{value};
    return invoke_async(Stream::upload_method(),
                        typename Stream::upload_batch_type(std::move(values)));
  }

  /** @brief Sends a bounded stream upload batch asynchronously. */
  template <typename Stream>
  async_call<void>
  write_batch_async(const Stream &channel,
                    const std::vector<typename Stream::upload_type> &values) {
    static_assert(is_stream<Stream>::value,
                  "client::write_batch_async requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    validate_stream_batch<Stream>(values.size());
    return invoke_async(Stream::upload_method(),
                        typename Stream::upload_batch_type(values));
  }

