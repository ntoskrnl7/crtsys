#if defined(NTL_USER_MODE)
namespace ntl {
namespace rpc {
/**
 * @brief User-mode helper for invoking an NTL RPC device.
 */
class client {
public:
  /**
   * @brief Opens the named NTL RPC device.
   * @param rpc_name Kernel device name without the \\Device prefix.
   * @param out_buffer_size Temporary output buffer size for non-void calls.
   */
  client(const std::wstring &rpc_name, size_t out_buffer_size = 4096)
      : handle_(::CreateFileW(
            (L"\\\\?\\Global\\GLOBALROOT\\Device\\" + rpc_name).c_str(),
            GENERIC_READ | GENERIC_WRITE, 0, NULL, OPEN_EXISTING, 0, NULL)),
        out_buffer_size_(out_buffer_size) {}

  /**
   * @brief Invokes a registered RPC callback by function index.
   * @param index Function code embedded into the device control request.
   * @param args Serializable callback arguments.
   * @return Deserialized callback return value for non-void calls.
   * @throws std::runtime_error if the device handle or DeviceIoControl fails.
   */
  template <typename Ret, typename... Args>
  Ret invoke(uint64_t index, Args &&... args) {
    if (!handle_)
      throw std::runtime_error("invalid handle");

    std::vector<uint8_t> in_buffer;
    zpp::serializer::memory_output_archive out(in_buffer);
    out(args...);

    DWORD returned = 0;
#pragma warning(disable : 4984)
    if constexpr (std::is_void_v<Ret>) {
      if (!::DeviceIoControl(handle_.get(), NTL_RPC_DEVICE_CTL(index),
                             in_buffer.empty() ? NULL : &in_buffer[0],
                             (DWORD)in_buffer.size(), NULL, 0, &returned, NULL))
        throw std::runtime_error("failed to DeviceIoControl (index : " +
                                 std::to_string(index) + ")");
    } else {
      std::vector<uint8_t> out_buffer(out_buffer_size_);
      if (!::DeviceIoControl(handle_.get(), NTL_RPC_DEVICE_CTL(index),
                             in_buffer.empty() ? NULL : &in_buffer[0],
                             (DWORD)in_buffer.size(), &out_buffer[0],
                             (DWORD)out_buffer.size(), &returned, NULL))
        throw std::runtime_error("failed to DeviceIoControl (index : " +
                                 std::to_string(index) + ")");
      zpp::serializer::memory_input_archive in(out_buffer);
      Ret rv;
      in(rv);
      return std::move(rv);
    }
#pragma warning(default : 4984)
  }

private:
  ntl::unique_handle handle_;
  size_t out_buffer_size_;
};
} // namespace rpc
} // namespace ntl

#define NTL_RPC_BEGIN(_rpc_name_) namespace _rpc_name_ {
#define NTL_RPC_END(_rpc_name_) }

/**
 * @brief Declares a zero-argument user-mode RPC wrapper with an explicit ID.
 */
#define NTL_ADD_CALLBACK_ID_0(_rpc_name_, _id_, _ret_, _name_, ...)            \
  static const int _name_##_0_index = (_id_);                                  \
  inline _ret_ _name_() {                                                      \
    return ntl::rpc::client(L#_rpc_name_).invoke<_ret_>((_id_));               \
  }

/**
 * @brief Declares a zero-argument user-mode RPC wrapper using __LINE__ as ID.
 */
#define NTL_ADD_CALLBACK_0(_rpc_name_, _ret_, _name_, ...)                     \
  NTL_ADD_CALLBACK_ID_0(_rpc_name_, __LINE__, _ret_, _name_, __VA_ARGS__)

/**
 * @brief Declares a one-argument user-mode RPC wrapper with an explicit ID.
 */
#define NTL_ADD_CALLBACK_ID_1(_rpc_name_, _id_, _ret_, _name_, _arg0_type_,    \
                              _arg0_name_, ...)                                \
  static const int _name_##_1_index = (_id_);                                  \
  inline _ret_ _name_(_arg0_type_ _arg0_name_) {                               \
    return ntl::rpc::client(L#_rpc_name_)                                      \
        .invoke<_ret_>((_id_), std::forward<_arg0_type_>(_arg0_name_));        \
  }

/**
