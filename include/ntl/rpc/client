  /** @brief Waits for one typed driver-to-app stream record. */
  template <typename Stream>
  notification_delivery<typename Stream::record_type>
  read(const Stream &channel) {
    return read_async(channel).get();
  }

  /**
   * @brief Queues a cancellable read for one typed stream record.
   *
   * @note A successful result remains replayable until acknowledge() is
   *
   * called. Timeout does not release the request; cancel or continue waiting.

   */
  template <typename Stream>
  notification_wait<notification_delivery<typename Stream::record_type>>
  read_async(const Stream &channel) {
    static_assert(is_stream<Stream>::value,
                  "client::read_async requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    return receive_reliable_async(Stream::download_notification());
  }

#if NTL_RPC_HAS_STOP_TOKEN
  /** @brief Queues a stream read bound to a C++20 stop token. */
  template <typename Stream>
  notification_wait<notification_delivery<typename Stream::record_type>>
  read_async(std::stop_token token, const Stream &channel) {
    static_assert(is_stream<Stream>::value,
                  "client::read_async requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    return receive_reliable_async(token, Stream::download_notification());
  }
#endif

  /** @brief ACKs one stream record and releases its queue capacity. */
  template <typename Stream>
  void acknowledge(
      const Stream &channel,
      const notification_delivery<typename Stream::record_type> &delivery) {
    static_assert(is_stream<Stream>::value,
                  "client::acknowledge requires an ntl::rpc::stream");
    (void)channel;
    require_session();
    acknowledge(Stream::download_notification(), delivery.sequence());
  }

  /**
   * @brief Invokes a typed RPC method.
   * @param rpc_method Shared
   * method descriptor.
   * @param args Serializable method arguments.
   * @return Deserialized method result, or no value for a void method.
   */
  template <typename Method, typename... Arguments>
  typename Method::return_type invoke(const Method &rpc_method,
                                      Arguments &&...args) {
    static_assert(is_method<Method>::value,
                  "ntl::rpc::client::invoke requires an ntl::rpc::method");
    static_assert(sizeof...(Arguments) == Method::arity(),
                  "RPC argument count does not match the method signature");

    using is_void = typename std::is_void<typename Method::return_type>::type;
    return invoke_impl(rpc_method, is_void{}, std::forward<Arguments>(args)...);
  }

  /**
   * @brief Starts a typed RPC invocation with overlapped DeviceIoControl.
   * @return An object that owns the request buffers and supports wait/cancel.
   */
  template <typename Method, typename... Arguments>
  async_call<typename Method::return_type>
  invoke_async(const Method &rpc_method, Arguments &&...args) {
    static_assert(
        is_method<Method>::value,
        "ntl::rpc::client::invoke_async requires an ntl::rpc::method");
    static_assert(sizeof...(Arguments) == Method::arity(),
                  "RPC argument count does not match the method signature");
    static_assert(
        Method::response_size() <=
            static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()),
        "NTL RPC response capacity exceeds DWORD capacity");
    (void)rpc_method;

    auto input =
        serialize_method_arguments<Method>(std::forward<Arguments>(args)...);
    if (input.size() > Method::request_size())
      throw std::length_error("NTL RPC request exceeded its method limit");

    auto state = std::make_shared<detail::async_operation>(
        handle_, Method::code(), std::move(input), Method::response_size());
    return make_async_call<Method>(
        std::move(state),
        typename std::is_void<typename Method::return_type>::type{});
  }

#if NTL_RPC_HAS_STOP_TOKEN
  /**
   * @brief Starts an overlapped RPC and binds it to a C++20 stop token.
   * @param token Token whose stop request cancels only this RPC operation.
   * @param rpc_method Shared method descriptor.
   * @param args Serializable method arguments.
   */
  template <typename Method, typename... Arguments>
  async_call<typename Method::return_type>
  invoke_async(std::stop_token token, const Method &rpc_method,
               Arguments &&...args) {
    // A stop request that predates the call must not reach the driver. Apart
    // from avoiding needless work, this removes the issue/cancel race that
    // would otherwise occur while constructing an immediately-invoked
    // std::stop_callback.
    if (token.stop_requested()) {
      auto state = std::make_shared<detail::async_operation>(
          handle_, detail::completed_error_operation_t{},
          ERROR_OPERATION_ABORTED);
      return make_async_call<Method>(
          std::move(state),
          typename std::is_void<typename Method::return_type>::type{});
    }

    auto call = invoke_async(rpc_method, std::forward<Arguments>(args)...);
    detail::attach_stop_token(token, call.state_);
    return call;
  }
#endif

  /**
   * @brief Waits for and returns one typed kernel notification.
   * @note Each successful receive consumes one notification. Start another
   * receive before asking the driver to publish the next event.
   */
  template <typename Notification>
  typename Notification::payload_type receive(const Notification &channel) {
    return receive_async(channel).get();
  }

  /**
   * @brief Queues a cancellable overlapped receive for one notification.
   * @return An owner that keeps its IRP buffers and device handle alive.
   */
  template <typename Notification>
  notification_wait<typename Notification::payload_type>
  receive_async(const Notification &channel) {
    static_assert(
        is_notification<Notification>::value,
        "ntl::rpc::client::receive_async requires an ntl::rpc::notification");
    static_assert(
        std::is_default_constructible<
            typename Notification::payload_type>::value,
        "NTL RPC notification payloads must be default constructible");
    static_assert(
        Notification::response_size() <=
            static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()),
        "NTL RPC notification capacity exceeds DWORD capacity");
    (void)channel;

    detail::notification_wait_request request{Notification::id()};
    std::vector<unsigned char> input(sizeof(request));
    std::memcpy(input.data(), &request, sizeof(request));
    auto state = std::make_shared<detail::async_operation>(
        handle_, notification_control_code(), std::move(input),
        Notification::response_size());
    return notification_wait<typename Notification::payload_type>(
        std::move(state), Notification::decode_allocation());
  }

  /**
   * @brief Waits for one replayable notification.
   * @return A payload paired with the sequence that must be acknowledged.
   */
  template <typename Notification>
  notification_delivery<typename Notification::payload_type>
  receive_reliable(const Notification &channel) {
    return receive_reliable_async(channel).get();
  }

  /**
   * @brief Queues a cancellable receive for this session's oldest
   * unacknowledged notification on the selected channel.
   */
  template <typename Notification>
  notification_wait<notification_delivery<typename Notification::payload_type>>
  receive_reliable_async(const Notification &channel) {
    static_assert(
        is_notification<Notification>::value,
        "client::receive_reliable_async requires an ntl::rpc::notification");
    static_assert(
        std::is_default_constructible<
            typename Notification::payload_type>::value,
        "NTL RPC notification payloads must be default constructible");
    static_assert(
        Notification::response_size() + reliable_notification_overhead <=
            static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()),
        "NTL RPC reliable notification capacity exceeds DWORD capacity");
    (void)channel;
    require_session();

    detail::reliable_notification_wait_request request{Notification::id(), 0};
    std::vector<unsigned char> input(sizeof(request));
    std::memcpy(input.data(), &request, sizeof(request));
    auto state = std::make_shared<detail::async_operation>(
        handle_, notification_control_code(), std::move(input),
        Notification::response_size() + reliable_notification_overhead);
    return notification_wait<
        notification_delivery<typename Notification::payload_type>>(
        std::move(state), Notification::decode_allocation());
  }

  /** @brief Receives a bounded batch from one typed reliable channel. */
  template <typename Notification>
  notification_batch<typename Notification::payload_type>
  receive_reliable_batch(const Notification &channel,
                         std::uint32_t max_records = static_cast<std::uint32_t>(
                             Notification::max_batch_records())) {
    return receive_reliable_batch_async(channel, max_records).get();
  }

  /** @brief Queues a bounded batch receive for one typed channel. */
  template <typename Notification>
  notification_batch_wait<Notification> receive_reliable_batch_async(
      const Notification &channel,
      std::uint32_t max_records =
          static_cast<std::uint32_t>(Notification::max_batch_records())) {
    static_assert(
        is_notification<Notification>::value,
        "client::receive_reliable_batch_async requires a notification");
    (void)channel;
    const auto max_bytes = batch_capacity<Notification>(max_records);
    return notification_batch_wait<Notification>(receive_reliable_batch_async(
        Notification::id(), max_records, max_bytes));
  }

  /** @brief Receives ready records across all subscribed channels. */
  reliable_batch receive_reliable_batch(std::uint32_t max_records,
                                        std::uint32_t max_bytes) {
    return receive_reliable_batch_async(max_records, max_bytes).get();
  }

  /**
   * @brief Queues an any-channel batch receive.
   * @note Ready channels
   * are selected by delivery_priority, then sequence.
   */
  reliable_batch_wait receive_reliable_batch_async(std::uint32_t max_records,
                                                   std::uint32_t max_bytes) {
    return receive_reliable_batch_async(0, max_records, max_bytes);
  }

#if NTL_RPC_HAS_STOP_TOKEN
  /** @brief Queues a notification receive bound to a C++20 stop token. */
  template <typename Notification>
  notification_wait<typename Notification::payload_type>
  receive_async(std::stop_token token, const Notification &channel) {
    if (token.stop_requested()) {
      auto state = std::make_shared<detail::async_operation>(
          handle_, detail::completed_error_operation_t{},
          ERROR_OPERATION_ABORTED);
