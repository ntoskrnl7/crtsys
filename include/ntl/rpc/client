private:
  template <typename Stream>
  static void validate_stream_batch(std::size_t count) {
    if (count == 0 || count > Stream::max_batch_records())
      throw std::invalid_argument(
          "NTL RPC stream upload batch record count is invalid");
  }

  template <typename Notification>
  static std::uint32_t batch_capacity(std::uint32_t max_records) {
    if (max_records == 0 || max_records > Notification::max_batch_records() ||
        max_records > maximum_batch_records)
      throw std::invalid_argument(
          "NTL RPC reliable batch record limit is invalid");
    constexpr std::size_t per_record =
        sizeof(detail::reliable_batch_record_header) +
        Notification::response_size() + reliable_notification_overhead;
    const auto bytes = sizeof(detail::reliable_batch_header) +
                       static_cast<std::size_t>(max_records) * per_record;
    if (bytes >
        static_cast<std::size_t>((std::numeric_limits<std::uint32_t>::max)()))
      throw std::length_error("NTL RPC batch receive capacity is too large");
    return static_cast<std::uint32_t>(bytes);
  }

  reliable_batch_wait
  receive_reliable_batch_async(std::uint32_t notification_id,
                               std::uint32_t max_records,
                               std::uint32_t max_bytes) {
    require_session();
    if (max_records == 0 || max_records > maximum_batch_records ||
        max_bytes < sizeof(detail::reliable_batch_header) +
                        sizeof(detail::reliable_batch_record_header) + 1)
      throw std::invalid_argument("NTL RPC reliable batch limits are invalid");
    detail::reliable_batch_wait_request request{notification_id, max_records,
                                                max_bytes, 0};
    std::vector<unsigned char> input(sizeof(request));
    std::memcpy(input.data(), &request, sizeof(request));
    auto state = std::make_shared<detail::async_operation>(
        handle_, notification_control_code(), std::move(input), max_bytes);
    return reliable_batch_wait(std::move(state), max_records);
  }

  void require_session() const {
    if (!session_.valid())
      throw std::logic_error(
          "NTL RPC client has not created or resumed a session");
  }

  session_info session_command(detail::session_control_operation operation,
                               session_token token,
                               std::uint32_t notification_id = 0,
                               std::uint64_t sequence = 0) {
    detail::session_control_request request{};
    request.version = detail::session_control_version;
    request.operation = operation;
    request.token = token;
    request.notification_id = notification_id;
    request.sequence = sequence;

    std::vector<unsigned char> input(sizeof(request));
    std::memcpy(input.data(), &request, sizeof(request));
    const bool returns_session =
        operation == detail::session_control_operation::create ||
        operation == detail::session_control_operation::resume;
    detail::session_control_response response{};
    DWORD returned = 0;
    call(session_control_code(), input,
         returns_session ? static_cast<void *>(&response) : nullptr,
         returns_session ? static_cast<DWORD>(sizeof(response)) : 0, returned);

    if (returns_session) {
      if (returned != sizeof(response) || !response.session.valid())
        throw std::runtime_error(
            "NTL RPC server returned an invalid session response");
      return response.session;
    }
    if (returned != 0)
      throw std::runtime_error(
          "NTL RPC session command returned unexpected output bytes");
    return {};
  }

  template <typename Tuple, std::size_t... Index>
  static std::vector<unsigned char>
  serialize_arguments(Tuple &arguments, std::index_sequence<Index...>) {
    std::vector<unsigned char> bytes;
    zpp::serializer::memory_output_archive archive(bytes);
    archive(std::get<Index>(arguments)...);
    return bytes;
  }

  template <typename Method, typename... Arguments>
  static std::vector<unsigned char>
  serialize_method_arguments(Arguments &&...args) {
    using storage = typename Method::argument_storage;
    static_assert(std::is_constructible<storage, Arguments &&...>::value,
                  "RPC arguments cannot initialize the method signature");
    storage arguments(std::forward<Arguments>(args)...);
    return serialize_arguments(
        arguments, std::make_index_sequence<std::tuple_size<storage>::value>{});
  }

  static void ensure_dword_size(std::size_t size, const char *description) {
    if (size > static_cast<std::size_t>((std::numeric_limits<DWORD>::max)())) {
      throw std::length_error(description);
    }
  }

  void call(unsigned long code, const std::vector<unsigned char> &input,
            void *output, DWORD output_size, DWORD &returned) const {
    if (!handle_ || !*handle_)
      throw std::system_error(ERROR_INVALID_HANDLE, std::system_category(),
                              "NTL RPC device is not open");

    ensure_dword_size(input.size(), "NTL RPC input exceeds DWORD capacity");
    ntl::unique_handle event(::CreateEventW(nullptr, TRUE, FALSE, nullptr));
    if (!event)
      throw std::system_error(static_cast<int>(::GetLastError()),
                              std::system_category(),
                              "NTL RPC event creation failed");

    OVERLAPPED overlapped{};
    overlapped.hEvent = event.get();
    if (!::DeviceIoControl(
            handle_->get(), code,
            input.empty() ? nullptr : const_cast<unsigned char *>(input.data()),
            static_cast<DWORD>(input.size()), output, output_size, &returned,
            &overlapped)) {
      const DWORD error = ::GetLastError();
      if (error != ERROR_IO_PENDING)
        throw std::system_error(static_cast<int>(error), std::system_category(),
                                "NTL RPC DeviceIoControl failed for code " +
                                    std::to_string(code));
      if (!::GetOverlappedResult(handle_->get(), &overlapped, &returned, TRUE))
        throw std::system_error(static_cast<int>(::GetLastError()),
                                std::system_category(),
                                "NTL RPC DeviceIoControl completion failed "
                                "for code " +
                                    std::to_string(code));
    }
  }

  template <typename Method>
  static async_call<typename Method::return_type>
  make_async_call(std::shared_ptr<detail::async_operation> state,
                  std::false_type) {
    return async_call<typename Method::return_type>(
        std::move(state), Method::decode_allocation());
  }

  template <typename Method>
  static async_call<typename Method::return_type>
  make_async_call(std::shared_ptr<detail::async_operation> state,
                  std::true_type) {
    return async_call<void>(std::move(state));
  }

  template <typename Method, typename... Arguments>
  void invoke_impl(const Method &, std::true_type, Arguments &&...args) {
    const auto input =
        serialize_method_arguments<Method>(std::forward<Arguments>(args)...);
    if (input.size() > Method::request_size())
      throw std::length_error("NTL RPC request exceeded its method limit");
    DWORD returned = 0;
    call(Method::code(), input, nullptr, 0, returned);
    if (returned != 0)
      throw std::runtime_error("void NTL RPC method returned output bytes");
  }

  template <typename Method, typename... Arguments>
  typename Method::return_type invoke_impl(const Method &, std::false_type,
                                           Arguments &&...args) {
    using return_type = typename Method::return_type;
    static_assert(std::is_default_constructible<return_type>::value,
                  "NTL RPC return types must be default constructible");
    static_assert(
        Method::response_size() <=
            static_cast<std::size_t>((std::numeric_limits<DWORD>::max)()),
        "NTL RPC response capacity exceeds DWORD capacity");

    const auto input =
        serialize_method_arguments<Method>(std::forward<Arguments>(args)...);
    if (input.size() > Method::request_size())
      throw std::length_error("NTL RPC request exceeded its method limit");
    std::vector<unsigned char> output(Method::response_size());
    DWORD returned = 0;
    call(Method::code(), input, output.data(),
         static_cast<DWORD>(output.size()), returned);

    if (returned > output.size())
      throw std::runtime_error("NTL RPC returned an invalid output size");

    output.resize(returned);
    zpp::serializer::memory_view_input_archive archive(
        output.data(), output.size(), Method::decode_allocation());
    return_type value{};
    archive(value);
    if (archive.offset() != output.size())
      throw std::runtime_error("NTL RPC response contains trailing bytes");
    return std::move(value);
  }

private:
  std::shared_ptr<ntl::unique_handle> handle_;
  session_info session_{};
};

/**
 * @brief Session-bound client facade for one typed bidirectional stream.
 *
 * @tparam Stream Shared `ntl::rpc::stream` descriptor type.
 * @note
 * Constructing this object opens the stream. Call close() explicitly
 * after
 * every delivered record is acknowledged and every pending operation is
 *
 * finished or cancelled. Destruction intentionally does not hide close
 *
 * failures or discard server-side replay state.
 */
template <typename Stream> class client_stream {
  static_assert(is_stream<Stream>::value,
                "client_stream requires an ntl::rpc::stream");

public:
  using upload_type = typename Stream::upload_type;
  using download_type = typename Stream::download_type;
  using record_type = typename Stream::record_type;
  using delivery_type = notification_delivery<record_type>;
  using read_wait_type = notification_wait<delivery_type>;

  /**
   * @brief Opens a typed stream on an existing client session.
   *
   * @param owner Client that has already created or resumed a session.
   *
   * @param channel Shared stream descriptor.
   */
  client_stream(client &owner, const Stream &channel)
      : owner_(&owner), channel_(channel) {
    owner_->open_stream(channel_);
    open_ = true;
  }

  client_stream(const client_stream &) = delete;
  client_stream &operator=(const client_stream &) = delete;

  /** @brief Transfers this non-owning stream binding. */
  client_stream(client_stream &&other) noexcept
      : owner_(other.owner_), channel_(other.channel_), open_(other.open_) {
    other.owner_ = nullptr;
    other.open_ = false;
  }

  client_stream &operator=(client_stream &&) = delete;

  /**
   * @brief Leaves server-side stream state unchanged.
   * @note Use
   * close() before destruction when the stream should be closed.
   */
  ~client_stream() = default;

  /** @brief Reports whether this facade still refers to an open stream. */
  bool is_open() const noexcept { return owner_ && open_; }

  /** @brief Sends one typed app-to-driver stream chunk synchronously. */
  void write(const upload_type &value) {
    require_open();
    owner_->write(channel_, value);
  }

  /** @brief Sends a bounded ordered upload batch in one request. */
  void write_batch(const std::vector<upload_type> &values) {
    require_open();
    owner_->write_batch(channel_, values);
  }

  /** @brief Sends one typed app-to-driver stream chunk asynchronously. */
  async_call<void> write_async(const upload_type &value) {
    require_open();
    return owner_->write_async(channel_, value);
  }

  /** @brief Sends a bounded upload batch asynchronously. */
  async_call<void> write_batch_async(const std::vector<upload_type> &values) {
    require_open();
    return owner_->write_batch_async(channel_, values);
  }

#if NTL_RPC_HAS_STOP_TOKEN
  /** @brief Sends a stream chunk bound to a C++20 stop token. */
  async_call<void> write_async(std::stop_token token,
                               const upload_type &value) {
    require_open();
    return owner_->write_async(token, channel_, value);
  }

  /** @brief Sends a bounded upload batch bound to a stop token. */
  async_call<void> write_batch_async(std::stop_token token,
                                     const std::vector<upload_type> &values) {
    require_open();
    return owner_->write_batch_async(token, channel_, values);
  }
#endif

  /** @brief Waits synchronously for one driver-to-app stream record. */
  delivery_type read() {
    require_open();
    return owner_->read(channel_);
  }

  /** @brief Starts a cancellable asynchronous stream read. */
  read_wait_type read_async() {
    require_open();
    return owner_->read_async(channel_);
  }

  /** @brief Receives up to max_records queued stream records at once. */
  notification_batch<record_type>
  read_batch(std::uint32_t max_records =
                 static_cast<std::uint32_t>(Stream::max_batch_records())) {
    require_open();
    return owner_->receive_reliable_batch(Stream::download_notification(),
                                          max_records);
  }

  /** @brief Starts a cancellable bounded stream batch read. */
  notification_batch_wait<typename Stream::download_notification_type>
  read_batch_async(std::uint32_t max_records = static_cast<std::uint32_t>(
                       Stream::max_batch_records())) {
    require_open();
    return owner_->receive_reliable_batch_async(Stream::download_notification(),
                                                max_records);
  }

#if NTL_RPC_HAS_STOP_TOKEN
  /** @brief Starts a stream read bound to a C++20 stop token. */
  read_wait_type read_async(std::stop_token token) {
    require_open();
    return owner_->read_async(token, channel_);
  }

  /** @brief Starts a bounded batch read bound to a stop token. */
  notification_batch_wait<typename Stream::download_notification_type>
  read_batch_async(std::stop_token token,
                   std::uint32_t max_records = static_cast<std::uint32_t>(
                       Stream::max_batch_records())) {
    require_open();
    return owner_->receive_reliable_batch_async(
        token, Stream::download_notification(), max_records);
  }
#endif

  /** @brief ACKs a delivered record and releases its queue capacity. */
  void acknowledge(const delivery_type &delivery) {
    require_open();
    owner_->acknowledge(channel_, delivery);
  }

  /** @brief ACKs each delivered stream record in order. */
  void acknowledge(const notification_batch<record_type> &batch) {
    require_open();
    owner_->acknowledge(Stream::download_notification(), batch);
  }

  /**
   * @brief Closes the stream after pending operations and ACKs are
   * complete.
   * @note If the server rejects the close, this object remains
   * open so the
   * caller can finish cleanup and retry.
   */
  void close() {
    require_open();
    owner_->close_stream(channel_);
    open_ = false;
  }

private:
  void require_open() const {
    if (!is_open())
      throw std::logic_error("NTL RPC client stream is not open");
  }

  client *owner_ = nullptr;
  Stream channel_{};
  bool open_ = false;
};

