/**
 * @brief Non-owning cancellation view passed to an RPC callback.
 * @note The view is valid only for the duration of that callback invocation.
 * Do not retain it or use it from work that outlives the callback.
 */
class call_context {
public:
  /**
   * @brief Returns whether the client cancelled the call or the server is
   * stopping.
   * @note Cancellation is cooperative. Kernel execution is never terminated
   * asynchronously.
   */
  bool cancelled() const noexcept {
    return is_set(request_cancelled_) || is_set(server_stopping_);
  }

  /** @brief Throws `STATUS_CANCELLED` when cancellation was requested. */
  void throw_if_cancelled() const {
    if (cancelled())
      throw ntl::exception(STATUS_CANCELLED, "NTL RPC call was cancelled");
  }

private:
  friend class detail::call_context_access;

  call_context(volatile LONG *request_cancelled,
               volatile LONG *server_stopping) noexcept
      : request_cancelled_(request_cancelled),
        server_stopping_(server_stopping) {}

  static bool is_set(volatile LONG *value) noexcept {
    return value && InterlockedCompareExchange(value, 0, 0) != 0;
  }

  volatile LONG *request_cancelled_ = nullptr;
  volatile LONG *server_stopping_ = nullptr;
};

namespace detail {

class call_context_access {
public:
  static call_context make(volatile LONG *request_cancelled,
                           volatile LONG *server_stopping) noexcept {
    return call_context(request_cancelled, server_stopping);
  }
};

class rundown_guard {
public:
  explicit rundown_guard(EX_RUNDOWN_REF &rundown) noexcept
      : rundown_(&rundown) {}
  rundown_guard(const rundown_guard &) = delete;
  rundown_guard &operator=(const rundown_guard &) = delete;
  ~rundown_guard() {
    if (rundown_)
      ExReleaseRundownProtection(rundown_);
  }

  /** @brief Transfers the acquired reference to a pending request. */
  void release() noexcept { rundown_ = nullptr; }

private:
  EX_RUNDOWN_REF *rundown_;
};

class fast_mutex_guard {
public:
  explicit fast_mutex_guard(FAST_MUTEX &mutex) noexcept : mutex_(&mutex) {
    ExAcquireFastMutex(mutex_);
  }
  fast_mutex_guard(const fast_mutex_guard &) = delete;
  fast_mutex_guard &operator=(const fast_mutex_guard &) = delete;
  ~fast_mutex_guard() { ExReleaseFastMutex(mutex_); }

private:
  FAST_MUTEX *mutex_;
};

template <typename Archive, typename Tuple, std::size_t... Index>
void deserialize_arguments(Archive &archive, Tuple &arguments,
                           std::index_sequence<Index...>) {
  archive(std::get<Index>(arguments)...);
}

template <typename Callback, typename Tuple, std::size_t... Index>
auto invoke_callback(int, Callback &callback, const call_context &,
                     Tuple &arguments, std::index_sequence<Index...>)
    -> decltype(callback(std::get<Index>(arguments)...)) {
  return callback(std::get<Index>(arguments)...);
}

template <typename Callback, typename Tuple, std::size_t... Index>
auto invoke_callback(long, Callback &callback, const call_context &context,
                     Tuple &arguments, std::index_sequence<Index...>)
    -> decltype(callback(context, std::get<Index>(arguments)...)) {
  return callback(context, std::get<Index>(arguments)...);
}

template <typename Method, typename Callback>
void invoke_method(Callback &callback,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output,
                   const call_context &context, std::true_type) {
  if (input.size > Method::request_size())
    throw ntl::exception(STATUS_INVALID_BUFFER_SIZE,
                         "NTL RPC request exceeded its method limit");

  typename Method::argument_storage arguments{};
  zpp::serializer::memory_view_input_archive archive(
      reinterpret_cast<const unsigned char *>(input.ptr), input.size,
      Method::decode_allocation());
  try {
    deserialize_arguments(
        archive, arguments,
        std::make_index_sequence<
            std::tuple_size<typename Method::argument_storage>::value>{});
  } catch (const std::exception &) {
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Invalid NTL RPC request payload");
  }

  if (archive.offset() != input.size)
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Trailing NTL RPC request bytes");

  invoke_callback(
      0, callback, context, arguments,
      std::make_index_sequence<
          std::tuple_size<typename Method::argument_storage>::value>{});
  output.clear();
}

template <typename Method, typename Callback>
void invoke_method(Callback &callback,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output,
                   const call_context &context, std::false_type) {
  if (input.size > Method::request_size())
    throw ntl::exception(STATUS_INVALID_BUFFER_SIZE,
                         "NTL RPC request exceeded its method limit");

  if (!output.can_write(Method::response_size()))
    throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                         "NTL RPC response buffer is below the method limit");

  typename Method::argument_storage arguments{};
  zpp::serializer::memory_view_input_archive input_archive(
      reinterpret_cast<const unsigned char *>(input.ptr), input.size,
      Method::decode_allocation());
  try {
    deserialize_arguments(
        input_archive, arguments,
        std::make_index_sequence<
            std::tuple_size<typename Method::argument_storage>::value>{});
  } catch (const std::exception &) {
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Invalid NTL RPC request payload");
  }

  if (input_archive.offset() != input.size)
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Trailing NTL RPC request bytes");

  typename Method::return_type result = invoke_callback(
      0, callback, context, arguments,
      std::make_index_sequence<
          std::tuple_size<typename Method::argument_storage>::value>{});

  try {
    zpp::serializer::memory_view_output_archive output_archive(
        reinterpret_cast<unsigned char *>(output.ptr), output.size);
    output_archive(result);
    output.size = output_archive.offset();
  } catch (const zpp::serializer::out_of_range &) {
    output.clear();
    throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                         "NTL RPC result exceeded its response limit");
  }
}

template <typename Method, typename Callback>
void invoke_method(Callback &callback,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output,
                   const call_context &context) {
  using is_void =
      typename std::is_void<typename Method::return_type>::type;
  invoke_method<Method>(callback, input, output, context, is_void{});
}

class notification_queue {
public:
  notification_queue() = default;
  notification_queue(const notification_queue &) = delete;
  notification_queue &operator=(const notification_queue &) = delete;

  void initialize(EX_RUNDOWN_REF &rundown,
                  std::uint32_t max_pending) {
    rundown_ = &rundown;
    max_pending_ = static_cast<LONG>(max_pending);
    InitializeListHead(&requests_);
    KeInitializeSpinLock(&lock_);
    const NTSTATUS status = IoCsqInitializeEx(
        &csq_, &notification_queue::insert,
        &notification_queue::remove, &notification_queue::peek,
        &notification_queue::acquire_lock,
        &notification_queue::release_lock,
        &notification_queue::complete_cancelled);
    if (!NT_SUCCESS(status))
      throw ntl::exception(status,
                           "NTL RPC notification queue initialization failed");
  }

  void start() noexcept {
    KIRQL irql = PASSIVE_LEVEL;
    KeAcquireSpinLock(&lock_, &irql);
    InterlockedExchange(&accepting_, 1);
    KeReleaseSpinLock(&lock_, irql);
  }

  ntl::device_control::dispatch_result
  enqueue(ntl::irp &request, std::uint32_t id) {
    notification_insert_context context{id};
    const NTSTATUS status =
        IoCsqInsertIrpEx(&csq_, request.get(), nullptr, &context);
    if (status == STATUS_CANCELLED) {
      // IO_CSQ owns and completes an IRP that was cancelled before insertion.
      return ntl::device_control::dispatch_result::pending;
    }
    if (!NT_SUCCESS(status))
      throw ntl::exception(status,
                           "NTL RPC notification receive was not queued");
    return ntl::device_control::dispatch_result::pending;
  }

  template <typename Notification>
  ntl::status
  try_notify(const typename Notification::payload_type &payload) noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return ntl::status{STATUS_INVALID_DEVICE_STATE};

    notification_match match{};
    match.id = Notification::id();
    match.match_id = true;
    PIRP request = IoCsqRemoveNextIrp(&csq_, &match);
    if (!request) {
      return ntl::status{
          InterlockedCompareExchange(&accepting_, 0, 0) != 0
              ? STATUS_NOT_FOUND
              : STATUS_DELETE_PENDING};
    }

    NTSTATUS status = STATUS_SUCCESS;
    ULONG_PTR information = 0;
    const auto stack = IoGetCurrentIrpStackLocation(request);
    const auto capacity = static_cast<std::size_t>(
        stack->Parameters.DeviceIoControl.OutputBufferLength);
    if (!request->AssociatedIrp.SystemBuffer ||
        capacity < Notification::response_size()) {
      status = STATUS_BUFFER_TOO_SMALL;
    } else {
      try {
        zpp::serializer::memory_view_output_archive archive(
            reinterpret_cast<unsigned char *>(
                request->AssociatedIrp.SystemBuffer),
            capacity);
        archive(payload);
        information = static_cast<ULONG_PTR>(archive.offset());
      } catch (const zpp::serializer::out_of_range &) {
        status = STATUS_BUFFER_TOO_SMALL;
      } catch (const std::exception &) {
        status = STATUS_INVALID_PARAMETER;
      }
    }

    complete_owned(request, status,
                   NT_SUCCESS(status) ? information : 0);
    return ntl::status{status};
  }

  void cleanup(PFILE_OBJECT file_object) noexcept {
    if (!file_object)
      return;
    notification_match match{};
    match.file_object = file_object;
    match.match_file = true;
    while (PIRP request = IoCsqRemoveNextIrp(&csq_, &match))
      complete_owned(request, STATUS_CANCELLED, 0);
  }

  void stop() noexcept {
    KIRQL irql = PASSIVE_LEVEL;
    KeAcquireSpinLock(&lock_, &irql);
    InterlockedExchange(&accepting_, 0);
    KeReleaseSpinLock(&lock_, irql);

    while (PIRP request = IoCsqRemoveNextIrp(&csq_, nullptr))
      complete_owned(request, STATUS_DELETE_PENDING, 0);
  }

private:
  struct notification_insert_context {
    std::uint32_t id;
  };

  struct notification_match {
    std::uint32_t id = 0;
    PFILE_OBJECT file_object = nullptr;
    bool match_id = false;
    bool match_file = false;
  };

  static notification_queue *from_csq(PIO_CSQ csq) noexcept {
    return CONTAINING_RECORD(csq, notification_queue, csq_);
  }

  static NTSTATUS NTAPI insert(PIO_CSQ csq, PIRP request,
                               PVOID insert_context) noexcept {
    auto *const self = from_csq(csq);
    const auto *const context =
        static_cast<const notification_insert_context *>(insert_context);
    if (!context || InterlockedCompareExchange(&self->accepting_, 0, 0) == 0)
      return STATUS_DELETE_PENDING;
    if (InterlockedCompareExchange(&self->pending_, 0, 0) >=
        self->max_pending_)
      return STATUS_DEVICE_BUSY;
    if (!ExAcquireRundownProtection(self->rundown_))
      return STATUS_DELETE_PENDING;

    request->Tail.Overlay.DriverContext[0] =
        reinterpret_cast<PVOID>(static_cast<ULONG_PTR>(context->id));
    request->Tail.Overlay.DriverContext[1] = self;
    InsertTailList(&self->requests_, &request->Tail.Overlay.ListEntry);
    InterlockedIncrement(&self->pending_);
    return STATUS_SUCCESS;
  }

  static void NTAPI remove(PIO_CSQ, PIRP request) noexcept {
    RemoveEntryList(&request->Tail.Overlay.ListEntry);
  }

  static PIRP NTAPI peek(PIO_CSQ csq, PIRP request,
                         PVOID peek_context) noexcept {
    auto *const self = from_csq(csq);
    const auto *const match =
        static_cast<const notification_match *>(peek_context);
    PLIST_ENTRY entry = request ? request->Tail.Overlay.ListEntry.Flink
                                : self->requests_.Flink;
    while (entry != &self->requests_) {
      PIRP candidate =
          CONTAINING_RECORD(entry, IRP, Tail.Overlay.ListEntry);
      entry = entry->Flink;
      if (!match)
        return candidate;

      bool selected = true;
      if (match->match_id) {
        const auto id = static_cast<std::uint32_t>(reinterpret_cast<ULONG_PTR>(
            candidate->Tail.Overlay.DriverContext[0]));
        selected = id == match->id;
      }
      if (selected && match->match_file) {
        selected = IoGetCurrentIrpStackLocation(candidate)->FileObject ==
                   match->file_object;
      }
      if (selected)
        return candidate;
    }
    return nullptr;
  }

  static void NTAPI acquire_lock(PIO_CSQ csq, PKIRQL irql) noexcept {
    KeAcquireSpinLock(&from_csq(csq)->lock_, irql);
  }

  static void NTAPI release_lock(PIO_CSQ csq, KIRQL irql) noexcept {
    KeReleaseSpinLock(&from_csq(csq)->lock_, irql);
  }

  static void NTAPI complete_cancelled(PIO_CSQ csq,
                                       PIRP request) noexcept {
    from_csq(csq)->complete_owned(request, STATUS_CANCELLED, 0);
  }

  void complete_owned(PIRP request, NTSTATUS status,
                      ULONG_PTR information) noexcept {
    const bool owns_rundown =
        request->Tail.Overlay.DriverContext[1] == this;
    request->Tail.Overlay.DriverContext[0] = nullptr;
    request->Tail.Overlay.DriverContext[1] = nullptr;
    request->IoStatus.Status = status;
    request->IoStatus.Information = information;
    IoCompleteRequest(request, IO_NO_INCREMENT);
    if (owns_rundown) {
      InterlockedDecrement(&pending_);
      ExReleaseRundownProtection(rundown_);
    }
  }

  IO_CSQ csq_{};
  LIST_ENTRY requests_{};
  KSPIN_LOCK lock_{};
  EX_RUNDOWN_REF *rundown_ = nullptr;
  LONG max_pending_ = 0;
  volatile LONG pending_ = 0;
  volatile LONG accepting_ = 0;
};

class dispatch_table {
public:
  using dispatch_handler =
      std::function<void(const ntl::device_control::in_buffer &,
                         ntl::device_control::out_buffer &,
                         const call_context &)>;

  dispatch_table(std::uint32_t contract_version,
                 std::uint64_t capabilities, bool asynchronous,
                 std::uint32_t max_pending_calls,
                 std::uint32_t max_pending_notifications)
      : contract_version_(contract_version), capabilities_(capabilities),
        asynchronous_(asynchronous),
        max_pending_calls_(static_cast<LONG>(max_pending_calls)) {
    ExInitializeRundownProtection(&rundown_);
    ExInitializeFastMutex(&registration_lock_);
    notifications_.initialize(rundown_, max_pending_notifications);
  }

private:
  class pending_call {
  public:
    pending_call(EX_RUNDOWN_REF &rundown, PIRP request,
                 dispatch_handler &handler,
                 const ntl::device_control::in_buffer &input,
                 const ntl::device_control::out_buffer &output,
                 dispatch_table *owner) noexcept
        : rundown_(&rundown), request_(request), handler_(&handler),
          input_(input), output_(output), owner_(owner) {}

    pending_call(const pending_call &) = delete;
    pending_call &operator=(const pending_call &) = delete;

    void start() noexcept {
#ifdef _MSC_VER
#pragma warning(push)
#pragma warning(disable : 4996) // Device-independent WORK_QUEUE_ITEM wrapper.
#endif
      ExInitializeWorkItem(&work_item_, &pending_call::run, this);
#ifdef _MSC_VER
#pragma warning(pop)
#endif

      IoMarkIrpPending(request_);
      KIRQL cancel_irql = PASSIVE_LEVEL;
      IoAcquireCancelSpinLock(&cancel_irql);
      request_->Tail.Overlay.DriverContext[0] = this;
      if (request_->Cancel) {
        InterlockedExchange(&cancel_requested_, 1);
      } else {
        IoSetCancelRoutine(request_, &pending_call::cancel);
      }
      IoReleaseCancelSpinLock(cancel_irql);

#ifdef _MSC_VER
#pragma warning(push)
#pragma warning(disable : 4996) // Device-independent WORK_QUEUE_ITEM wrapper.
#endif
      ExQueueWorkItem(&work_item_, DelayedWorkQueue);
#ifdef _MSC_VER
#pragma warning(pop)
#endif
    }

  private:
    static void NTAPI cancel(PDEVICE_OBJECT, PIRP request) noexcept {
      auto *const self = static_cast<pending_call *>(
          request->Tail.Overlay.DriverContext[0]);
      if (self)
        InterlockedExchange(&self->cancel_requested_, 1);
      IoReleaseCancelSpinLock(request->CancelIrql);
    }

    static void NTAPI run(void *context) noexcept {
      ntl::pool_ptr<pending_call> owner(
          static_cast<pending_call *>(context),
          ntl::pool_deleter<pending_call>{"NTRa"});
      owner->execute();
    }

    void execute() noexcept {
      NTSTATUS status = STATUS_SUCCESS;

      if (InterlockedCompareExchange(&cancel_requested_, 0, 0) == 0) {
        const auto seh_result = ntl::seh::try_except([&]() {
          try {
            const auto context = call_context_access::make(
                &cancel_requested_, &owner_->stopping_);
            (*handler_)(input_, output_, context);
          } catch (const ntl::exception &error) {
            status = error.get_status();
            output_.clear();
          } catch (const std::exception &) {
            status = STATUS_UNSUCCESSFUL;
            output_.clear();
          }
        });
        if (!std::get<0>(seh_result)) {
          status = static_cast<NTSTATUS>(std::get<1>(seh_result));
          output_.clear();
        }
      }

      KIRQL cancel_irql = PASSIVE_LEVEL;
      IoAcquireCancelSpinLock(&cancel_irql);
      (void)IoSetCancelRoutine(request_, nullptr);
      const bool cancelled =
          request_->Cancel ||
          InterlockedCompareExchange(&cancel_requested_, 0, 0) != 0;
      request_->Tail.Overlay.DriverContext[0] = nullptr;
      IoReleaseCancelSpinLock(cancel_irql);

      if (cancelled) {
        status = STATUS_CANCELLED;
        output_.clear();
      }

      request_->IoStatus.Status = status;
      request_->IoStatus.Information =
          NT_SUCCESS(status) ? static_cast<ULONG_PTR>(output_.size) : 0;
      IoCompleteRequest(request_, IO_NO_INCREMENT);
      InterlockedDecrement(&owner_->pending_calls_);
      ExReleaseRundownProtection(rundown_);
    }

    EX_RUNDOWN_REF *rundown_;
    PIRP request_;
    dispatch_handler *handler_;
    ntl::device_control::in_buffer input_;
    ntl::device_control::out_buffer output_;
    dispatch_table *owner_;
    WORK_QUEUE_ITEM work_item_{};
    volatile LONG cancel_requested_ = 0;
  };

public:
  dispatch_table(const dispatch_table &) = delete;
  dispatch_table &operator=(const dispatch_table &) = delete;

  template <typename Method, typename Callback>
  void add(Callback &&callback) {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0 ||
        InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC methods are immutable after start");

    const auto code = Method::code();
    if (handlers_.find(code) != handlers_.end())
      throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                           "Duplicate NTL RPC method ID");

    using callback_type = typename std::decay<Callback>::type;
    handlers_.emplace(
        code,
        [fn = callback_type(std::forward<Callback>(callback))](
            const ntl::device_control::in_buffer &input,
            ntl::device_control::out_buffer &output,
            const call_context &context) mutable {
          detail::invoke_method<Method>(fn, input, output, context);
        });
    method_ids_.push_back(static_cast<std::uint32_t>(Method::id()));
  }

  template <typename Notification> void add_notification() {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0 ||
        InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(
          STATUS_INVALID_DEVICE_STATE,
          "NTL RPC notifications are immutable after start");

    const auto inserted = notification_limits_.emplace(
        Notification::id(), Notification::response_size());
    if (!inserted.second)
      throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                           "Duplicate NTL RPC notification ID");
  }

  void start() {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_DELETE_PENDING,
                           "Cannot start a stopped NTL RPC server");
    std::sort(method_ids_.begin(), method_ids_.end());
    const auto features =
        transport_features::current |
        (asynchronous_ ? transport_features::asynchronous_calls : 0) |
        (!notification_limits_.empty()
             ? transport_features::kernel_notifications
             : 0);
    contract_ = contract_info(current_protocol_version, contract_version_,
                              features, capabilities_, method_ids_);
    notifications_.start();
    InterlockedExchange(&started_, 1);
  }

  void stop() noexcept {
    if (InterlockedCompareExchange(&stopping_, 1, 0) == 0) {
      notifications_.stop();
      ExWaitForRundownProtectionRelease(&rundown_);
    }
  }

  void dispatch(const ntl::device_control::code &code,
                const ntl::device_control::in_buffer &input,
                ntl::device_control::out_buffer &output) {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      throw ntl::exception(STATUS_DEVICE_NOT_READY,
                           "NTL RPC server has not started");
    if (!ExAcquireRundownProtection(&rundown_))
      throw ntl::exception(STATUS_DELETE_PENDING,
                           "NTL RPC server is stopping");
    rundown_guard guard(rundown_);

    if (code.value == control_code(contract_query_id)) {
      write_contract(input, output);
      return;
    }

    const auto found = handlers_.find(code.value);
    if (found == handlers_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                           "Unknown NTL RPC method ID");
    const auto context =
        call_context_access::make(nullptr, &stopping_);
    found->second(input, output, context);
  }

  ntl::device_control::dispatch_result
  dispatch_pending(ntl::irp &request, const ntl::device_control::code &code,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output) {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      throw ntl::exception(STATUS_DEVICE_NOT_READY,
                           "NTL RPC server has not started");

    if (code.value == notification_control_code()) {
      if (input.size != sizeof(detail::notification_wait_request))
        throw ntl::exception(
            STATUS_INVALID_PARAMETER,
            "Invalid NTL RPC notification receive request");
      const auto wait = input.as<detail::notification_wait_request>();
      if (!wait)
        throw ntl::exception(
            STATUS_INVALID_PARAMETER,
            "Missing NTL RPC notification receive request");
      const auto registered = notification_limits_.find(wait->id);
      if (registered == notification_limits_.end())
        throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                             "Unknown NTL RPC notification ID");
      if (!output.can_write(registered->second))
        throw ntl::exception(
            STATUS_BUFFER_TOO_SMALL,
            "NTL RPC notification receive buffer is too small");
      return notifications_.enqueue(request, wait->id);
    }

    if (!ExAcquireRundownProtection(&rundown_))
      throw ntl::exception(STATUS_DELETE_PENDING,
                           "NTL RPC server is stopping");
    rundown_guard guard(rundown_);

    if (code.value == control_code(contract_query_id)) {
      write_contract(input, output);
      return ntl::device_control::dispatch_result::complete;
    }

    const auto found = handlers_.find(code.value);
    if (found == handlers_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                           "Unknown NTL RPC method ID");

    if (!asynchronous_) {
      const auto context =
          call_context_access::make(nullptr, &stopping_);
      found->second(input, output, context);
      return ntl::device_control::dispatch_result::complete;
    }

    if (!try_acquire_pending_call())
      throw ntl::exception(STATUS_DEVICE_BUSY,
                           "NTL RPC pending-call limit reached");

    auto pending = ntl::try_make_pool<pending_call>(
        "NTRa", rundown_, request.get(), found->second, input, output, this);
    if (!pending) {
      InterlockedDecrement(&pending_calls_);
      throw ntl::exception(pending.status(),
                           "NTL RPC pending request allocation failed");
    }

    pending.value()->start();
    (void)pending.value().release();
    guard.release();
    return ntl::device_control::dispatch_result::pending;
  }

  void cleanup(ntl::irp &request) noexcept {
    notifications_.cleanup(request.stack_location()->FileObject);
  }

  template <typename Notification>
  ntl::status
  try_notify(const typename Notification::payload_type &payload) noexcept {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      return ntl::status{STATUS_DEVICE_NOT_READY};
    if (!ExAcquireRundownProtection(&rundown_))
      return ntl::status{STATUS_DELETE_PENDING};
    rundown_guard guard(rundown_);

    const auto registered = notification_limits_.find(Notification::id());
    if (registered == notification_limits_.end() ||
        registered->second != Notification::response_size())
      return ntl::status{STATUS_INVALID_DEVICE_REQUEST};
    return notifications_.template try_notify<Notification>(payload);
  }

private:
  bool try_acquire_pending_call() noexcept {
    LONG observed = InterlockedCompareExchange(&pending_calls_, 0, 0);
    while (observed < max_pending_calls_) {
      const LONG previous =
          InterlockedCompareExchange(&pending_calls_, observed + 1, observed);
      if (previous == observed)
        return true;
      observed = previous;
    }
    return false;
  }

  void write_contract(const ntl::device_control::in_buffer &input,
                      ntl::device_control::out_buffer &output) const {
    if (input.size != 0)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "NTL RPC contract query does not accept input");
    if (!output.can_write(contract_response_size))
      throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                           "NTL RPC contract response buffer is too small");

    try {
      zpp::serializer::memory_view_output_archive archive(
          reinterpret_cast<unsigned char *>(output.ptr), output.size);
      archive(contract_);
      output.size = archive.offset();
    } catch (const zpp::serializer::out_of_range &) {
      output.clear();
      throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                           "NTL RPC contract response exceeded its limit");
    }
  }

  std::unordered_map<unsigned long, dispatch_handler> handlers_;
  std::unordered_map<std::uint32_t, std::size_t> notification_limits_;
  std::vector<std::uint32_t> method_ids_;
  contract_info contract_;
  EX_RUNDOWN_REF rundown_{};
  FAST_MUTEX registration_lock_{};
  notification_queue notifications_;
  std::uint32_t contract_version_;
  std::uint64_t capabilities_;
  bool asynchronous_;
  LONG max_pending_calls_;
  volatile LONG pending_calls_ = 0;
  volatile LONG started_ = 0;
  volatile LONG stopping_ = 0;
};

