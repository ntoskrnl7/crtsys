#define NTL_RPC_BEGIN(_rpc_name_)                                              \
  namespace _rpc_name_ {                                                       \
  inline std::shared_ptr<ntl::rpc::server> init(ntl::driver &driver) {         \
    auto rpc_server = ntl::rpc::make_server(driver, L#_rpc_name_);

#define NTL_RPC_END(_rpc_name_)                                                \
  return rpc_server;                                                           \
  }                                                                            \
  }

#define NTL_ADD_CALLBACK_ID_0(_rpc_name_, _id_, _ret_, _name_, ...)           \
  {                                                                            \
    using rpc_method_type = ntl::rpc::make_method_t<(_id_), _ret_>;           \
    constexpr rpc_method_type rpc_method{};                                    \
    rpc_server->on(rpc_method,                                                 \
                   []() -> ntl::rpc::response_type_t<_ret_> __VA_ARGS__);      \
  }

#define NTL_ADD_CALLBACK_0(_rpc_name_, _ret_, _name_, ...)                    \
  NTL_ADD_CALLBACK_ID_0(_rpc_name_, NTL_RPC_DETAIL_LINE_ID, _ret_, _name_,    \
                        __VA_ARGS__)

