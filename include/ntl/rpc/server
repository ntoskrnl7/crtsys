#define NTL_RPC_BEGIN_CONTRACT(_rpc_name_, _version_, _capabilities_)          \
  namespace _rpc_name_ {                                                       \
  constexpr std::uint32_t rpc_contract_version = (_version_);                  \
  constexpr std::uint64_t rpc_capabilities = (_capabilities_);                 \
  inline std::shared_ptr<ntl::rpc::server>                                     \
  make_server(ntl::driver &driver,                                             \
              ntl::rpc::server_options rpc_options =                           \
                  ntl::rpc::server_options(L#_rpc_name_)) {                    \
    rpc_options.contract_version(rpc_contract_version)                         \
        .capabilities(rpc_capabilities);                                       \
    auto rpc_server = ntl::rpc::make_server(driver, rpc_options);

#define NTL_RPC_BEGIN(_rpc_name_) NTL_RPC_BEGIN_CONTRACT(_rpc_name_, 1, 0)

#define NTL_RPC_END(_rpc_name_)                                                \
  return rpc_server;                                                           \
  }                                                                            \
  inline std::shared_ptr<ntl::rpc::server> init(                               \
      ntl::driver &driver, ntl::rpc::server_options rpc_options =              \
                               ntl::rpc::server_options(L#_rpc_name_)) {       \
    auto rpc_server =                                                          \
        ::_rpc_name_::make_server(driver, std::move(rpc_options));             \
    rpc_server->start();                                                       \
    return rpc_server;                                                         \
  }                                                                            \
  }

// The server expansion registers the upload callback and supplies a
// callback-scoped stream facade. The matching client expansion creates the
// descriptor and opening helper from this same declaration.
#define NTL_ADD_STREAM_ID(_rpc_name_, _id_, _name_, _upload_type_,             \
                          _upload_name_, _download_type_, _stream_name_, ...)  \
  {                                                                            \
    using rpc_stream_type =                                                    \
        ntl::rpc::stream<(_id_), _upload_type_, _download_type_>;              \
    constexpr rpc_stream_type rpc_stream{};                                    \
    auto *const rpc_stream_server = rpc_server.get();                          \
    rpc_server->on_stream(                                                     \
        rpc_stream,                                                            \
        [rpc_stream_server](const ntl::rpc::call_context &rpc_stream_call,     \
                            const _upload_type_ &_upload_name_) {              \
          ntl::rpc::stream_context<rpc_stream_type> _stream_name_(             \
              *rpc_stream_server, rpc_stream_call);                            \
          __VA_ARGS__                                                          \
        });                                                                    \
  }

#define NTL_ADD_STREAM(_rpc_name_, _name_, _upload_type_, _upload_name_,       \
                       _download_type_, _stream_name_, ...)                    \
  NTL_ADD_STREAM_ID(_rpc_name_, NTL_RPC_DETAIL_LINE_ID, _name_, _upload_type_, \
                    _upload_name_, _download_type_, _stream_name_,             \
                    __VA_ARGS__)

