#define NTL_RPC_BEGIN_CONTRACT(_rpc_name_, _version_, _capabilities_)         \
  namespace _rpc_name_ {                                                       \
  constexpr std::uint32_t rpc_contract_version = (_version_);                 \
  constexpr std::uint64_t rpc_capabilities = (_capabilities_);                \
  inline std::shared_ptr<ntl::rpc::server>                                    \
  make_server(ntl::driver &driver,                                            \
              ntl::rpc::server_options rpc_options =                          \
                  ntl::rpc::server_options(L#_rpc_name_)) {                   \
    rpc_options.contract_version(rpc_contract_version)                         \
        .capabilities(rpc_capabilities);                                       \
    auto rpc_server = ntl::rpc::make_server(driver, rpc_options);

#define NTL_RPC_BEGIN(_rpc_name_)                                              \
  NTL_RPC_BEGIN_CONTRACT(_rpc_name_, 1, 0)

#define NTL_RPC_END(_rpc_name_)                                                \
  return rpc_server;                                                           \
  }                                                                            \
  inline std::shared_ptr<ntl::rpc::server>                                    \
  init(ntl::driver &driver,                                                   \
       ntl::rpc::server_options rpc_options =                                 \
           ntl::rpc::server_options(L#_rpc_name_)) {                          \
    auto rpc_server = ::_rpc_name_::make_server(                              \
        driver, std::move(rpc_options));                                       \
    rpc_server->start();                                                       \
    return rpc_server;                                                         \
  }                                                                            \
  }

