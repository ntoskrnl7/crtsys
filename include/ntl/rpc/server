         fn = callback_type(std::forward<Callback>(callback))](
            const ntl::device_control::in_buffer &input,
            ntl::device_control::out_buffer &output,
            const call_context &context) mutable {
          const NTSTATUS status =
              detail::authorization_status(authorize(context));
          if (!NT_SUCCESS(status))
            throw ntl::exception(status, "NTL RPC stream authorization denied");
          auto invoke_batch = [this,
                               &fn](const call_context &call,
                                    const typename Stream::upload_batch_type
                                        &batch) {
            if (batch.values().empty() ||
                batch.values().size() > Stream::max_batch_records())
