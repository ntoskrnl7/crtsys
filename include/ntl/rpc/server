/**
 * @brief Non-owning cancellation view passed to an RPC callback.
 * @note The view is valid only for the duration of that callback invocation.
 * Do not retain it or use it from work that outlives the callback.
 */
class call_context {
public:
  /**
   * @brief Returns whether the client cancelled the call or the server is
   * stopping.
   * @note Cancellation is cooperative. Kernel execution is never terminated
   * asynchronously.
   */
  bool cancelled() const noexcept {
    return is_set(request_cancelled_) || is_set(server_stopping_);
  }

  /** @brief Throws `STATUS_CANCELLED` when cancellation was requested. */
  void throw_if_cancelled() const {
    if (cancelled())
      throw ntl::exception(STATUS_CANCELLED, "NTL RPC call was cancelled");
  }

  /** @brief Returns the processor mode of the original I/O requester. */
  KPROCESSOR_MODE requestor_mode() const noexcept { return requestor_mode_; }

  /** @brief Reports whether the original request came from user mode. */
  bool is_user_mode() const noexcept { return requestor_mode_ == UserMode; }

  /** @brief Reports whether the original request came from kernel mode. */
  bool is_kernel_mode() const noexcept { return requestor_mode_ == KernelMode; }

  /** @brief Reports whether this call belongs to an opted-in client session. */
  bool has_session() const noexcept { return session_ != nullptr; }

  /**
   * @brief Returns the client session for this call, or nullptr.
   * @note The pointer is valid only during the callback invocation.
   */
  client_session *session() const noexcept { return session_; }

  /**
   * @brief Resolves a pointer-free shared-memory token for this callback.
   * @note The returned owner keeps the MDL pinned until the value is destroyed.
   */
  [[nodiscard]] ntl::result<ntl::ipc::pinned_buffer>
  try_resolve(ntl::ipc::buffer_token token,
              ntl::ipc::region_access required) const noexcept;

  /**
   * @brief Returns the process ID recorded for the requesting thread.
   * @note This value is for diagnostics and policy correlation. Process IDs
   * can be reused after a process exits and are not authentication objects.
   */
  HANDLE requestor_process_id() const noexcept { return requestor_process_id_; }

  /**
   * @brief Checks the captured requester against a kernel security descriptor.
   * @param security_descriptor Descriptor protecting the method operation.
   * @param desired_access Access mask requested by this RPC method.
   * @param generic_mapping Mapping for GENERIC_READ/WRITE/EXECUTE/ALL bits.
   * @param granted_access Optional destination for the granted access mask.
   * @return STATUS_SUCCESS when access is granted, otherwise the status
   * returned by the Windows security reference monitor.
   * @note The descriptor and mapping are trusted kernel objects supplied by
   * the driver. The captured subject remains valid for this callback even when
   * an asynchronous RPC executes on a system worker thread.
   */
  ntl::status check_access(PSECURITY_DESCRIPTOR security_descriptor,
                           ACCESS_MASK desired_access,
                           const GENERIC_MAPPING &generic_mapping,
                           ACCESS_MASK *granted_access = nullptr) const {
    if (!subject_context_ || !security_descriptor)
      return ntl::status{STATUS_INVALID_PARAMETER};

    GENERIC_MAPPING mapping = generic_mapping;
    ACCESS_MASK granted = 0;
    NTSTATUS access_status = STATUS_ACCESS_DENIED;
    const BOOLEAN allowed = SeAccessCheck(
        security_descriptor, subject_context_, FALSE, desired_access, 0,
        nullptr, &mapping, requestor_mode_, &granted, &access_status);
    if (granted_access)
      *granted_access = allowed ? granted : 0;
    if (allowed)
      return ntl::status::ok();
    return ntl::status{NT_SUCCESS(access_status) ? STATUS_ACCESS_DENIED
                                                 : access_status};
  }

  /**
   * @brief Returns the captured native subject context for advanced checks.
   * @note Treat the structure as opaque. Do not inspect or modify its members,
   * and do not release or retain the pointer. Pass it only to documented
   * Windows security routines such as SePrivilegeCheck. Prefer check_access()
   * for ordinary authorization. The pointer is valid only during the callback.
   */
  PSECURITY_SUBJECT_CONTEXT native_subject_context() const noexcept {
    return subject_context_;
  }

private:
  friend class detail::call_context_access;

  call_context(volatile LONG *request_cancelled, volatile LONG *server_stopping,
               PSECURITY_SUBJECT_CONTEXT subject_context,
               KPROCESSOR_MODE requestor_mode, HANDLE requestor_process_id,
               client_session *session) noexcept
      : request_cancelled_(request_cancelled),
        server_stopping_(server_stopping), subject_context_(subject_context),
        requestor_mode_(requestor_mode),
        requestor_process_id_(requestor_process_id), session_(session) {}

  static bool is_set(volatile LONG *value) noexcept {
    return value && InterlockedCompareExchange(value, 0, 0) != 0;
  }

  volatile LONG *request_cancelled_ = nullptr;
  volatile LONG *server_stopping_ = nullptr;
  PSECURITY_SUBJECT_CONTEXT subject_context_ = nullptr;
  KPROCESSOR_MODE requestor_mode_ = KernelMode;
  HANDLE requestor_process_id_ = nullptr;
  client_session *session_ = nullptr;
};

namespace detail {

/** Owns the requester's referenced access tokens across asynchronous work. */
class captured_caller_context {
public:
  explicit captured_caller_context(PIRP request) noexcept
      : requestor_mode_(request ? request->RequestorMode : KernelMode),
        requestor_process_id_(
            request ? reinterpret_cast<HANDLE>(static_cast<ULONG_PTR>(
                          IoGetRequestorProcessId(request)))
                    : nullptr) {
    SeCaptureSubjectContext(&subject_context_);
  }

  captured_caller_context(const captured_caller_context &) = delete;
  captured_caller_context &operator=(const captured_caller_context &) = delete;

  ~captured_caller_context() { SeReleaseSubjectContext(&subject_context_); }

  PSECURITY_SUBJECT_CONTEXT subject_context() noexcept {
    return &subject_context_;
  }

  KPROCESSOR_MODE requestor_mode() const noexcept { return requestor_mode_; }

  HANDLE requestor_process_id() const noexcept { return requestor_process_id_; }

private:
  SECURITY_SUBJECT_CONTEXT subject_context_{};
  KPROCESSOR_MODE requestor_mode_ = KernelMode;
  HANDLE requestor_process_id_ = nullptr;
};

class call_context_access {
public:
  static call_context make(volatile LONG *request_cancelled,
                           volatile LONG *server_stopping,
                           captured_caller_context &caller,
                           client_session *session = nullptr) noexcept {
    return call_context(request_cancelled, server_stopping,
                        caller.subject_context(), caller.requestor_mode(),
                        caller.requestor_process_id(), session);
  }
};

template <typename Result> NTSTATUS authorization_status(Result &&result) {
  using result_type = typename std::decay<Result>::type;
  static_assert(!std::is_same<result_type, bool>::value,
                "NTL RPC authorization policies must return NTSTATUS or "
                "ntl::status, not bool");
  static_assert(std::is_convertible<result_type, NTSTATUS>::value,
                "NTL RPC authorization policies must return NTSTATUS or "
                "ntl::status");
  return static_cast<NTSTATUS>(std::forward<Result>(result));
}

class rundown_guard {
public:
  explicit rundown_guard(EX_RUNDOWN_REF &rundown) noexcept
      : rundown_(&rundown) {}
  rundown_guard(const rundown_guard &) = delete;
  rundown_guard &operator=(const rundown_guard &) = delete;
  ~rundown_guard() {
    if (rundown_)
      ExReleaseRundownProtection(rundown_);
  }

  /** @brief Transfers the acquired reference to a pending request. */
  void release() noexcept { rundown_ = nullptr; }

private:
  EX_RUNDOWN_REF *rundown_;
};

class fast_mutex_guard {
public:
  explicit fast_mutex_guard(FAST_MUTEX &mutex) noexcept : mutex_(&mutex) {
    ExAcquireFastMutex(mutex_);
  }
  fast_mutex_guard(const fast_mutex_guard &) = delete;
  fast_mutex_guard &operator=(const fast_mutex_guard &) = delete;
  ~fast_mutex_guard() { ExReleaseFastMutex(mutex_); }

private:
  FAST_MUTEX *mutex_;
};

