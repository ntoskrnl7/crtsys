/**
 * @brief Reconnectable state associated with one opted-in RPC client.
 * @note The framework owns this object. A callback may retain typed user state,
 * but must not retain the `client_session` pointer itself.
 */
class client_session {
public:
  /** @brief Returns the endpoint-local numeric session ID. */
  std::uint64_t id() const noexcept { return info_.id; }

  /**
   * @brief Returns the opaque token used to reconnect this session.
   * @note Treat this capability as a secret. Do not write it to diagnostic
   * output or expose it to an unrelated caller.
   */
  const session_token &token() const noexcept { return info_.token; }

  /** @brief Reports whether a file handle is currently attached. */
  bool connected() const noexcept {
    return InterlockedCompareExchange(&connected_, 0, 0) != 0;
  }

  /** @brief Replaces the application-owned typed session state. */
  template <typename T> void state(std::shared_ptr<T> value) {
    std::shared_ptr<void> previous;
    {
      detail::fast_mutex_guard guard(state_lock_);
      previous = std::move(state_);
      state_ = std::move(value);
      state_type_ = state_ ? type_key<T>() : nullptr;
    }
    // A user-owned state destructor may require PASSIVE_LEVEL. Keep it out of
    // the fast-mutex region, which runs at APC_LEVEL.
    previous.reset();
  }

  /** @brief Returns typed application state, or empty on a type mismatch. */
  template <typename T> std::shared_ptr<T> state() const {
    detail::fast_mutex_guard guard(state_lock_);
    if (!state_ || state_type_ != type_key<T>())
      return {};
    return std::static_pointer_cast<T>(state_);
  }

  /** @brief Clears application-owned session state. */
  void clear_state() noexcept {
    std::shared_ptr<void> previous;
    {
      detail::fast_mutex_guard guard(state_lock_);
      previous = std::move(state_);
      state_type_ = nullptr;
    }
    previous.reset();
  }

  /** @brief Resolves a registered region while retaining its MDL. */
  [[nodiscard]] ntl::result<ntl::ipc::pinned_buffer>
  try_resolve(ntl::ipc::buffer_token token,
              ntl::ipc::region_access required) noexcept {
    return regions_.try_resolve(token, required);
  }

private:
  friend class detail::session_registry;
  friend class detail::session_operation_guard;

  explicit client_session(session_info info, ntl::ipc::region_limits limits)
      : info_(info), regions_(limits) {
    ExInitializeFastMutex(&state_lock_);
    ExInitializeRundownProtection(&operations_);
  }

  template <typename T> static const void *type_key() noexcept {
    static const unsigned char key = 0;
    return &key;
  }

  struct queued_notification {
    std::uint32_t id = 0;
    std::uint64_t sequence = 0;
    delivery_priority priority = delivery_priority::normal;
    std::vector<unsigned char> bytes;
    bool terminal = false;
    bool ready = true;
    bool in_flight = false;
    bool acknowledging = false;
  };

  enum class stream_phase {
    open,
    terminal_reserving,
    terminal_queued,
    terminal_acknowledged,
  };

  struct stream_state {
    stream_phase phase = stream_phase::open;
    std::uint32_t active_publishers = 0;
    std::uint64_t terminal_sequence = 0;
  };

  session_info info_{};
  mutable FAST_MUTEX state_lock_{};
  EX_RUNDOWN_REF operations_{};
  std::shared_ptr<void> state_;
  const void *state_type_ = nullptr;
  std::unordered_set<std::uint32_t> subscriptions_;
  std::unordered_map<std::uint32_t, stream_state> streams_;
  std::deque<queued_notification> notifications_;
  PFILE_OBJECT file_object_ = nullptr;
  std::uint64_t next_sequence_ = 1;
  std::uint64_t disconnected_at_ = 0;
  mutable volatile LONG connected_ = 0;
  bool connecting_ = false;
  bool closed_ = false;
  ntl::ipc::pinned_region_registry regions_;
};

inline ntl::result<ntl::ipc::pinned_buffer>
call_context::try_resolve(ntl::ipc::buffer_token token,
                          ntl::ipc::region_access required) const noexcept {
  if (!session_)
    return ntl::unexpected(STATUS_INVALID_DEVICE_STATE);
  return session_->try_resolve(token, required);
}

/** @brief Immutable serialized record passed to persistence hooks. */
struct notification_record_view {
  session_token session{};
  std::uint64_t session_id = 0;
  std::uint32_t notification_id = 0;
  std::uint64_t sequence = 0;
  const unsigned char *data = nullptr;
  std::size_t size = 0;
  bool terminal = false;
};

/** @brief Receives records restored by an application persistence hook. */
class notification_restore_sink {
public:
  virtual ~notification_restore_sink() = default;

  /** @brief Adds one serialized notification to the reconnecting session. */
  virtual ntl::status add(std::uint32_t notification_id, std::uint64_t sequence,
                          const void *data, std::size_t size,
                          bool terminal = false) noexcept = 0;
};

/**
 * @brief Optional application storage hooks for reliable notifications.
 * @note NTL does not perform file or registry I/O. Hooks run at PASSIVE_LEVEL
 * without an internal session lock held.
 */
class notification_store {
public:
  virtual ~notification_store() = default;

  /** @brief Persists a record before it becomes visible to the client. */
  virtual ntl::status persist(const notification_record_view &) noexcept {
    return ntl::status::ok();
  }

  /** @brief Removes one record after the client explicitly ACKs it. */
  virtual ntl::status acknowledge(const session_token &, std::uint32_t,
                                  std::uint64_t) noexcept {
    return ntl::status::ok();
  }

  /** @brief Restores records when an in-memory session no longer exists. */
  virtual ntl::status restore(const session_token &,
                              notification_restore_sink &) noexcept {
    return ntl::status{STATUS_NOT_FOUND};
  }

  /** @brief Removes all external state for an explicitly closed session. */
  virtual void erase_session(const session_token &) noexcept {}
};

namespace detail {

class session_operation_guard {
public:
  explicit session_operation_guard(
      std::shared_ptr<client_session> session) noexcept
      : session_(std::move(session)) {
    acquired_ = !session_ ||
                ExAcquireRundownProtection(&session_->operations_) != FALSE;
  }

  session_operation_guard(const session_operation_guard &) = delete;
  session_operation_guard &operator=(const session_operation_guard &) = delete;

  ~session_operation_guard() {
    if (session_ && acquired_)
      ExReleaseRundownProtection(&session_->operations_);
  }

  bool available() const noexcept { return acquired_; }
  client_session *get() const noexcept {
    return acquired_ ? session_.get() : nullptr;
  }

private:
  std::shared_ptr<client_session> session_;
  bool acquired_ = false;
};

class session_registry {
public:
  using session_policy =
      std::function<NTSTATUS(client_session &, const call_context &)>;
  using session_event = std::function<void(client_session &)>;

  session_registry(std::uint32_t max_sessions, std::uint32_t max_per_session,
                    std::uint32_t max_total, std::uint64_t retention_ms,
                    ntl::ipc::region_limits region_limits)
      : max_sessions_(max_sessions), max_per_session_(max_per_session),
        max_total_(max_total), retention_ms_(retention_ms),
        region_limits_(region_limits) {
    ExInitializeFastMutex(&lock_);
  }

  session_registry(const session_registry &) = delete;
  session_registry &operator=(const session_registry &) = delete;

  void register_notification(std::uint32_t id, std::size_t capacity,
                             delivery_priority priority,
                             std::size_t batch_records) {
    notification_limits_.emplace(id, capacity);
    notification_priorities_.emplace(id, priority);
    notification_batch_limits_.emplace(id, batch_records);
  }

  void register_stream(std::uint32_t id, std::size_t capacity,
                       delivery_priority priority, std::size_t batch_records) {
    notification_limits_.emplace(id, capacity);
    notification_priorities_.emplace(id, priority);
    notification_batch_limits_.emplace(id, batch_records);
    stream_ids_.insert(id);
  }

  void store(std::shared_ptr<notification_store> value) {
    store_ = std::move(value);
  }

  bool has_store() const noexcept { return static_cast<bool>(store_); }

  void on_open(session_policy value) { on_open_ = std::move(value); }
  void on_resume(session_policy value) { on_resume_ = std::move(value); }
  void on_disconnect(session_event value) { on_disconnect_ = std::move(value); }
  void on_close(session_event value) { on_close_ = std::move(value); }

  session_info create(PFILE_OBJECT file_object, captured_caller_context &caller,
                      volatile LONG *stopping) {
    if (!file_object)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "NTL RPC session requires a file object");
    prune_expired();

    std::shared_ptr<client_session> session;
    for (;;) {
      // ExAcquireFastMutex raises IRQL to APC_LEVEL. Generate the token before
      // taking lock_, because SystemFunction036/BCryptGenRandom requires
      // PASSIVE_LEVEL. The collision check and insertion remain atomic below.
      const session_token token = generate_token();

      fast_mutex_guard guard(lock_);
      if (by_file_.find(file_object) != by_file_.end())
        throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                             "The RPC handle already owns a session");
      if (by_token_.size() >= max_sessions_)
        throw ntl::exception(STATUS_DEVICE_BUSY,
                             "NTL RPC session limit reached");
      if (by_token_.find(token) != by_token_.end())
        continue;

      session_info info{};
      info.id = allocate_session_id_locked();
      info.token = token;
      session = std::shared_ptr<client_session>(
          new client_session(info, region_limits_));
      session->file_object_ = file_object;
      session->connecting_ = true;
      by_token_.emplace(info.token, session);
      by_id_.emplace(info.id, session);
      by_file_.emplace(file_object, session);
      break;
    }

    try {
      const auto context =
          call_context_access::make(nullptr, stopping, caller, session.get());
      const NTSTATUS status =
          on_open_ ? on_open_(*session, context) : STATUS_SUCCESS;
      if (!NT_SUCCESS(status))
        throw ntl::exception(status, "NTL RPC session open was denied");

      fast_mutex_guard guard(lock_);
      const auto bound = by_file_.find(file_object);
      if (session->closed_ || session->file_object_ != file_object ||
          bound == by_file_.end() || bound->second != session)
        throw ntl::exception(STATUS_CANCELLED,
                             "NTL RPC session open was cancelled");
      session->connecting_ = false;
      InterlockedExchange(&session->connected_, 1);
      return session->info_;
    } catch (...) {
      remove_failed_connection(session);
      throw;
    }
  }

  session_info resume(PFILE_OBJECT file_object, const session_token &token,
                      captured_caller_context &caller,
                      volatile LONG *stopping) {
    if (!file_object || !token.valid())
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "NTL RPC resume request is invalid");
    prune_expired();

    auto session = find_or_restore(token);
    {
      fast_mutex_guard guard(lock_);
      if (by_file_.find(file_object) != by_file_.end())
        throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                             "The RPC handle already owns a session");
      if (session->closed_ || session->connecting_ || session->connected())
        throw ntl::exception(STATUS_DEVICE_BUSY,
                             "NTL RPC session is already connected");
      session->connecting_ = true;
      session->file_object_ = file_object;
      by_file_.emplace(file_object, session);
    }

    session->regions_.reopen();

    try {
      const auto context =
          call_context_access::make(nullptr, stopping, caller, session.get());
      const NTSTATUS status =
          on_resume_ ? on_resume_(*session, context) : STATUS_SUCCESS;
      if (!NT_SUCCESS(status))
        throw ntl::exception(status, "NTL RPC session resume was denied");

      fast_mutex_guard guard(lock_);
      const auto bound = by_file_.find(file_object);
      if (session->closed_ || session->file_object_ != file_object ||
          bound == by_file_.end() || bound->second != session)
        throw ntl::exception(STATUS_CANCELLED,
                             "NTL RPC session resume was cancelled");
      for (auto &record : session->notifications_) {
        record.in_flight = false;
        record.acknowledging = false;
      }
      session->disconnected_at_ = 0;
      session->connecting_ = false;
      InterlockedExchange(&session->connected_, 1);
      return session->info_;
    } catch (...) {
      session->regions_.close();
      fast_mutex_guard guard(lock_);
      by_file_.erase(file_object);
      if (!session->closed_) {
        session->file_object_ = nullptr;
        session->connecting_ = false;
        session->disconnected_at_ = now_ms();
      }
      throw;
    }
  }

  std::shared_ptr<client_session> find(PFILE_OBJECT file_object) const {
    if (!file_object)
      return {};
    fast_mutex_guard guard(lock_);
    const auto found = by_file_.find(file_object);
    return found == by_file_.end() ? std::shared_ptr<client_session>{}
                                   : found->second;
  }

  ntl::ipc::region_handle
  register_region(PFILE_OBJECT file_object, const session_token &token,
                  const ntl::ipc::region_registration &registration,
                  KPROCESSOR_MODE requestor_mode) {
    std::shared_ptr<client_session> session;
    {
      fast_mutex_guard guard(lock_);
      session = require_bound_locked(file_object, token);
    }
    session_operation_guard operation(session);
    if (!operation.available())
      throw ntl::exception(STATUS_DELETE_PENDING,
                           "NTL RPC session is closing");
    auto result = session->regions_.try_register(registration, requestor_mode);
    if (!result)
      throw ntl::exception(result.status(),
                           "NTL RPC shared-region registration failed");
    return *result;
  }

  void unregister_region(PFILE_OBJECT file_object, const session_token &token,
                         ntl::ipc::region_handle region) {
    std::shared_ptr<client_session> session;
    {
      fast_mutex_guard guard(lock_);
      session = require_bound_locked(file_object, token);
    }
    session_operation_guard operation(session);
    if (!operation.available())
      throw ntl::exception(STATUS_DELETE_PENDING,
                           "NTL RPC session is closing");
    const auto status = session->regions_.try_unregister(region);
    if (!status.is_ok())
      throw ntl::exception(status, "NTL RPC shared region was not found");
  }

  bool is_stream_writable(const client_session *session,
                          std::uint32_t stream_id) const {
    if (!session)
      return false;
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session->info_.id);
    if (found == by_id_.end() || found->second.get() != session ||
        session->closed_ ||
        session->subscriptions_.find(stream_id) ==
            session->subscriptions_.end())
      return false;
    const auto stream = session->streams_.find(stream_id);
    return stream != session->streams_.end() &&
           stream->second.phase == client_session::stream_phase::open;
  }

  void subscribe(PFILE_OBJECT file_object, const session_token &token,
                 std::uint32_t notification_id, bool enabled) {
    if (notification_limits_.find(notification_id) ==
        notification_limits_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                           "Unknown reliable notification ID");

    fast_mutex_guard guard(lock_);
    auto session = require_bound_locked(file_object, token);
    if (enabled) {
      session->subscriptions_.insert(notification_id);
      if (stream_ids_.find(notification_id) != stream_ids_.end() &&
          session->streams_.find(notification_id) == session->streams_.end())
        session->streams_.emplace(notification_id,
                                  client_session::stream_state{});
    } else {
      const auto pending = std::find_if(
          session->notifications_.begin(), session->notifications_.end(),
          [=](const client_session::queued_notification &record) {
            return record.id == notification_id;
          });
      if (pending != session->notifications_.end())
        throw ntl::exception(
            STATUS_DEVICE_BUSY,
            "A reliable notification must be acknowledged before "
            "unsubscribing");
      const auto stream = session->streams_.find(notification_id);
      if (stream != session->streams_.end() &&
          stream->second.active_publishers != 0)
        throw ntl::exception(STATUS_DEVICE_BUSY,
                             "The RPC stream still has active publishers");
      session->subscriptions_.erase(notification_id);
      session->streams_.erase(notification_id);
    }
  }

  void acknowledge(PFILE_OBJECT file_object, const session_token &token,
                   std::uint32_t notification_id, std::uint64_t sequence) {
    std::shared_ptr<client_session> session;
    {
      fast_mutex_guard guard(lock_);
      session = require_bound_locked(file_object, token);
      auto found = find_record(*session, notification_id, sequence);
      if (found == session->notifications_.end())
        throw ntl::exception(STATUS_NOT_FOUND,
                             "Reliable notification ACK was not found");
      if (found->acknowledging)
        throw ntl::exception(STATUS_DEVICE_BUSY,
                             "Reliable notification ACK is already active");
      if (!ExAcquireRundownProtection(&session->operations_))
        throw ntl::exception(STATUS_DELETE_PENDING,
                             "NTL RPC session is closing");
      found->acknowledging = true;
    }
    rundown_guard operation(session->operations_);

    const auto store = store_;
    if (store) {
      const auto status = store->acknowledge(token, notification_id, sequence);
      if (!status.is_ok()) {
        fast_mutex_guard guard(lock_);
        auto found = find_record(*session, notification_id, sequence);
        if (found != session->notifications_.end())
          found->acknowledging = false;
        throw ntl::exception(status,
                             "Reliable notification ACK persistence failed");
      }
    }

    fast_mutex_guard guard(lock_);
    auto found = find_record(*session, notification_id, sequence);
    if (!session->closed_ && found != session->notifications_.end()) {
      if (found->terminal) {
        const auto stream = session->streams_.find(notification_id);
        if (stream != session->streams_.end() &&
            stream->second.phase ==
                client_session::stream_phase::terminal_queued &&
            stream->second.terminal_sequence == sequence)
          stream->second.phase =
              client_session::stream_phase::terminal_acknowledged;
      }
      session->notifications_.erase(found);
      --queued_total_;
    }
  }

  enum class receive_result { queued, completed };

  receive_result receive(PFILE_OBJECT file_object,
                         std::uint32_t notification_id,
                         ntl::device_control::out_buffer &output) {
    fast_mutex_guard guard(lock_);
    auto session = require_bound_locked(file_object, session_token{});
    if (session->subscriptions_.find(notification_id) ==
        session->subscriptions_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "Reliable notification channel is not subscribed");

    auto found = first_ready_record(*session, notification_id);
    if (found == session->notifications_.end()) {
      const auto stream = session->streams_.find(notification_id);
      if (stream != session->streams_.end() &&
          stream->second.phase ==
              client_session::stream_phase::terminal_acknowledged)
        throw ntl::exception(STATUS_END_OF_FILE,
                             "The RPC stream has reached its terminal state");
      return receive_result::queued;
    }
    if (!output.write_bytes(found->bytes.data(), found->bytes.size()))
      throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                           "Reliable notification receive buffer is too small");
    found->in_flight = true;
    return receive_result::completed;
  }

  struct batch_delivery_key {
    std::uint32_t id = 0;
    std::uint64_t sequence = 0;
  };

  receive_result receive_batch(PFILE_OBJECT file_object,
                               std::uint32_t notification_id,
                               std::uint32_t max_records,
                               std::uint32_t max_bytes,
                               ntl::device_control::out_buffer &output) {
    fast_mutex_guard guard(lock_);
    auto session = require_bound_locked(file_object, session_token{});
    validate_batch_request_locked(*session, notification_id, max_records,
                                  max_bytes);

    std::vector<unsigned char> bytes;
    std::vector<record_iterator> selected;
    build_batch_locked(*session, notification_id, max_records, max_bytes, bytes,
                       selected);
    if (selected.empty()) {
      if (notification_id != 0) {
        const auto stream = session->streams_.find(notification_id);
        if (stream != session->streams_.end() &&
            stream->second.phase ==
                client_session::stream_phase::terminal_acknowledged)
          throw ntl::exception(STATUS_END_OF_FILE,
                               "The RPC stream has reached its terminal state");
      }
      return receive_result::queued;
    }
    if (!output.write_bytes(bytes.data(), bytes.size()))
      throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                           "Reliable batch receive buffer is too small");
    for (auto record : selected)
      record->in_flight = true;
    return receive_result::completed;
  }

  template <typename Enqueue>
  std::uint64_t enqueue_receive(PFILE_OBJECT file_object,
                                std::uint32_t notification_id,
                                Enqueue &&enqueue) {
    fast_mutex_guard guard(lock_);
    auto session = require_bound_locked(file_object, session_token{});
    if (session->subscriptions_.find(notification_id) ==
        session->subscriptions_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "Reliable notification channel is not subscribed");
    const auto stream = session->streams_.find(notification_id);
    if (stream != session->streams_.end() &&
        stream->second.phase ==
            client_session::stream_phase::terminal_acknowledged)
      throw ntl::exception(STATUS_END_OF_FILE,
                           "The RPC stream has reached its terminal state");
    enqueue();
    return session->info_.id;
  }

  template <typename Enqueue>
  std::uint64_t
  enqueue_batch_receive(PFILE_OBJECT file_object, std::uint32_t notification_id,
                        std::uint32_t max_records, std::uint32_t max_bytes,
                        Enqueue &&enqueue) {
    fast_mutex_guard guard(lock_);
    auto session = require_bound_locked(file_object, session_token{});
    validate_batch_request_locked(*session, notification_id, max_records,
                                  max_bytes);
    enqueue();
    return session->info_.id;
  }

  template <typename Notification>
  ntl::status
  publish(std::uint64_t session_id,
          const typename Notification::payload_type &payload) noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return ntl::status{STATUS_INVALID_DEVICE_STATE};

    std::shared_ptr<client_session> session;
    std::uint64_t sequence = 0;
    {
      fast_mutex_guard guard(lock_);
      const auto found = by_id_.find(session_id);
      if (found == by_id_.end() || found->second->closed_)
        return ntl::status{STATUS_NOT_FOUND};
      session = found->second;
      if (session->subscriptions_.find(Notification::id()) ==
          session->subscriptions_.end())
        return ntl::status{STATUS_NOT_FOUND};
      if (session->notifications_.size() >= max_per_session_ ||
          queued_total_ >= max_total_)
        return ntl::status{STATUS_DEVICE_BUSY};
      if (!ExAcquireRundownProtection(&session->operations_))
        return ntl::status{STATUS_DELETE_PENDING};
      sequence = session->next_sequence_++;
    }
    rundown_guard operation(session->operations_);

    std::vector<unsigned char> bytes;
    try {
      bytes.resize(Notification::response_size() +
                   reliable_notification_overhead);
      notification_delivery<typename Notification::payload_type> delivery(
          sequence, payload);
      zpp::serializer::memory_view_output_archive archive(bytes.data(),
                                                          bytes.size());
      archive(delivery);
      bytes.resize(archive.offset());
    } catch (const zpp::serializer::out_of_range &) {
      return ntl::status{STATUS_BUFFER_TOO_SMALL};
    } catch (const std::bad_alloc &) {
      return ntl::status{STATUS_INSUFFICIENT_RESOURCES};
    } catch (const std::exception &) {
      return ntl::status{STATUS_INVALID_PARAMETER};
    }

    const auto store = store_;
    if (store) {
      const notification_record_view record{
          session->info_.token, session->info_.id, Notification::id(), sequence,
          bytes.data(),         bytes.size()};
      const auto status = store->persist(record);
      if (!status.is_ok())
        return status;
    }

    NTSTATUS queue_status = STATUS_DEVICE_BUSY;
    try {
      fast_mutex_guard guard(lock_);
      if (!session->closed_ &&
          session->subscriptions_.find(Notification::id()) !=
              session->subscriptions_.end() &&
          session->notifications_.size() < max_per_session_ &&
          queued_total_ < max_total_) {
        typename client_session::queued_notification record;
        record.id = Notification::id();
        record.sequence = sequence;
        record.priority = Notification::priority();
        record.bytes = std::move(bytes);
        session->notifications_.push_back(std::move(record));
        ++queued_total_;
        queue_status = STATUS_SUCCESS;
      }
    } catch (const std::bad_alloc &) {
      queue_status = STATUS_INSUFFICIENT_RESOURCES;
    }

    if (!NT_SUCCESS(queue_status) && store) {
      const auto rollback = store->acknowledge(session->info_.token,
                                               Notification::id(), sequence);
      if (!rollback.is_ok())
        return rollback;
    }
    return ntl::status{queue_status};
  }

  template <typename Notification>
  ntl::status publish_stream(std::uint64_t session_id,
                             const typename Notification::payload_type &payload,
                             bool terminal) noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return ntl::status{STATUS_INVALID_DEVICE_STATE};

    std::shared_ptr<client_session> session;
    std::uint64_t sequence = 0;
    {
      fast_mutex_guard guard(lock_);
      const auto found = by_id_.find(session_id);
      if (found == by_id_.end() || found->second->closed_)
        return ntl::status{STATUS_NOT_FOUND};
      session = found->second;
      if (session->subscriptions_.find(Notification::id()) ==
          session->subscriptions_.end())
        return ntl::status{STATUS_NOT_FOUND};
      const auto stream = session->streams_.find(Notification::id());
      if (stream == session->streams_.end() ||
          stream->second.phase != client_session::stream_phase::open)
        return ntl::status{STATUS_INVALID_DEVICE_STATE};
      if (session->notifications_.size() >= max_per_session_ ||
          queued_total_ >= max_total_)
        return ntl::status{STATUS_DEVICE_BUSY};
      if (!ExAcquireRundownProtection(&session->operations_))
        return ntl::status{STATUS_DELETE_PENDING};
      sequence = session->next_sequence_++;
      if (terminal) {
        stream->second.phase = client_session::stream_phase::terminal_reserving;
        stream->second.terminal_sequence = sequence;
      } else {
        ++stream->second.active_publishers;
      }
    }
    rundown_guard operation(session->operations_);

    bool reservation_active = true;
    const auto release_reservation = [&]() noexcept {
      if (!reservation_active)
        return;
      fast_mutex_guard guard(lock_);
      const auto stream = session->streams_.find(Notification::id());
      if (stream == session->streams_.end()) {
        reservation_active = false;
        return;
      }
      if (terminal) {
        if (stream->second.phase ==
                client_session::stream_phase::terminal_reserving &&
            stream->second.terminal_sequence == sequence) {
          stream->second.phase = client_session::stream_phase::open;
          stream->second.terminal_sequence = 0;
        }
      } else {
        release_stream_publisher_locked(*session, Notification::id());
      }
      reservation_active = false;
    };

    std::vector<unsigned char> bytes;
    try {
      bytes.resize(Notification::response_size() +
                   reliable_notification_overhead);
      notification_delivery<typename Notification::payload_type> delivery(
          sequence, payload);
      zpp::serializer::memory_view_output_archive archive(bytes.data(),
                                                          bytes.size());
      archive(delivery);
      bytes.resize(archive.offset());
    } catch (const zpp::serializer::out_of_range &) {
      release_reservation();
      return ntl::status{STATUS_BUFFER_TOO_SMALL};
    } catch (const std::bad_alloc &) {
      release_reservation();
      return ntl::status{STATUS_INSUFFICIENT_RESOURCES};
    } catch (const std::exception &) {
      release_reservation();
      return ntl::status{STATUS_INVALID_PARAMETER};
    }

    const auto store = store_;
    if (store) {
      const notification_record_view record{session->info_.token,
                                            session->info_.id,
                                            Notification::id(),
                                            sequence,
                                            bytes.data(),
                                            bytes.size(),
                                            terminal};
      const auto status = store->persist(record);
      if (!status.is_ok()) {
        release_reservation();
        return status;
      }
    }

    NTSTATUS queue_status = STATUS_DEVICE_BUSY;
    try {
      fast_mutex_guard guard(lock_);
      const auto stream = session->streams_.find(Notification::id());
      const bool valid_state =
          stream != session->streams_.end() &&
          (terminal
               ? stream->second.phase ==
                         client_session::stream_phase::terminal_reserving &&
                     stream->second.terminal_sequence == sequence
               : stream->second.active_publishers != 0);
      if (!session->closed_ && valid_state &&
          session->subscriptions_.find(Notification::id()) !=
              session->subscriptions_.end() &&
          session->notifications_.size() < max_per_session_ &&
          queued_total_ < max_total_) {
        typename client_session::queued_notification record;
        record.id = Notification::id();
        record.sequence = sequence;
        record.priority = Notification::priority();
        record.bytes = std::move(bytes);
        record.terminal = terminal;
        record.ready = !terminal || stream->second.active_publishers == 0;
        const auto position = std::find_if(
            session->notifications_.begin(), session->notifications_.end(),
            [=](const client_session::queued_notification &queued) {
              return queued.sequence > sequence;
            });
        session->notifications_.insert(position, std::move(record));
        ++queued_total_;
        if (terminal) {
          stream->second.phase = client_session::stream_phase::terminal_queued;
        } else {
          release_stream_publisher_locked(*session, Notification::id());
        }
        reservation_active = false;
        queue_status = STATUS_SUCCESS;
      }
    } catch (const std::bad_alloc &) {
      queue_status = STATUS_INSUFFICIENT_RESOURCES;
    }

    if (!NT_SUCCESS(queue_status) && store) {
      const auto rollback = store->acknowledge(session->info_.token,
                                               Notification::id(), sequence);
      if (!rollback.is_ok()) {
        release_reservation();
        return rollback;
      }
    }
    release_reservation();
    return ntl::status{queue_status};
  }

  bool take_for_delivery(std::uint64_t session_id,
                         std::uint32_t notification_id,
                         std::vector<unsigned char> &bytes,
                         PFILE_OBJECT &file_object, std::uint64_t &sequence) {
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session_id);
    if (found == by_id_.end() || !found->second->connected())
      return false;
    auto &session = *found->second;
    auto record = first_ready_record(session, notification_id);
    if (record == session.notifications_.end())
      return false;
    file_object = session.file_object_;
    if (!file_object)
      return false;
    try {
      bytes = record->bytes;
    } catch (const std::bad_alloc &) {
      return false;
    }
    record->in_flight = true;
    sequence = record->sequence;
    return true;
  }

  bool take_batch_for_delivery(std::uint64_t session_id,
                               std::uint32_t notification_id,
                               std::uint32_t max_records,
                               std::uint32_t max_bytes,
                               std::vector<unsigned char> &bytes,
                               PFILE_OBJECT &file_object,
                               std::vector<batch_delivery_key> &keys) {
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session_id);
    if (found == by_id_.end() || !found->second->connected())
      return false;
    auto &session = *found->second;
    validate_batch_request_locked(session, notification_id, max_records,
                                  max_bytes);

    std::vector<record_iterator> selected;
    build_batch_locked(session, notification_id, max_records, max_bytes, bytes,
                       selected);
    if (selected.empty())
      return false;
    file_object = session.file_object_;
    if (!file_object)
      return false;
    keys.clear();
    keys.reserve(selected.size());
    for (auto record : selected)
      keys.push_back(batch_delivery_key{record->id, record->sequence});
    for (auto record : selected)
      record->in_flight = true;
    return true;
  }

  bool has_ready_delivery(std::uint64_t session_id,
                          std::uint32_t notification_id) const noexcept {
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session_id);
    if (found == by_id_.end() || !found->second->connected())
      return false;
    const auto &records = found->second->notifications_;
    return std::find_if(records.begin(), records.end(),
                        [=](const client_session::queued_notification &record) {
                          return (notification_id == 0 ||
                                  record.id == notification_id) &&
                                 record.ready && !record.in_flight &&
                                 !record.acknowledging;
                        }) != records.end();
  }

  void release_delivery(std::uint64_t session_id, std::uint32_t notification_id,
                        std::uint64_t sequence) noexcept {
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session_id);
    if (found == by_id_.end())
      return;
    auto record = find_record(*found->second, notification_id, sequence);
    if (record != found->second->notifications_.end() && !record->acknowledging)
      record->in_flight = false;
  }

  void
  release_batch_delivery(std::uint64_t session_id,
                         const std::vector<batch_delivery_key> &keys) noexcept {
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session_id);
    if (found == by_id_.end())
      return;
    for (const auto &key : keys) {
      auto record = find_record(*found->second, key.id, key.sequence);
      if (record != found->second->notifications_.end() &&
          !record->acknowledging)
        record->in_flight = false;
    }
  }

  PFILE_OBJECT connected_file(std::uint64_t session_id) const {
    fast_mutex_guard guard(lock_);
    const auto found = by_id_.find(session_id);
    if (found == by_id_.end() || !found->second->connected())
      return nullptr;
    return found->second->file_object_;
  }

  void disconnect(PFILE_OBJECT file_object) noexcept {
    std::shared_ptr<client_session> session;
    {
      fast_mutex_guard guard(lock_);
      const auto found = by_file_.find(file_object);
      if (found == by_file_.end())
        return;
      session = found->second;
      by_file_.erase(found);
      session->file_object_ = nullptr;
      session->connecting_ = false;
      session->disconnected_at_ = now_ms();
      for (auto &record : session->notifications_) {
        record.in_flight = false;
        record.acknowledging = false;
      }
      InterlockedExchange(&session->connected_, 0);
    }
    session->regions_.close();
    invoke_event_noexcept(on_disconnect_, *session);
  }

  void close(PFILE_OBJECT file_object, const session_token &token) {
    std::shared_ptr<client_session> session;
    {
      fast_mutex_guard guard(lock_);
      session = require_bound_locked(file_object, token);
      remove_locked(session);
    }
    session->regions_.close();
    ExWaitForRundownProtectionRelease(&session->operations_);
    finalize_closed(session, true);
  }

  void stop() noexcept {
    for (;;) {
      std::shared_ptr<client_session> session;
      {
        fast_mutex_guard guard(lock_);
        if (by_token_.empty()) {
          by_file_.clear();
          by_id_.clear();
          queued_total_ = 0;
          break;
        }
        session = by_token_.begin()->second;
        remove_locked(session);
      }
      session->regions_.close();
      ExWaitForRundownProtectionRelease(&session->operations_);
      invoke_event_noexcept(on_close_, *session);
    }
  }

private:
  struct token_hash {
    std::size_t operator()(const session_token &value) const noexcept {
      const auto mixed = value.high ^ (value.low + 0x9e3779b97f4a7c15ull +
                                       (value.high << 6) + (value.high >> 2));
      return static_cast<std::size_t>(mixed ^ (mixed >> 32));
    }
  };

  class restore_collector final : public notification_restore_sink {
  public:
    restore_collector(const session_registry &owner) : owner_(owner) {}

    ntl::status add(std::uint32_t id, std::uint64_t sequence, const void *data,
                    std::size_t size, bool terminal = false) noexcept override {
      try {
        const auto limit = owner_.notification_limits_.find(id);
        if (limit == owner_.notification_limits_.end() || sequence == 0 ||
            sequence == (std::numeric_limits<std::uint64_t>::max)() || !data ||
            size == 0 ||
            size > limit->second + reliable_notification_overhead ||
            records_.size() >= owner_.max_per_session_)
          return ntl::status{STATUS_INVALID_PARAMETER};
        const auto duplicate = std::find_if(
            records_.begin(), records_.end(),
            [=](const client_session::queued_notification &record) {
              return record.id == id && record.sequence == sequence;
            });
        if (duplicate != records_.end())
          return ntl::status{STATUS_OBJECT_NAME_COLLISION};
        client_session::queued_notification record;
        record.id = id;
        record.sequence = sequence;
        const auto priority = owner_.notification_priorities_.find(id);
        if (priority == owner_.notification_priorities_.end())
          return ntl::status{STATUS_INVALID_PARAMETER};
        record.priority = priority->second;
        record.terminal = terminal;
        const auto *first = static_cast<const unsigned char *>(data);
        record.bytes.assign(first, first + size);
        records_.push_back(std::move(record));
        return ntl::status::ok();
      } catch (const std::exception &) {
        return ntl::status{STATUS_INSUFFICIENT_RESOURCES};
      }
    }

    ntl::status validate_and_sort() noexcept {
      try {
        std::sort(records_.begin(), records_.end(),
                  [](const client_session::queued_notification &left,
                     const client_session::queued_notification &right) {
                    return left.sequence < right.sequence;
                  });

        std::unordered_set<std::uint32_t> terminated_streams;
        std::uint64_t previous_sequence = 0;
        for (const auto &record : records_) {
          if (record.sequence == previous_sequence)
            return ntl::status{STATUS_OBJECT_NAME_COLLISION};
          previous_sequence = record.sequence;

          const bool is_stream =
              owner_.stream_ids_.find(record.id) != owner_.stream_ids_.end();
          if (record.terminal && !is_stream)
            return ntl::status{STATUS_INVALID_PARAMETER};
          if (is_stream &&
              terminated_streams.find(record.id) != terminated_streams.end())
            return ntl::status{STATUS_INVALID_PARAMETER};
          if (record.terminal)
            terminated_streams.insert(record.id);
        }
        return ntl::status::ok();
      } catch (const std::bad_alloc &) {
        return ntl::status{STATUS_INSUFFICIENT_RESOURCES};
      }
    }

    const session_registry &owner_;
    std::vector<client_session::queued_notification> records_;
  };

  static std::uint64_t now_ms() noexcept {
    return static_cast<std::uint64_t>(
        std::chrono::duration_cast<std::chrono::milliseconds>(
            std::chrono::steady_clock::now().time_since_epoch())
            .count());
  }

  static session_token generate_token() {
    std::random_device random;
    session_token token{};
    do {
      token.high = (static_cast<std::uint64_t>(random()) << 32) | random();
      token.low = (static_cast<std::uint64_t>(random()) << 32) | random();
    } while (!token.valid());
    return token;
  }

  using record_iterator =
      std::deque<client_session::queued_notification>::iterator;

  static record_iterator find_record(client_session &session, std::uint32_t id,
                                     std::uint64_t sequence) {
    return std::find_if(session.notifications_.begin(),
                        session.notifications_.end(),
                        [=](const client_session::queued_notification &record) {
                          return record.id == id && record.sequence == sequence;
                        });
  }

  static record_iterator first_ready_record(client_session &session,
                                            std::uint32_t id) {
    return std::find_if(session.notifications_.begin(),
                        session.notifications_.end(),
                        [=](const client_session::queued_notification &record) {
                          return record.id == id && record.ready &&
                                 !record.in_flight && !record.acknowledging;
                        });
  }

  void validate_batch_request_locked(const client_session &session,
                                     std::uint32_t id,
                                     std::uint32_t max_records,
                                     std::uint32_t max_bytes) const {
    if (max_records == 0 || max_records > maximum_batch_records ||
        max_bytes < sizeof(detail::reliable_batch_header) +
                        sizeof(detail::reliable_batch_record_header) + 1)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "Invalid reliable batch receive limits");
    if (id == 0) {
      if (session.subscriptions_.empty())
        throw ntl::exception(
            STATUS_INVALID_DEVICE_STATE,
            "Reliable batch receive requires at least one subscription");
      return;
    }
    if (notification_limits_.find(id) == notification_limits_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                           "Unknown reliable batch channel ID");
    const auto batch_limit = notification_batch_limits_.find(id);
    if (batch_limit == notification_batch_limits_.end() ||
        max_records > batch_limit->second)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "Reliable batch record limit exceeds its channel");
    if (session.subscriptions_.find(id) == session.subscriptions_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "Reliable batch channel is not subscribed");
  }

  void build_batch_locked(client_session &session, std::uint32_t id,
                          std::uint32_t max_records, std::uint32_t max_bytes,
                          std::vector<unsigned char> &bytes,
                          std::vector<record_iterator> &selected) const {
    bytes.clear();
    selected.clear();
    bytes.resize(sizeof(detail::reliable_batch_header));

    while (selected.size() < max_records) {
      auto best = session.notifications_.end();
      for (auto current = session.notifications_.begin();
           current != session.notifications_.end(); ++current) {
        if ((id != 0 && current->id != id) || !current->ready ||
            current->in_flight || current->acknowledging ||
            std::find(selected.begin(), selected.end(), current) !=
                selected.end())
          continue;
        if (best == session.notifications_.end() ||
            (id == 0 && (static_cast<std::uint32_t>(current->priority) >
                             static_cast<std::uint32_t>(best->priority) ||
                         (current->priority == best->priority &&
                          current->sequence < best->sequence))) ||
            (id != 0 && current->sequence < best->sequence))
          best = current;
      }
      if (best == session.notifications_.end())
        break;

      const auto required =
          sizeof(detail::reliable_batch_record_header) + best->bytes.size();
      if (required > max_bytes - bytes.size()) {
        if (selected.empty())
          throw ntl::exception(
              STATUS_BUFFER_TOO_SMALL,
              "Reliable batch limit cannot hold the next delivery");
        break;
      }

      const detail::reliable_batch_record_header header{
          best->id, static_cast<std::uint32_t>(best->bytes.size()),
          best->sequence};
      const auto offset = bytes.size();
      bytes.resize(offset + required);
      std::memcpy(bytes.data() + offset, &header, sizeof(header));
      std::memcpy(bytes.data() + offset + sizeof(header), best->bytes.data(),
                  best->bytes.size());
      selected.push_back(best);
    }

    if (selected.empty()) {
      bytes.clear();
      return;
    }
    const detail::reliable_batch_header header{
        detail::reliable_batch_version,
        static_cast<std::uint32_t>(selected.size())};
    std::memcpy(bytes.data(), &header, sizeof(header));
  }

  static void release_stream_publisher_locked(client_session &session,
                                              std::uint32_t id) noexcept {
    const auto stream = session.streams_.find(id);
    if (stream == session.streams_.end() ||
        stream->second.active_publishers == 0)
      return;
    --stream->second.active_publishers;
    if (stream->second.active_publishers != 0 ||
        stream->second.phase != client_session::stream_phase::terminal_queued)
      return;
    auto terminal = find_record(session, id, stream->second.terminal_sequence);
    if (terminal != session.notifications_.end() && terminal->terminal)
      terminal->ready = true;
  }

  std::shared_ptr<client_session>
  require_bound_locked(PFILE_OBJECT file_object,
                       const session_token &token) const {
    const auto found = by_file_.find(file_object);
    if (found == by_file_.end() || found->second->closed_ ||
        (!token.valid() ? false : found->second->info_.token != token))
      throw ntl::exception(STATUS_INVALID_HANDLE,
                           "RPC handle has no matching client session");
    return found->second;
  }

  std::shared_ptr<client_session> find_or_restore(const session_token &token) {
    {
      fast_mutex_guard guard(lock_);
      const auto found = by_token_.find(token);
      if (found != by_token_.end())
        return found->second;
    }

    const auto store = store_;
    if (!store)
      throw ntl::exception(STATUS_NOT_FOUND,
                           "NTL RPC session token was not found");

    restore_collector collector(*this);
    const auto restored = store->restore(token, collector);
    if (!restored.is_ok())
      throw ntl::exception(restored,
                           "NTL RPC persisted session restore failed");
    const auto validated = collector.validate_and_sort();
    if (!validated.is_ok())
      throw ntl::exception(validated,
                           "NTL RPC persisted session records are invalid");

    fast_mutex_guard guard(lock_);
    const auto existing = by_token_.find(token);
    if (existing != by_token_.end())
      return existing->second;
    if (by_token_.size() >= max_sessions_ ||
        queued_total_ + collector.records_.size() > max_total_)
      throw ntl::exception(STATUS_DEVICE_BUSY,
                           "NTL RPC restored session exceeds limits");

    session_info info{token, allocate_session_id_locked()};
    auto session = std::shared_ptr<client_session>(
        new client_session(info, region_limits_));
    session->regions_.close();
    std::uint64_t next_sequence = 1;
    for (auto &record : collector.records_) {
      next_sequence = (std::max)(next_sequence, record.sequence + 1);
      session->subscriptions_.insert(record.id);
      if (stream_ids_.find(record.id) != stream_ids_.end()) {
        const auto inserted = session->streams_.emplace(
            record.id, client_session::stream_state{});
        if (record.terminal) {
          inserted.first->second.phase =
              client_session::stream_phase::terminal_queued;
          inserted.first->second.terminal_sequence = record.sequence;
        }
      }
      session->notifications_.push_back(std::move(record));
      ++queued_total_;
    }
    session->next_sequence_ = next_sequence;
    session->disconnected_at_ = now_ms();
    by_token_.emplace(token, session);
    by_id_.emplace(info.id, session);
    return session;
  }

  void remove_failed_connection(
      const std::shared_ptr<client_session> &session) noexcept {
    {
      fast_mutex_guard guard(lock_);
      remove_locked(session);
    }
    session->regions_.close();
    ExWaitForRundownProtectionRelease(&session->operations_);
    finalize_closed(session, true);
  }

  std::uint64_t allocate_session_id_locked() noexcept {
    std::uint64_t id = 0;
    do {
      id = next_session_id_++;
    } while (id == 0 || by_id_.find(id) != by_id_.end());
    return id;
  }

  void remove_locked(const std::shared_ptr<client_session> &session) noexcept {
    if (session->file_object_)
      by_file_.erase(session->file_object_);
    by_id_.erase(session->info_.id);
    by_token_.erase(session->info_.token);
    queued_total_ -= session->notifications_.size();
    session->file_object_ = nullptr;
    session->closed_ = true;
    session->connecting_ = false;
    InterlockedExchange(&session->connected_, 0);
  }

  void finalize_closed(const std::shared_ptr<client_session> &session,
                       bool erase_persisted) noexcept {
    const auto store = store_;
    if (store && erase_persisted)
      store->erase_session(session->info_.token);
    invoke_event_noexcept(on_close_, *session);
  }

  void prune_expired() {
    const auto now = now_ms();
    std::vector<std::shared_ptr<client_session>> expired;
    {
      fast_mutex_guard guard(lock_);
      // Reserve before mutating maps so an allocation failure leaves every
      // session reachable and internally consistent.
      expired.reserve(by_token_.size());
      for (auto iterator = by_token_.begin(); iterator != by_token_.end();) {
        auto session = iterator->second;
        if (!session->connected() && !session->connecting_ &&
            session->disconnected_at_ != 0 &&
            now - session->disconnected_at_ >= retention_ms_) {
          by_id_.erase(session->info_.id);
          queued_total_ -= session->notifications_.size();
          session->closed_ = true;
          expired.push_back(session);
          iterator = by_token_.erase(iterator);
        } else {
          ++iterator;
        }
      }
    }
    for (auto &session : expired) {
      session->regions_.close();
      ExWaitForRundownProtectionRelease(&session->operations_);
      // Retention expiry releases kernel memory, but an application-provided
      // store remains authoritative and may restore the token later.
      finalize_closed(session, false);
    }
  }

  static void invoke_event_noexcept(const session_event &event,
                                    client_session &session) noexcept {
    if (!event)
      return;
    try {
      event(session);
    } catch (...) {
      // Session lifecycle hooks are observational once teardown has started.
      // An application exception must not escape a kernel cleanup path.
    }
  }

  mutable FAST_MUTEX lock_{};
  std::unordered_map<session_token, std::shared_ptr<client_session>, token_hash>
      by_token_;
  std::unordered_map<std::uint64_t, std::shared_ptr<client_session>> by_id_;
  std::unordered_map<PFILE_OBJECT, std::shared_ptr<client_session>> by_file_;
  std::unordered_map<std::uint32_t, std::size_t> notification_limits_;
  std::unordered_map<std::uint32_t, delivery_priority> notification_priorities_;
  std::unordered_map<std::uint32_t, std::size_t> notification_batch_limits_;
  std::unordered_set<std::uint32_t> stream_ids_;
  std::shared_ptr<notification_store> store_;
  session_policy on_open_;
  session_policy on_resume_;
  session_event on_disconnect_;
  session_event on_close_;
  std::uint32_t max_sessions_;
  std::size_t max_per_session_;
  std::size_t max_total_;
  std::uint64_t retention_ms_;
  std::size_t queued_total_ = 0;
  std::uint64_t next_session_id_ = 1;
  ntl::ipc::region_limits region_limits_{};
};

template <typename Archive, typename Tuple, std::size_t... Index>
void deserialize_arguments(Archive &archive, Tuple &arguments,
                           std::index_sequence<Index...>) {
  archive(std::get<Index>(arguments)...);
}

template <typename Callback, typename Tuple, std::size_t... Index>
auto invoke_callback(int, Callback &callback, const call_context &,
                     Tuple &arguments, std::index_sequence<Index...>)
    -> decltype(callback(std::get<Index>(arguments)...)) {
  return callback(std::get<Index>(arguments)...);
}

template <typename Callback, typename Tuple, std::size_t... Index>
auto invoke_callback(long, Callback &callback, const call_context &context,
                     Tuple &arguments, std::index_sequence<Index...>)
    -> decltype(callback(context, std::get<Index>(arguments)...)) {
  return callback(context, std::get<Index>(arguments)...);
}

template <typename Method, typename Callback>
void invoke_method(Callback &callback,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output,
                   const call_context &context, std::true_type) {
  if (input.size > Method::request_size())
    throw ntl::exception(STATUS_INVALID_BUFFER_SIZE,
                         "NTL RPC request exceeded its method limit");

  typename Method::argument_storage arguments{};
  zpp::serializer::memory_view_input_archive archive(
      reinterpret_cast<const unsigned char *>(input.ptr), input.size,
      Method::decode_allocation());
  try {
    deserialize_arguments(
        archive, arguments,
        std::make_index_sequence<
            std::tuple_size<typename Method::argument_storage>::value>{});
  } catch (const std::exception &) {
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Invalid NTL RPC request payload");
  }

  if (archive.offset() != input.size)
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Trailing NTL RPC request bytes");

  invoke_callback(
      0, callback, context, arguments,
      std::make_index_sequence<
          std::tuple_size<typename Method::argument_storage>::value>{});
  output.clear();
}

template <typename Method, typename Callback>
void invoke_method(Callback &callback,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output,
                   const call_context &context, std::false_type) {
  if (input.size > Method::request_size())
    throw ntl::exception(STATUS_INVALID_BUFFER_SIZE,
                         "NTL RPC request exceeded its method limit");

  if (!output.can_write(Method::response_size()))
    throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                         "NTL RPC response buffer is below the method limit");

  typename Method::argument_storage arguments{};
  zpp::serializer::memory_view_input_archive input_archive(
      reinterpret_cast<const unsigned char *>(input.ptr), input.size,
      Method::decode_allocation());
  try {
    deserialize_arguments(
        input_archive, arguments,
        std::make_index_sequence<
            std::tuple_size<typename Method::argument_storage>::value>{});
  } catch (const std::exception &) {
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Invalid NTL RPC request payload");
  }

  if (input_archive.offset() != input.size)
    throw ntl::exception(STATUS_INVALID_PARAMETER,
                         "Trailing NTL RPC request bytes");

  typename Method::return_type result = invoke_callback(
      0, callback, context, arguments,
      std::make_index_sequence<
          std::tuple_size<typename Method::argument_storage>::value>{});

  try {
    zpp::serializer::memory_view_output_archive output_archive(
        reinterpret_cast<unsigned char *>(output.ptr), output.size);
    output_archive(result);
    output.size = output_archive.offset();
  } catch (const zpp::serializer::out_of_range &) {
    output.clear();
    throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                         "NTL RPC result exceeded its response limit");
  }
}

template <typename Method, typename Callback>
void invoke_method(Callback &callback,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output,
                   const call_context &context) {
  using is_void = typename std::is_void<typename Method::return_type>::type;
  invoke_method<Method>(callback, input, output, context, is_void{});
}

template <typename Callback, typename Upload>
void invoke_stream_upload(Callback &callback, const call_context &context,
                          const Upload &upload) {
  std::tuple<const Upload &> arguments(upload);
  invoke_callback(0, callback, context, arguments, std::index_sequence<0>{});
}

class notification_queue {
public:
  enum class wait_mode : ULONG_PTR {
    live = 0,
    reliable = 1,
    reliable_batch = 2,
  };

  notification_queue() = default;
  notification_queue(const notification_queue &) = delete;
  notification_queue &operator=(const notification_queue &) = delete;

  void initialize(EX_RUNDOWN_REF &rundown, std::uint32_t max_pending) {
    rundown_ = &rundown;
    max_pending_ = static_cast<LONG>(max_pending);
    InitializeListHead(&requests_);
    KeInitializeSpinLock(&lock_);
    const NTSTATUS status = IoCsqInitializeEx(
        &csq_, &notification_queue::insert, &notification_queue::remove,
        &notification_queue::peek, &notification_queue::acquire_lock,
        &notification_queue::release_lock,
        &notification_queue::complete_cancelled);
    if (!NT_SUCCESS(status))
      throw ntl::exception(status,
                           "NTL RPC notification queue initialization failed");
  }

  void start() noexcept {
    KIRQL irql = PASSIVE_LEVEL;
    KeAcquireSpinLock(&lock_, &irql);
    InterlockedExchange(&accepting_, 1);
    KeReleaseSpinLock(&lock_, irql);
  }

  ntl::device_control::dispatch_result
  enqueue(ntl::irp &request, std::uint32_t id,
          wait_mode mode = wait_mode::live) {
    notification_insert_context context{id, mode};
    const NTSTATUS status =
        IoCsqInsertIrpEx(&csq_, request.get(), nullptr, &context);
    if (status == STATUS_CANCELLED) {
      // IO_CSQ owns and completes an IRP that was cancelled before insertion.
      return ntl::device_control::dispatch_result::pending;
    }
    if (!NT_SUCCESS(status))
      throw ntl::exception(status,
                           "NTL RPC notification receive was not queued");
    return ntl::device_control::dispatch_result::pending;
  }

  template <typename Notification>
  ntl::status
  try_notify(const typename Notification::payload_type &payload) noexcept {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      return ntl::status{STATUS_INVALID_DEVICE_STATE};

    notification_match match{};
    match.id = Notification::id();
    match.match_id = true;
    match.mode = wait_mode::live;
    match.match_mode = true;
    PIRP request = IoCsqRemoveNextIrp(&csq_, &match);
    if (!request) {
      return ntl::status{InterlockedCompareExchange(&accepting_, 0, 0) != 0
                             ? STATUS_NOT_FOUND
                             : STATUS_DELETE_PENDING};
    }

    NTSTATUS status = STATUS_SUCCESS;
    ULONG_PTR information = 0;
    const auto stack = IoGetCurrentIrpStackLocation(request);
    const auto capacity = static_cast<std::size_t>(
        stack->Parameters.DeviceIoControl.OutputBufferLength);
    if (!request->AssociatedIrp.SystemBuffer ||
        capacity < Notification::response_size()) {
      status = STATUS_BUFFER_TOO_SMALL;
    } else {
      try {
        zpp::serializer::memory_view_output_archive archive(
            reinterpret_cast<unsigned char *>(
                request->AssociatedIrp.SystemBuffer),
            capacity);
        archive(payload);
        information = static_cast<ULONG_PTR>(archive.offset());
      } catch (const zpp::serializer::out_of_range &) {
        status = STATUS_BUFFER_TOO_SMALL;
      } catch (const std::exception &) {
        status = STATUS_INVALID_PARAMETER;
      }
    }

    complete_owned(request, status, NT_SUCCESS(status) ? information : 0);
    return ntl::status{status};
  }

  PIRP remove_next(std::uint32_t id, PFILE_OBJECT file_object,
                   wait_mode mode) noexcept {
    notification_match match{};
    match.id = id;
    match.file_object = file_object;
    match.mode = mode;
    match.match_id = true;
    match.match_file = true;
    match.match_mode = true;
    return IoCsqRemoveNextIrp(&csq_, &match);
  }

  void complete(PIRP request, NTSTATUS status, ULONG_PTR information) noexcept {
    complete_owned(request, status, information);
  }

  void cleanup(PFILE_OBJECT file_object) noexcept {
    if (!file_object)
      return;
    notification_match match{};
    match.file_object = file_object;
    match.match_file = true;
    while (PIRP request = IoCsqRemoveNextIrp(&csq_, &match))
      complete_owned(request, STATUS_CANCELLED, 0);
  }

  void cancel(PFILE_OBJECT file_object, std::uint32_t id,
              wait_mode mode) noexcept {
    if (!file_object)
      return;
    notification_match match{};
    match.id = id;
    match.file_object = file_object;
    match.mode = mode;
    match.match_id = true;
    match.match_file = true;
    match.match_mode = true;
    while (PIRP request = IoCsqRemoveNextIrp(&csq_, &match))
      complete_owned(request, STATUS_CANCELLED, 0);
  }

  void stop() noexcept {
    KIRQL irql = PASSIVE_LEVEL;
    KeAcquireSpinLock(&lock_, &irql);
    InterlockedExchange(&accepting_, 0);
    KeReleaseSpinLock(&lock_, irql);

    while (PIRP request = IoCsqRemoveNextIrp(&csq_, nullptr))
      complete_owned(request, STATUS_DELETE_PENDING, 0);
  }

private:
  struct notification_insert_context {
    std::uint32_t id;
    wait_mode mode;
  };

  struct notification_match {
    std::uint32_t id = 0;
    PFILE_OBJECT file_object = nullptr;
    wait_mode mode = wait_mode::live;
    bool match_id = false;
    bool match_file = false;
    bool match_mode = false;
  };

  static notification_queue *from_csq(PIO_CSQ csq) noexcept {
    return CONTAINING_RECORD(csq, notification_queue, csq_);
  }

  static NTSTATUS NTAPI insert(PIO_CSQ csq, PIRP request,
                               PVOID insert_context) noexcept {
    auto *const self = from_csq(csq);
    const auto *const context =
        static_cast<const notification_insert_context *>(insert_context);
    if (!context || InterlockedCompareExchange(&self->accepting_, 0, 0) == 0)
      return STATUS_DELETE_PENDING;
    if (InterlockedCompareExchange(&self->pending_, 0, 0) >= self->max_pending_)
      return STATUS_DEVICE_BUSY;
    if (!ExAcquireRundownProtection(self->rundown_))
      return STATUS_DELETE_PENDING;

    request->Tail.Overlay.DriverContext[0] =
        reinterpret_cast<PVOID>(static_cast<ULONG_PTR>(context->id));
    request->Tail.Overlay.DriverContext[1] = self;
    request->Tail.Overlay.DriverContext[2] =
        reinterpret_cast<PVOID>(static_cast<ULONG_PTR>(context->mode));
    InsertTailList(&self->requests_, &request->Tail.Overlay.ListEntry);
    InterlockedIncrement(&self->pending_);
    return STATUS_SUCCESS;
  }

  static void NTAPI remove(PIO_CSQ, PIRP request) noexcept {
    RemoveEntryList(&request->Tail.Overlay.ListEntry);
  }

  static PIRP NTAPI peek(PIO_CSQ csq, PIRP request,
                         PVOID peek_context) noexcept {
    auto *const self = from_csq(csq);
    const auto *const match =
        static_cast<const notification_match *>(peek_context);
    PLIST_ENTRY entry =
        request ? request->Tail.Overlay.ListEntry.Flink : self->requests_.Flink;
    while (entry != &self->requests_) {
      PIRP candidate = CONTAINING_RECORD(entry, IRP, Tail.Overlay.ListEntry);
      entry = entry->Flink;
      if (!match)
        return candidate;

      bool selected = true;
      if (match->match_id) {
        const auto id = static_cast<std::uint32_t>(reinterpret_cast<ULONG_PTR>(
            candidate->Tail.Overlay.DriverContext[0]));
        selected = id == match->id;
      }
      if (selected && match->match_file) {
        selected = IoGetCurrentIrpStackLocation(candidate)->FileObject ==
                   match->file_object;
      }
      if (selected && match->match_mode) {
        const auto mode = static_cast<wait_mode>(reinterpret_cast<ULONG_PTR>(
            candidate->Tail.Overlay.DriverContext[2]));
        selected = mode == match->mode;
      }
      if (selected)
        return candidate;
    }
    return nullptr;
  }

  static void NTAPI acquire_lock(PIO_CSQ csq, PKIRQL irql) noexcept {
    KeAcquireSpinLock(&from_csq(csq)->lock_, irql);
  }

  static void NTAPI release_lock(PIO_CSQ csq, KIRQL irql) noexcept {
    KeReleaseSpinLock(&from_csq(csq)->lock_, irql);
  }

  static void NTAPI complete_cancelled(PIO_CSQ csq, PIRP request) noexcept {
    from_csq(csq)->complete_owned(request, STATUS_CANCELLED, 0);
  }

  void complete_owned(PIRP request, NTSTATUS status,
                      ULONG_PTR information) noexcept {
    const bool owns_rundown = request->Tail.Overlay.DriverContext[1] == this;
    request->Tail.Overlay.DriverContext[0] = nullptr;
    request->Tail.Overlay.DriverContext[1] = nullptr;
    request->Tail.Overlay.DriverContext[2] = nullptr;
    request->IoStatus.Status = status;
    request->IoStatus.Information = information;
    IoCompleteRequest(request, IO_NO_INCREMENT);
    if (owns_rundown) {
      InterlockedDecrement(&pending_);
      ExReleaseRundownProtection(rundown_);
    }
  }

  IO_CSQ csq_{};
  LIST_ENTRY requests_{};
  KSPIN_LOCK lock_{};
  EX_RUNDOWN_REF *rundown_ = nullptr;
  LONG max_pending_ = 0;
  volatile LONG pending_ = 0;
  volatile LONG accepting_ = 0;
};

class dispatch_table {
public:
  using dispatch_handler = std::function<void(
      const ntl::device_control::in_buffer &, ntl::device_control::out_buffer &,
      const call_context &)>;

  dispatch_table(std::uint32_t contract_version, std::uint64_t capabilities,
                 bool asynchronous, std::uint32_t max_pending_calls,
                 std::uint32_t max_pending_notifications,
                 std::uint32_t max_sessions,
                 std::uint32_t max_reliable_per_session,
                  std::uint32_t max_reliable_total,
                  std::uint64_t session_retention_ms,
                  ntl::ipc::region_limits region_limits)
      : contract_version_(contract_version), capabilities_(capabilities),
        asynchronous_(asynchronous),
        max_pending_calls_(static_cast<LONG>(max_pending_calls)),
        sessions_(max_sessions, max_reliable_per_session, max_reliable_total,
                  session_retention_ms, region_limits) {
    ExInitializeRundownProtection(&rundown_);
    ExInitializeFastMutex(&registration_lock_);
    ExInitializeFastMutex(&delivery_lock_);
    notifications_.initialize(rundown_, max_pending_notifications);
  }

private:
  class pending_call {
  public:
    pending_call(EX_RUNDOWN_REF &rundown, PIRP request,
                 dispatch_handler &handler,
                 const ntl::device_control::in_buffer &input,
                 const ntl::device_control::out_buffer &output,
                 dispatch_table *owner,
                 std::shared_ptr<client_session> session) noexcept
        : rundown_(&rundown), request_(request), handler_(&handler),
          input_(input), output_(output), owner_(owner), caller_(request),
          session_(std::move(session)) {}

    pending_call(const pending_call &) = delete;
    pending_call &operator=(const pending_call &) = delete;

    void start() noexcept {
#ifdef _MSC_VER
#pragma warning(push)
#pragma warning(disable : 4996) // Device-independent WORK_QUEUE_ITEM wrapper.
#endif
      ExInitializeWorkItem(&work_item_, &pending_call::run, this);
#ifdef _MSC_VER
#pragma warning(pop)
#endif

      IoMarkIrpPending(request_);
      KIRQL cancel_irql = PASSIVE_LEVEL;
      IoAcquireCancelSpinLock(&cancel_irql);
      request_->Tail.Overlay.DriverContext[0] = this;
      if (request_->Cancel) {
        InterlockedExchange(&cancel_requested_, 1);
      } else {
        IoSetCancelRoutine(request_, &pending_call::cancel);
      }
      IoReleaseCancelSpinLock(cancel_irql);

#ifdef _MSC_VER
#pragma warning(push)
#pragma warning(disable : 4996) // Device-independent WORK_QUEUE_ITEM wrapper.
#endif
      ExQueueWorkItem(&work_item_, DelayedWorkQueue);
#ifdef _MSC_VER
#pragma warning(pop)
#endif
    }

  private:
    static void NTAPI cancel(PDEVICE_OBJECT, PIRP request) noexcept {
      auto *const self =
          static_cast<pending_call *>(request->Tail.Overlay.DriverContext[0]);
      if (self)
        InterlockedExchange(&self->cancel_requested_, 1);
      IoReleaseCancelSpinLock(request->CancelIrql);
    }

    static void NTAPI run(void *context) noexcept {
      auto *const call = static_cast<pending_call *>(context);
      auto *const rundown = call->rundown_;
      auto *const dispatch = call->owner_;
      {
        ntl::pool_ptr<pending_call> owner(
            call, ntl::pool_deleter<pending_call>{"NTRa"});
        owner->execute();
      }
      InterlockedDecrement(&dispatch->pending_calls_);
      ExReleaseRundownProtection(rundown);
    }

    void execute() noexcept {
      NTSTATUS status = STATUS_SUCCESS;

      if (!session_.available()) {
        status = STATUS_DELETE_PENDING;
        output_.clear();
      } else if (InterlockedCompareExchange(&cancel_requested_, 0, 0) == 0) {
        const auto seh_result = ntl::seh::try_except([&]() {
          try {
            const auto context = call_context_access::make(
                &cancel_requested_, &owner_->stopping_, caller_,
                session_.get());
            (*handler_)(input_, output_, context);
          } catch (const ntl::exception &error) {
            status = error.get_status();
            output_.clear();
          } catch (const std::exception &) {
            status = STATUS_UNSUCCESSFUL;
            output_.clear();
          }
        });
        if (!std::get<0>(seh_result)) {
          status = static_cast<NTSTATUS>(std::get<1>(seh_result));
          output_.clear();
        }
      }

      KIRQL cancel_irql = PASSIVE_LEVEL;
      IoAcquireCancelSpinLock(&cancel_irql);
      (void)IoSetCancelRoutine(request_, nullptr);
      const bool cancelled =
          request_->Cancel ||
          InterlockedCompareExchange(&cancel_requested_, 0, 0) != 0;
      request_->Tail.Overlay.DriverContext[0] = nullptr;
      IoReleaseCancelSpinLock(cancel_irql);

      if (cancelled) {
        status = STATUS_CANCELLED;
        output_.clear();
      }

      request_->IoStatus.Status = status;
      request_->IoStatus.Information =
          NT_SUCCESS(status) ? static_cast<ULONG_PTR>(output_.size) : 0;
      IoCompleteRequest(request_, IO_NO_INCREMENT);
    }

    EX_RUNDOWN_REF *rundown_;
    PIRP request_;
    dispatch_handler *handler_;
    ntl::device_control::in_buffer input_;
    ntl::device_control::out_buffer output_;
    dispatch_table *owner_;
    captured_caller_context caller_;
    session_operation_guard session_;
    WORK_QUEUE_ITEM work_item_{};
    volatile LONG cancel_requested_ = 0;
  };

public:
  dispatch_table(const dispatch_table &) = delete;
  dispatch_table &operator=(const dispatch_table &) = delete;

  template <typename Method, typename Callback> void add(Callback &&callback) {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0 ||
        InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC methods are immutable after start");

    const auto code = Method::code();
    if (handlers_.find(code) != handlers_.end())
      throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                           "Duplicate NTL RPC method ID");

    using callback_type = typename std::decay<Callback>::type;
    handlers_.emplace(
        code, [fn = callback_type(std::forward<Callback>(callback))](
                  const ntl::device_control::in_buffer &input,
                  ntl::device_control::out_buffer &output,
                  const call_context &context) mutable {
          detail::invoke_method<Method>(fn, input, output, context);
        });
    method_ids_.push_back(static_cast<std::uint32_t>(Method::id()));
  }

  template <typename Method, typename Authorization, typename Callback>
  void add_authorized(Authorization &&authorization, Callback &&callback) {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0 ||
        InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC methods are immutable after start");

    const auto code = Method::code();
    if (handlers_.find(code) != handlers_.end())
      throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                           "Duplicate NTL RPC method ID");

    using authorization_type = typename std::decay<Authorization>::type;
    using callback_type = typename std::decay<Callback>::type;
    handlers_.emplace(
        code, [authorize = authorization_type(
                   std::forward<Authorization>(authorization)),
               fn = callback_type(std::forward<Callback>(callback))](
                  const ntl::device_control::in_buffer &input,
                  ntl::device_control::out_buffer &output,
                  const call_context &context) mutable {
          const NTSTATUS authorization =
              detail::authorization_status(authorize(context));
          if (!NT_SUCCESS(authorization))
            throw ntl::exception(authorization,
                                 "NTL RPC method authorization denied");
          detail::invoke_method<Method>(fn, input, output, context);
        });
    method_ids_.push_back(static_cast<std::uint32_t>(Method::id()));
  }

  template <typename Stream, typename Callback>
  void add_stream(Callback &&callback) {
    using upload_method = typename Stream::upload_method_type;
    using download_notification = typename Stream::download_notification_type;
    using callback_type = typename std::decay<Callback>::type;

    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0 ||
        InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC streams are immutable after start");
    if (handlers_.find(upload_method::code()) != handlers_.end() ||
        notification_limits_.find(download_notification::id()) !=
            notification_limits_.end())
      throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                           "Duplicate NTL RPC stream ID");

    handlers_.emplace(
        upload_method::code(),
        [this, fn = callback_type(std::forward<Callback>(callback))](
            const ntl::device_control::in_buffer &input,
            ntl::device_control::out_buffer &output,
            const call_context &context) mutable {
          auto invoke_batch = [this,
                               &fn](const call_context &call,
                                    const typename Stream::upload_batch_type
                                        &batch) {
            if (batch.values().empty() ||
                batch.values().size() > Stream::max_batch_records())
              throw ntl::exception(
                  STATUS_INVALID_PARAMETER,
                  "NTL RPC stream upload batch record count is invalid");
            for (const auto &upload : batch.values()) {
              call.throw_if_cancelled();
              if (!sessions_.is_stream_writable(call.session(), Stream::id()))
                throw ntl::exception(
                    STATUS_INVALID_DEVICE_STATE,
                    "NTL RPC stream is not writable for this client session");
              detail::invoke_stream_upload(fn, call, upload);
            }
          };
          detail::invoke_method<upload_method>(invoke_batch, input, output,
                                               context);
        });
    method_ids_.push_back(static_cast<std::uint32_t>(upload_method::id()));
    notification_limits_.emplace(download_notification::id(),
                                 download_notification::response_size());
    sessions_.register_stream(download_notification::id(),
                              download_notification::response_size(),
                              download_notification::priority(),
                              download_notification::max_batch_records());
    streams_registered_ = true;
  }

  template <typename Stream, typename Authorization, typename Callback>
  void add_stream_authorized(Authorization &&authorization,
                             Callback &&callback) {
    using upload_method = typename Stream::upload_method_type;
    using download_notification = typename Stream::download_notification_type;
    using authorization_type = typename std::decay<Authorization>::type;
    using callback_type = typename std::decay<Callback>::type;

    fast_mutex_guard guard(registration_lock_);
