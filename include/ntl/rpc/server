#define NTL_RPC_BEGIN_CONTRACT(_rpc_name_, _version_, _capabilities_)         \
  namespace _rpc_name_ {                                                       \
  constexpr std::uint32_t rpc_contract_version = (_version_);                 \
  constexpr std::uint64_t rpc_capabilities = (_capabilities_);                \
  inline std::shared_ptr<ntl::rpc::server>                                    \
  init(ntl::driver &driver,                                                   \
       ntl::rpc::server_options rpc_options =                                 \
           ntl::rpc::server_options(L#_rpc_name_)) {                          \
    rpc_options.contract_version(rpc_contract_version)                         \
        .capabilities(rpc_capabilities);                                       \
    auto rpc_server = ntl::rpc::make_server(driver, rpc_options);

#define NTL_RPC_BEGIN(_rpc_name_)                                              \
  NTL_RPC_BEGIN_CONTRACT(_rpc_name_, 1, 0)

#define NTL_RPC_END(_rpc_name_)                                                \
  rpc_server->start();                                                         \
  return rpc_server;                                                           \
  }                                                                            \
  }

#define NTL_ADD_CALLBACK_ID_0(_rpc_name_, _id_, _ret_, _name_, ...)           \
  {                                                                            \
    using rpc_method_type = ntl::rpc::make_method_t<(_id_), _ret_>;           \
    constexpr rpc_method_type rpc_method{};                                    \
    rpc_server->on(rpc_method,                                                 \
                   []() -> ntl::rpc::response_type_t<_ret_> __VA_ARGS__);      \
  }

#define NTL_ADD_CALLBACK_0(_rpc_name_, _ret_, _name_, ...)                    \
  NTL_ADD_CALLBACK_ID_0(_rpc_name_, NTL_RPC_DETAIL_LINE_ID, _ret_, _name_,    \
                        __VA_ARGS__)

#define NTL_ADD_CALLBACK_ID_1(_rpc_name_, _id_, _ret_, _name_, _arg0_type_,   \
                              _arg0_name_, ...)                               \
  {                                                                            \
    using rpc_method_type =                                                    \
        ntl::rpc::make_method_t<(_id_), _ret_, _arg0_type_>;                  \
    constexpr rpc_method_type rpc_method{};                                    \
    rpc_server->on(                                                            \
        rpc_method,                                                            \
        [](_arg0_type_ _arg0_name_)                                            \
            -> ntl::rpc::response_type_t<_ret_> __VA_ARGS__);                 \
  }

#define NTL_ADD_CALLBACK_1(_rpc_name_, _ret_, _name_, _arg0_type_,            \
                           _arg0_name_, ...)                                  \
  NTL_ADD_CALLBACK_ID_1(_rpc_name_, NTL_RPC_DETAIL_LINE_ID, _ret_, _name_,    \
                        _arg0_type_, _arg0_name_, __VA_ARGS__)

#define NTL_ADD_CALLBACK_ID_2(_rpc_name_, _id_, _ret_, _name_, _arg0_type_,   \
                              _arg0_name_, _arg1_type_, _arg1_name_, ...)     \
  {                                                                            \
    using rpc_method_type = ntl::rpc::make_method_t<                          \
        (_id_), _ret_, _arg0_type_, _arg1_type_>;                             \
    constexpr rpc_method_type rpc_method{};                                    \
    rpc_server->on(                                                            \
        rpc_method,                                                            \
        [](_arg0_type_ _arg0_name_, _arg1_type_ _arg1_name_)                  \
