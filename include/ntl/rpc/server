        });
    method_ids_.push_back(static_cast<std::uint32_t>(upload_method::id()));
    notification_limits_.emplace(download_notification::id(),
                                 download_notification::response_size());
    sessions_.register_stream(download_notification::id(),
                              download_notification::response_size(),
                              download_notification::priority(),
                              download_notification::max_batch_records());
    streams_registered_ = true;
  }

  void set_notification_store(std::shared_ptr<notification_store> store) {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0)
      throw ntl::exception(
          STATUS_INVALID_DEVICE_STATE,
          "NTL RPC notification storage is immutable after start");
    sessions_.store(std::move(store));
  }

  template <typename Callback> void set_session_open(Callback &&callback) {
    using callback_type = typename std::decay<Callback>::type;
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC session hooks are immutable after start");
    sessions_.on_open(
        [fn = callback_type(std::forward<Callback>(callback))](
            client_session &session, const call_context &context) mutable {
          return authorization_status(fn(session, context));
        });
  }

  template <typename Callback> void set_session_resume(Callback &&callback) {
    using callback_type = typename std::decay<Callback>::type;
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC session hooks are immutable after start");
    sessions_.on_resume(
        [fn = callback_type(std::forward<Callback>(callback))](
            client_session &session, const call_context &context) mutable {
          return authorization_status(fn(session, context));
        });
  }

  template <typename Callback>
  void set_session_disconnect(Callback &&callback) {
    using callback_type = typename std::decay<Callback>::type;
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC session hooks are immutable after start");
    sessions_.on_disconnect(
        [fn = callback_type(std::forward<Callback>(callback))](
            client_session &session) mutable { fn(session); });
  }

  template <typename Callback> void set_session_close(Callback &&callback) {
    using callback_type = typename std::decay<Callback>::type;
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC session hooks are immutable after start");
    sessions_.on_close([fn = callback_type(std::forward<Callback>(callback))](
                           client_session &session) mutable { fn(session); });
  }

  template <typename Notification> void add_notification() {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&started_, 0, 0) != 0 ||
        InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC notifications are immutable after start");

    const auto inserted = notification_limits_.emplace(
        Notification::id(), Notification::response_size());
    if (!inserted.second)
      throw ntl::exception(STATUS_OBJECT_NAME_COLLISION,
                           "Duplicate NTL RPC notification ID");
    sessions_.register_notification(
        Notification::id(), Notification::response_size(),
        Notification::priority(), Notification::max_batch_records());
  }

  void start() {
    fast_mutex_guard guard(registration_lock_);
    if (InterlockedCompareExchange(&stopping_, 0, 0) != 0)
      throw ntl::exception(STATUS_DELETE_PENDING,
                           "Cannot start a stopped NTL RPC server");
    std::sort(method_ids_.begin(), method_ids_.end());
    const auto features =
        transport_features::current |
        (asynchronous_ ? transport_features::asynchronous_calls : 0) |
        (!notification_limits_.empty()
             ? transport_features::kernel_notifications |
                   transport_features::reliable_notifications |
                   transport_features::bounded_batches |
                   transport_features::priority_delivery
             : 0) |
        (sessions_.has_store()
             ? transport_features::notification_persistence_hooks
             : 0) |
        (streams_registered_ ? transport_features::typed_streams : 0);
    contract_ = contract_info(current_protocol_version, contract_version_,
                              features, capabilities_, method_ids_);
    notifications_.start();
    InterlockedExchange(&started_, 1);
  }

  void stop() noexcept {
    if (InterlockedCompareExchange(&stopping_, 1, 0) == 0) {
      notifications_.stop();
      ExWaitForRundownProtectionRelease(&rundown_);
      sessions_.stop();
    }
  }

  void dispatch(const ntl::device_control::code &code,
                const ntl::device_control::in_buffer &input,
                ntl::device_control::out_buffer &output) {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC dispatch requires PASSIVE_LEVEL");
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      throw ntl::exception(STATUS_DEVICE_NOT_READY,
                           "NTL RPC server has not started");
    if (!ExAcquireRundownProtection(&rundown_))
      throw ntl::exception(STATUS_DELETE_PENDING, "NTL RPC server is stopping");
    rundown_guard guard(rundown_);

    if (code.value == control_code(contract_query_id)) {
      write_contract(input, output);
      return;
    }

    const auto found = handlers_.find(code.value);
    if (found == handlers_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                           "Unknown NTL RPC method ID");
    captured_caller_context caller(nullptr);
    const auto context = call_context_access::make(nullptr, &stopping_, caller);
    found->second(input, output, context);
  }

  ntl::device_control::dispatch_result
  dispatch_pending(ntl::irp &request, const ntl::device_control::code &code,
                   const ntl::device_control::in_buffer &input,
                   ntl::device_control::out_buffer &output) {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      throw ntl::exception(STATUS_DEVICE_NOT_READY,
                           "NTL RPC server has not started");

    if (code.value == session_control_code()) {
      dispatch_session_control(request, input, output);
      return ntl::device_control::dispatch_result::complete;
    }

    if (code.value == notification_control_code()) {
      if (!ExAcquireRundownProtection(&rundown_))
        throw ntl::exception(STATUS_DELETE_PENDING,
                             "NTL RPC server is stopping");
      rundown_guard notification_rundown(rundown_);

      if (input.size == sizeof(detail::reliable_batch_wait_request)) {
        const auto wait = input.as<detail::reliable_batch_wait_request>();
        if (!wait || wait->reserved != 0 || wait->max_records == 0 ||
            wait->max_records > maximum_batch_records ||
            wait->max_bytes != output.size)
          throw ntl::exception(STATUS_INVALID_PARAMETER,
                               "Invalid reliable batch receive request");

        auto pending = ntl::device_control::dispatch_result::complete;
        std::uint64_t session_id = 0;
        {
          fast_mutex_guard delivery_guard(delivery_lock_);
          const auto result = sessions_.receive_batch(
              request.stack_location()->FileObject, wait->id, wait->max_records,
              wait->max_bytes, output);
          if (result == session_registry::receive_result::completed)
            return ntl::device_control::dispatch_result::complete;

          session_id = sessions_.enqueue_batch_receive(
              request.stack_location()->FileObject, wait->id, wait->max_records,
              wait->max_bytes, [&] {
                pending = notifications_.enqueue(
                    request, wait->id,
                    notification_queue::wait_mode::reliable_batch);
              });
        }
        try_complete_reliable_batch(session_id, wait->id);
        return pending;
      }

      if (input.size == sizeof(detail::reliable_notification_wait_request)) {
        const auto wait =
            input.as<detail::reliable_notification_wait_request>();
        if (!wait || wait->reserved != 0)
          throw ntl::exception(STATUS_INVALID_PARAMETER,
                               "Invalid reliable notification receive request");
        const auto registered = notification_limits_.find(wait->id);
        if (registered == notification_limits_.end())
          throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                               "Unknown reliable notification ID");
        if (!output.can_write(registered->second +
                              reliable_notification_overhead))
          throw ntl::exception(
              STATUS_BUFFER_TOO_SMALL,
              "Reliable notification receive buffer is too small");

        auto pending = ntl::device_control::dispatch_result::complete;
        std::uint64_t session_id = 0;
        {
          fast_mutex_guard delivery_guard(delivery_lock_);
          const auto result = sessions_.receive(
              request.stack_location()->FileObject, wait->id, output);
          if (result == session_registry::receive_result::completed)
            return ntl::device_control::dispatch_result::complete;

          session_id = sessions_.enqueue_receive(
              request.stack_location()->FileObject, wait->id, [&] {
                pending = notifications_.enqueue(
                    request, wait->id, notification_queue::wait_mode::reliable);
              });
        }
        try_complete_reliable(session_id, wait->id);
        return pending;
      }

      if (input.size != sizeof(detail::notification_wait_request))
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC notification receive request");
      const auto wait = input.as<detail::notification_wait_request>();
      if (!wait)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Missing NTL RPC notification receive request");
      const auto registered = notification_limits_.find(wait->id);
      if (registered == notification_limits_.end())
        throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                             "Unknown NTL RPC notification ID");
      if (!output.can_write(registered->second))
        throw ntl::exception(
            STATUS_BUFFER_TOO_SMALL,
            "NTL RPC notification receive buffer is too small");
      return notifications_.enqueue(request, wait->id);
    }

    if (!ExAcquireRundownProtection(&rundown_))
      throw ntl::exception(STATUS_DELETE_PENDING, "NTL RPC server is stopping");
    rundown_guard guard(rundown_);

    if (code.value == control_code(contract_query_id)) {
      write_contract(input, output);
      return ntl::device_control::dispatch_result::complete;
    }

    const auto found = handlers_.find(code.value);
    if (found == handlers_.end())
      throw ntl::exception(STATUS_INVALID_DEVICE_REQUEST,
                           "Unknown NTL RPC method ID");

    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC dispatch requires PASSIVE_LEVEL");

    if (!asynchronous_) {
      captured_caller_context caller(request.get());
      session_operation_guard session(
          sessions_.find(request.stack_location()->FileObject));
      if (!session.available())
        throw ntl::exception(STATUS_DELETE_PENDING,
                             "NTL RPC client session is closing");
      const auto context =
          call_context_access::make(nullptr, &stopping_, caller, session.get());
      found->second(input, output, context);
      return ntl::device_control::dispatch_result::complete;
    }

    if (!try_acquire_pending_call())
      throw ntl::exception(STATUS_DEVICE_BUSY,
                           "NTL RPC pending-call limit reached");

    auto session = sessions_.find(request.stack_location()->FileObject);
    auto pending = ntl::try_make_pool<pending_call>(
        "NTRa", rundown_, request.get(), found->second, input, output, this,
        std::move(session));
    if (!pending) {
      InterlockedDecrement(&pending_calls_);
      throw ntl::exception(pending.status(),
                           "NTL RPC pending request allocation failed");
    }

    pending.value()->start();
    (void)pending.value().release();
    guard.release();
    return ntl::device_control::dispatch_result::pending;
  }

  void cleanup(ntl::irp &request) noexcept {
    const auto file_object = request.stack_location()->FileObject;
    sessions_.disconnect(file_object);
    notifications_.cleanup(file_object);
  }

  template <typename Notification>
  ntl::status
  try_notify(const typename Notification::payload_type &payload) noexcept {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      return ntl::status{STATUS_DEVICE_NOT_READY};
    if (!ExAcquireRundownProtection(&rundown_))
      return ntl::status{STATUS_DELETE_PENDING};
    rundown_guard guard(rundown_);

    const auto registered = notification_limits_.find(Notification::id());
    if (registered == notification_limits_.end() ||
        registered->second != Notification::response_size())
      return ntl::status{STATUS_INVALID_DEVICE_REQUEST};
    return notifications_.template try_notify<Notification>(payload);
  }

  template <typename Notification>
  ntl::status
  try_notify(std::uint64_t session_id,
             const typename Notification::payload_type &payload) noexcept {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      return ntl::status{STATUS_DEVICE_NOT_READY};
    if (!ExAcquireRundownProtection(&rundown_))
      return ntl::status{STATUS_DELETE_PENDING};
    rundown_guard guard(rundown_);

    const auto registered = notification_limits_.find(Notification::id());
    if (registered == notification_limits_.end() ||
        registered->second != Notification::response_size())
      return ntl::status{STATUS_INVALID_DEVICE_REQUEST};
    const auto status =
        sessions_.template publish<Notification>(session_id, payload);
    if (status.is_ok()) {
      try_complete_reliable_batch(session_id, Notification::id());
      try_complete_reliable_batch(session_id, 0);
      try_complete_reliable(session_id, Notification::id());
    }
    return status;
  }

  template <typename Notification>
  ntl::status
  try_stream_record(std::uint64_t session_id,
                    const typename Notification::payload_type &payload,
                    bool terminal) noexcept {
    if (InterlockedCompareExchange(&started_, 0, 0) == 0)
      return ntl::status{STATUS_DEVICE_NOT_READY};
    if (!ExAcquireRundownProtection(&rundown_))
      return ntl::status{STATUS_DELETE_PENDING};
    rundown_guard guard(rundown_);

    const auto registered = notification_limits_.find(Notification::id());
    if (registered == notification_limits_.end() ||
        registered->second != Notification::response_size())
      return ntl::status{STATUS_INVALID_DEVICE_REQUEST};
    const auto status = sessions_.template publish_stream<Notification>(
        session_id, payload, terminal);
    if (status.is_ok()) {
      try_complete_reliable_batch(session_id, Notification::id());
      try_complete_reliable_batch(session_id, 0);
      try_complete_reliable(session_id, Notification::id());
    }
    return status;
  }

private:
  void dispatch_session_control(ntl::irp &request,
                                const ntl::device_control::in_buffer &input,
                                ntl::device_control::out_buffer &output) {
    if (KeGetCurrentIrql() != PASSIVE_LEVEL)
      throw ntl::exception(STATUS_INVALID_DEVICE_STATE,
                           "NTL RPC session control requires PASSIVE_LEVEL");
    if (input.size < sizeof(detail::session_control_header))
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "NTL RPC session control header is missing");
    const auto header = input.as<detail::session_control_header>();
    if (!header || header->version != detail::session_control_version)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "Unsupported NTL RPC session control request");

    if (!ExAcquireRundownProtection(&rundown_))
      throw ntl::exception(STATUS_DELETE_PENDING, "NTL RPC server is stopping");
    rundown_guard rundown(rundown_);
    const auto file_object = request.stack_location()->FileObject;

    if (header->operation == detail::session_control_operation::register_region ||
        header->operation ==
            detail::session_control_operation::unregister_region) {
      if (input.size != sizeof(detail::region_control_request))
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC shared-region request");
      const auto command = input.as<detail::region_control_request>();
      if (!command || !command->token.valid())
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC shared-region session token");

      if (command->operation ==
          detail::session_control_operation::register_region) {
        if (command->region.valid() || !command->registration.valid())
          throw ntl::exception(STATUS_INVALID_PARAMETER,
                               "Invalid NTL RPC region registration");
        if (!output.can_write(sizeof(detail::region_control_response)))
          throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                               "NTL RPC region response is too small");
        const auto handle = sessions_.register_region(
            file_object, command->token, command->registration,
            request.get()->RequestorMode);
        if (!output.write(detail::region_control_response{handle}))
          throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                               "NTL RPC region response is too small");
        return;
      }

      if (!command->region.valid() || command->registration.user_address != 0 ||
          command->registration.length != 0 ||
          command->registration.access != ntl::ipc::region_access::none ||
          command->registration.reserved != 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC region unregistration");
      sessions_.unregister_region(file_object, command->token, command->region);
      output.clear();
      return;
    }

    if (input.size != sizeof(detail::session_control_request))
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "Invalid NTL RPC session control request");
    const auto command = input.as<detail::session_control_request>();
    if (!command || command->version != detail::session_control_version ||
        command->reserved != 0)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "Unsupported NTL RPC session control request");

    switch (command->operation) {
    case detail::session_control_operation::create: {
      if (command->token.valid() || command->notification_id != 0 ||
          command->sequence != 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC session create request");
      if (!output.can_write(sizeof(detail::session_control_response)))
        throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                             "NTL RPC session response buffer is too small");
      captured_caller_context caller(request.get());
      const detail::session_control_response response{
          sessions_.create(file_object, caller, &stopping_)};
      if (!output.write(response))
        throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                             "NTL RPC session response buffer is too small");
      return;
    }
    case detail::session_control_operation::resume: {
      if (!command->token.valid() || command->notification_id != 0 ||
          command->sequence != 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC session resume request");
      if (!output.can_write(sizeof(detail::session_control_response)))
        throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                             "NTL RPC session response buffer is too small");
      captured_caller_context caller(request.get());
      const detail::session_control_response response{
          sessions_.resume(file_object, command->token, caller, &stopping_)};
      if (!output.write(response))
        throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                             "NTL RPC session response buffer is too small");
      return;
    }
    case detail::session_control_operation::close:
      if (!command->token.valid() || command->notification_id != 0 ||
          command->sequence != 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC session close request");
      sessions_.close(file_object, command->token);
      notifications_.cleanup(file_object);
      output.clear();
      return;
    case detail::session_control_operation::subscribe:
      if (!command->token.valid() || command->notification_id == 0 ||
          command->sequence != 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC session subscribe request");
      sessions_.subscribe(file_object, command->token, command->notification_id,
                          true);
      output.clear();
      return;
    case detail::session_control_operation::unsubscribe:
      if (!command->token.valid() || command->notification_id == 0 ||
          command->sequence != 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC session unsubscribe request");
      sessions_.subscribe(file_object, command->token, command->notification_id,
                          false);
      notifications_.cancel(file_object, command->notification_id,
                            notification_queue::wait_mode::reliable);
      notifications_.cancel(file_object, command->notification_id,
                            notification_queue::wait_mode::reliable_batch);
      output.clear();
      return;
    case detail::session_control_operation::acknowledge:
      if (!command->token.valid() || command->notification_id == 0 ||
          command->sequence == 0)
        throw ntl::exception(STATUS_INVALID_PARAMETER,
                             "Invalid NTL RPC notification ACK request");
      sessions_.acknowledge(file_object, command->token,
                            command->notification_id, command->sequence);
      output.clear();
      return;
    default:
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "Unknown NTL RPC session control operation");
    }
  }

  void try_complete_reliable(std::uint64_t session_id,
                             std::uint32_t notification_id) noexcept {
    fast_mutex_guard delivery_guard(delivery_lock_);
    const auto file_object = sessions_.connected_file(session_id);
    if (!file_object)
      return;

    std::vector<unsigned char> bytes;
    PFILE_OBJECT current_file = nullptr;
    std::uint64_t sequence = 0;
    if (!sessions_.take_for_delivery(session_id, notification_id, bytes,
                                     current_file, sequence))
      return;

    PIRP request = notifications_.remove_next(
        notification_id, file_object, notification_queue::wait_mode::reliable);
    if (!request || current_file != file_object) {
      sessions_.release_delivery(session_id, notification_id, sequence);
      if (request)
        notifications_.complete(request, STATUS_CANCELLED, 0);
      return;
    }

    const auto stack = IoGetCurrentIrpStackLocation(request);
    const auto capacity = static_cast<std::size_t>(
        stack->Parameters.DeviceIoControl.OutputBufferLength);
    if (!request->AssociatedIrp.SystemBuffer || capacity < bytes.size()) {
      sessions_.release_delivery(session_id, notification_id, sequence);
      notifications_.complete(request, STATUS_BUFFER_TOO_SMALL, 0);
      return;
    }
    std::memcpy(request->AssociatedIrp.SystemBuffer, bytes.data(),
                bytes.size());
    notifications_.complete(request, STATUS_SUCCESS,
                            static_cast<ULONG_PTR>(bytes.size()));
  }

  void try_complete_reliable_batch(std::uint64_t session_id,
                                   std::uint32_t notification_id) noexcept {
    fast_mutex_guard delivery_guard(delivery_lock_);
    const auto file_object = sessions_.connected_file(session_id);
    if (!file_object ||
        !sessions_.has_ready_delivery(session_id, notification_id))
      return;

    PIRP request = notifications_.remove_next(
        notification_id, file_object,
        notification_queue::wait_mode::reliable_batch);
    if (!request)
      return;

    const auto stack = IoGetCurrentIrpStackLocation(request);
    const auto input_size = static_cast<std::size_t>(
        stack->Parameters.DeviceIoControl.InputBufferLength);
    const auto capacity = static_cast<std::size_t>(
        stack->Parameters.DeviceIoControl.OutputBufferLength);
    if (!request->AssociatedIrp.SystemBuffer ||
        input_size != sizeof(detail::reliable_batch_wait_request)) {
      notifications_.complete(request, STATUS_INVALID_PARAMETER, 0);
      return;
    }
    detail::reliable_batch_wait_request wait{};
    std::memcpy(&wait, request->AssociatedIrp.SystemBuffer, sizeof(wait));
    if (wait.id != notification_id || wait.reserved != 0 ||
        wait.max_bytes != capacity) {
      notifications_.complete(request, STATUS_INVALID_PARAMETER, 0);
      return;
    }

    std::vector<unsigned char> bytes;
    std::vector<session_registry::batch_delivery_key> keys;
    PFILE_OBJECT current_file = nullptr;
    try {
      if (!sessions_.take_batch_for_delivery(session_id, notification_id,
                                             wait.max_records, wait.max_bytes,
                                             bytes, current_file, keys)) {
        notifications_.complete(request, STATUS_DEVICE_BUSY, 0);
        return;
      }
    } catch (const std::bad_alloc &) {
      notifications_.complete(request, STATUS_INSUFFICIENT_RESOURCES, 0);
      return;
    } catch (const ntl::exception &error) {
      notifications_.complete(request, error.get_status(), 0);
      return;
    } catch (const std::exception &) {
      notifications_.complete(request, STATUS_INVALID_PARAMETER, 0);
      return;
    }

    if (current_file != file_object || capacity < bytes.size()) {
      sessions_.release_batch_delivery(session_id, keys);
      notifications_.complete(request,
                              current_file != file_object
                                  ? STATUS_CANCELLED
                                  : STATUS_BUFFER_TOO_SMALL,
                              0);
      return;
    }
    std::memcpy(request->AssociatedIrp.SystemBuffer, bytes.data(),
                bytes.size());
    notifications_.complete(request, STATUS_SUCCESS,
                            static_cast<ULONG_PTR>(bytes.size()));
  }

  bool try_acquire_pending_call() noexcept {
    LONG observed = InterlockedCompareExchange(&pending_calls_, 0, 0);
    while (observed < max_pending_calls_) {
      const LONG previous =
          InterlockedCompareExchange(&pending_calls_, observed + 1, observed);
      if (previous == observed)
        return true;
      observed = previous;
    }
    return false;
  }

  void write_contract(const ntl::device_control::in_buffer &input,
                      ntl::device_control::out_buffer &output) const {
    if (input.size != 0)
      throw ntl::exception(STATUS_INVALID_PARAMETER,
                           "NTL RPC contract query does not accept input");
    if (!output.can_write(contract_response_size))
      throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                           "NTL RPC contract response buffer is too small");

    try {
      zpp::serializer::memory_view_output_archive archive(
          reinterpret_cast<unsigned char *>(output.ptr), output.size);
      archive(contract_);
      output.size = archive.offset();
    } catch (const zpp::serializer::out_of_range &) {
      output.clear();
      throw ntl::exception(STATUS_BUFFER_TOO_SMALL,
                           "NTL RPC contract response exceeded its limit");
    }
  }

  std::unordered_map<unsigned long, dispatch_handler> handlers_;
  std::unordered_map<std::uint32_t, std::size_t> notification_limits_;
  std::vector<std::uint32_t> method_ids_;
  contract_info contract_;
  EX_RUNDOWN_REF rundown_{};
  FAST_MUTEX registration_lock_{};
  FAST_MUTEX delivery_lock_{};
  notification_queue notifications_;
  std::uint32_t contract_version_;
  std::uint64_t capabilities_;
  bool asynchronous_;
  LONG max_pending_calls_;
  session_registry sessions_;
  volatile LONG pending_calls_ = 0;
  bool streams_registered_ = false;
  volatile LONG started_ = 0;
  volatile LONG stopping_ = 0;
};

} // namespace detail

/** @brief Owns a WDM device and typed RPC method dispatch table. */
class server {
public:
  /**
   * @brief Creates a named RPC device.
   * @param driver NTL driver that owns the native device.
   * @param rpc_name Device name without the `\\Device\\` prefix.
   */
  server(ntl::driver &driver, const std::wstring &rpc_name)
      : server(driver, server_options(rpc_name)) {}

  /** @brief Creates a named RPC device with explicit endpoint options. */
  server(ntl::driver &driver, const server_options &server_opts)
      : dispatch_(std::make_shared<detail::dispatch_table>(
            server_opts.contract_version(), server_opts.capabilities(),
            server_opts.is_asynchronous(), server_opts.max_pending_calls(),
            server_opts.max_pending_notifications(), server_opts.max_sessions(),
            server_opts.max_reliable_notifications_per_session(),
            server_opts.max_reliable_notifications(),
            server_opts.session_retention_ms(),
            server_opts.shared_region_limits())) {
    ntl::device_options options;
    options.name(server_opts.name())
        .type(static_cast<ntl::device_type>(ntl::rpc::device_type))
        .security_descriptor(server_opts.security_descriptor(),
                             server_opts.class_guid());
    device_ = driver.create_device<void>(options);
    const auto dispatch = dispatch_;
    device_
        ->on_pending_device_control(
            [dispatch](ntl::irp &request, const ntl::device_control::code &code,
                       const ntl::device_control::in_buffer &input,
                       ntl::device_control::out_buffer &output) {
              return dispatch->dispatch_pending(request, code, input, output);
            })
        .on_cleanup(
            [dispatch](ntl::irp &request) { dispatch->cleanup(request); });
  }

  server(const server &) = delete;
  server &operator=(const server &) = delete;
  server(server &&) = delete;
  server &operator=(server &&) = delete;

  /** @brief Stops new calls and drains active callbacks before member teardown.
   */
  ~server() { stop(); }

  /**
   * @brief Registers a callback for a shared typed method descriptor.
   * @return This server for fluent registration.
   */
  template <typename Method, typename Callback>
  server &on(const Method &, Callback &&callback) {
    static_assert(is_method<Method>::value,
                  "ntl::rpc::server::on requires an ntl::rpc::method");

    dispatch_->template add<Method>(std::forward<Callback>(callback));
    return *this;
  }

  /**
   * @brief Registers a method with an authorization policy.
   * @param method Shared typed method descriptor.
   * @param authorization Callable receiving `const call_context&` and
   * returning `NTSTATUS` or `ntl::status`.
   * @param callback Typed RPC implementation invoked only after authorization.
   * @return This server for fluent registration.
   * @note Authorization runs before request deserialization and before the
   * application callback. Returning a failed status completes the call with
   * that status. A bool result is intentionally rejected because `true` is a
   * successful nonzero NTSTATUS value and would invert typical policy code.
   */
  template <typename Method, typename Authorization, typename Callback>
  server &on_authorized(const Method &method, Authorization &&authorization,
                        Callback &&callback) {
    static_assert(
        is_method<Method>::value,
        "ntl::rpc::server::on_authorized requires an ntl::rpc::method");
    (void)method;
    dispatch_->template add_authorized<Method>(
        std::forward<Authorization>(authorization),
        std::forward<Callback>(callback));
    return *this;
  }

  /**
   * @brief Registers both directions of a session-bound typed stream.

   * * @param channel Shared stream descriptor.
   * @param callback Upload
   * callback accepting `call_context` and one chunk.
   * @note The client must
   * create a session and open the stream before use.
   * Upload calls use the
   * endpoint pending-call limit. Download records use the
   * reliable
   * per-session and endpoint queue limits.
   */
  template <typename Stream, typename Callback>
  server &on_stream(const Stream &channel, Callback &&callback) {
    static_assert(is_stream<Stream>::value,
                  "server::on_stream requires an ntl::rpc::stream");
    (void)channel;
    dispatch_->template add_stream<Stream>(std::forward<Callback>(callback));
    return *this;
  }

  /**
   * @brief Registers a stream whose uploads require per-stream
   * authorization.
   * @note Authorization runs before upload deserialization
   * and callback
   * execution, using the original requester's captured
   * security context.
   */
  template <typename Stream, typename Authorization, typename Callback>
  server &on_stream_authorized(const Stream &channel,
                               Authorization &&authorization,
                               Callback &&callback) {
    static_assert(is_stream<Stream>::value,
                  "server::on_stream_authorized requires an ntl::rpc::stream");
    (void)channel;
    dispatch_->template add_stream_authorized<Stream>(
        std::forward<Authorization>(authorization),
        std::forward<Callback>(callback));
    return *this;
  }

  /** @brief Attaches optional external reliable-notification storage hooks. */
  server &notification_storage(std::shared_ptr<notification_store> store) {
    dispatch_->set_notification_store(std::move(store));
    return *this;
  }

  /** @brief Registers policy and state initialization for new sessions. */
  template <typename Callback> server &on_session_open(Callback &&callback) {
    dispatch_->set_session_open(std::forward<Callback>(callback));
    return *this;
  }

  /** @brief Registers policy applied before a token reconnect succeeds. */
  template <typename Callback> server &on_session_resume(Callback &&callback) {
    dispatch_->set_session_resume(std::forward<Callback>(callback));
    return *this;
  }

  /** @brief Observes a handle disconnect while retaining its session. */
  template <typename Callback>
  server &on_session_disconnect(Callback &&callback) {
    dispatch_->set_session_disconnect(std::forward<Callback>(callback));
    return *this;
  }

  /** @brief Observes explicit close, expiry, or final server teardown. */
  template <typename Callback> server &on_session_close(Callback &&callback) {
    dispatch_->set_session_close(std::forward<Callback>(callback));
    return *this;
  }

  /** @brief Registers a typed notification channel before start(). */
  template <typename Notification>
  server &register_notification(const Notification &) {
    static_assert(is_notification<Notification>::value,
                  "register_notification requires an ntl::rpc::notification");
    dispatch_->template add_notification<Notification>();
    return *this;
  }

  /**
   * @brief Completes the oldest matching receive with one typed payload.
   * @return STATUS_NOT_FOUND when no app currently waits on this channel.
   * @note Serialization requires PASSIVE_LEVEL. Notifications are not buffered
   * when no receive IRP is available.
   */
  template <typename Notification>
  ntl::status
  try_notify(const Notification &,
             const typename Notification::payload_type &payload) noexcept {
    static_assert(is_notification<Notification>::value,
                  "try_notify requires an ntl::rpc::notification");
    return dispatch_->template try_notify<Notification>(payload);
  }

  /**
   * @brief Queues a replayable notification for one subscribed session.
   * @return STATUS_DEVICE_BUSY when a configured queue limit is reached.
   */
  template <typename Notification>
  ntl::status
  try_notify(std::uint64_t session_id, const Notification &,
             const typename Notification::payload_type &payload) noexcept {
    static_assert(is_notification<Notification>::value,
                  "try_notify requires an ntl::rpc::notification");
    return dispatch_->template try_notify<Notification>(session_id, payload);
  }

  /** @brief Queues one typed driver-to-app stream chunk. */
  template <typename Stream>
  ntl::status try_write(std::uint64_t session_id, const Stream &,
                        const typename Stream::download_type &value) noexcept {
    static_assert(is_stream<Stream>::value,
                  "server::try_write requires an ntl::rpc::stream");
    using notification_type = typename Stream::download_notification_type;
    using record_type = typename Stream::record_type;
    return dispatch_->template try_stream_record<notification_type>(
        session_id, record_type::chunk(value), false);
  }

  /** @brief Queues a successful terminal record for one typed stream. */
  template <typename Stream>
  ntl::status try_complete(std::uint64_t session_id, const Stream &) noexcept {
    static_assert(is_stream<Stream>::value,
                  "server::try_complete requires an ntl::rpc::stream");
    using notification_type = typename Stream::download_notification_type;
    using record_type = typename Stream::record_type;
    return dispatch_->template try_stream_record<notification_type>(
        session_id, record_type::completed(), true);
  }

  /** @brief Queues a failed terminal record for one typed stream. */
  template <typename Stream>
  ntl::status try_fail(std::uint64_t session_id, const Stream &,
                       NTSTATUS status) noexcept {
    static_assert(is_stream<Stream>::value,
                  "server::try_fail requires an ntl::rpc::stream");
    if (NT_SUCCESS(status))
      return ntl::status{STATUS_INVALID_PARAMETER};
    using notification_type = typename Stream::download_notification_type;
    using record_type = typename Stream::record_type;
    return dispatch_->template try_stream_record<notification_type>(
        session_id, record_type::failed(static_cast<std::int32_t>(status)),
        true);
  }

  /** @brief Publishes the immutable method table for request dispatch. */
  server &start() {
    dispatch_->start();
    return *this;
  }

  /** @brief Rejects new calls and waits for active callbacks to finish. */
  void stop() noexcept {
    if (dispatch_)
      dispatch_->stop();
  }

private:
  std::shared_ptr<detail::dispatch_table> dispatch_;
  std::shared_ptr<ntl::device<void>> device_;
};

/**
 * @brief Callback-scoped server facade for one typed bidirectional stream.

 * * @tparam Stream Shared `ntl::rpc::stream` descriptor type.
 * @note This
 * object and every reference returned by it are valid only while
 * the upload
 * callback is running. Do not retain them in asynchronous work.
 */
template <typename Stream> class stream_context {
  static_assert(is_stream<Stream>::value,
                "stream_context requires an ntl::rpc::stream");

public:
  using upload_type = typename Stream::upload_type;
  using download_type = typename Stream::download_type;

  /**
   * @brief Binds a server and the current upload call to one stream.
   *
   * @throws ntl::exception when the upload has no active client session.
   */
  stream_context(server &owner, const call_context &call)
      : owner_(&owner), call_(&call) {
    if (!call_->session())
      throw ntl::exception(STATUS_INVALID_HANDLE,
                           "NTL RPC stream upload has no client session");
  }

  /** @brief Returns the original upload call context. */
  const call_context &call() const noexcept { return *call_; }

  /** @brief Returns the callback-scoped client session. */
  client_session &session() const noexcept { return *call_->session(); }

  /** @brief Returns the endpoint-local client session ID. */
  std::uint64_t session_id() const noexcept { return session().id(); }

  /** @brief Reports whether this upload was cooperatively cancelled. */
  bool cancelled() const noexcept { return call_->cancelled(); }

  /** @brief Throws `STATUS_CANCELLED` after a cooperative cancellation. */
  void throw_if_cancelled() const { call_->throw_if_cancelled(); }

  /** @brief Tries to queue one typed driver-to-app stream chunk. */
  ntl::status try_write(const download_type &value) noexcept {
    return owner_->try_write(session_id(), Stream{}, value);
  }

  /** @brief Queues one typed chunk or throws the returned NTSTATUS. */
  void write(const download_type &value) {
    const auto result = try_write(value);
    if (!result.is_ok())
      throw ntl::exception(result, "NTL RPC stream chunk was not queued");
  }

  /** @brief Tries to queue a successful terminal stream record. */
  ntl::status try_complete() noexcept {
    return owner_->try_complete(session_id(), Stream{});
  }

  /** @brief Completes the stream or throws the returned NTSTATUS. */
  void complete() {
    const auto result = try_complete();
    if (!result.is_ok())
      throw ntl::exception(result, "NTL RPC stream completion was not queued");
  }

  /** @brief Tries to queue a failed terminal stream record. */
  ntl::status try_fail(NTSTATUS status) noexcept {
    return owner_->try_fail(session_id(), Stream{}, status);
  }

  /** @brief Fails the stream or throws the returned NTSTATUS. */
  void fail(NTSTATUS status) {
    const auto result = try_fail(status);
    if (!result.is_ok())
      throw ntl::exception(result, "NTL RPC stream failure was not queued");
  }

private:
  server *owner_;
  const call_context *call_;
};

/** @brief Creates a shared owner for an NTL RPC server. */
