/** @brief Setup class used by secure NTL RPC control devices. */
constexpr GUID device_class_guid = {
    0xdcf4f515, 0xb540, 0x40cb,
    {0x82, 0x47, 0x88, 0x10, 0xaa, 0x38, 0x9b, 0xda}};

/** @brief Configures one secure kernel RPC endpoint. */
class server_options {
public:
  static constexpr std::uint32_t default_max_pending_calls = 256;
  static constexpr std::uint32_t default_max_pending_notifications = 256;
  static constexpr std::uint32_t default_max_sessions = 256;
  static constexpr std::uint32_t
      default_max_reliable_notifications_per_session = 64;
  static constexpr std::uint32_t default_max_reliable_notifications = 4096;
  static constexpr std::uint64_t default_session_retention_ms = 5 * 60 * 1000;

  /** @brief Creates SYSTEM/Administrators-only defaults for a device name. */
  explicit server_options(std::wstring name) : name_(std::move(name)) {}

  /**
   * @brief Replaces the endpoint ACL and setup class GUID.
   * @note Use a project-owned GUID and an SDDL policy appropriate for the
   * callers that are allowed to issue kernel RPC requests.
   */
  server_options &security_descriptor(std::wstring sddl,
                                      const GUID &class_guid) {
    security_descriptor_ = std::move(sddl);
    class_guid_ = class_guid;
    return *this;
  }

  /** @brief Sets the application contract version published to clients. */
  server_options &contract_version(std::uint32_t version) noexcept {
    contract_version_ = version;
    return *this;
  }

  /** @brief Sets application-defined capability bits published to clients. */
  server_options &capabilities(std::uint64_t capability_mask) noexcept {
    capabilities_ = capability_mask;
    return *this;
  }

  /**
   * @brief Runs application RPC callbacks as pending PASSIVE_LEVEL work items.
   *
   * This endpoint mode allows an overlapped client to observe timeout and
   * request cancellation without changing the existing synchronous API.
   */
  server_options &asynchronous(bool enabled = true) noexcept {
    asynchronous_ = enabled;
    return *this;
  }

  /**
   * @brief Sets the maximum number of application calls retained as IRPs.
   * @note The limit applies only when asynchronous mode is enabled.
   */
  server_options &max_pending_calls(std::uint32_t count) {
    if (count == 0 || count > static_cast<std::uint32_t>(MAXLONG))
      throw std::invalid_argument("NTL RPC pending-call limit is invalid");
    max_pending_calls_ = count;
    return *this;
  }

  /** @brief Sets the maximum number of queued notification receive IRPs. */
  server_options &max_pending_notifications(std::uint32_t count) {
    if (count == 0 || count > static_cast<std::uint32_t>(MAXLONG))
      throw std::invalid_argument(
          "NTL RPC pending-notification limit is invalid");
    max_pending_notifications_ = count;
    return *this;
  }

  /** @brief Sets the maximum number of live and reconnectable sessions. */
  server_options &max_sessions(std::uint32_t count) {
    if (count == 0)
      throw std::invalid_argument("NTL RPC session limit is invalid");
    max_sessions_ = count;
    return *this;
  }

  /** @brief Sets the per-session reliable-notification queue limit. */
  server_options &max_reliable_notifications_per_session(
      std::uint32_t count) {
    if (count == 0)
      throw std::invalid_argument(
          "NTL RPC per-session notification limit is invalid");
    max_reliable_notifications_per_session_ = count;
    return *this;
  }

  /** @brief Sets the endpoint-wide reliable-notification queue limit. */
  server_options &max_reliable_notifications(std::uint32_t count) {
    if (count == 0)
      throw std::invalid_argument(
          "NTL RPC reliable notification limit is invalid");
    max_reliable_notifications_ = count;
    return *this;
  }

  /** @brief Sets how long disconnected sessions remain reconnectable. */
  server_options &session_retention_ms(std::uint64_t milliseconds) {
    if (milliseconds == 0)
      throw std::invalid_argument("NTL RPC session retention is invalid");
    session_retention_ms_ = milliseconds;
    return *this;
  }

  /** @brief Returns the device name without the `\\Device\\` prefix. */
  const std::wstring &name() const noexcept { return name_; }

  /** @brief Returns the SDDL applied during secure device creation. */
  const std::wstring &security_descriptor() const noexcept {
    return security_descriptor_;
  }

  /** @brief Returns the setup class GUID used for secure device creation. */
  const GUID &class_guid() const noexcept { return class_guid_; }

  /** @brief Returns the application contract version. */
  std::uint32_t contract_version() const noexcept { return contract_version_; }

  /** @brief Returns application-defined capability bits. */
  std::uint64_t capabilities() const noexcept { return capabilities_; }

  /** @brief Returns whether this endpoint pends application RPC calls. */
  bool is_asynchronous() const noexcept { return asynchronous_; }

  /** @brief Returns the configured asynchronous pending-call limit. */
  std::uint32_t max_pending_calls() const noexcept {
    return max_pending_calls_;
  }

  /** @brief Returns the queued notification receive limit. */
  std::uint32_t max_pending_notifications() const noexcept {
    return max_pending_notifications_;
  }

  /** @brief Returns the maximum session count. */
  std::uint32_t max_sessions() const noexcept { return max_sessions_; }

  /** @brief Returns the reliable queue limit for one session. */
  std::uint32_t max_reliable_notifications_per_session() const noexcept {
    return max_reliable_notifications_per_session_;
  }

  /** @brief Returns the endpoint-wide reliable queue limit. */
  std::uint32_t max_reliable_notifications() const noexcept {
    return max_reliable_notifications_;
  }

  /** @brief Returns disconnected-session retention in milliseconds. */
  std::uint64_t session_retention_ms() const noexcept {
    return session_retention_ms_;
  }

private:
  std::wstring name_;
  std::wstring security_descriptor_ =
      L"D:P(A;;GA;;;SY)(A;;GA;;;BA)";
  GUID class_guid_ = device_class_guid;
  std::uint32_t contract_version_ = 1;
  std::uint64_t capabilities_ = 0;
  bool asynchronous_ = false;
  std::uint32_t max_pending_calls_ = default_max_pending_calls;
  std::uint32_t max_pending_notifications_ =
      default_max_pending_notifications;
  std::uint32_t max_sessions_ = default_max_sessions;
  std::uint32_t max_reliable_notifications_per_session_ =
      default_max_reliable_notifications_per_session;
  std::uint32_t max_reliable_notifications_ =
      default_max_reliable_notifications;
  std::uint64_t session_retention_ms_ = default_session_retention_ms;
};

