namespace ntl {
namespace detail {
namespace driver {
inline ntl::exception make_exception(NTSTATUS status) {
  const char *message;
  switch (status) {
  case STATUS_INSUFFICIENT_RESOURCES:
    message = " Insufficient system resources exist to complete the API.";
    break;
  case STATUS_OBJECT_NAME_COLLISION:
    message = "Object Name already exists.";
    break;
  default:
    message = "Unknown error.";
    break;
  }
  return ntl::exception(status, message);
}
} // namespace driver
} // namespace detail

/**
 * @brief Wraps DRIVER_OBJECT state and owns NTL-created devices.
 */
class driver {
  friend class driver_initializer;
  friend class driver_unload_invoker;
  friend class device_dispatch_invoker;

private:
  driver(PDRIVER_OBJECT driver)
      : object_(driver), name_(driver->DriverName.Buffer,
                               driver->DriverName.Length / sizeof(WCHAR)) {}

public:
  using unload_routine = std::function<void()>;

  /**
   * @brief Creates a WDM device object with an optional C++ extension payload.
   * @param opts Device creation options.
   * @return Shared owner for the created NTL device wrapper.
   * @throw ntl::exception when IoCreateDevice fails.
   */
  template <typename Extension>
  std::shared_ptr<device<Extension>> create_device(device_options &opts) {
    auto created = try_create_device<Extension>(opts);
    if (!created)
      throw detail::driver::make_exception(created.status());

    return std::move(created).value();
  }

  /**
   * @brief Creates a WDM device object and returns NTSTATUS on creation failure.
   * @param opts Device creation options.
   * @return Shared owner for the created NTL device wrapper, or failure status.
   *
   * This is the NTSTATUS-oriented counterpart to create_device(). C++ object
   * construction/allocation exceptions still propagate after cleaning up the
   * native DEVICE_OBJECT.
   */
  template <typename Extension>
  ntl::result<std::shared_ptr<device<Extension>>>
  try_create_device(device_options &opts) {
    PDEVICE_OBJECT dev = NULL;
    status s = [&dev, &opts, this]() {
      ULONG extension_size =
          (ULONG)sizeof(detail::device::extension_data_t<Extension>);
      if (opts.name_.empty()) {
        if (opts.secure_)
          return STATUS_INVALID_PARAMETER;
        return IoCreateDevice(object_, extension_size, NULL, opts.type_, 0,
                              opts.exclusive_, &dev);
      } else {
        unicode_string dev_name(L"\\Device\\" + opts.name_);
        if (opts.secure_) {
          unicode_string sddl(opts.security_descriptor_);
          return IoCreateDeviceSecure(
              object_, extension_size, &*dev_name, opts.type_, 0,
              opts.exclusive_, &*sddl, &opts.class_guid_, &dev);
        }
        return IoCreateDevice(object_, extension_size, &*dev_name, opts.type_,
                              0, opts.exclusive_, &dev);
      }
    }();
    if (s.is_err())
      return ntl::unexpected(s);

    bool extension_constructed = false;
    bool device_owner_transferred = false;

    try {
      new (dev->DeviceExtension) detail::device::extension_data_t<Extension>();
      extension_constructed = true;

      auto ptr =
          std::make_shared<device<Extension>>(device<Extension>(dev, opts));
      device_owner_transferred = true;

      dispatchers_.insert({dev, &ptr->dispatchers()});
      ClearFlag(dev->Flags, DO_DEVICE_INITIALIZING);

      return ntl::ok(std::move(ptr));
    } catch (...) {
      if (!device_owner_transferred) {
        if (extension_constructed) {
          using extension_data =
              detail::device::extension_data_t<Extension>;
          reinterpret_cast<extension_data *>(dev->DeviceExtension)
              ->~extension_data();
        }
        IoDeleteDevice(dev);
      }
      throw;
    }
  }

  /**
   * @brief Registers a C++ unload callback.
   */
  void on_unload(unload_routine &&f) { unload_routine_ = f; }

  /**
   * @brief Returns the native driver object name.
   */
  const std::wstring &name() const { return name_; }

protected:
  detail::device::dispatchers_t *dispatchers(PDEVICE_OBJECT ptr) noexcept {
    try {
      return dispatchers_[ptr];
    } catch (...) {
      return nullptr;
    }
  }

private:
  PDRIVER_OBJECT object_;
  std::wstring name_;
  std::unordered_map<PDEVICE_OBJECT, detail::device::dispatchers_t *>
      dispatchers_;
  unload_routine unload_routine_;
};

#if _X86_
// warning C4007: 'main' : must be '__cdecl'
#pragma warning(disable : 4007)
#endif
/**
 * @brief User-provided NTL driver entry point.
 * @param driver NTL driver facade.
 * @param registry_path Service registry path.
 */
status main(driver &driver, const std::wstring &registry_path);
