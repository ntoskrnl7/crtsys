<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="CrtSysValidateNativePackage" BeforeTargets="PrepareForBuild">
    <Error
      Condition="'$(CrtSysUseDriverSupport)' == 'true' and '$(CrtSysUseNtlMain)' != 'true'"
      Text="The prebuilt crtsys NuGet package currently supports the ntl::main entry point flow only. Leave CrtSysUseNtlMain set to true." />
    <Error
      Condition="'$(CrtSysUseDriverSupport)' == 'true' and '$(CrtSysLibPlatform)' != 'x64' and '$(CrtSysLibPlatform)' != 'ARM64'"
      Text="crtsys NuGet package contains prebuilt driver libraries for x64 and ARM64 only. Current platform is '$(Platform)'." />
    <Error
      Condition="'$(CrtSysUseDriverSupport)' == 'true' and !Exists('$(CrtSysLibDir)crtsys.lib')"
      Text="crtsys.lib was not found under '$(CrtSysLibDir)'." />
    <Error
      Condition="'$(CrtSysUseDriverSupport)' == 'true' and !Exists('$(CrtSysLibDir)Ldk.lib')"
      Text="Ldk.lib was not found under '$(CrtSysLibDir)'." />
    <Message
      Importance="high"
      Condition="'$(CrtSysUseDriverSupport)' != 'true'"
      Text="crtsys NuGet package is being used in header-only app mode because CrtSysUseDriverSupport is '$(CrtSysUseDriverSupport)'." />
  </Target>

  <ItemDefinitionGroup>
    <Link Condition="'$(CrtSysUseDriverSupport)' == 'true'">
      <AdditionalLibraryDirectories>$(CrtSysLibDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>crtsys.lib;Ldk.lib;libcntpr.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <EntryPointSymbol Condition="'$(CrtSysUseNtlMain)' == 'true'">CrtSysDriverEntry</EntryPointSymbol>
      <AdditionalOptions>/FORCE:MULTIPLE %(AdditionalOptions)</AdditionalOptions>
      <TreatLinkerWarningAsErrors>false</TreatLinkerWarningAsErrors>
    </Link>
  </ItemDefinitionGroup>
</Project>
