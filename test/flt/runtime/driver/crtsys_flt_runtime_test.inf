[Version]
Signature   = "$WINDOWS NT$"
Class       = "ActivityMonitor"
ClassGuid   = {b86dff51-a31e-4bac-b3cf-e8cfe75c9fc2}
Provider    = %ProviderName%
DriverVer   = 07/17/2026,0.1.0.0
CatalogFile = crtsys_flt_runtime_test.cat
PnpLockdown = 1

[DestinationDirs]
DriverCopyFiles.Downlevel = 12
DriverCopyFiles.24H2      = 13

[DefaultInstall.NTamd64]
OptionDesc = %ServiceDescription%
CopyFiles  = DriverCopyFiles.Downlevel

[DefaultInstall.NTamd64.10.0...26100]
OptionDesc = %ServiceDescription%
CopyFiles  = DriverCopyFiles.24H2

[DefaultInstall.NTamd64.Services]
AddService = %ServiceName%,,ServiceInstall.Downlevel

[DefaultInstall.NTamd64.10.0...26100.Services]
AddService = %ServiceName%,,ServiceInstall.24H2

[ServiceInstall.Downlevel]
DisplayName    = %ServiceDescription%
Description    = %ServiceDescription%
ServiceBinary  = %12%\crtsys_flt_runtime_test.sys
ServiceType    = 2
StartType      = 3
ErrorControl   = 1
LoadOrderGroup = "FSFilter Activity Monitor"
Dependencies   = FltMgr
AddReg         = Instances.AddRegistry.Downlevel

[ServiceInstall.24H2]
DisplayName    = %ServiceDescription%
Description    = %ServiceDescription%
ServiceBinary  = %13%\crtsys_flt_runtime_test.sys
ServiceType    = 2
StartType      = 3
ErrorControl   = 1
LoadOrderGroup = "FSFilter Activity Monitor"
Dependencies   = FltMgr
AddReg         = Instances.AddRegistry.24H2

[Instances.AddRegistry.Downlevel]
HKR,"Instances","DefaultInstance",0x00000000,%DefaultInstance%
HKR,"Instances\%DefaultInstance%","Altitude",0x00000000,%DefaultAltitude%
HKR,"Instances\%DefaultInstance%","Flags",0x00010001,0
HKR,"Instances\%SecondaryInstance%","Altitude",0x00000000,%SecondaryAltitude%
HKR,"Instances\%SecondaryInstance%","Flags",0x00010001,1

[Instances.AddRegistry.24H2]
HKR,"Parameters\Instances","DefaultInstance",0x00000000,%DefaultInstance%
HKR,"Parameters\Instances\%DefaultInstance%","Altitude",0x00000000,%DefaultAltitude%
HKR,"Parameters\Instances\%DefaultInstance%","Flags",0x00010001,0
HKR,"Parameters\Instances\%SecondaryInstance%","Altitude",0x00000000,%SecondaryAltitude%
HKR,"Parameters\Instances\%SecondaryInstance%","Flags",0x00010001,1

[DriverCopyFiles.Downlevel]
crtsys_flt_runtime_test.sys

[DriverCopyFiles.24H2]
crtsys_flt_runtime_test.sys

[SourceDisksFiles]
crtsys_flt_runtime_test.sys = 1,,

[SourceDisksNames]
1 = %DiskName%,,,

[Strings]
ProviderName       = "ntoskrnl7"
ServiceName        = "CrtSysFltRuntimeTest"
ServiceDescription = "crtsys NTL minifilter runtime test"
DefaultInstance    = "CrtSys FLT runtime test instance"
SecondaryInstance  = "CrtSys FLT runtime test secondary instance"
DefaultAltitude    = "370030.227"
SecondaryAltitude  = "370030.228"
DiskName           = "crtsys NTL minifilter runtime test media"
