[Manufacturer]
%ProviderName%=Models,NTamd64.10.0...16299,NTarm64.10.0...16299,NTx86.10.0...16299

[Models.NTamd64.10.0...16299]
%DeviceDescription%=Device_Install,Root\CrtSysKmdfNtlBusSample

[Models.NTarm64.10.0...16299]
%DeviceDescription%=Device_Install,Root\CrtSysKmdfNtlBusSample

[Models.NTx86.10.0...16299]
%DeviceDescription%=Device_Install,Root\CrtSysKmdfNtlBusSample

[Device_Install.NT]
CopyFiles=DriverCopyFiles

[DriverCopyFiles]
crtsys_kmdf_bus_ntl_sample.sys

[Device_Install.NT.Services]
