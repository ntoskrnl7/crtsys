[Version]
Signature="$WINDOWS NT$"
Class=System
ClassGuid={4d36e97d-e325-11ce-bfc1-08002be10318}
Provider=%ProviderName%
CatalogFile=crtsys_kmdf_bus_ntl_sample.cat
DriverVer=06/21/2006,1.0.0.0
PnpLockdown=1

[DestinationDirs]
